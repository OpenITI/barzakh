# ٢٨٥)
~~٢٠- ونـاظراً لمجْـرِي الأسْـبَابِ   المالـك المقـدر الوهـابِ
~~۲۱- لأنَّه هُـو الذي قـدَّرَها   ولم تكـن إلا لإذنـه بهـا
~~۲۲ - وإن يَشَـأ أَوْقَفَهَـا بقـاطِع   أو أي مـانع مـن الموانع
~~۲٣ - والكـل عنـد ربنا قـد قُـدّراً   ومـا يشـاء نافـذ بـلا مـرا
~~٢٤ - فلا يصح الخوف مـن سواهُ   وكل جـار فهـوقـد قضـاه
~~٢٥ - وإن تكُ الأسباب قـد أثبتّها   وحُـزْتَ في توحيـد ربي المنتهـى
~~٢٦ - تَنَلْ مِنْ اسْتِقَامَةِ القلبِ الذَّرَى   مُشّمّراً في السير نحو مـن بَرَا
~~٢٧- مُسْتَوضِحاً طَرِيقَ أَعْلاَم الهُدَى   مـن النبيـين وسـائر القُـدَى
~~۲۸ - على الصراط المستقيم وهو ما   دعـا إليـهِ الأنبيـا والعلـما
~~٢٩- ومـا به العلـم الإلهي سبق   فإِنَـه حَـقٌ وَحَـقٌ أَيُ حَـقْ
~~٣٠ - فليس بالأسباب ما کان جَرَی   لكنْ بحسـبان وعلم قدرا
~~٣١- ولا ينـافي ذاك إثبـات السبَبْ   ولـيس في ذا الأمـر اَيُّما عَجَـبْ
~~۳۲- لكنْ حصـولُه بعلم ربي   وإذنـه فـافهم تفـز بـالقرب
~~٣٣- وَكُنْ مَعَ اللهِ عَـلى تَوَكُّـلِ   واخـذر هـداك الله شر الزلـل
~~٣٤- واحرص على ما اَلنفعُ فيه قَدْ بَدَا   مـع اسـتعانةِ بِـرَبَّي أبَـدا
~~٣٥ - فـالأمر ذا أوصى بـه نبينـا   وقـد أتانـا في الصحيح بَيَنَا
~~٣٦ - والـدين دائرٌ عـلى ذا المعنـى   بهَينَـالِ المتقـون الحسـنىَ
~~٣٧- والله قـد دعـا إلى حسـن النظر   وبعـده أثنـى عـلى مَـنِ اعْتَـبَرْ
~~٣٨- وذاك محـض حكمـةٍ يَعْلَمُها   وَمَسْرَحُ الفِكْـرٍ لأَرْبَـابِ النُهَـى
~~٣٩- والكون قد علق بالأسباب   تعلـقَ الثـواب والعقـاب

PageV03P286

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0287.png)

~~۱- تَمكَّـن الـدؤوبِ ذي التشـميرِ   بجمعـهِ القلـبَ عـلى الخبـيرِ
~~۲ - مستأنفَ التـوبِ عـن التقصيرِ   منفـذاً أوامـرَ القـديرِ
~~٣- مـن المنـازل العظيمـة التـي   أتقنهـا جـدا أولـو البصـيرة
~~٤ - بجمعـه القلـب عـلى المعبـود   ينفـذ الأمـر بـلا قيـود
~~٥- مجاهـداً مـن أجـل هذا فيهِ   يـدعو عبـاده لمـا يرضِـيهِ
~~٦ - حتـى وإن كـان عـلى انْقِبـاضِ   مـن حـالهم أو كـان غيرَ راضِ
~~۷٧- لأنـه قـد فـاز بالجمعيـة   عـلى العظـيم خـالق البريَّـة
~~۸- ويُظْهرُ البسطَ مع العبـاد   حرصـاً عـلى الهـدى إلى الرشَـادِ
~~٩- فيـا لهذا من محب مُتَّصِـلْ   ومـن تقـي بـائن ومنفصـل
~~١٠ - ولم يكـن بصـادقِ المسـيرِ   مـن لم يتـب دومـأً إلى القـديرِ
~~۱۱- لأنهـا بدايـةُ الطريـقِ   وختمـه أيضـاً عـلى التحقيـق
~~۱۲- وسرُّ سـير الخلـق للأمـام   وفـوزهم بأحسـنِ الختـام
~~١٣ - وحيث لم يك المتاب كـالنَّفَسْ   مـن العبـاد فالعـدو مـاخنس
~~١٤ - وحيـث لم يرافـق المنـازلا   فالعبـد مغرور وليس واصـلا
~~۱٥ - وقد يقال كيفَ عُدْنا نحوها   وقـد قضينا مـن قـديم أمرهـا
~~١٦ - نقـول لا تعجـلْ بـذا السؤالِ   واعـرف مقـام الله ذي الجـلالِ
~~۱٧- واعلم بأن ما فعلت مـن تقى   لم يك لـولا أنـه قـد وَفَّقَـا
~~۱۸ - ونحن في عجزِ عن الوفاء لَهْ   ولم نكافئ بعض مـا قـد أَجَّلَهْ
~~١٩ - فحَقَّهُ أعظـم ممـايَعْمَـلُ   كُلُّ الوَرَى إنْ أحسنوا وأجملوا

PageV03P287

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0288.png)

~~٢٠ - إذن فـلا يُعليـك شيء أبـدا   كتوبةِ تغدو بها مُسَدَّدا
~~۲۱- مقتـدياً بالمصـطفى المقـدسِ   مـن تاب في ختـام كـل مجلسِ
~~۲۲ - صـلی عليه الله دائـم الأبد   وآلـه وصـحبه أولي الرشـد
~~۲۳_ فهـي بدايـة هـي النهایـة   وهي لكـل السـالكين غايـة
~~٢٤ - والمـرء للمتـاب في الختـام   أحـوج وهـو غايـةُ المـرامِ
~~۲٥- وانظر خطاب الله للمختـار   وللمهـاجرين والأنصـار
~~۲٦ - مـن تبعوه في اشتداد العسرة   وأخلصـوا في حبـه والنصـرة
~~۲۷- تاب عليهم لیتوبوا فاعْتَبِرْ   ولا تكـن في الباب ذا ممـن خَسِرْ
~~۲٨ - وختم ذي الجـلال للقـرآنِ   بسـورة النصر لهـذا الشـانِ
~~۲٩- وانظر إلى استغفار خير مرسل   عقيب ما يأتي به مـن عمل
~~٣٠ - وفي الصحيح أنـه يستغفرُ   خلـف الصـلاة دائمًا ويـذكرُ
~~۳۱- وكان كل صالح من العمَلْ   يَخْتِمُهُ مُسْتَغَفِراً مع الوَجَـلْ
~~۳۲ - كالصـوم والحج وكالجهـادِ   وعَـوْدِهِ منـهُ إلى الـبِلادِ
~~٣٣- وعلَّـم العبـاد أن يستغفروا   ويحمـدوا إلههـم ويشكروا
~~٣٤ - بتوبـة أيضـاً وبالأذكـارِ   في سـائر الليـل وفي النهـارِ
~~۳۵- فـنحن باستئنافنا للتوبـةِ   نسـعد عنـد الله بالمحبَّـةِ
~~٣٦- نكـون حقَّقْنـا العبوديةًَ لَـهْ   بكل مندوب وما قد فَضَّـلَهْ
~~٣٧- عَلَّمَنَـا مَراتِـبَ العبـادة   وكـل مـا تـأتي بـه السعادة
~~٣٨ - ولم ينـل كمال هـذا مطلقـا   إلا الخلـيلان بـما قـد وُفَّقَـا
~~٣٩- صـلى علـيهما إلهـي أبَـدا   وآلهـم مـدى الحيـاةٍ سرمَـدا
~~٤٠ - وشـهد الله لإبـراهيما   بأنـه وفى فكـن علـيُما
~~٤١- وسيد الخلق عـلى الإطـلاقِ   محمـد السـامي بـلا شـقاقِ

PageV03P288

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0289.png)

~~(۲۸۸)
~~٤٢- قـد فـاز بالتقـديم والوسيلة   وفـاز بالشـفاعة الجليلـة
~~٤٣- فحـين يستأخر كـل الرسُـل   يشـفع عنـد ربـه الـبَرّ العـليْ
~~٤٤ - فإنه أفضـل مـن لـه عَبَدْ   وخير مـن صـام ولبـى وسجد
~~٤٥- وبالعبوديـة ربي وصَـفَهْ   لأنهـا في خلقـه أعـلى صِـفَة
~~٤٦ - والحال هـذا حـال كـل الرُّسُلِ   والصحب ثـم التابعين الكمـل
~~٤٧ - وهـو بجمع همـة العبـد عـلى   مخافـة الله وحب كَمُـلا
~~٤٨ - مـع الرجـا والخـوف والإنابـة   وحرصه دومـاً عـلى الإصَـابَة
~~٤٩- منفـذاً أمـر إلهِـهِ الأَحَـدْ   مراقبـاً لربـهِ الفردِ الصـمد
~~٥٠- فالقلب مجموعُ عـلى المعبودِ   حبـاً وطاعـة بلا جحـودِ
~~٥١- وَالْـهَمُّ مجموعُ عـلى العبـادة   لعـالم الغيـوبِ والشـهادة
~~٥٢- وشـاهد الجمعين في القـرآنِ   في غايـة الوضـوح والبيـانِ
~~٥٣- فـإن في تقـديم لفـظ (نعبدُ)   تخصيصـه فغـيرُهُ لا يعبَـدُ
~~٥٤- ولفـظ (نستعينُ) لَمـا قُـدِّما   خصصه بالعون يا مَنْ فَهِـمَا
~~٥٥- وذا الذي دعـت إليه الرسل   ومن على منهاجهم قد عملوا
~~٥٦- فـاجمع كمال الحـب والتـذلل   وانقـد لأمـر الله في توكـل
~~٥٧- في كل ما يرضى به وما أمر   تكن له عبدا جنى أحلى الثمر
~~٥٨ - ولازم التوبـةَ مـن تقصـير   كـي لا تكـون سَيّءِ المصـير
~~٥٩- فإنهـا الـروح لكـل يـائِسِ   وَمُنْقِـدُ المـرْءِ مِـنَ الَخسَـائِسِ
~~٦٠ - وَمَـا لِـذِي الغفلـة والتفريطِ   كتوبـةٍِ تُنْجِـي مِـنَ القُنُوطِ

PageV03P289

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0290.png)

~~۱- ويظفـر السـالك في النهايـة   بِخالصِ التوحيـد خير غايـة
~~٢- لأنَّـه استأنفَ مـا بِهِ بدا   وكـان في مسيره مُسَدَّدا
~~٣- ورسل الله جميعـاً قـد دعـوا   إليه كـل قومهم حتى وعـوا
~~٤ - وَكُلُّهُمْ قـالوا (اعبـدوا الله) ولم   يُقَصروا وذكّروهم بـالنعم
~~٥- فالواجـب الأول بـالتحقيق   شـهادة التوحيـد في تصـديق
~~٦ - فإنهـا أولُ مـا بـه دخَـل   كلُّ امري في ديـنِ رَبَّهِ الأَجَـلَّ
~~٧- وإنهـا مسك الختـام العَطِـرَة   عنـد خروجنـا لـدار الآخـرة
~~۸- والمصطفى بَشَّرَمَـنْ بِهَانَطَقْ   عند الممات وهو خير مـن صدق
~~٩- بأنه مـن ضِـمْنِ أهْـلِ الجنـة   فالحمـد لله عـلى ذي المنَّـة
~~١۰- ولم يكُ التنزيـهُ للحميـدِ   عـن الحـدوث غايـة التوحيـدِ
~~۱۱- فكم مـن الطوائف الضلال   قـد نزَّهـوا الرحمن ذا الجـلالِ
~~١٢ - بـأنهم قـد أثبتـوا لـه القِـدَمْ   لكنهـا زلت بهـم بعـدُ القـدم
~~۱٣ - لأنهـم لم يثبتـوا إفـراده   بـل شـابهوا بـربهم عبـادهٔ
~~١٤- فلـيس ذا التنزيـه للـديان   يَشْـهَدُ بالإسـلام والإيـمانِ
~~۱٥- وسيد الطائفـة (الجنيدُ)   قيل له: يا شيخ، ما التوحيد?
~~١٦ - قـال: هـو الإفـراد للقـديم   عن حدث فاصغ لذا التفهيم
~~١۷- فإنه نبـه للإفراد   فافهم هـداك الله للرشـاد

PageV03P290

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0291.png)

~~۱۸ - و(الأشعريْ) ردَّ على من ادعت   حلـول ربهـا، فبئس مـا أتت
~~١٩- فواجـبٌُ إفرادُنـا في الخـبرِ   وفي اعتقـاد للعظـيم الأكـبر
~~٢٠- وذاك نوعان لهـا الذكر حوى:   إثباتنـا عُلُـوَّهُ والاسـتوا
~~٢١- دليلُ هـذا في جميع الكتـب   جـاء بـه كـلِّ رسـولِ ونبـي
~~۲۲- ثـانيهما اِثباتُنـا لوصـفهِ   بِوِفْقِ مـا جاء عـلى مُراده
~~۲۳ - مـن دون تحریفِ ولا تعطیل   ودون تكييـفٍ ولا تمثيـل
~~۲٤- نثبتهـا لـه کـما يلیق به   فوصـفه بغيره لا يَشتَبهْ
~~٢٥ - فلـيس شيءُ مثلـه إطلاقـا   واهبنـا الحيـاةَ والأرزاقـا
~~٢٦ - والنـوع ذا يُفْرَدُ فيـه البـاري   بسـائر القضـاء والأقـدار
~~۲۷- وأنهـا تجري عـلى مشـيئته   وَحُكْمِـهِ وعلمه وقدرته
~~٢٨ - وكلُّ مَـنْ قال بذا الإفرادِ   فـارق مـن يقـول بِاتُّحَـادِ
~~٢٩- وزمـرة الحلـول والتَجَهُّم   مِمَّن يقولـون بـلا تَلَعْثُم
~~٣٠- لـيس عـلى العـرش إلـه يعبـد   فـإنهم لـربهم قـد جَحَـدوا
~~٣۱- والقدريـةُ الـذينَ قـالوا   وقـولهم إقـرارُهُ ضَـلالُ
~~٣٢ - يرید ربنـا ولا یکُـونُ   وغـير مـا يريـده يكـون
~~٣٣- وبعـد ذَا الإفـراد للـرحمن   نـأتي إلى النـوع العظـيم الثـاني
~~٣٤- إفرادنـا القـديم بالعبـادة   عـن كـل مُحْــدَثِ بـما أراده
~~٣٥- كالحـب والتعظـيم والتوكـل   والنـذر والتوبـة والتـذلل
~~٣٦- وبسجودنا مع الإجـلال لـه   وكـل مـا ذا البـاب حقـأ شمله
~~٣٧- والغايـة العظمـى بـلا جـدال   في سـائر الأعـمال والأحـوال

PageV03P291

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0292.png)

~~۳۸- توحيـدُنا لله ذي الجـلالِ   بـدون تقصـيرِ ولا إخـلال
~~٣٩- وإنـما حقيقـةُ التوحيـد   تَوَكُّـلُ العبـدِ مَــعَ التَجْريـدِ
~~٤٠ - وربـما اعترتـه بعـض العلـل   تُوْقِعُ في التوحيـد بعضَ الخلَلِ
~~٤١- كترك أسباب بهـا الله أمر   والترك هـذا ربنا عنه زجر
~~٤٢ - وإنه عجـز وجهـل دمجـا   وإنما يرضى به مـن سـذجا
~~٤٣- وبعـده توكـل المطـامع   كالسـعي لـلأرزاق والمنـافع
~~٤٤ - مع اهـتمام بحظـوظ الـنفس   فربما يجـره للـتعس
~~٤٥ - لكنـه لـو كـان في الجهـاد   ودفع أهـل الشرك والفسـاد
~~٤٦ - مـع الخلـو مـن جميـع العلـل   يكـون في أسمى ذرى التوكـل
~~٤٧ - والعلـة الثالثـة الأخـيرة   غفلتـه عـن عـالم السَّرِيرة
~~٤٨ - وأن يرى التوكل الذي فعل   بجهدهِ وليس بالله حَصـلْ
~~٤٩- والعارفون سَلِمُوا من ذا الخلل   لأنهـم قـد جـانبوا تلك العلـل
~~٥٠- والناس في التوحيد قد تفاوتت   وكم نصوصٍ للفروق أثبتتْ
~~٥١- فالأنبيـاءُ أَكْمَـلُ البَرِيَّـةِ   والمرسـلون في الـذّرى العليـة
~~٥٢ - وإن أعلاهـم أولـو العـزم كما   دل عـلى ذا مـدحهم وأفهـما
~~٥٣- ولـيس أعـلى مـن محمـدٍ أحدْ   صلى عليه ربنا الفرد الصمد
~~٥٤ - فإنـه أكمـل مـن وحـدهُ   وخير مـن بـأمره أفرده
~~٥٥- وخير من جاهد أيضاً ودعا   وخير من لكل ما يرضى سعى

PageV03P292

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0293.png)

~~٥٦- من أجل ذا قد قال فيهم (اقتده)   فكـل شيء أخـذه مـن محتـده
~~٥٧ - وَجُعلـوا أئمـة الخلائـق   يتـبعهم كـل تقـي صـادق
~~٥٨ - وباتبـاع ملـة الخليـل   قـد جـاء أمـر الله في التنزيـل
~~٥٩ - إلى النبـي المصـطفى وأمَتِـهْ   إشـادة مـن ربـه بملَتِـهْ
~~٦٠ - وذَمَّ من يرغب عنها بالسَّفهٔ   لكـن مـن أحبهـا مـا أحصـفهٔ
~~٦١- وَوَصَـف الخليـل بالإمامـة   لأنـه في الحـق عـالي الهامـة
~~٦٢ - ورسـل الله وكـل الكتب   دعـت إلى التوحيـد يـا ذا الأدب
~~٦٣- وهـو بـأن يُخْلِصَ لله الصـمد   في الـدين كلـه بوفـق مـا ورد
~~٦٤- نفيـاً وإثباتـاً كما يشـاء   وذا هـو الفنـاء والبقـاء
~~٦٥ - يفنی بحب الله عـن سـواه   ولم يـرد غير الـذي ارتضـاه
~~٦٦ - في سـائر الطاعـات والعبـادة   ومـا بـه الرقـي للسعادة
~~٦٧ - كخشـية الجبـار والـولاء   والصـدق في التفـويض والـدعاء
~~٦٨ - وفي لجـوء العبـد واستغنائه   وفي توكـل وفي رجائه
~~٦٩- هذا هو التوحيد وهو المقصد   وهـو الـذي بـه الإلـه يعبـد
~~٧٠- وكـلُّ مـنْ تَـدبَّرَ القُرآنا   يَجـدْهُ قـد أَوْسَـعهُ بَيَانَـا
~~۷۱- كـما لـه أن لـيس يبقى مطلقـا   في قلب مـن وَحَـدَه وَصَـدَقا
~~۷۲- شيءٌ لغيره تعـالى أبـدا   هذا کماله فکـن مُسَدَّدَا
~~۷٣- يُحِبُّ مـا أحبه ويـبغض   مـا أبغض الله وعنـه يُعْـرِضُ
~~٧٤- ولا يـوالي غـير مـن والاه   معاديـاً لكـل مـن عـاداهُ
~~٧٥- يـأمر بـالأمر الـذي بـه أمر   وناهياً عـن كل ما عنه زجر

PageV03P293

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0294.png)

~~٧٦- هـذا هـو الموحـد الموفَّقُ   وهو الـذي لكـل خـيرٍ يسبقُ
~~۷۷_ مصـيره لجنـة الخلـودِ   إن مـات ثابتـأَ عـلى التوحيـدِ
~~۷۸- كـما أتـى بـذا صحيح الخبر   عـن النبي المصطفى مـن مُضَرِ
~~۷٩- صلى عليه الله مـا بـرق برق   وقدر علمه وعد ما خلق
~~٨۰- وإن ذا التوحيد في القلب اشتتَر   عنـد كثير وفـق مـا الله أمـر
~~۸۱- مـن دون تنمیق ولا تدلیل   عـلى حقـوق الخـالق الجليـل
~~٨٢ - لأنهـم لم يحسـنوا التعبـيرا   ولم يكـن جهـلاً ولا تقصـيرا
~~۸٣ - فكـم مـن الموحـدين الـبررة   لا يقـدرون دفع زيـغ الفجـرة
~~٨٤ - لا أَنَهـم ليسـوا عـلى توحيـد   وإنما عجـزاً عـن التفنيـد
~~۸٥- فيستدلّ کلّ واحدِ بما   ألمـهُ إهـهُ وأفهـما
~~۸٦ - وربما العـي عـن الكـلام   أعظـم مـن أئمـة أعـلام
~~٨۷٧ - الضـاربين في صـنوف الجَـدَلِ   بـالمنطقِ المُنَمَّــقِ المُـدَلَّلِ
~~۸۸- وربما حـازوا عـلى أدلـة   تجعلهـم مـن خـير أهـل الملـة
~~۸٩ - وكـل أهـل الفطـر السليمة   أمـورهم في الحـق مسـتقيمة
~~٩٠ - وكـل ما في الكون من آيات   كافيـة في النفـي والإثبـات
~~٩١- والحِسُّ والعقل مع الدليل   تنقلنَـا للعلمِ بالمـدْلُولِ

PageV03P294

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0295.png)

~~٩۲- وجوبه بالعقل والسمع كما   قـرره المحققـون العلـما
~~۹٣- أمـا وجـوده فبـالتوفيق   مـن بعـد تبصـير إلى الطريـق
~~٩٤- وبإجابـة لـداعي الحـق   نموه فـاحرص عـلى الترقـي
~~۹٥- وهكذا تبَصُرُ الشواهدِ   مِـنْ دالِّ عـلى الإلـه الواحد
~~٩٦- وجوبه بالعقل يعني الاقتضا   لفعله وذم مـن قـد أغرضا
~~٩٧- والسمع موجب لذا المعنى كما   يزيـد إثبـات الجـزاء فـافهما
~~٩٨- أيضاً وإخبار الورى عـن ربهم   ببعض تارکي الهدی وَمَقْتِهِمْ
~~٩٩- وذلك التبصـير إمـا التـامٌ   أي أنـه للاهتـدا مُــلازِمُ
~~١٠٠ - أو أنـه لم يوجب الهدايـة   بـل وجـدت واختـيرت الغوايـة
~~۱٠١ - مثـلُ ثَمُـودَ اِذهداها الله   فاستحسنوا العمـى عـلى هـداهُ
~~۱٠۲- وإنما يوصـل للجنـان   مـا استلزم الهـدى بـلا نقصـان
~~١٠٣ - وهـو الذي نطلبه من ربنا   في صـلوات سرنـا وجهرنا
~~١٠٤ - فـدعوة البيـان والدلالـة   عمت ، وخصت دعـوة الهداية
~~١٠٥ - فالمهتدون زادهم ربي هدی   ونقصـها فيمن عصى تأكـدا
~~١٠٦- وإنما الإیمان يزداد بـما   أُبْصرَمـن شواهدِ بهـا نما
~~۱٠۷- وهكذا تَعَلُـقُ العبيـد   بشـاهدٍ يهـدي إلى التوحيـد
~~۱٠٨ - من كل ما يُتْلَى من القرآنِ   ومـابـدا في الكـونِ للعَيَـانِ

PageV03P295

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0296.png)

# ٢٩٥)
~~۱٠٩ - لأن ربي نَصَـبَ الأَدِلَّـة   لينصُرَ التوحيـدَ خـيرَ ملـة
~~۱۱٠ - والخلـق آيـة عـلى التوحيدِ   لكـلِّ عبـدِ صـالح رشـيد
~~۱۱۱ - ففقرنـا والاحتيـاج مشهدُ   بهـا لخـالق الـورى نُوَحَّـدُ
~~۱١٢ - وإنما التوحيـد في أن نشهدا   دلالـةً في كـل شيء وجـدا
~~١١٣ - والمرسلون أرشـدوا الأنامـا   حتـى تجـلى الحـق واسـتقاما
~~١١٤- أَمْرُ العبوديـةِ والقيـامُ لَه   بكلـما فَصَّـله وأجمله
~~۱۱٥- والمصطفى استحلف بعض صحبه   لعلمـه بقـربهم مـن ربـه
~~١١٦- فحلفـوا بأنهم تذکروا   مِنَـةَ ربهـم فقـالوا نشكُرُ
~~۱١٧- حيث هُدُوا به إلى الإسلام   والعلـم بـالحلالِ والحـرام
~~۱۱۸- فکان معجَباً بهم معظما   وقـال مـا اشتحلفتكم متهما
~~۱١٩- لكنَّ ربَّ العرشِ قد باهی بكم   أمْلاكهُ فقلتُ ماذا عندكم؟
~~۱٢٠ - فأثر التوحيد عندهم شهد   والخير حقـاً في نفوسهم وُجِدْ
~~۱۲۱ - ولم يكـن شعورنا بـالفخر   یمنع من سرورنا والبشر
~~۱۲۲ - بمـنن الله علينـا الـوافرة   في هـذه الـدنيا ودار الآخـرة
~~۱٢٣- إن كـان ذكرهـا بـلا غرور   ولا افتخـار سيء منكـور
~~١٢٤ - إذ صاحب الغرور والتعـالي   والفخـر مـذموم بـلا جـدال
~~۱۲٥- ومـن يُرِدْ تحدثاً بالنعم   ففخْـرُهُ يحمـد بـين الأمـم
~~۱۲٦ - لكونه يدعو لهـا مرغباً   ولم يكـن بـما أنيـل معجبـا
~~١٢٧ - وافتخـر المختـار في أحـوال   مبيّنـا إفضـال ذي الجـلال
~~۱۲۸- وبعض أصحاب النبي افتخروا   تحـدثاً بــأنعم لاتحصر

PageV03P296

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0297.png)

~~۱٢٩- وذلك الفخر هـو المحمود   وذا الـذي صـاحبه يسـود
~~١٣٠ - وعكسه الممقوت والمذموم   فَشَـرُّه محقـق معلـوم
~~١٣١- والجمعُ والفرقُ أخا الإسلام يوص
# يوصـل في التوحيـد للـتمام
~~١٣٢- وهو شُخُوصُ المرء بالبصيرةِ   إلى الكـريم عـالم السريـرة
~~۱٣٣- فالمتفرقـاتُ عنـه صـادرة   جميعهـا كثيرهـا والنـادرة
~~١٣٤- وديننا بِمِيْزَةِ الفرق ارتفع   كـالفرق بـين مالـه الله شرع
~~۱۳٥- ومـا أحبه ومـا به أمـر   وما به يرضى وما عنه زجر
~~١٣٦ - والفرق ذا من لم يكن من أهله   فَـأَيُّ إسـلام لَـهُ لجهلـه
~~۱٣۷- ورَبُنَا قَدْ ذَمَ مُنْکِرِیهِ   للقـول مـنهم بالتسـاوي فيه
~~۱۳۸- كقولهم بيع الورى مثل الربا   والبيع حـل والربا قـد حوربا
~~۱۳٩- والجمع جمعان: بِعِلْم يكمل   توحيـده ربـاً وهـذا الأول
~~١٤٠- ثـانيهما: توحيـده إِلَـا   سبحان رب العرش لا يضاهى
~~١٤١- مـدبر الأمـر بـلا أعـوان   والمـانع المعطـي عـلى حسـبان
~~١٤٢ - سبحانه البر اللطيف الخالق   المـنعم المحيـي لهـم والـرازق
~~١٤٣- وهو الذي يميتهم ويبعث   بعلمـه وإذنـه مـا يحـدث
~~١٤٤- من أضخم الأشياء والصغار   وسـاقط مـن ورق الأشجار
~~١٤٥- فعلمه لاشيء عنه يَعْزُبُ   وليس شيء قط عنه يحجب

PageV03P297

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0298.png)

~~١٤٦ - فجمعك القلبَ عبادة له   بِهِمَـةِ لكـي تُـؤدي حقّـهُ
~~١٤٧ - نشهد ذاتـاً كلهـا كـمالا   سبحانه سبحانه تعـالى
~~١٤٨- وذلنـا لـه بقـول (نعبـد)   به نعـز في الـورى ونسعد
~~١٤٩- والحب في العبد متى يؤكد   يعبـده محبـة لا يجحـد
~~١٥٠ - بظـاهر وبـاطن مـن العمـل   کما يرید ربنا عز وجـل
~~١٥۱ - وقولنـا (إيـاك نستعين)   أي أنـه لا غـيره المعـين
~~١٥٢ - وإننا نشهد من قول (اهدنا)   عشر مراتب بهـا سُـمُوُّنَا
~~۱٥٣ - أولهـا: هدايـة البيـان   والعلـم بالطاعـة والعصـيان
~~١٥٤- وبعدها قدرته على الهدی   وجعله العبـد لـذاك قاصـدا
~~١٥٥- وأن يكـون ثابتـاً مهتـديا   وأن يكـون للرشـاد داعيـا
~~١٥٦ - سادسها: الحفظ مـن الموانع   وكـل عـائق وكـل قـاطع
~~١٥٧ - وأن يخصـه عنایـة به   بـما يكـون نافعـاً لقربه
~~١٥٨ - ثامنهـا: أن يشهد المقصـودا   ملتفتـا إليـه مسـتزيدا
~~١٥۹- ولم يكـن بسـائر الوسـائل   مُختجِبـاً عنـه ولا بِــذَاهِلِ
~~١٦٠ - تاسعها: شهود فقره القوي   إلى الهـدى فلـم يـزغ أو يَلتَوي
~~۱٦۱- عاشرها أن يشهد اللهُ العليم   مـن اهتـدى طريـق أمـة الجحيم
~~۱٦٢ - من اليهود السائرين للعطب   والمستحقين مـن الله الغضـب
~~١٦٣ - والضالين عن هـداه الواضح   مـن النصـارى أمـة القبـائح
~~١٦٤- وبعده يُشْهِدُه نهج الهدی   ومن عليه من نبيٍّ وقدى

PageV03P298

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0299.png)

~~۱- تحقيقنـا منزلـة الشهادة   توحيـد ربنـا کـما أراده
~~۲ - وقولنـا عنـه بـما يليـق بهْ   لا وفـق رأينـا فحـاذر وانتبهْ
~~٣- في الـذات والأسماء والصـفات   والنفي والأفعـال والإثبـات
~~٤ - وفي علـوه وفي كلامـه   أيضـاً وفي الأقـدار أو أحكامه
~~٥- وكـل آيـة مـن القـرآن   تشـهد بالتوحيـد للـرحمن
~~٦ - أو أنهـا تـدعو إلى التوحيـدٍِ   أو حولـه كالوعـد والوعيـد
~~٧- وانظـر إلى فاتحـة الكتـاب   وما حوت من علم هذا الباب
~~۸- فقـد حـوت علماً وإخباراً کما   قَـدْ حَـوَتِ الإعـلام والتكلما
~~٩- أيضـاً وفيهـا الأمـر بالتوحيـدِ   عـلى مـراد ربنـا المجيـدِ
~~۱٠ - لأنـه أخـبر عنـه وحكم   بالسير وفُقَـه بعدله الأتمْ
~~۱۱- والله بالتوحيـد هذا شَهدا   أوجبـه عـلى الـورى وأكـدا
~~١۲ - وشـهدت بـذلك الأمـلاك   والعلماء الأتقيـا النسـاك
~~۱۳ - وقـد أعـاد لفظـة الشـهادة   معلـماً ومرشـداً عبـادهٔ
~~١٤- لیشهدوا بها کما قد شهدا   ويأخـذوا التوحيـد أخـذاً جيـدا
~~۱٥- فإنهـا دلت عـلى توحيـده   وعدلـه والقسط في عَبِيدِهِ
~~١٦ - وَعِزَّةِ المولى وحُسْنِ حِكْمَتِهْ   كما نفت أضدَادَها بِخِبْرَتِـهْ
~~۱۷- وإنها تضمنت تكذیبَ مَنْ   عَطَلَ أو شَبَه فَـافْهَمْ وَاعلَمَـنْ

PageV03P299

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0300.png)

~~١٨ - وإن مـن رحمـة ذي الإنعـام   إرسـالَ مرسَـلِيه لِلاْنَـام
~~١٩- بالمعجزاتِ البينـاتِ والكتُبْ   فبشروا وأنذروا مَـنْ لَمْ يَتُبْ
~~٢٠- وإن مـن عـدل الإله التـامّ   عِقَابَـه لكـل عبـدٍ ظـالم
~~۲۱- والله دل الخلـق بالآیـاتِ   أيضـاً وبالأسـماءِ والصـفاتِ
~~۲۲- فإنـه الـدليل والمـدلولُ   الملـك المهـيمنُ الجليـلُ
~~۲٣- ومـن دلائـل الكمال المطلـقِ   شـهادة الـبر الكـريم الـرازِقِ
~~٢٤ - بكامـل التفصـيل والـدقائقِ   في كـل ذرة مـن الخلائـقِ
~~٢٥- في بـاطن منهـا وفيما ظهـرا   فليس شيء عـن إلهـي استترا
~~٢٦ - وإن مـن أعـرف خلـق الله بِهْ   من فهموا من فعله الإعلام به
~~۲۷ - ونفيهم مالـيس لائقـاَبِهِ   عـن ربهـم وذا دليـل حبه
~~۲۸ - والله لا يـأمر بالفحشـاءِ   سبحانه ذو العـزّ والآلاء
~~٣٠ - ليعرفـوا الله بـأنوارِ الهُـدَی   ۲٩- قـد حَرَّمَ الشرك وكـل ظلم   وأرشـد النـاس لكسب العلم   مِمَابِهِ عَلَّمَهُـمْ وَأَزْشَدَا
~~٣١- وَلم يَكُـنْ في العِلْـم كَـالقُرْآنِ   الحجـةُ العظمـى بـلا مُـداني
~~٣٣- ومن شهادة الرحيم ما وعتْ   ٣٢- والله قـال للنبي (قـل كفى   بالله) فاستشهد به لتعرفا   قلوب مـن بحبه تعلقتْ
~~٣٤- بما غـدا فيهـا مـن التصـديقِ   ومـن يقـينٍ ثابتِ عميـقِ
~~۳٥- ومـن طمأنينتهم بذکرهِ   ونطقهم بحمـده وشكره
~~٣٦- وفِطَـرُ النـاس بهـا أَسْرَارُ   بالـذكر والقـرآن تُسْـتَثَارُ
~~٣٧ - من أجـل ذا فالله ذو الإحسان   حث عـلى تـدبّر القـرآنِ
~~٣٨- لأنهـا لـو بقيـت كـما فَطَرْ   ما آثرت شيئاً على الحـق الأغَرْ
~~۳٩- ولاأَحَبَتْ غـيرَهُ إطلاقَا   ولم تطـق لـذكره فراقـا

PageV03P300

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0301.png)

~~(٣۰٠)
~~٤٠ - بـل إنـه يزيـدها يَقِينَـا   أيضـاً وعلـماً نافعـاً مبينا
~~٤١- والغـافلون حظهـم وبال   قلـوبهم تغلقهـا الأقفـالُ
~~٤٢ - لـو فُتِحَتْ باشرها القرآنُ   وزاد فيهـا النـورُ والإيـمانُ
~~٤٣ - وَعَظَّمَتْ خالقهـا ووحَدَتْ   وأسعدت بخـيره وأبهجتْ
~~٤٤- وسـائر الآيـات لله حُجَجْ   والمهتـدي مـن وفق نهجه نهَجْ
~~٤٥ - وربنـا يمـن بالهدايـة   وتلك آيـة وأي آيـة
~~٤٦ - وإنْ تَقُـل كيـف الإله أغفـلا   في آيـة الإشـهاد مـن قـد أرسـلا
~~٤٧ - جوابهـا العلـم يعـمّ الرسـلا   والعلـما فالكـل فيهـا دَخـلا
~~٤٨- وهـو بذکره لهم قد بَجَّلا   يجعلهـم جِنْسـاً فَـزِدْ تـأمُلا
~~٤٩ - أيضـاً وفيهـا ضـابط للعلما   فكـن لـذا المـدلول مِمَّـنْ فَهِمَا
~~٥٠ - لأن مـن لم يك مِمَّـنْ شَـهِدا   لم يكُ عالمِـاً فع مـا وردَا
~~٥١- ولا يكـون كـاتم الشـهادة   مستأهلاً مـن رَبَـهِ الإشـادَة
~~٥٢- وهـل شهادةٌ كـذي الشهادة   خص بهـا رب الـورى عبـادهٔ
~~٥٣ - لأنهـا جـاءت مـع شهادتهٔ   فالحمـد لله عـلى عنايتِـهْ
~~٥٤- وَفُسَّرَتْ بـالعلم والإقـرَارِ   أيضـاً وبـالتبيين والإظهـارِ
~~٥٥- فإنهم هُمْ شُهَدَاء البـاري   عـلى الـورى فالحمـد للغفـارِ
~~٥٦- لم يرتضوا بأي غيٍّ أَوْ شَطَطْ   لأنهـم في الأمـر كلـه وَسَـطْ
~~٥٧- وبعـد هـذا أخـبر العَـلاَّمُ   حـتماً بـأن دينـه الإسـلامُ
~~٥٨- وقول أهل العلم فيه اختلفا   هل هو حكمٌ قَدْ أتى مُسْتَأنَفَا
~~٥٩- أم أنه من ضمن ما به شهد   لأنـه الحـقُّ الـذي بـه عُبِـدْ

PageV03P301

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0302.png)

~~۱ - خَتَمْتُـهُ بَعـدَ مُضوِيَُ عـام   مِـنْ بَدْيِـهِ في المسجدِ الحـرامِ
~~٢ - مجـاوراً للبيـت والمقَـام   فالحمـد لله عـلى الـتمام
~~۳- والفضـل بعـد الله للمرغب   إليَّ نظـمَ ذا الكتـابِ الطيَّـبِ
~~٤ - أعنـي بـه محمـدَ بْنِ المرْوَعِـي   مـن كـان لي خَـيْرَ أخٍ مُشَجَّعِ
~~٥ - لمـا رأى بعـض متـونِ العلم   مِـنَ الـذْي أوجْزتُـهُ بِنَظْمـي
~~٦ - مـن صـفوة إيجازهـا في المنتهـى   علـم المواريث جميعـه بهـا
~~۷- ومنحـةٍ وأصـلها الطحاويـة   غـدت لأحكـام اعتقـادٍ حاوية
~~۸- ونخبـة عصرتها للطلبـة   ينـال فيهـا ذو اهـتمام أربه
~~٩- فقـال لي: هَيَـا إلى المـدارجِ   فإنهـا مِـنْ أفضَـلِ المعـارجِ
~~۱٠- قد زادها التهذيب حسناً فَسَمَتْ   ولـونظمتها لراقت وحلـت
~~۱۱- فكان قلبي راغبـاً وراجفَا   وكنت من حَجْمِ الكتابِ خائفَا
~~١٢- هـذا لمـا استقر في ضـميريْ   مـن شدة الخـوفِ مـن التقصيرِ
~~۱٣ - اِذ كنـت ذا بِضَـاعةِ مزجـاةِ   قليـل علـم وافر الـزلات
~~١٤ - فقلـت أَطَفَـلُ أم اعتـذرُ   لأنَني بِحَـالِ نفسي أخـبَرُ
~~۱۰- وعندما شوقني فيما اقْتَرَخْ   شعرتُ بالرغْبة والقلب الشرحْ
~~١٦ - حینئذِ صـلیتُ رکعتینِ   وقلـت يـا اللهُ كُـنْ مُعِينـيْ
~~۱۷- وأَشـعَفَتْني بالـدعاءِ أي   فزال عـن صدري جميع همي

PageV03P302

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0303.png)

~~۱۸- وقـد بـذلت الوُسعَ للإجـادة   بقصـد نيـل النفع والإفـادة
~~١٩- فجاء مثل العسجد النظيم   بفضـل ربي المـنعمِ الكـريمٍ
~~٢٠- بـل إنـه كالشـمسِ للأنـام   يَمْـدِيْهمُ في أَحْلَـك الظـلام
~~۲١- فيـا له والله مـن كتـاب   مصـدره فاتحـةُ الكتـاب
~~۲۲- وَنظمُهُ قَـدْ زَادَهُ سَلاسَة   وزاده في الحسـن والنَّفَاسَـة
~~٢٣- آَبْياته خَمْسَةُ ألفِ حَصْرُهَا   واستثن بعد الحصر ربع عشرها
~~٢٤- وإن أردتَ عَـدَّهَا بِالجُمَـلِ   غُض غَضَّ خِلَّ طَرْفَ عَيْنِهٔ وادْعُ ليْ
~~۲٥ - وربما أبصرت فيه عيبَا   فـلا تضخمه وكـن لبيبا
~~٢٦ - فـأي نفس بسواها تشتغل   يصيبها عـدوانها فتضمحل
~~٢٧ - واشكر لمحسن وسدد إن هفا   وقل كفى نفسي عيوبها كفى
~~۲۸- وإن منحت قـدرةً أن تنقـدا   وجهُ نحو من غوى وأفسدا
~~٢٩- وأسـألُ اللهَ لِمـنْ قـراهُ   أن يعـتلى بـه إلى رضـاهُ
~~٣٠ - وأَسـألُ الـرَّعْمَنَ أَنْ يُـوزِعَني   شكراً عـلى النَّعمًا وأنْ يرحمنِـي
~~۳۱- وأن يعيننـي عـلى الطاعـاتِ   ويصـلح الظـاهر والنيـاتِ
~~٣٢- ويلهـم القراءَ للـدعاءِ   لي ولهـم بأوسعِ العَطَـاءِ
~~٣٣- ويغفر الـزلات والـذنُوبا   ويكشـف الهمـوم والكروبَا
~~٣٤- ويـرحم الآبـاء والأشياخا   وكـل مـن أحـبهم وآخى
~~٣٥- ويحفـظ الأحبـاب والأولادًا   وَمَـنْ إلى نَهْج الرَّسُـولِ نَـادَى
~~٣٦ - وَيَـدْفَعُ الشرُورَ عَنَّـا دَفْعَـا   ويقطع البـاغي علينـا قطعـا
~~۳٧- ويجزل الأجر لـمنشي الأصل   وصاحب الشرح عظيم الفضل

PageV03P303

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0304.png)

~~۳۸- وللمهـذب الـذي قـد صـاغه   صـياغة بالغـة النصـاعه
~~۳٣٩- ويحسـن الختـام للجميع   مَنَـأ ويـدنينا مـن الشـفيعِ
~~٤٠ - وينقـذ الأمـة مـن ذئابهّـا   مـن أمـة الكفـر ومـن أذنابهـا
~~٤١- وينشـر الرحمـة في العبـادِ   وأن يقيهم فتن الأعـادي
~~٤٢ - مِنْ بَاثَّي الإرهابٍ في القلوبِ   بالـدجل والتضـليل والحُـرُوبِ
~~٤٣- مَـنْ روَّجُـوا للشر والفسـادِ   في سـائر الأنحـاءِ والـبلادِ
~~٤٤ - وحـاربوا التقـوى بكـل حيلة   لم يتركـوا مـن أجـل ذا وسيلة
~~٤٥- طغـوا بغوا في سـائر البلادِ   أحصوا صُنُوفَ الشرّ والفساد
~~٤٦- داعي الخنَـا والشرُّ زادَ فِينَا   لـولاك يـا الله مـا اهتـدينا
~~٤٧ - (فـأنزلن سكينةً علينّـا   وثبـت الأقـدام إن لاقينـا)
~~٤٨ - رَبَّـاهُ حَصّـناً مـن الرجيم   واسلك بنا نهج الهـدى القويم
~~٤٩ - وصـل يـا ربي عـلى الشـفيع   ومـن حـوتهم تربة البقيع
~~٥٠- والآل والأصحاب أجمعينـا   ومـن عـلى المنهـاج ثابتينَـا
~~٥۱- واجعل سلامي دائماً عليهم   وقل: (شُبَيْلٌ) يـا كَرِيمُ فِيهمْ
~~٥٢- والحمـد في بـدئي وفي ختامي   لله مسـدي الخـير بالـدوام
# الحمد لله رب العالمين

