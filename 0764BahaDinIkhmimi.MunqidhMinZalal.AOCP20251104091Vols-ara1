# (١۳٣)
~~۱۸- ملتزمـاً حـدود شرع الله   بـلا اغـترار وبـلا تبـاهي
~~۱٩- لأنـه والله لا يطيق   مقـدار مـا بربـه يَلِيـقُ
~~۲۰- مستغفراً مـولاه ذا الجـلالِ   عَقِيْبَ مـا يـأتي مـن الأعمال
~~۲۱- تأسياً بالمصـطفی محمـدِ   شـفيعنا الرؤوف يـومَ الموْعِـدِ
~~۲۲- فإن شهدت ما لمولاك وجبْ   وقـدر مـا تعملـه ممـا كتـبْ
~~۲٣- وعيب نفسك التي تغويكـا   ستطلب المتـاب مـن باريكـا
~~٢٤- مستغفراً مـن ذلك التقصيرِ   مستصغراً لفعلـك الكبـير
~~۲٥- ثـم القيـام بعـد هـذا العمـل   بِـمَا بِـهِ إصْـلاحُهُ مـن خلـلِ
~~٢٦ - كي لا يكون ضمن ما قد حبطا   أيضـاً ولا مـن عين ربي سقطا
~~٢٧- وأليـق الأشياء أن يتَّهما   يقينـه لكـي يكـون سـالما
~~۲۸ - فكـل مـا یملکه عاریّةٔ   ولـيس مـن جهـوده الذاتيـة
~~۲۹- ولـيس ملكـاً مستقراً عندَهُ   يعلـم منه قـدره وحـدّهُ
~~٣٠- بـل منـة مـن مـنن الوهـابِ   وربـما آلَـتْ إلى الـذَّهابِ
~~٣۱- وهكـذا يـزدادُ في التطهـيرِ   لنفسه مـن شرّهـا الخطـيرِ
~~۳۲- ومـن رعونات ادعائها الغَبِيْ   وكلـما يجرهـا للعطـب
~~٣٣- يُخَلَّصُ القَلْبَ بـلا تـواني   مِن سوء حَظَّ النَفْسِ والشَّيْطانِ
~~٣٤ - منفصـلاً عـن نفسه بحَزْمِهِ   وسـائراً لربـه بِعَزْمِـهِ
~~٣٥- مصحّحاً خطـاه في المسـيرِ   عـلى هـدی رسوله البشير
~~٣٦- فمثـل ذا تصـفو لـه الرعايـة   بفضـل مـن بـأمره الهدايـة

PageV03P134

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0135.png)

~~۱- إن الـذي يُكْـرَم بالمراقبـة   لاشك أنـه حميـد العاقبـة
~~٢- وهي خُلُوص السر والإعـلانِ   لله فاحْـذَرْ خُـدَعَ الشـيطانِ
~~٣- وإنهـا لَمـن ثـمار علمنـا   بعـالم الغيـب القـوي ربنـا
~~٤- لأنـه الرقيبُ والمُطَّلِعُ   لكـل مـا نفعلـه أوندع
~~٥ - في سـائر الأوقـات والأنَفـاَس   وكـل مطلـوق وذي انْحِبَـاس
~~٦ - إن كـان ذا تحـرك وإن سَكَنْ   في ظـاهر الأمـر وفي الـذي بَطَنْ
~~٧- وإن وقفـت واعظـاً للنـاس   فاحـذر مـن الموسـوس الخنَّاسِ
~~۸- يدعوك للغرور باجتماعِهِمْ   وما ترى في الناس مـن إصغائهِمْ
~~۹- لأنهـم قـد نظـروا للظـاهرِ   وربـك العلـيم بالسـرائرِ
~~١٠- فـدغ مُراقبـاً لأمـرِ ظَـاهِرِ   واهـتم بالقلـب وبـالخواطرِ
~~۱۱- وراقب الله الـذي يراقبُكْ   في الأمـر كُلَّـهِ وَقَـدْ يُعَاقبُكْ
~~١٢- وَوَجَّهِ الوَعْظَ لِنَفْسِكَ التِيْ   إنْ لم تَكُـنْ جَاهَـدْتها لم تَثْبُتِ
~~١٣ - واَلْزِمِ القَلبَ بِتَقْـوى اللهِ   وَكُـنْ مِـنَ الشَّيطانِ في انْتِبَاهِ
~~١٤- واحرض عَلَى نَفْعِ العبادِ دائسماً   مراقبـاً لله تحيـا غَـاتِما
~~۱٥ - تعبّـداً للواحـد العظـیم   باسم الرقيب واسـمه العليم
~~١٦- وباسـمه السميع والبصيرِ   وباسـمه الحفـيظ والخبيرِ
~~١٧ - متلـئ القلب مـن التعظـيمِ   لربـك الحفـيظ والقيـومِ

PageV03P135

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0136.png)

~~۱۸- وحـاضرَ القلـب مـع الرحمن   بـالأنس والحب بـلا نسـيانِ
~~۱۹ - وإن رُزقت كـل ذي الفضـائلِ   ونلت مـا أسـلفته بالكامـل
~~٢٠ - وفـزت بـالإجلال والتعظيم   لـذي الجـلال الملك الكـريم
~~۲۱ - وعشت أكمل السرور والفَرحْ   ونلت مـن مولاك أعظم المنَحْ
~~۲۲- وازددت من مولاك قرباً سَتَرَی   بأن كـل مـا سـواه أحقرا
~~٢٣- تَنَـلْ سُرُوراً في الفـؤاد يوجدُ   وقـرة العـين التـي لا تنفـد
~~٢٤- ومـا لـذا الإنعـام مـن نظـائرِ   عنـد ذوي العقـول والبصـائر
~~٢٥ - فإنه مـن طيبـات الجنـةِ   في هـذه الـدنيا بـدون مريـةِ
~~٢٦- بـل فـاق مـا بهـا مـن النعـيم   وفقـده شرُّ مـن الجحـيم
~~٢٧ - فمن يجد هذا يكون في عَجَلْ   للسـير في مراد ربـه الأجـلْ
~~۲۸- ويبـذل الجهـد بـلا ترَدُّدِ   لنيـل مرضـاة الإلـه الصـمد
~~۲۹_ وهـذه حـلاوة الإيمانِ   ينبتهـا الـرحمن في الجنَـانِ
~~٣٠- وأي شخص لم يجـدها يتهمْ   إيمانَـه وليحـترس ممـا يَصِـمْ
~~٣۱- وإن وعيت ذا بـأذن واعية   تَنَـلْ أعـالي الـدرجات العاليـةٌ
~~٣٢- وَيَخْلُصُ الباطنُ من أمر وَرَدْ   مخالفـاً لأمـر ربنـا الأحـد
~~۳۳- وكل ما زاحم حب الباريْ   ممـا أبـيح دونـما إنكـارِ
~~۳٤- وهـذه حقيقـة التجريـد   وسرُّ فـوزِ العبـد بالمزيْـدٍِ

PageV03P136

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0137.png)

~~۱- (ومـن يعظـم حرمـاتِ الله)   بتركـه لسـائر النـواهي
~~٢ - يرجـو ثوابَه الـذي لا يحصرُ   ومِـن عذابـه الشـديد يحـذَرُ
~~٣- (فَهُوَ) لذا التعظيم في اطمئنانِ   في هـذه الـدنيا وفي الجِنَـانِ
~~٤ - وفي ريـاض الخلـد في حبـورِ   بين قصـورها وعنـد الحورِ
~~٥ - (خَـيْرٌلَـهُ) تعظـيم أمـر الله   فلاحـه ليس لـه مضـاهي
~~٦ - وهكـذا كـان جميع الرُسُـلِ   والأنبيـا والتـابعين الكمـل
~~٧- مجتهـدينَ في دعـاء البـارِي   بـأنْ يَقِـيْهِمْ مِـنْ عـذاب النَـارِ
~~٨- وأن يحلهـم جِنَانـهِ التـيْ   أَعَـدَّهَا لِكُـلَّ عَبْـدٍ مخبِـتِ
~~٩- وَفَـوْٰا فَـوَفَّی رَبُهُـمْ وَأكرَمَا   يَا سَعْدَ مَـنْ للحُرَمَـاتِ عَظَّـما
~~١٠ - والنظرُ المبهج نحـو البـاري   مـن أنعـم الجنـة للأبـرارِ
~~١١- وليست الجنة خُضْرَ الشَّجَرِ   كجنـة الـدنيا فجـل بـالنظرِ
~~١٢- بـل إنهـا دار النعـيم المطلـقِ   والحلـم فيهـا واجـبُ التحقَّـقِ
~~۱٣- نظـرتهم لله خـير منـة   ينيلهـا عبـادَهُ في الجنـة
~~١٤- وذروةَ التعظيمِ فاعْلَمْ واغرِفِ   أن تحفـظ التوحيـد مـن تكلـف
~~۱٥- فكلُما عقولنـا لا تدرِكُهْ   نقبله كـما أتـى لانثركـه

PageV03P137

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0138.png)

~~١٦- فـنحن بالتسـليم والتبجيـلِ   ننجـو مـن التشـبيهِ والتعطيـل
~~۱٧ - لأن ذا الجـلال لا شبيه لَـهْ   فكيف خَوْضُنَا بوَصْفٍ هولَهْ
~~۱٨ - بل نثبت الوصف كما يليق بِهْ   هذا هو الأحكم فاعْلَمْ وانتبهْ

PageV03P138

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0139.png)

~~١- أَيُّ عِبـادةٍ أتت مـن البشرْ   بدون إخـلاص فما لهـا ثَمَرْ
~~٢- فـالله بـالإخلاص فيهـا أمَرا   وقرر الأمـر بـه وكـررا
~~٣- ولا يكون المرء أخلص العمل   إلا إذا أخلـص لله الأجـل
~~٤ - والتزم الصواب كي لا يغلطـا   ولا يكـون ضمن أربـاب الَخطَـا
~~٥- وكـل مـا خـالف ذا المـذكورا   یغدو هباءَ عنده منثورا
~~٦ - والمقصـد الجميـل يعـلى الناسـا   إذا غـدا إخلاصـهم أساسـا
~~٧- إن حصـل الفعـل وإن لم يحصـلِ   فـالأمر بالنيَـةِ لا بالعمـلِ
~~۸- ولـيس كالسنة هـادِ أبـدا   يحمي الورى من الشقاء والردَى
~~٩- والقلب لا يَغِـلٌ إنْ كَـانَ لَهُ   ثلاثـة ربي بهـا جَمَّلَـهُ
~~١٠ - إخلاصـه لله والمناصحة   لمـن تـولى الأمـر لا المفاضحة
~~١١- وهو بأن يَصْدُقَ في النصح كما   كـان هـداة الخـير ممـن علـما
~~۱٢- وهكذالُزُومُـهُ الَجماعـة   في حسـن سيرة وحسـنِ طَاعة
~~۱۳- فهذه بهـا القلوب تصـفو   وللنجـاح والفـلاح تهفـو
~~١٤- حتى الجهادُ وهو بَدْلُ النَّفْسِ   لـيس بمقبـولٍ إذا لم يُخْلَـصِ
~~١٥ - وهكـذا قراعة القرآنِ   والبـذل للأمـوال في الإحسـانِ
~~١٦ - لا تجعـل القـرآن والقتـالا   مـن أجـل أن تَغْـنَمْ أو يقَـالا
~~١٧ - فـإنما قلوبنـا المنظـورة   مـن ربنـا لا ظـاهراً أو صـورة

PageV03P139

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0140.png)

~~١٨- وَعُرَّفَ الإخـلاص بـالإفرادِ   لله في القصـدٍ وفي المـرَادِ
~~۱٩ - وقيـل بـل تصـفية الأفعـالِ   لله ذي العـزةِ والجـلالِ
~~٢٠ - وقيـل صدق العبد في التَّوَقَّي   عـن المـراءاة لأجَـلِ الحَخْلْـقِ
~~۲۱- وقيـل أن تستوي الأعمالُ   فبـاطن وظـاهر جَمَــالُ
~~٢٢ - أكملـه بـأن يكـون البـاطنُ   أفْضَـلُ مـن ظَـاهِرِهِ وأحسنُ
~~۲۳ - وقيـل تـرك رؤيـة الخلائقِ   والنظـر الـدائم نحـو الخـالِقِ
~~٢٤- ومن يرائي الناس في أيٍّ عَمَل   فإنـه في شَرَك الشّرْك دخـلْ
~~۲٥ - وكـل عامـلِ لأجـل النـاسِ   فهـو مـراءٍ فاقـد الأسـاس
~~٢٦ - وَعَنْ فُضَيلِ لا يَكُونُ مُخْلِصَا   إلا الـذي مـن ذين حقأ خلصا
~~٢٧- والله أغنـى الشركاءِ قاطبـة   والشرك بؤس وهو شر عاقبة
~~٢٨ - وَبَرِيَ الَجبَّارُ مِمَّـنْ يُشْرِكُ   فهـو لكـل المشـركين يَـتْرُكُ
~~۲۹- فالشرك أن يعملهـا للنـاس   وهـو مراد المـارد الخنـاس
~~٣٠- أمـا الجنيـد قـال سِرٌّ يُكْتَمُ   فغـير مَوْلانَـا بِـهِ لا يَعْلَـمُ
~~٣١- لم تقـدر الأمـلاك أن ترصـدَهُ   أيضـاً ولا الشيطانُ أنْ يُفْسدَهُ
~~۳۲- وقـال سهل أصعبُ الأمور   إخلاصـنا للملك الشكور
~~٣٣- فلـم يكـن أشـدّ منـه مطلقـا   على النفوس وهو مصدر النَقَا
~~٣٤ - لأنهـا إن أخلصـت تَغِيـبُ   حقوقُهـا فـما لهـانَصِـيبُ
~~٣٥- وان تُرد ما قاله مکحولُ   وقولـه مـؤثرٌ معقـولُ
~~٣٦- يقـول مـن أخلص أربعينـا   ولم يكـن في الأمـر ذا غَبِينَـا
~~٣٧- ينـابع الحكمـة حقـاً تظهـرُ   مـن قلبه وباللسان تُشْهَرُ

PageV03P140

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0141.png)

~~٣٨- وإِنَ مِمَّـا قالـه الـدَّارَانِي   الزاهـدُ العلامـةُ الربّـاني
~~۳٩- ينقطع الوسواس عمّن زانَهْ   إخلاصـهُ لربـهِ سـبحانَه
~~٤٠- ولا يری مجازيـاً أو شـاهدا   غـير إلهـه تعـالى أبـدا
~~٤١- ويحفـظ الأعـمال أن تَشُـوبَها   إرادةٌ لنفسـه تَهْـوِيْ بهـا
~~٤٢- كحبه للمـدح حبّـاً جمـا   وشـدة الغـيظ عـلى مـن ذمَـا
~~٤٣ - وحرصه بـأن يكـونَ أحسَنا   عنـد الـورى مـن غيره وأزْينا
~~٤٤ - وحبه التعظـيم والإجـلالا   وأن ينـال خدمـةً ومـالا
~~٤٥ - أيضاً وأن يقضوا له الحوائجـا   وكلـما أضحى لهـا ممازجـا
~~٤٦- مع الخلاص عن إرادة العِوَضْ   أو الرضـا بـه وكلما عَـرَضْ
~~٤٧ - بـل يشـهد المنـة للـرحمنِ   ذي الفضل والإكرام والإحسانِ
~~٤٨ - فربنـا بفضله قـد وَفَقَا   وشـاءه سبحانَهُ وَحَقَّقا
~~٤٩- (والله لـولا الله مـا اهتـدينا   ولا تصـدقنا ولا صـلينا)
~~٥٠ - فكـل خـير فهـو فضـل الله   جَزْمـاً بـلا شَـكِ ولا اشتِبَاهِ
~~٥١- ومن يرد عن الرضا - مخلصا-   عـن نفسه لكي يكـون مخلصا
~~٥٢ - فلا يكـن عنها براض مطلقا   وليشهدِ التقصـيرَ مَهـما دققـا
~~٥٣- فـربما الـنفس بـه تستأثرُ   وربما عيوبـه لا تحصـرُ
~~٥٤ - وربما يكـون للشـيطانِ   فيـه نصـيب بـان للعيـانِ
~~٥٥- ومـن تكـن صلاته لا تَسْلَمُ   مـن اختلاسه فَكَيْـفَ يَسْـلَمُ
~~٥٦- لأن تمييـز حظـوظ الـنفسِ   أصعب شيء وهـي شر متعس
~~٥۷- وهكذا تخليصه مـن الرضا   عن نفسه فيما يجي وما انقضا

PageV03P141

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0142.png)

~~٥۸- بعلمه بحـق ربـه العَـلي   وعجزه عـن فعـل أدنى عمل
~~٥٩- لأن عجزنـا كبـير جـداً   وَحَالُنا في الضـعف فـاق الَحـدَّا
~~٦٠ - وآفة العبـد الرضـا عن نفسهِ   لأنَّهـا تَجُـرُّهُ لِتَعْسِـهِ
~~٦۱- وكـل مـن لم يتهم دوامـا   للـنفس حَسْـبُهُ بِـذا إِجْرامَـا
~~٦٢- علامـة المخلـص في أي عمـل   حيـاؤه مـن ربه مع الوجَـل
~~٦٣- مـن بعـد بذل كاملِ المجهودِ   تقربـاً إلى عظـيم الجُـودٍِ
~~٦٤ - وذو الغرور يحسـن الظَنُونـا   بنفسه فلـم يـزل مغبونا
~~٦٥ - ومحسـن الظـن بربـه الأجَـلّ   يجيء بـالأعمال دونما خَلَـلْ
~~٦٦- منفـذاً للأمـر في تَقَيُّـدِ   ممتـثلاً لحكمـه المسـدَّدِ
~~٦٧- ينظـر للحقـائق البديعـة   بُحَقَّقـأَ مَقَاصِـدَ الشَرِيعَة
~~٦۸- على الهدى والعلم سَيْرُهُ انْسَجَمْ   مشـاهداً لمَـابِـهِ اللهُ حَكَـمْ
~~٦٩- والسير إن لم يك للعلم صَحِبْ   فهو من الشيطان كيفما حُسِبْ
~~۷٠- مثل الذي يُسْقِطُ مـا قد وجبا   ويـدعى لمـا افـتراه الكَـذِبَا
~~٧۱- مخالفـاً لسـنَةِ المُخْتَـارِ   ولاجـاً في الشـرَّ والأخطـارِ
~~۷٢- وكـل مـن بالمصطفى لم يَقْتَفِ   طَرِيقُـهُ منكـرةُ لم تُعْـرَفِ
~~۷۳- وعلمنـا مشـيد بالسـنةِ   ولَـيسَ بِالمنَـاكِرِ الدَخِيلَـةِ
~~٧٤- لأنها العلـم الصحيح والهـدى   وَرُوحُ سَيْرِ مَنْ عَلَى الَحقَّ غَدَا

PageV03P142

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0143.png)

~~١- سَـبْكُ العبوديـة يـا لَبِيْبُ   بالامتحانـات هـو التهـذيبُ
~~٢- لِتُخْرِجَ الـذي بهـا قـد حَـلاً   مـن خبثهـا والغش مهـما قَـلا
~~٣- ثـم العبوديـةُ مهـما ارتبطَتْ   بجهلنـا أو بهوانـا خُولِطَتْ
~~٤- بِعَـادَةِ وكلما يعيبها   أو يجعـل الإخـلاص ناقصـاً بِهَا
~~٥- فإنهـا تحتـاج للتهـذيبِ   مـن كـل مـا فيهـا مـن العيوب
~~٦- فأدّهـا متقنـةً ووفَّها   ومـن مخالجـات جهـلِ صَـفَّهَا
~~۷- واخـدم إلهك الـذي تفَضَـلا   ولا تكـن بغـيرِهِ مشْـتَغِلا
~~٨- وَأَرْدِفِ الخدمـةَ علـماً ثانيا   ولا تكـن عـن المعـالي وانيـا
~~۹- وإنهـا مـا لم تكـن كَـذَلِكا   فربما تـوردك المَهَالِكَـا
~~۱۰- ولا تقف عند حدود الخدمةِ   لأن هـذا مـن سـفول الهمـةِ
~~۱۱- بل کن حريصاً أن تفوز بالرضا   لأنـه غايـةُ مـا قـد فُرضَـا
~~١٢- وَحُمِـدَتْ قناعـةُ الإنسـان   في كـل مـا لم يك مِـنْ ذا الشَّانِ
~~١٣- وكـل مَـنْ كَانَ محباً صادِقَا   يبغـي رضـا خلاقـه موافِقَـا
~~١٤- فلتعبـدِ اللهَ كَـمَا أَرَادَا   تَنَـلْ لَدَيـهِ رفعـة وزادا
~~١٥- وليس وفق الرأي والأهواء   وَكُلـما يُـودِي إلى الشَّـقَاءِ
~~١٦ - وإنـما منفـذاً لأَمْـرِهِ   وَطَامِعـاً في جـوده وخَـيْرِهِ
~~١٧- واجعل هواك والذي اعتدت تَبَعْ   لأمْرٍ مَـوْلاكَ وَوفْقَ مَـا شَرَعْ

PageV03P143

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0144.png)

~~۱۸ - والقصـدَ صَـفَّهِ مِـنَ الغـرورِ   ومرض الإكـراه والفتـور
~~۱٩ - وَحَقَّقِ النَصرَ عـلى الفضـولِ   بالعلم كي تفـوز بالمـأمولِ
~~٢٠- ثـم امـلأً الفـؤادَ بالإيثَـارِ   والحـب والتعظـيم والإكبَـارِ
~~۲۱- لله ربِّ العـرش ذي الآلاءِ   لكى تفـوز منه بالعطـاءِ
~~۲۲- فـإنَّ هـذا حَـالُ مـن أحبَّـا   وقلبه قبـل اللسـان لبى
~~٢٣- فهـؤلاءِ هـم أولـو الصّـلاتِ   عيـونهم تَقِـرُّ بِالصـلاةِ
~~۲٤- طاعـاتهم هـي النعـيم الأكبرُ   وَحُـبُهمْ لله لـيسَ يُحْصُرُ
~~٢٥ - وأي إكسـير كمثـل الحـبِّ   يزيـل كـل وحشـةٍ وكــرْب
~~٢٦- ويملأُ القلبَ انتعاشاً في فَرَحْ   ويكسب المـؤمن أفضـل المِنَحْ
~~۲٧ - كـما يَقِيـهِ مَـرَض الفتـورِ   في السيرِ نَحْـوَ المُنْعِمِ الشَّكورِ
~~۲۸ - وخوضـه في كـل مـا لم يُفِدِ   وكُلَّمَا يَكُـونُ عكسَ المَقْصِـدِ
~~۲٩ - وإنما يأخـذ بالقواعـدِ   وبأصـول العلـم والفوائد
~~٣٠ - ويترك المجاذبـات الواهيَـةْ   تطلُّعـاً إلى المعـاني السـاميةْ

PageV03P144

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0145.png)

~~۱- عرَفهـا الصدِّيق تعريفاً يَفِيْ   بحقهـا فَاصغ إليهِ واعٔرف
~~٢ - فإنَّهُ قـد قـال حينما سُـئِلْ   لا تشركنْ بـالله فَـافْهَمُ وامتثل
~~٣- أيضـاً وقـد عرَّفهـا الفـاروقُ   وقولـه بالاعتنـا خليـقُ
~~٤ - فـلا تَرُغ كما يروغ الثعلبُ   فالمسـتقيم هكـذا لا يُغْلَـبُ
~~٥ - وقـال عثمانُ: هي الإخـلاصُ   وقولـه يرجى بـه الخـلاصُ
~~٦- أمَّـا عَـِليُ وابـنِ عبـاسِ فَقَـدْ   قـالا: أداء الفـرض مـثلما وَرَدْ
~~٧- وذلك الشخص الـذي قـد قالا   للمصـطفى: أجـب لي السـؤالا
~~٨- بما به الغنـاء عـن كـل أحَـدْ   فقـال (قـل آمنت بـالله) الصمد
~~٩- (ثـم اسـتقم) فـذلك الجـوابُ   هـو الُهُـدَى والحـق والصـوابُ
~~١٠ - المسـتقيم شـأنه عظـيمُ   بِـما حَبَـاهُ المِـنْعِمُ الكَـــريمُ
~~١۱- قد تاب موقناً مع الإخلاصِ   لكـي يكـون مـن أولي الخـلاصِ
~~۱٢ - والمسـتقيم للمفـاز طالـبُ   إن لم يكـن مُسَـدَّداً يقـاربُ
~~۱۳- وكل هذا ليس ينجي أحدا   مـا لم يكـن بِرَحْمَـةٍ تُغُمَّـدا
~~١٤- فلا تكـن بـراكن إلى العمـل   والجـأ إلى مَـولاكَ غفَّـار الزلَـلْ
~~١٥ - وحَقَـقِ اسـتقامة الأقـوَالِ   والفعـل والنيـات والأحـوالِ
~~١٦- عـلى كـمال الصـدق والوفاءِ   لعـالم السرِّبـلا رِيَـاءِ

PageV03P145

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0146.png)

~~۱٧- مفهومُها عند الإمام الهروي   أجْمَلَـهُ بوفـق فهمـه السـويْ
~~۱٨ - علـم مع الإخـلاص باجتهـادِ   أيضـاً وبـذل الجهـد باقتصـادِ
~~١٩ - مـن دون إفراطٍِ ولا تفريطِ   ولا ابتـداع لا ولا تخلـيطِ
~~٢٠ - بل بالوقوف وفق رسم العلم   وحسب أمـر المصـطفى المعظـم
~~٢١- وتُفْـردُ الـرحمنَ بـالإرادة   لكـى تنـال أكمـل السـعادة
~~۲٢- والمـرء لا يغلبـهُ الشيطانُ   أيضـاً ولا يدركـه الخسرانُ
~~٢٣- إلا إذا عـن الصـواب حـادا   أو كـان في أخطائـه تمـادى
~~٢٤- أو كان في السير أو الفهم انْحَرَفْ   أو كان ممن قـد طغى أو اقترفْ
~~۲٥- والمصطفى بالاقتصاد قد أمرْ   لأنه يُجْنَـى بـه أحـلى الثَّمَـرْ

PageV03P146

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0147.png)

~~۱ - من كان مؤمناً ومن أهل الرشد   يكـون ذا توكـل عـلى الصـمد
~~٢ - وذاكَ شرطُ صـحةِ الإيـمانِ   كـما أتـى في محكـم القـرآن
~~٣- وقد كفى الرحمنُ مـن توكلوا   مـن أوليائـه فـنعم المفضـل
~~٤ - يحـبّهم يرشـدهم إلى الهـدى   يقيهمُ شر الحسـود والعـدا
~~٥- وهـذه نتـائج التوكَّـلِ   وطاعـةِ الله بـلا تسـاهل
~~٦ - ولم يكـن في الخلـق طـراً أبـدا   في البـاب ذا مثـل الرسـول أحمَـدَا
~~٧- فإنـه الأوفى بـلا نقصـانِ   في الشـأن ذا أيضـاً وكـلّ شـانِ
~~٨ - وَيَحْرِمُ الإنسـانَ مـن أن يَعْتَليْ   تقصـيرُهُ والضـعفُ في التوكُّـلِ
~~۹- سـبعون ألفـاً بُشّروا بالجنـةِ   بـلا حساب بل بِمَحْضِ المِنَّةِ
~~١٠ - لأنهـم عاشـوا عـلى التوكَّـل   كـما أتـى عـن النبـي المرسـل
~~۱۱- مـن دونما تطیِّر أو رقيةِ   لـدفع مـا بِهِـمْ مـن البليَّـةِ
~~۱۲- حسبهم الله بـه اعتصـامُهُمْ   وذا الـذي سـما بـهِ مَقَـامُهُمْ
~~۱٣- وكم دعا مولاه خيرُ الرُّسُلِ   مخاطبـاً إيـاه بالتوكـلِ
~~١٤- وحَرَّضَ العباد كي لا يغفلوا   ولا يكـون الطـير مـنهم أفضلُ
~~۱٥- لـو أنكـم توكلـون حقا   نلتم مـن الله الكـريم رزقـا
~~١٦- كرزقِهِ الطير الـذي لا يَقْدِرُ   نفعـاً ولا دفعـاً ولا يُـدَبّرُ
~~١٧- وقـد غـدا توكـل الإنسـانِ   شطراً لدينـه بـلا نقصـانِ

PageV03P147

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0148.png)

~~١٨ - ونصـفه الثـاني: هـو الإنابة   مـن أمـة التوحيـد والإجابة
~~۱٩- والعلـم بـاب الخـير في التعبُدٍِ   فاظفر به لنيـل أسمى الرشد
~~٢٠- ثـم التعبـد الـذي قـد اتسع   جميعهُ بـابٌ بجـدرانِ الـورغ
~~٢١- والـورع العظيم أيضا كله   بـاب مـن الزهـد فما أجلَّه
~~۲٢- والزهد مـن كـل تقي أمثَـلِ   جميعـهُ بـابٌْ مِـنَ التَوكُـلِ
~~۲٣- وأنـه أجمعهـا بـلا مِـرَا   کماأتـى مقرراً مسطَّرا
~~٢٤- وهكذا رتبها (ابن التستري)   ليـدفع النـاس لخـيرٍ مُثْمِـرِ
~~٢٥ - فأوليـاء الله في توكـلِ   وطالب الرزق وكـل آمـل
~~٢٦ - والجـن والأمـلاك في السـماء   عـلى اخـتلاف القصـد والرجاء
~~٢٧- والصـدق في توكـل الإنسـانِ   ينيلـه مـا رام مـن أمـاني
~~۲۸- وإن تـرد حقيقـةَ التوكـل   فإنـه مركَّـب ممـا يـليْ:
~~٢٩ - مـن أنه انطراح قلب المـؤمِنِ   بين يـدي خلأَقـه المهـيمنِ
~~۳- وقيـل هجـر النـاس للعلائقِ   مواصـلين السـير بالحقـائقِ
~~۳۱- وفَسَّروه بالرضـا بالقـدرِ   بـلا اختيـار في قضـاء الـوطرِ
~~۳۲- وقـد أفـاد أحمـد بـن حنبـل   مبيّنـاً عبـادةَ التوكـلِ
~~۳٣- بأنه مـن عمـل القلـوب   مع الجليـل عـالم الغيـوبِ
~~٣٤ - وقيـل إنـه مـن المعـارفِ   فالقلب كم يدرك من لطائف

PageV03P148

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0149.png)

~~٣٥ - توكل الإنسان في نيل الوطر   من أعظم الأسباب عند مـن نظر
~~٣٦ - مثل الدعاء في حصول المطلب   بفعـل ربي لا بفعـل السـبَب
~~۳٧- فهي محـل حكمـة الجبـارِ   سبحانه مقـدر الأقـدار
~~٣٨ - فَاقْطَعْ علاقةَ الفؤاد بالسَّبَبْ   فإنـه والله يـورث العطب
~~٣٩- وَخلص القلب مـن التعلق   بهـا وكـنَ بـالله خـير واثِقِ
~~٤٠ - فأنت بالله ولست بالسبب   وإن فعلتـه لنيـل مـا كتـبْ
~~٤١ - وكـل مـن أخـل بالتوكـلِ   يصـاب في توحيـده بالخلـلِ
~~٤٢ - والقلب لَا تُشْغِلْهُ بالأسباب   واركـن إلى إلهـك الوهَـابِ
~~٤٣- فـإن يكـن عُلَّـقَ بالأسباب   يُمـلأ تشويشـاً مع اضطرابِ
~~٤٤- يا قلب فاعتمد علی باریکا   فإنـه بفضـله يعطيكـا
~~٤٥- واسكن إلى مولاك ذي الإنعـام   ولا تعـش في الجهـلِ والأوهـام
~~٤٦ - وحسَّن الظـن بمولاك الغني   تعـشّ تـوكلا وعزّا لا ينـي
~~٤٧ - ومـن أسـاء ظنَّـه بالبـارِي   فليتبـوأ منـزلاً في النَّـارِ
~~٤٨ - والمرء إن يكـن على استسـلام   لربِّـه المهـيمنِ العـلام
~~٤٩ - مسـلَماً لله في التَّـدْبِيرِ   في كامـل الحاجـات والأمـورِ
~~٥٠ - قـد فوَّض الأمـر إلى الـرحمنِ   بـلاتَـرَدُدٍ ولا تَـوَاني
~~٥١ - يُلْقِي بعجزه وكامل الثَقة   إلى الـذي أَمَـدَّهُ ووفَّقـهْ

PageV03P149

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0150.png)

# ١،٩)
~~٥٢ - لأن مـن فـوَض أمره لَـهُ   لا شك أن فضـله يَنَالـهُ
~~٥٣ - وذاك شأن مـن بقلبه اعتمَدْ   عـلى عظيم الجـود رَبَّهِ الصَّـمَدْ
~~٥٤- وهو بذا يكون من أهـل الرضا   لأنـه لربه قـد فوضا
~~٥٥ - ففعلـه يسـبقه التوكـل   وبعـده الرضـا فنعم العمـل
~~٥٦ - وذاك معنى قول طه المرتضى   لمـا استَخَارَ رَبَّـهُ مفوَّضـا
~~٥۷ - فقـد نفى العلـم وأي حول   أو قـوةٍ إلا عـلى ذي الطـولِ
~~٥٨ - عليه في مراده تَـوَكَّلا   وبصـفاتِ رَبَـهِ توسَّـلا
~~٥٩- العجز بعض القوم ظنه ثقة   والفهـم ذا مـن الفهـوم الموبقـة
~~٦٠ - وعنـد قـوم فُهِـم التفـويضُ   بأنـه التضييع والتمريض
~~٦۱ - وبعضـهم قـد فهـم التـوكُّلا   أن يستريح فارتضى التكاسـلا
~~٦٢ - وبعضهم قـد عطَّـل الأسبَابَا   وكلهـم للحـق مـا أصـابا
~~٦٣- والواثقـون نفَّـذوا الأوامـرا   وبذلوا الجهـود كيما تُثمِرَا
~~٦٤ - والعـاجزون فرَّطـوا وقصَّروا   وقـد غـدا غُرُورُهُمْ لا يحصَرُ
~~٦٥ - وحسبوا سكونهم للبـارِيْ   ومجـري الأحكـام والأقـدَارِ
~~٦٦ - مثـل سكونهم إلى سِـوَاهُ   تبـأَ لمــن أضـله هـواهُ
~~٦۷ - وربنا یحب من تَوکّلا   بمنه وجوده تفضلا
~~٦٨ - ولا يكـون مؤمنـاً مـن أهمَـلا   في قولـه وفعلـه التـوكلا
~~٦٩- لأنـه بـأمر ربي وجبـا   وليس مثلـه ينيـل الرتبَا

PageV03P150

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0151.png)

~~۱- وثقـة الإنسـان بـالرحمنِ   ترفعُـهُ إلى ذرى الإيـمانِ
~~۲ - يسيرُ وفـق أمـره كـما أمـرْ   في ثقـةٍ بأنـه إلى الظَّفَـرُ
~~٣- وإن رأى بعقلـه الهلاكـا   يقـول: إني طـائع بـذاكا
~~٤ - وذاك شـأن المـؤمن الحقيقِيْ   المخلـصِ الواثـق ذي التصـديقِ
~~٥- مـن فاز بالتفويض والتسليم   وحب ذي الجـلال والتعظـيم
~~٦ - ولا يك التفـويض إلا بالثقـة   فإنهـا للأمـر ذا محقَّقَـةٌ
~~٧- وإنهـا لمهجـة التسـليم   والروح للتوكـل العظيم
~~۸- والمـؤمن الواثـق بالمنَّـانِ   ذي الفضـل والإنعـام والإحسـان
~~٩- لم يخش قط الفوت في المقـدورِ   ولا انتقـاض الثابـتِ المسْـطُورِ
~~١٠ - ينيلـه إلهـه روح الرضَـا   لكونـه مسـلّماً لَمــا قَضَى
~~۱۱- مُحكماً للمصطفى فيما شَجَرْ   وراضياً بحكمـه ومـا أمرْ
~~١٢- ولم يكـن في النفس أيّما حَرَجْ   وذلك التسـليم سلم الفرج
~~۱۳ - وهـو الـذي يقـود للجنَـانِ   ذا ثقـة بالملـك الـديَّانِ
~~١٤ - فطرتـه تقـوده في دَرْبِهِ   والمصـطفى دليلـه لِرَبَّـهِ
~~۱٥- متبعـاً بهمـةِ خطـاهُ   مقتـدياً لا تابعـا هـوَاهُ
~~١٦- فالقلب للـرحمنِ حقـاً عَبَـدا   بمقتضی أسمائه وَوَحَـدَا
~~۱۷- تسليمه سَـلَّمَهُ مـن الخَطَرْ   وكـلَّ شـبهةٍ تعـارضُ الخَـبَرْ

PageV03P151

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0152.png)

~~۱٨- وكلِّ زَيغ واعتراضٍ في القدَرْ   أو شهوةِ قد عارضت فيما أَمَرْ
~~۱٩ - فالقلب هـذا صاحبُ الكرامة   وإنَـه السـليمُ في القِيَامـة
~~٢٠ - وصاحب التسليم ذا صديق   بالمكرمـاتِ كُلَّهـا خَلِيْـقُ
~~۲۱- ولـيس يعلـوه مقـام أبَـدا   إلا مقـام الأنبيـاء السعدا

PageV03P152

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0153.png)

~~۱- الصـبر واجب بـلا خـلافِ   وهـو مـن الإيـمان نصـفٌ وافي
~~٢ - أنواعُهُ في سِتَّ عشرٍ قد خُصِرْ   في محكـم القـرآن تسعين ذُكـرْ
~~٣- أولهـا: أمـرٌ بِـهِ، والثـانِيْ:   عَـنْ ضِـدِّهِ نَهْيٌ مِـنَ الرَّحمنِ
~~٤ - ثـم ثنـاء الملك الـديَّانِ   عـلى ذوي الصـبر أولي الإيـمانِ
~~٥ - رابعهـا: إيجابُـهُ الحـبَّ لهمْ   خامسها: معيـةٌ تخُصُّـهُمْ
~~٦ - والسـادس: الإخبـار أن الصبرا   خـير لأهلـه وأعـلى قـدراً
~~٧- سـابعها: إيجـاب ذي الجـلالِ   جـزاءَهُمْ بأحسـنِ الإفضـال
~~٨- والوعد من رب الورى التواب   جزاءه لهـم بـلا حِسَـابِ
~~٩- وبعـده البشرى عـلى الإطـلاق   لكـل صـابرِ بـلا إخفَـاقِ
~~۱٠ - عاشرها: ضَمَانُ نَصْرِ مَنْ صَبَرْ   فكل ذي صبر يَفُـوزُ بـالظَّفَرْ
~~۱۱- ومدحهم من دونما مُزَاحم   بِـأَنَّهُمْ هُـمُ أولـو العـزائمِ
~~۱۲ - وأنهـم حقـاً أولـو العظـاتِ   مـن عِـبَرِ الحـديث والآيـاتِ
~~۱٣- وإنه أوسع مـا نـال البشرْ   فيا لحظًّ مَـنْ مَعَ العـزم صَبَرْ!
~~١٤- ثـم دخـول الجنـة المباركـة   ثـم تـزورهم بهـا الملائكـةْ
~~۱٥ - وأنه مع اليقين يـورث   إمامـةً كمثلهـا لا يـورث
~~١٦ - وآخـر الأنـواع أن الصـبرا   مـع المقامـات جميعـاً ذُكِـرَا
~~١٧ - وعجـب الله لأمـر المـؤمن   لكونـه في الصـبر ذا تمكـن

PageV03P153

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0154.png)

~~١٨- فالصبر في الإيمان مثـل الرآسِ   في جسـدٍ حَـيّ مـن الأَنَـاسي
~~۱۹- وأنـه الضـياءُ للعبـادِ   كما أتـى عـن الرسول الهـادِيْ
~~۲٠ - وأنـه خـير لـدى الضرَّاءِ   مقابـل للشكر في السَرَّاءِ
~~۲۱- وخير عيش مثلما قـال عُمَرْ   والمصـطفى نبينـا بـه أمَـرْ
~~٢٢- في أَثْـرَةِ تَنْـزِلُ بِالأنصـارِ   وفي قتـال زمـرةِ الكفـارِ
~~٢٣- وفي الـذي حلـت بـه المصـيبة   ليكسب الأجـرَ بـدون ريبة
~~٢٤- وليس كالصبر عطاءٌ أوسَعُ   ينيـل أجـراً والـبلاءَ يَـدْفَعُ
~~٢٥ - والصبر حَبْسُ النَفْسِ والجوارح   عـن كـل مـا يجـر للقبـائح
~~٢٦ - وهو على الطاعةِ أو عَنْ معصيهٔ   وذاك أعلى الصبر فاشكر معطيه
~~۲۷- وبعـده الصـبر عـلى الـبلاءِ   لنيـلٍِ فضـلِ الله والجـزاء
~~٢٨- بـالله لله مع الله العَـلي   من نالهـا جميعهـا هـو الـولي
~~۲٩- أولهـا: اسـتعانةٌ بـالرَّبِّ   ونفعـلُ الثـاني بقصْـدِ القُـرْبِ
~~٣۳٠- ثالثهـا: بـأن نَـدُورَ مطلقا   وفقَ مرادِ رَبنـا وَنَصـدقا
~~٣١- في سـائر الأحكـام والأوامـرِ   عـلى مـرادِ ذي الجـلالِ القَـادِرِ
~~٣٢- والصـبر هـذا رتبـةُ الصـدِّيقِ   وهـو أشـدها عـلى التَحْقِيـقِ
~~۳٣- لأنـه تجـرع المـرارةِ   بـلاعبُـوس وبـلاكراهـة

PageV03P154

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0155.png)

~~(١٥٤
~~٣٤ - وقيـل: تعويـد لـنفس المتَّقِـي   أن تهجـم المكـروه كـيما تَرْتَقِـي
~~۳٥- وقيـل حسـن صحبةِ البَلاءِ   كأنـهُ مِـنْ أفضـل النعماء
~~٣٦- وقـال بعضهم: ثبات المؤمنِ   عـلى صراط ربـه المهـيمنِ
~~٣٧- مـع التلقـي للبلاء بالسَّعَةْ   وكامل الترحيب أيضا والدعة
~~۳۸- وقـال بعضـهم: ثبـات الأمـةِ   عـلى كتـاب ربّهـا والسنَة
~~۳۹- وبعضهم رتبهـا (بالصـابر)   وهو أعمهـا بـلا نظَـائر
~~٤٠- وبعـده (مُصْـطَبِرٌ) أي المـِلي   منه اكتسـاباً دونما تخَلْخُـلِ
~~٤١- يليهما الشخص الذي (تَصَبَّرًا)   تكلفـاً ولم يكـن مُقَصَّرَا
~~٤٢ - ثم (الصبور) أي عظيم الصبر   بـلا تضـايق ولا تضجّرِ
~~٤٣ - ومثله (الصَبّار) قدراً وصِفَة   فالصبر نعـم الميـزةُ الـمشرفة
~~٤٤- وفي (اصبروا وصابروا ورابطوا)   معنـى عظـيم بـالجميع حَـائطُ
~~٤٥ - رَتَبَتِ الصبر عـلى التَفَاضُـلِ   بـدءًا بـأدنى الصـبر لا بالأكمـل
~~٤٦ - وقيل في (اصبروا) على الطاعاتِ   بـالنفسِ والعَـزم مع الثبـات
~~٤٧ - (وصابروا) بالقلب إن أمر عرا   مـن ابـتلاءِ الله فـيما قَـدَّرَا
~~٤٨- (ورابطوا) دُومُوا عَلَى الأشواقِ   إلى الكـريم المـنعم الخـلاقِ
~~٤٩ - وقيل في الله (اصبروا وصابروا)   بـالله رب العـرش نعـم القـادرُ
~~٥٠- ثم مع الله الكريم (رابِطُوا)   والقـول هـذا جيـد وضَـابِطُ
~~٥١- وبعضهم قال: (اصبروا) على النِعَمْ   (وصابروا) البأساء إن أمر دهم
~~٥٢- (ورابطـوا) في موضع النَّزَالِ   في سـائر الأوقـات والأخـوالِ
~~٥٣ - ثم اتقـوا الإلهَذا الإكـرامِ   التفلحـوا في جَنَّـةِ الإنعـامِ

PageV03P155

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0156.png)

# (١٥٥)
~~٥٤ - وقال بعضهم مع النفس (اصبروا)   ثم مع الأعداء طُراً (صابِروا)
~~٥٥- (ورابطُوا) مع الثبات الكامل   وأعـددوا العـدة للمنـازل
~~٥٦- فالزم ثغور القلب كي لا يهجُما   عليك شيطان فتلقى الندما
~~٥٧- وقيل: جَرِّعْ نفسَكَ الصبرَ تَنَلْ   شـهادةً إذا انتهـى بك الأجـل
~~٥٨- وقيـل: (لله) هـو الغَنـاءُ   والصـبر (بـالله) هـو البقـاءُ
~~٥٩- والصـبر (في الله) هـو البَلاءُ   أمـا (مع الله) فـذا الوفـاءُ
~~٦٠ - لكـن (عـن الله) هـو الجَجفَـاءُ   وأهلُـهُ مَصـيرُهُمْ شـقَاءُ
~~٦١- والصبرُ عنوانُ حصولِ الظفرِ   لمـن عـلى مطلبـه لم يَقْـدرِ
~~٦٢ - أيضاً وعنوان الفلاح والفَرَجْ   لكـل مـن في مِحَـنِ الـدنيا دَرَجْ
~~٦٣ - والله بالصـبر الجميـل قـد أمَرْ   صبراً بِـلا شكوى إلى أي بَشَرْ
~~٦٤- والله للهجر الجميـل وجَّهـا   وإنما يَعْلَــمُ ذا أولـو النُّهَـى
~~٦٥ - فإنـه هجـرُ بـلا إيـذاءِ   ولا تطـاول ولا شخْنَاءِ
~~٦٦- وعن رسول الله ذي الفصاحة   إيماننـا صـبرٌُ مـع السَّمَاحة
~~٦٧ - وقولـه مِـنْ أجمـع الكـلام   عليـه صـلينا مـع السـلام
~~٦۸ - وكـل آخـذ برأس الأمـرِ   يكون رأساً في الهـدى والذَّكْرِ
~~٦٩- هم قادة الناس جميعًا للنَّجا   في محكم القرآن هذا الوعد جا

PageV03P156

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0157.png)

~~٧٠- الصـبر فيـه لـذةُ وَيُطْربُ   وهو عـلى الأكثر جـدًّا يصعب
~~۷۱- ومـوحش لغير أهـل الدُرْبَةِ   إن سـلكوا في طـرق المحبـةِ
~~٧٢- لكثرة الشكاء مـنهم والهَلَعْ   وقلـةٍ احـتمالهِم مَعَ الجـزَعْ
~~٧٣- ويسـتلذ المتَّقُـون بـالِحَنْ   لأنهـا مـن المُحِـبَّ ذي المِـنَنْ
~~٧٤- فتـأنس القلـوب بـالمحبوب   وتتتشي للأمـر في رُغُـوبِ
~~۷٥- فهو لـذا مـن آكـد المنـازِلِ   في السير نحـو ذي الجـلال العـادِلِ
~~٧٦- وَيُعلَمُ المُحِـبٌّ مِـنْ سِـوَاهُ   بالصـبر فـيما شـاءَهُ مـولاهُ
~~۷٧- وهكـذا الصـادق والكـذابُ   ومخلص الفـؤادِ والمرتـابُ
~~۷۸- والله قد أثنى عـلى مـن صبَرا   وخصهم بمدحـه وأشهرا
~~٧٩- ولـيس في الإحسـاس والتـألم   مـن قَـادحِ في صبر أي مُسْـلِمِ
~~٨۰ - وكل مـن برَبّه الأعـلى صَـبَرْ   لا تعتريـه وحشـةٌ ولا ضجرْ
~~۸٨۱- وإنما تصیب مـن تعلَّقـا   بِغَـيْرِ رَبَّـهِ فيحيـا قَلِقَـا
~~٨٢ - والمرء إمـا أن يكـون ذا وَرَعْ   مستحياً أو خائفـاً لكي يَدَعْ
~~۸٣ - ولـيس شـك أن ذا الحيـاءِ   أَجَـلُ عنـدَ الله ذي الآلاءِ
~~٨٤- والخـوف أيضـاً نـافعُ مفيـدُ   وذو الحيـاءِ أمْـرُهُ رَشِيدُ
~~۸٥- لأَنَّـهُ أبْلَـغُ في المراقَبَـةْ   وذاك يخشى الله أن يعاقبـهْ
~~٨٦- فإِنَهُ بـالترك يخشـى الضَّرَرَا   وذو الحيـاءِ للإله وَقَـرَا
~~۸۷ - فصار للإحسان جـداً يَقْرُبُ   وذاك مـن شر الرزايـا يهْرُبُ
~~۸۸- وأحسـن الصبر دوامُ الرغبـةِ   في الصدق والإخـلاص في المحبَّةِ
~~٨٩- وأن تكـون وفق سنة النبي   صلى عليـه الله مجـري السحب

PageV03P157

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0158.png)

~~٩٠- ويستعينُ العبـدُ في الـلأواءِ   وَظُلْـمِ ظَــالمٍ وفي الـبَلاءِ
~~٩١- بـأن يلاحـظ الجـزاء الأعظَمَا   ونقمـة الجبـار فـيمن ظَلَمَا
~~٩٢- وبانتظـاره لحسْـنِ الفَـرَج   لوعـده مَـن اتَّقَـى بـالَخْرَج
~~٩٣- فـإن هـذا مـن خَفِـيّ لطفهِ   ومنـهِ وبرّه وعطفهِ
~~٩٤- وَيَـذْكُرُ الإفضـالَ فيما سبقَا   ومـا به الإنعـام قـد تعلَّقَا
~~٩٥- وقيل بعض الصالحات انقطعَتْ   إصـبعُها لِعَثْـرَةِ قَـدْ وَقَعَـتْ
~~٩٦- فضحكت لما جرى وانشرَحَتْ   وشكرت لربهـا وكـبَرتْ
~~۹۷- فقيـل: تضـحكين لـلآلام   قالـت: حَبَـاني الله ذو الإنعـام
~~٩٨- فَفَرْحَتِـيْ بأجرهـا أنسَـاني   آلامَهـا وكـلَّ مـادَهَــانِيْ

PageV03P158

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0159.png)

~~١- إن الرضـا منزلـة عظيمـة   وهـو لمـن فـاز بـه غنيمـة
~~٢ - لَم يَـأتِ أمرٌّ بالرضـا وإِنَّما   جاء الثنـا لمـن بهِ قـد أَكْرمَـا
~~٣- لأنـه عـلى النفـوس يصعبُ   فلم يكـن حتماً عَليهـا يَجبُ
~~٤- والحكـم هـذا خُص بـالبلاء   ومايصـيب المـرء مـن لأواء
~~٥- أمـا الرضـا بـالله والرسـول   والـدين فهـو واجب الحصـول
~~٦- وإن للإيمان ذوقـاً يُطْعَـمُ   كـما أفـاده النبـي الأعظـم
~~٧- يذوقُـهُ الراضـون بـالله العـلي   ربا وبالإسـلام ديـن الكمـل
~~۸- وبـالنبي المصـطفى رسـولا   فمـن يَقُـلْ ذا حقَـقَ المـأمولا
~~۹- يَغْفِرُ ربي ذَنْبَهُ وَيَسْتُرُ   وفضـل ربي واسعٌ لا يحْصَرُ
~~۱۰- وقد أتى ذا في حديثين هُمَا   كـل مقامـاتِ الرّضَـا عَلَـيْهِمَا
~~۱۱- وقـد تَضَمَّنا الرضـا بالله   ربـاً تعـالى مَـا لَـهُ مُضَـاهِي
~~۱۲- وبمحمد رسولاًهادِیا   وقائـداً إلى المعـالي دَاعِيَـا
~~١٣- ثم الرضـا بالـدين في تَسْليم   لله رب العـزة العظيم
~~١٤- فمن حوى هذا بعلم وَعَمَلْ   هذا هو الصّـدِّيقُ دونما جَـدَلْ
~~١٥- وكل من قال وجانب العمل   يعش رهين وهمِـهِ وفي الزلَـل
~~١٦ - وبـالأخص إن يكـن أتـاهُ مَـا   يُخَالِفُ الهـوى الـذي قـد لازَمَـا
~~١٧ - فذو الرضا بالله رباً بالوفا   يُحبُـهُ موحـداً وخَائفَا

PageV03P159

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0160.png)

~~۱۸- منجـذباً إليـه في تبتّـل   منشَـرِحَ الصـدرٍ وفي تَهلَّـلِ
~~۱٩- يرجـو اِلَـهُ لـه معظَّـما   لحكْمِـهِ وأَمْـرِهِ مُسَـلَما
~~۲٠- رضـاؤنا عـن أحمـدِ رسـولا   بـأن يكـون أمره مقبـولا
~~۲۱- وليس من شرط الرضا في المُسلم   أن لا يكـون شـاعراً بـالألم
~~٢٢- وإنما الواجب تـرك الغَلَطِ   مثل اعتراض العبد والتسخط
~~۲٣- وبعضهم قال الرضا لا يعقل   واستشكلوا الأمر الذي لا يشكل
~~٢٤ - قـالوا أيـرضى كـارهٔ لمـا يَجِـدْ   والأصل أن يكون بالأمر سعد
~~۲٥ - نقول للمستشكل استَمِعْ وَع   مِثَالـهُ شرب الـدواء النـافعِ
~~٢٦- فيـه مـرارة ويبعث الألَم   وبالرضـا والحب والتسليم تَمْ
~~٢۷ - وهكـذا الرضـا مـن الإنسـانِ   في كـل مـا جـاء مـن الرحمنِ
~~۲۸ - لكنـه يحتـاج أعـلى همَّـةِ   ونفس حر زكيت بالطاعـة
~~٢٩ - يَعْلَمُ عَجْزَ نَفِسِهِ مِنْ ضَعْفِهِ   وَبِرِّ ذي الجـود وحسن لطفهِ
~~٣٠- فمـن لهـذا العلـم كلـه وصـل   ولم يسـلم لإهِـهِ الأجَـلّ
~~۳۱- ولم يكـن منجـذباً لِبَابِهِ   ومسرعَ السـير إلى جنابِـهِ
~~٣٢- فإنـه المطرود عُرضـةُ البَلا   لأنـه للقرب مـا تـأهلا
~~٣٣- ولـيس كالرضـا مشيرٌُ للفَرَحْ   ولـيس كـالراضي موفَقٌ نَجَحْ
~~٣٤- وقيـل للحُسَينِ سِبْطِ الهـادي   إن أبـا ذرٍ أتـى ينـادِي
~~۳٥- بقوله الفَقْـرُ أَحَـبُّ دائماً   مـن الغنـى والله خـيرٌ راحمـا

PageV03P160

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0161.png)

~~(١٦٠)
~~٣٦ - والسَّقْمُ خَيْرٌ في ذَوِي المحبةِ   مـن صحةٍِ تُنْسِيكَ فضل المنـة
~~٣٧- فقـال رحمـةُ الإلـه الواسعة   تغشـى أبـا ذر ونعـم النافعـة
~~۳۸- لكنني أقـول مـن يَتَكـلُ   عـلى اختيـار الله ذاك الأكْمَـلُ
~~۳٩- ومن هنا قال الفضيل مرشدا   يشراً بما يغـدو بهِ مُسدَّدا
~~٤٠- إن الرضا أفضل من زهد الوَرَى   وليس للنـاس سوى مـا قُدرا
~~٤١ - قال أبو عثمان في قول النبي   عـلى سـؤال طالب وراغبِ
~~٤٢ - (أسـألك الرضـا) أيـا ربـاه   (بعـد القضـاء) شـارحاً معنـاهُ
~~٤٣ - إن الرضا بعـد القضاء يحصُلُ   وَقَبْلَـهُ العَـزْمُ فَلَـيْسَ يُشْـكِلُ
~~٤٤ - وقيـل إنـه انتفـاء الجزَع   في كـل مـا كـان بـلا تَصَـدُّع
~~٤٥- وقيـل رفع الاختيـارِ مطلقـا   فـلا يكـون هـائماً أو قلقـا
~~٤٦ - وقيـل أن يسـتقبل الأحكامـا   بـالفَرَح الكامِـلِ لا مـا رَامَـا
~~٤٧ - وقيل أن يسكن قلب العابد   لمـن لـه الحكـم بعقـلِ راشِـدٍِ
~~٤۸ - وكتب الفـاروق لابـن قيسِ   رسـالة واجبـة التقـديس
~~٤٩- يقول فيها الخير كلـه الرضـا   ما لم تطق فاصبر عـلى مُرَّ القضـا
~~٥٠ - ومن يُعَوّد نفسه اطمئنانا   نال الرضـا مـن ربـه إحسـانا
~~٥۱ - وفاز بالبشری وبالرضا انتفَعْ   عنـد وفاتِـهِ وفي يـوم الفَزَعْ
~~٥٢- لأنه قـد ألـزَم الـنفس بـما   يجعلهـا حَريَّـةَ أن تكرمـا

PageV03P161

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0162.png)

~~٥٣ - ثم الرضـا بـالله عنـد المسـلم   هـو الأسـاس للثبـات الأقـوم
~~٥٤- لم يتخـذ ربـاً سـواه مطلقـا   مـدبراً وهاديـاً ورازقا
~~٥٥ - وكـل شيء ربـه الله العـلي   فهـل يكـون غَـيْرُهُ لنـا وَلي
~~٥٦ - وَهَـلْ لنَـا مـن حَكَم سواهُ   والكـون سـائر بـما قَضـاهُ
~~٥٧ - وأنـزل القـرآن فينـا حكـما   لنهتـدي به ونهـدي الأممـا
~~٥٨ - فذي المفـاهيم أسـاس للرضـا   فلا تكن عن فهم هذا معرضا
~~٥٩- وذا الرضـا فرض بـلا خـلافِ   وَسِرُّ فَـوزِ العبـد بالألْطَـافِ
~~٦٠ - أمـا الرضـاءُ بالقضـاءِ والقَدر   فإنـه كـالفرع منـه والثمر
~~٦١- وما على العبد سوى التسليم   فيـه بحكـم القـادر العلـيم
~~٦٢ - ولـيس كالرضـا به معبـودا   مـن عابـد لا يعـرف الجحـودا
~~٦٣ - فإنـه يسـتلزِمُ الرضـا بـما   يـأمرُ أو ينهـى ومـا قـد قَسَما
~~٦٤ - وعلـق المختـار هـادي الأمـم   تَـذَوُّق الإيـمان فيـه فـافهم
~~٦٥- وكل أنواع الرضا قد دخلت   فيه ومنه كلهـا قـد حصلت
~~٦٦ - وإنه قطـب الرحـى الرصـينِ   لـديننا وحبلـه المتـينِ
~~٦٧ - وسـائر الأحـوال والأعـمال   والعـزم والأقـوال والأفعـال
~~٦٨- عليه تبنـى كلهـا بالكامِـلِ   لكـل عبـدٍ محْسـنِ التَعامـلِ
~~٦٩- أيضـا وتـرك الزيـغ والإشراك   وكـل مـا يوقع في الشباك
~~۷۰- وروح إيمانـك حـب البـاري   حبـاَ شـديداً فـائق المقـدار

PageV03P162

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0163.png)

~~۷۱- وحبنـا للمصـطفى المختـار   وكره ذي كفـر ككـره النـار
~~۷۲- والحب ذا فاق الرضا المجرّدا   وكل مـن فاز به قـد وَجَـدا
~~٧٣- حـلاوة الإيمانِ فيما قـد أتـى   عـن النبـي في الصحيح مثبتـا
~~۷٤- ومـن يكن بالله راضِ هكذا   يرضـاه عبـداً ويكـون الأسعدا
~~٧٥- وكل مـن كرر أذكـار الرضا   يُرْضِيهِ ربي ويقيهِ مِـنْ لَظَى
~~٧٦- وذاك نفع الصادقين صـدقهمْ   لهـم جنـان الخلـد والفـوزُ لهـمْ
~~٧٧- فهم عن الجبار ربهم رَضُوا   وعـن مراد ربهـم مـا أعرضوا
~~٧۸- ورضي الله عليهم حقـا   وزادهم مـن فضـله وأعـدقا
~~۷۹- ومـا قضی ربي ومايَشَاءُ   فـلا تقل معناهمـا سـواء
~~۸٠- ولم يكونـا استلزما رضَـاهُ   أو حُبَّه يـا سعد مـن وَعـاهُ
~~۸۱ - وواجبُ رضاؤنا بما قَضَی   قاعـدةُ الإيـمان فـيما فَرَضَـا
~~۸۲ - لأنه حكـمٌ قضـاه البـارِي   يميّز العـاصي مـن الأبْـرَارِ
~~٨٣ - وكل من لم يرض حكم المصطفَى   ولم يسـلم راضـياً وخائفَـا
~~٨٤ - ولـيس ما شاء بلازم الرضا   من كل ما للمكرمات ناهضا
~~۸٥ - وربـما يشـاؤه لذاتِهَ   وقـد يشـاؤه لغير ذَاتـهِ
~~٨٦ - مثـل وجـود المـارد اللعـينِ   وكـل مـن حارَبَ أهلَ الدِين
~~۸۷ - وكل شيءٍ شاءه فيه حِكَـمْ   وقد يكون سِرُّها عنَا انكـتَمْ

PageV03P163

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0164.png)

~~۸۸ - وللرضـا جَـمٌّ مـن الثمارِ   ينالهـا العبـد بفضـل البـاري
~~۸۹- من ذاك من يرضى بما له كَرِهْ   حقق ما فات سواه فانتبه
~~٩٠- مـن العبوديـة بـالكمالِ   وعـاش في أنـس وخـير حَـالِ
~~٩۱- رضـاؤنا عـن الإلـه يثمـر   رضـاعه وهـو النعـيم الأكـبر
~~٩٢ - والسُخْطُ باب الهم والأحزان   يُغْلَـقُ بالرضـا عـن الـرحمنِ
~~٩٣- وذا الـذي يفتح بـاب الأمـلِ   في جـود ربَّنا الكـريم المُفْضِـلِ
~~٩٤- ويسكن القلـب إلى باريـهِ   ولم يُـرِدْ غير الـذي يُرْضِيهِ
~~٩٥- وذو الرضا لم يكُ خَصْمَ رَبَّهِ   بل هـو خير فـائزِ بقربِـهِ
~~٩٦ - فحكمه ماضِ بدون مانِع   في كـل سـاخطٍ وكـل طـائع
~~۹۷- والعـدل لازم لـه دَوَامَـا   وإن يكـن قـد خـالف الأفهاما
~~۹٨- والسخط لا يجنى به سوى الضَّرَرْ   ونيـل أسباب الشرور والخطَـرْ
~~۹۹- ومـن ثماره النجـا مـن الدَّغَلْ   والغِشَّ والغِلِّ وأسبَابِ الَخطَلْ
~~١٠٠ - فليس ينجو من عذاب ربّهِ   غير سليم القلبِ راجي قُرْبِهِ
~~١٠١ - يعـيش بالرضـا مع اليقينِ   عـلى صراط ربـه المبـينِ
~~١٠٢- وكل مـن لم يستطع ذا مُطلقا   يلتـزم الصـبر لكـي لا يخفقـا
~~١٠٣ - فـإن في الصـبر عـلى المكـروهِ   خيراً كثـيراً للفتـى النَبيـهِ
~~١٠٤ - وكل راض بالقضاء والقَدَرْ   يجني به أشـهى وأطيب الثمر
~~۱٠٥- يمـلأ قلبه محبـةً لَهُ   ثـم ينيلـه الـذي أمله

PageV03P164

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0165.png)

~~١٦٤
~~١٠٦- مـن الغنى والأمـن والقناعة   وأوجـه الخير وحسـن الطاعـة
~~١٠٧ - والشكر وهو في بني الإنسانِ   أعـلى مقامـات ذرى الإيـمانِ
~~١٠٨ - وكـل فاقِـدٍِ مقـامَ الشُّكْرِ   يكـون مـن جملـة أهـل الكفرِ
~~١٠٩ - وربـما يجـره كفـر النَعمْ   للكفـر بالمنَّـان واسع الكـرَمْ
~~١١٠ - ويظفر الشيطان بالإنسـانِ   في السخط والشـهوة والطغيـانِ
~~۱۱۱- من أجل ذا قال حبيبنا النبي   لمـن أراد نصـحه لا تغضـبِ
~~۱١٢- علمنا في يوم موت نجلِهِ   بحزنـه ودمعـه وقولهِ
~~١١٣- لأننـا في حالـة الأحـزانِ   يخشـى علينـا فـتن الشـيطانِ
~~١١٤- والقول والفعل الذي لا يحمدُ   تسخطٌ وفي الجحـيم يـورِدُ
~~١١٥- والحـزن والـدموع جـائزان   بـل مظهـر الرحمـة في الإنسـان
~~١١٦- أيضاً ومن ثماره طرد الهوی   من قلب راضِ لهدی الله حَوَى
~~۱۱۷ - وليس للراضي من اخْتِيَارِ   بـل اختيـارُهُ مُـرادُ البَـارِي
~~۱١٨- وذو الرضـا بربّه وَعَنْهُ   يـرضى بـما يـأتي إليـه مِنْـهُ
~~۱١٩- وليس يُرْضِي أحداً بالسخط   لربّـه فـذاك شـر الغَلَطِ
~~۱۲۰ - وحمـده لله لا لغيرِهِ   لأن مـا أنيـل عـين خـيرِهِ
~~۱٢۱- ينيله أفضـل مِمَّـنْ سَـأَله   لأن ذكـر الله عنهـا شغله
~~۱٢٢- ولا يذُم النـاسَ فيما فاتـا   لأن مـولاه لـه مـا آتـى
~~١۲۳ - ولـيس يشكو قادراً لعاجزِ   إلا سخيفٌّ مـا لـه مـن حـاجِزِ

PageV03P165

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0166.png)

~~١- الشكر لله العظـيم العـادل   منزلـةٌ مـن أفضـل المنـازِلِ
~~٢- والشكرُ أعـلى رفعة مـنَ الرضا   والكفرُ ضد الشكرِ ممـن أعرَضا
~~۳- وربنـا بـه العبـاد قـد أمـرْ   وكـل مـن لم يتصف بِـهِ كَفَرْ
~~٤- وكـم له مـن الثنـاءِ العـاطِر   عـلى تَقِـيِّ صـابرِ وشـاكِرِ
~~٥- وغايـة الخلـق هـي الشكر، فَع   وكـنْ لأمـر الله خـيرَ طـائع
~~٦ - والشكر حقـأَ سـبب المزيـدِ   مـن مالك الملك عظيم الجـودِ
~~٧- وفهم آيـات الكتـاب والعبر   يحظى بها كلّ شكور قد صَبَرْ
~~۸ - وسعي أهل الشكر مشكورا غدا   والله يـرضى الشكر ممنْ اهتَدى
~~٩- وهـم أقـل العـالمين مطلقـا   وفضـلهم للأمر ذا تحَققـا
~~١٠ - ولم يكـن عبـد شكورا أبـدا   مثـل نبينـا الشـفيع المقتـدى
~~۱۱- صلى عليه الله عـد مـن شكر   وعـد جاحـد به ومـن كفر
~~۱۲- قد دلّنا بلطفه وأرشدا   على طريـق الشكر كيما نَسْعَدَا
~~۱۳- حب نبینا معاذا قد نفع   ونصحه الذي مـن القلب نبع
~~١٤- بـأن يقـول داعيَـا أعِنَّيْ   للذكر والشكر عظـيم المـن
~~۱۵٥- وَحُسْنَ ما آتیه من عبادَتِكْ   لكي أكون مـن ذوي عنايتك

PageV03P166

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0167.png)

~~۱٦ - وقـد دعـا إلهـه الغفَّـارا   بـأن يكـون عبـده الشّكارا
~~١٧- كـما أتى عـن أحمـد في المسـندٍِ   والترمذي عن ابن عباس الندي
~~۱٨- وإن ترد قواعـد الشكر التـي   يبنى عليهـا كالبنـاء الثابـتِ
~~۱۹- خضوع شاکر لمن له شَكَرْ   وحبه حبـاً بـلا حـدٍ حصرْ
~~٢٠ - مـع اعترافـه بكـل الـنعم   ثـم ثنـاؤه بـأحلى الكلـم
~~۲۱- أيضـاً ولا يستعملن مـا نـالاً   في مُغْضِـبِ لربـه تعـالى
~~۲۲- وقيـل حده اعتراف بالنَّعَم   مـع الخضـوع والتـذلل الأتَمّ
~~۲٣- وقيل أن نثني على مـن أحسَنا   بـذكر إحسـان بـه أمَـدَّنَا
~~٢٤- وقيل أن لا يستعين من حبي   بـنعم الله لفعـل المغْضِـبِ
~~۲٥ - وقيل أن يَعْكِفَ قلبُ الشاكِر   عـلى محبـة الكـريم الغَـافِرِ
~~٢٦ - في طاعـةٍ بالقلبِ والأركـانِ   والـذكر والثنـاء باللسـانِ
~~۲۷- وقيـل أن تشـهد كـل منَةِ   وحفظك الحرمـة يـا ذا الهمـةِ
~~۲۸ - وأن تكـون كـالطفيليَّ لِـا   تعیش فيه دائماً منعَما
~~۲۹- ولا ترى نفسك أهلا للنعمْ   من كل ما أسداه بارئ النَّسَمْ
~~٣٠- وقيـل باستفراغ كـل الطاقـةِ   مجتهـداً بـدون مـا إضـاعةِ
~~٣۱- والشكر شكران: فشكر العامة   للـنعم المحسوسـة الموائمـةٌ
~~۳۲- وشكر مـن يطمع في المزيـدِ   شكر عـلى الإيـمان والتوحيـد
~~۳٣- وللجنيـد حكمـة في المنتهـى   فاصغ إذا مـا شئت أن تحظى بها
~~٣٤- الشكر أن لا تستعين بـالنعَم   عـلى معـاصي الله واسِعِ الكَرَم

PageV03P167

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0168.png)

~~۳٥- معرفـة النعمـة أن تستَحْضرا   في ذهن من حظي بها وتُشكرا
~~٣٦- قبولها بأن تکون مُظهرا   فقرَك للمـنعم مهـما أَكْثَـرَا
~~۳۷- وأنها جـاءت بـلا استحقاقِ   وإنما فضـلا مـن الـرزَّاقِ
~~۳۸- ثناؤنـا شكرٌّ لرب الجـود   شكراً وعرفانـاً بـلا قُيُودِ
~~٣٩- هذا على العموم، والخصُوصُ   تَحَدُّثٌُ جـاءت بـه النصُـوصِ
~~٤٠- بأنهـا واصـلة مـن ربنـا   فضـلاً وإنعامـاً وإكرامـاً لنـا
~~٤۱- وسورة الضحى كفت دلالـة   لفهـم ذا الأمـر بـلا جهالة
~~٤٢ - والمرء إمـا أن يكـون مجْزيـا   أو عـاجزاً فَمُثْنِيـاً إن أعْطِيـا
~~٤٣- وصـاحب الثنـاء هذا شـاكِرُ   وكـاتم النعمـة لؤمـا كـافرُ
~~٤٤ - ومـن تَحَلَّى بالذي لم يعطَ   فَإنَـهُ في زُورِهِ قـد شطًا
~~٤٥ - كلابس ثـوبين لكـن زُورَا   فلم يزل عند الـورى محقورا
~~٤٦- وكـل مـن لم يشكر القلـيلا   لم يشكرِ الكثـيرَ مهـما نـيلا
~~٤٧ - وكـل مـن لم يشكر الأناسـا   لم يشكر الله، فخـذ مقياسـا
~~٤٨- ودعـوة النـاس إلى ربّ الكـرم   تَحَـدُّث مِـنْ الـدعاة بالنَّعم
~~٤٩- يُعَلَّمُ الخَلْـقَ بِـما قَـدْ فَرَضَـا   ويرتجي مـن ربه الأعلى الرضا
~~٥٠- تأسَّـياً بِأَفْضَـلِ الـداعِينَا   وخـير خلـقِ الله أجمعينَـا
~~٥١- محمد المختـار خيرِ مـن شَكَرْ   وخير من صام وصلى وذكر
~~٥٢ - صلى عليه الله مـا الحق ظهر   وما اختفى صوت ضلال واندحر

PageV03P168

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0169.png)

~~۱٢٨
~~٥٣- والشكر منهاجُ جميع الرُسُلِ   والأنبيـا والتـابعين الكمـل
~~٥٤ - وأقرب الناس إلى الخَلاَّق همْ   فجَـلَّ مَـنْ بِفَضْـلِهِ أَجَلَّهُـمْ
~~٥٥ - لـيس مقـام منه أعـلى مطلقـا   وکل من فاز به فقد رَقَی
~~٥٦ - وأنـه أعـلى المقامـات كَما   بينـه المحققـون العلـما
~~٥٧ - وكلـما سـواه فيه تَـدْخُلُ   فهـو مقـام للجميع يشملُ
~~٥٨ - والشكر إنعـام مـن الـرحمنِ   ونفعـه يرجِـعُ للإِنسـانِ
~~٥۹- ولم يكـن مكافئـاً مـن يشكرُ   لربـه بـل بالمزيـد يظفرُ
~~٦٠ - لأن فضـل الله لـيس يحصَرُ   والله إن أمـدنا لا يخسرُ
~~٦۱- سبحانه یشکر من له شَکَرْ   لا لاحتيـاج، لا ولا دفع ضرَرْ
~~٦٢- وشكرنا لله من خيرِ النَّعَمْ   وشكره للعبـد غايـة الكرم
~~٦٣- أنْعَمَ بالخير، وللشكرِ هَـدَى   وللعبـاد الشـاكرين مَجَّـدا
~~٦٤- والله لا ينفعُـهُ مَـنْ يَشْكُرُ   أيضـاً ولا يضُرُّهُ مَـنْ يَكْفُـرُ
~~٦٥ - وإنـما يجـزي بوفـق العَمَـلِ   سبحانه مـن منعمِ ومُفضل
~~٦٦ - وكل مَـنْ لله مُخْلِصاً شَكَرْ   عـلى الـذي يَكْرَهُـهُ نَـالَ الظَفَـرْ
~~٦٧ - لأنـه أفضـل مِـن شُكْر عَـلَى   مَحَـابِّ وُجُودُهَـا قَـدْ حصَـلا
~~٦٨ - والمرء إما أن يكـون في الذُّرَى   في شكره لربـه الـذي بَـرَى
~~٦٩- ينظر للمكروه كـالمحبوبِ   لأنـه مـن عـالم الغُيُـوبِ
~~٧٠- أو أن يكـون في المقـام الثـاني   في شكره لربـه المنَّـانِ

PageV03P169

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0170.png)

# (١٦٩)
~~٧۱- فشكره لله إظهـار الرضَـا   لأنـه لربـه قـد فوضا
~~٧٢- يُحْزِنُـهُ المكـروهُ لا يُحبُّهُ   ولم يكـن يرضى بـأن يصيبَهُ
~~٧٣- لكـن إذا قـدَّره مـولاهُ   يشكُرُهُ عـلى الـذي قَضَـاُه
~~٧٤- رعايـةً لحَحقَّهِ الـذي وجَبْ   ومسلك العلم الشريف والأدب
~~٧٥- إذ أوجبـا الشكر لـذي الآلاءِ   دومـأعـلى السَّراءِ والضَّرَّاء

PageV03P170

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0171.png)

~~۱- حقيقةُ الحيـاءِ يـا مـن يَسْمَعُ   ما كان عـن ترك القبيح يَمْنَعُ
~~۲- برؤيـة الآلاء للحميـدِ   أهـل الثنـاء الواحـد المجيـدِ
~~٣- ورؤيـة التقصـير حتـى يُولَـدا   بينهما الحيـاءُ زَيْـنُ السعدا
~~٤ - قـال السَّرِيٌ العـالم الربّـاني:   إن الحيـا والأنـس يَطْرُقـان
~~٥- قلبَك يطلبـان فيه الوَرَعَـا   والزهـدَ مـا لم يجـداها ودَّعـا
~~٦- فـإن يكونـا فيه حَـلاًّ فيهِ   ولم يعـد يفعـل مـا يُشقِيهِ
~~۷- وخذ علامات الشقا عـن عـالم   ابـنِ عيـاضِ الْفُضَـيْلِ الْفَـاهِمِ
~~٨ - إذا قسى القلب وعين جَمَدَتْ   فالنفس في درب الشقاءِ قد غَدَتْ
~~٩- وقلـةُ الحيـاءِ أعـلى خَطَـرا   تَجُـرُ للشـقوة جـراً أكـبرا
~~١٠ - وحبنـا الـدنيا بـلا تَعَقُـل   في رَغَب فيهـا وطـول الأمَـلِ
~~۱۱- ومـن أطـاع واستحى تأدُبا   يستح مِنْـهُ رَبُـهُ إن أذنبـا
~~۱۲ - وكل مـن طاعاتُه تَزْيْنُهُ   يـدفع عنـهُ الله مـا يشينهُ
~~۱٣ - أقسامه عشر فخـذْ بيـاني   أولهـا حيـاءُ عبـدٍ جـاني
~~١٤- وبعـده الإقرار بالتقصـيرِ   عـن حـق مـولاهُ مع التشميرِ
~~۱٥ - ثم حيـاءُ من لربه عرَف   فهـو يُجِلُّهُ ليكسب الشرف

PageV03P171

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0172.png)

~~۱٦- وبعـده يـأتي حيـاء الكرَم   مثـل حيـاء المصـطفى المعظَّـم
~~١٧- لمـادعـا إلى طعـام طَيَّبِ   أصحابَه لعرسـهِ بزَيْنَـبِ
~~١٨- ثم الحيـاء حِشْـمةَ كما فَعَـلْ   (عليُ) عن حكم لِـمَذْي إذ سأل
~~۱۹- وبعـده حيـاء الاستصـغَارِ   مـن نـاظر للنفس باحتقارِ
~~٢٠ - وهو الذي يخجل عـن أن يطلبا   مـن ربـه مرامـه المحببـا
~~۲۱- معظـماً لربـه العظـيم   أو خائفـا مـن ذنبه الـذميم
~~۲۲- وبعـده يـأتي حيـاء الحبَّ   بروعـةٍ كامنـةِ في القلـب
~~۲٣- وللعبوديـة في النـاس حيـا   يُمْزَجُ من حبِ وخوفٍ قَوِيا
~~٢٤ - فيستحي العبـد مـن المعبـودِ   يجله مـن دونما قُيُـودِ
~~٢٥ - وتاسع الأقسـام: عز وشرف   والقسم هذا قلّ من له عرف
~~٢٦ - فيستحي وهـو عظيم البذلِ   إذ لا يـراه جـود أهـل الفضـلِ
~~۲۷- ويستحي مـن ذلةِ في السائل   فيـا لـه مـن محسـنٍ وخاجِـلِ
~~٢٨- ثـم حيـاء الأنفـس الشريفةِ   مـن ذاتهـا خوفـاً مـن النَقِيصَةِ
~~۲۹- طريـق نيـل ذا الحيـاء العـالي   بـالعلم بـاطلاع ذي الجـلالي
~~٣٠- بـالنظر الـدائم نحـو الخـالق   سبحانه مـن عـالم ورازق
~~۳۱- عندئذٍِ ينجـذب الإنسَـانُ   إلى الـذي يـرضى بـه الرحمنُ
~~۳٢ - يستقبح العصيان مهـما نَـدَرا   ولا يكـون شـاكياً ممـا جَـرَى
~~٣٣- وكـل مـن يستقبح المعـاصي   الحُبَّـهِ لمالـك النـواصيْ

PageV03P172

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0173.png)

~~٣٤- حيـاؤه أرفعُ مِمَّـنْ خافـا   لأنـه إلى الكمال وافی
~~٣٥- لا يشـتكي خَلاَقَـهُ للبشرِ   لعجـزهم عـن نفعـه والضررِ
~~٣٦- وإن شكواه لـذي الجـلالِ   مفتقـراً تعليـهِ للكـمالِ
~~۳۷- وبعـده حيـاءُ أهـل الحـبِّ   مَـن أكرمـوا مـن ربهم بالقربِ
~~٣٨- فـإنهم أهـل المعيـةِ التـي   خُصُّـوا بهـا عَـنْ سَـائرِ البريّة
~~۳٩- أقرب مـن کـل قريبِ ربي   بعلمـه ولطفـه والحـبِّ
~~٤٠ - ويقـربُ العبـد إذا تهجّـدا   ثـم يزيـد قربـه إن سجدا
~~٤١ - فـإنهم لأنسِـهِمْ بـربهم   لم يشبعوا مـن موجبـات حبهم
~~٤٢ - قد شمَّروالصالح الأعمالِ   وكـلِ مـا يُحِـبٌّ ذو الجـلالِ

PageV03P173

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0174.png)

~~۱- الصدق سرّ فوزِ كل من سلك   وتركُه سرّ هـلاك مـن هلك
~~٢ - وإنـه الفـارق بـين المـؤمِنِ   والهالـكِ المنـافقِ المـداهِنِ
~~٣- وإنه السيف الـذي لا يكسرُ   وكل من بالصدق صال يُنصَرُ
~~٤- وكـل مـن قـال بـه لا يُهـزَمُ   وهـو الـذي بـه الإله يكرم
~~٥ - وإنـه العـون عـلى الشـدائد   ومُـنجح الآمـال والمقاصـد
~~٦- وهـو أسـاس في بنـاء الـدينِ   وعمـدة الإخـلاص واليقين
~~۷- وهو الذي يوصل نحو الباري   رغم صنوف الصدّ والأخطارِ
~~۸- والله نـادى المـؤمنين قاطبـة   أن يلزموا الصدق لحسن العاقبة
~~٩- وضـمهم في الفـوز والإنعـام   مـع النبيـين أولي الإكـرامِ
~~۱۰ - والشهداء بعدهم قد ذكروا   فهل كهذا الفضل فضل يُذْكرُ
~~۱۱- والصالحون بعدهم بهم خَتَمْ   فلازم الصدق لتحظى بالكرم
~~۱۲- هـذا يـدل أنهـم أعـلى الـوری   کما أتى عـن ربنـا مسطرا
~~۱٣- وهم أولوا البرّ كما قـد وردا   مبيّنـاً مفصـلاً مفنّـدا
~~١٤ - وهم أولوا التقوى على التحقيق   في حالـة اليسْرِ وعنـد الضـيق
~~١٥ - فالصـدق بـالأعمال والأقـوالِ   وبـاطنِ وظـاهرِ الأحـوالِ
~~١٦- يستفرغ الطاقـات نحو الرّشدِ   في طاعـة الله العـلي الأحـدِ
~~١٧- حتـى يكـون في ذرى المعـالي   وراقيـاً في سُـلَّمِ الكـمال

PageV03P174

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0175.png)

~~١٨ - وهو الذي ينجي مـن النيرانِ   ويرفع المطيـع في الجِنَـانِ
~~۱۹_ وکل منقادِ بلا انتکاس   يكون بين النـاس كـالنبراس
~~٢٠- قد نال في الصدق أعالي الرتبِ   ومـن صنوف الخير كلهـا حُبِيْ
~~۲۱- أمـا لسـانه فعنـوانٌُ عـلی   ما ضمّه فـؤاده واشتملا
~~۲۲- ومقعـد الصـدق لـدى المنَّان   يحظـى بـه في روضـة الجِنَـانِ
~~٢٣ - وَقَدَم الصدق لهـم لصدقهمْ   كرامـة ممنوحـة مـن ربهـمْ
~~٢٤- وصاحب الصدق على اطمئنانِ   في كـل حالـة وكـل آنِ
~~۲٥ - وكل كذاب حبيس الرَّيبِ   ولم ينـل ذو الـزور أدنـى أربِ
~~٢٦ - يكفيـه أن يهـدى إلى النـيرانِ   وصـاحب الصـدق إلى الجنَـانِ
~~۲۷- وأن يكـون كاذبـاً وفـاجرا   ونادمـاً يـوم اللقـا وخـاسرا
~~۲٨ - والصدق في البيع يُحـل البركة   والمحقُ والخسرانُ فيمن تركه
~~۲۹- وإن ترد حقيقـة الصـدق فع   لمـا أقـول في نظـامي واسمَعِ
~~٣٠- هـو الوفـا لربنـا بالعمَـلِ   وهو استواء السر والأمـر الجلي
~~۳۱- وقيل قول الصدق عند الهلكة   وعند ذي ظلم وتخشـى شَرَكه
~~۳٢- وقيل أهل الصدق في تقلُّبِ   ما بين مندوبِ وأمرِ واجبِ
~~۳٣- بـأربعين حالةً قـد مروا   أمـا الكـذوب فهـو مستقر
~~٣٤- فما له مـن واردات تَردُ   ولا مـن الشـيطان شيء يُجْهِـدُ
~~٣٥- بل في قيود الزور أضحى مُوثقا   وفي رياض الأنس ذو الصدق رقى

PageV03P175

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0176.png)

~~۳٣٦- فهـو إلى خَلَّاقِـهِ يسـير   وفي جِنَـان حبـه يطـيرُ
~~٣٧- ولا يشـم الصـدقَ مَـن يُـداهنُ   لَـا بـهِ مـن الشرور كـامِنُ
~~٣٨- قال الجنيد: الصدق فافهم واعلمَنْ   صـدقك في مـوطن شرٍ وفِتَنْ
~~٣٩- ولا ترى النجا سوى أن تكـذبا   لكـن ترى صدقك أمرا وجبا
~~٤٠- وأولُ الصدق بصدق المقصِدٍِ   بالجـد والعـزم بـلاتـردُّدِ
~~٤١ - والصادق الحق هو الذي انجذَبْ   إلى رضـا خلأَقـه كـما أَحـبّ
~~٤٢ - ولم يصـاحب قـاطعي الطريـقِ   خوفـاً مـن الحصر أو التعويـق
~~٤٣ - إلا إذا اضـطر فبالجسـم فَقَطْ   ولم يكن بالروحٍ والقلبِ اختلَط
~~٤٤ - لا يقْصدُ العـيشَ لغير الحـقِّ   لأنـه يعرف معنـى الصـدق
~~٤٥- ولا يرى شيئاً سوى النقصانِ   مـن نفسـه مقابـل الإحسـان
~~٤٦- فهـو يريـد أن يعـيش سـاجدا   وعالمـاً معلـماً مجاهِـدا
~~٤٧- فـلا لأزواج ولا أشجارِ   ولا لجـري المـاء في الأنهـارِ
~~٤٨- وإنـما للصـوم في الهـواجِرِ   تقربـاً إلى الإلـه الغـافِرِ
~~٤- والقول هذا من (معاذ بن جبل)   قد قاله ساعةً مـا الموتُ نَزَلْ
~~٥٠ - متابعـاً للمصطفى الرسـولِ   مسـلَّماً بكامـلِ القبـولِ
~~٥١ - ومخلصـاً في قولـه والعمَـلِ   مستصـغراًلنفسِـهِ في وَجَـلِ

PageV03P176

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0177.png)

~~۱- منزلـة الإيثـار سـام قـدرها   الجـود والإحسـان والسخا بهـا
~~۲- والله قـد أثنى عـلى مـن آثرا   وذم أهـل الشّح ذمـأَ سـافِرا
~~۳- وعرفـوا حقيقـة السخاءِ   باليُسْرٍ في البـذل وفي العطـاءِ
~~٤ - والجود أن تُعْطِيْ العطاء الأكثرا   أو مـثلما تُبْقِــيْ إذا مـا قُـدَّرا
~~٥- وإنما المـؤثر مـن يعطِـيْ ولا   يبقـي ولكـن في الثـواب أمَّـلا
~~٦ - وعكسه الأثرَةُ وهي أخذُ مـا   يحتاجُـهُ أخـوهُ لا أن يُكْرِمـا
~~٧- وَوَصْفُ رب العرش للأنصارِ   بصـدقهم في الحـب والإيثـار
~~۸- ونصحهم من النبي الـمرتضى   بالصـبر عنـد أثـرة مـع الرضـا
~~٩- كي مـا ينالون الجزاء الأجمَـلا   بفعلهـم وصـبرهم مكمـلا
# مصاعد الجود
~~١٠ - والجـود في النـاس له مراتبُ   عشرٌّ حِسَـانٌ كُلَّهـا مناقِـبُ
~~١١- الجـود بـالنفس وبالمناصبِ   والجـود بـالعلم لكـل طالِـبِ
~~۱٢- والجود بالراحةِ من أجلِ الورى   مضحياً بلـذةِ وبـالكری
~~۱۳- والجود بالجاه بلا استنكافِ   ولا تكـبرِ ولا اسـتعفافِ
~~١٤- وجـوده أيضـاً بنفع البَـدَنِ   والجـود بـالعِرض لكـل مـؤمنِ
~~۱٥- مثل أبي ضمضم حين صرحا   بعفـوه عـن شـاتم تسـامحا
~~١٦- فقـال إذ ذاك النبي الهـادي   مرغبـا في جـود ذا الجـواد

PageV03P177

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0178.png)

~~۱۷- مـن يستطيع أن يكـون مثله   والقـول ذا مـدح وإعـلاء له
~~١٨- لأن ذا الجـودَ يـريح المؤمنـا   فـلا يكـون حاقـدا وضـاغنا
~~۱۹- محققـا سـلامة الصـدور   بـلا عـداوة ولا شرور
~~٢٠ - والجـود بالصـبر والاحتمالِ   وهـذه تفـوق بـذل المـالِ
~~۲۱- والجـود باليشرِ وبالتهلـلِ   مع انبساطِ الوجـه والتجمـل
~~۲۲- وجود ترك ما بأيدي الناسِ   فـاق سخاء بـاذلٍِ مُـواسي
~~٢٣- لأنه بزهـده قـد فَـاقَهُم   منفـرداً براحـةِ ليستْ لهـم
~~٢٤- يـؤثر بالـدنيا ولا يبـالي   لا الـدين فهـو أكـرم الغـوالي
~~٢٥- والعبـد بالإيثـار يرقی آبـدا   ولم يكـن بخـاسرِ مـا فَقَـدا
~~۲٦ - ومـن یکن لربه قد آثرا   يرقى بذا الإيثار قمـة الذرى
~~٢٧- وربـما ابتلي بأقصى المحـنِ   فلـم يـزل مـؤاثراً لم يَنْـثَنِ
~~٢٨ - ولم يقصّرْ في رضـا بارئهِ   ولم يَحِدْ عـن فعـل مـا يرضيهِ
~~۲٩- فالحزن بعد الصبر يغـدو فرحـا   والخوف والأتعاب تغدوا مِنَحَا
~~۳٠- يفـوز بـالعزة والتأييـدِ   والحـب والإجـلال والتمجيـدٍ
~~۳۱- وضـده يبـوء بالخسرانِ   وكُرْه مـن أرضـاه والخِـدْلانِ
~~۳۲- وربما يصـاب منه بالمحَنْ   والذم والسخط وأسباب الَحزَنْ
~~٣٣- فلا على مقصوده منه حَصَلْ   ولا إلى ثـواب ربـه وَصَـلْ
~~٣٤- لأن إرضـاء الـورى لا يُـدْرَكُ   فهـو بحكـم العقـل ممـا يُتْرَكُ
~~۳۵- والله یکفي کل من قد آثرا   شر الأعادي مُطلَقاً كيف جرى

PageV03P178

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0179.png)

~~۱- الُخلُـق الـدين الـذي ارتَضـاهُ   إهنـا ولم يـرد سـواهُ
~~۲ - وصح أيضـاً أنـه القرآن   كما روت عائشـةُ الحصَـانُ
~~٣- إجابـةً عـلى هشـام إذ سـأل   فحقـق العلـم لديـه واكتمـل
~~٤- والمصطفى حَثَّ على الأخـلاقِ   لأنهـا تُكْسَـبُ كـالأرزاقِ
~~٥- وانَّ (خُدْ) (وَأمُرْ) (وَأعْرِضْ) جامعة   لكـل أخـلاق الكـمال النافعـة
~~٦- فالأمر بالمعروف من خير الشّيَم   وهو الذي نَسمو به إلى القمم
~~٧- والأمر بـالعفو حـوى كثيرا   ولم يعـد تفسـيره محصـورا
~~٨- كاليسر والإغضاء والتسائح   وكفنـا عـن سـائرِ القبـائحِ
~~٩- والصـدق والتيسـير في التعامُـلِ   بـلا تعنُّـت ولا تحامُـلِ
~~۱٠ - وقـد أجـاب المصطفى الأبَرُّ   نَـوَّاسَ إذ قـال لـه: مـا البِرُّ
~~۱۱- بأنـه محاسـن الأخـلاق   فيـا لعلـم صـفوة الَخـلَّاقِ
~~۱٢ - البر ما اطمأنت النفس له   لأنهـا قـد فطرت تألفـهُ
~~۱١٣- والإثم مـا يحيك في الصـدورِ   وكنت تخفيـه عـن الظهـور
~~١٤- كراهـة مـن اطـلاع النـاسِ   لأنـه مـن جملـةِ الأرجـاسِ
~~۱۵- وخیر من یفوز بالعطایا   همُ أولـو الأخـلاق في البرايا

PageV03P179

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0180.png)

~~١٦- وأحمد الهـادي لهـم قـد ضمِنا   أعـلى الجنـان منـزلاً ومسكَنَا
~~١٧ - وهم أحـب آلـه إليه   والأقربـون مقعـدا لديـهِ
~~١٨- لأنـه الأثقـل في الميـزانِ   وأهلـه الأكمـل في الإيـمانِ
~~١٩- والخلـق المحمـود في الإنسـانِ   قـام عـلى أربعـةٍ أركـانِ
~~٢٠ - الصبر وهو في الخصـال الأولُ   وعفةٌ عـن كـل مـا لا يَجْمُـلُ
~~۲۱- ثـم شجاعةٌ وعدلُ وهُمَا   كـل معـاني النبـل جـاءت مِنْهُما
~~۲۲ - وكـل محمـود مـن الفضـائلِ   مُكْتَنَـفٌ بــأقبحِ الرَّذَائـلِ
~~٢٣- كحِلْم من يَحْلُمُ بين الغضبِ   وذلـة الـنفس لأدنـى سبب
~~٢٤ - والجـودِ بين البخـلُ والتبذيرِ   وقِسْ عـلى ذا سـائرَ الخيـورِ
~~٢٥ - وأربعُ أسـاس كـل سـافِلِ   مِـنْ سَيّءِ الأخـلاقِ والرذائلِ
~~٢٦ - فالجهلُ مصدرُ الشقاءِ والعلل   والظلم رأس كـل شرٍ وخلل
~~٢٧ - وإن يك الإفراط في الضعف ارتفع   أو كـان في القـوة زادَ واتسع
~~۲٨ - فكـل نـوع منهما يُولَدُ   كََا مِـنَ الأخـلاقِ ليس تُحمَدُ
~~٢٩- فَفَرْطُ ضعفِ النفس مِنْهُ يحصُلُ   الـذلُّ والحـرص ومـا لا يَجْمُلُ
~~٣٠- وإنَّ مِـنْ إفراطهـا في القـوةِ   ظلمٌ وطَـيشُّ وارتفـاعُ الحِـدَّةِ
~~۳۱- وكل مَـنْ مال عـن التوسطِ   يعيشُ في شتى صنوفِ الغَلَطِ
~~٣٢ - مـن شـدة الإفراط والتفريط   وسيء الأخـلاقِ والتخبـيطِ
~~۳٣- والانحراف عن معـالي الخلُقِ   إلى دنيئهـا ومـا لم يَلِـقِ

PageV03P180

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0181.png)

~~٣٤- ولم يكـن أصعب في التحويـل   مـن طبع إنسـان أو التبـديل
~~٣٥- وقـوةُ الشـهوة في الإنسـانِ   والغضـبُ المحبـوب للشـيطانِ
~~٣٦- طبيعـة وسـميت إرادةٔ   تجـر للشـقا أو السـعادة
~~۳۷- وإنهـا في الحيـوان توجـدُ   والأمـر هـذا واضح لا يجحـدُ
~~۳٨- بقـوة الشـهوة نفع يُجلبُ   كمـثلما يَـدفَعُ ضراً غَضَـبُ
~~۳۹- وعاجز عـن دفع ضرِ يحقد   فحقـده ينـوب عـن مـا يجـد
~~٤٠- وشهوة الحاسد حـين الظفَر   تجرُّ للشح شـديدِ الخطَـرِ
~~٤١- وإن يك الحرصُ بـه مشتدا   يكـون للعـدوانِ مستعداً
~~٤٢ - بالغضـبية التـي لديـهِ   فَـيُظْلَمُ النـاس عـلى يديهِ
~~٤٣- والكبر من تلك الصفات يوجدُ   والفخر والعجب وما لا يحمد
~~٤٤ - وربما المذموم صـار في القرب   يعلـو بـه المسـلم أرفـع الرتـب
~~٤٥- مثل اختيـال المرء في الحروب   وبغض فعـل الشروالذنوب
~~٤٦ - إذن فـنفس المـرء كالمُسَـلَّم   إلى طبيـبِ فـائق الـتفهم
~~٤٧ - يـدلها عـلى الـذي يشـفيها   مـن مـؤلم أو مفرح يرضيها
~~٤٨ - ومـا لهـا بدٌ مـن القبـولِ   خوفـاً مـن المـوت أو الـذبولِ
~~٤٩- فـاعلمْ بـأنْ لا طِبَّ للإنسانِ   في هـذه الـدنيا سـوى القـرآنِ
~~٥٠ - ولا طبيب غير خيرِ الرسلِ   فافهم تكـن مـن التقـاة الكمـل
~~٥۱ - ومن يعـالج نفسه بفهمه   يموت مخنوقـاً بحبـل وفمهِ

PageV03P181

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0182.png)

~~٥٢ - فسَـلَّم الـنَّفْسَ إلى الطبيـبِ   والجـأ إلى مقلـب القلـوبِ
~~٥٣ - واعرف مقام الخَلْقِ في الأخلاقِ   تسـلمْ مـن الخصـام والشـقاقِ
~~٥٤- وَتُحْسِـن الصحبةَ للأنـام   منتهيَـا لأحسـن المَـرَام
~~٥٥ - وإن ترد مشـاهد الأخيـارِ   فـيما يصـيبهم مـن الأشرارِ
~~٥٦ - أولهـا يـا صـاح مشهد القـدَرْ   نعـم المريح مـن همـوم وكـدرْ
~~٥٧- وبعـده الصـبر عظيم العاقبـة   بـلا انتقـام وبـلا معاقبـة
~~٥٨ - فمشهد الصَّفح وحلـم يُعْلي   هـو الـذي يقيك شر الـذل
~~٥٩- والمشهد الرابع: مشهد الرضـا   للمطمئنـين بـما الله قَضَى
~~٦٠ - ومشهد الإحسـانِ كيما يُكرَمـا   مِنْ ربّه بكل ما قد قدَّما
~~٦۱- وبعـده مشهدُ بَرْدِ القلبِ   لكـي يكـون في ظـلال الحـبِّ
~~٦۲- ومشهد الأمـن مِـنَ الشرورِ   بـلا عـداواتِ ولا محـذورِ
~~٦٣- ومشهد الجهـاد ممـن باعـا   لله نفسه ومـا أضـاعا
~~٦٤- فالناس من أجل جهاده غدؤا   يضایقونه وربما اعتـدوا
~~٦٥ - ولا يـرى حقـاً لـه إطلاقـا   عليهمُ كَـلَّا ولا استحقَاقا
~~٦٦- ومشهد النعمـة يـا ذا الرَّشَدِ   إذ لم تكـن أنت الظلوم المُعْتَدي
~~٦٧- فترقبُ النصر وحسـن المَرْحمَة   ولست تخشى مَقْتَ تلك المَظْلَمة
~~٦٨ - وتشهد النعمـة في التكفـيرِ   في ذنبك الصـغير والكبيرِ
~~٦٩ - ومـا يُحِي عَنْكَ مـن الـذنوبِ   وشرّ كـل محنـةٍِ وحـوبِ
~~٧٠- وإنَّ مـا بـه أصِـبت أسـهلُ   ممـا بـه بعضُ العصـاة مُثقَـلُ
~~۷۱- فتحمـد الله مـع الححبُـورِ   وتعـرف الفروق في الشرورِ

PageV03P182

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0183.png)

~~۷۲- وتحمـد الله الـذي قـد سلّمك   في الـدين مـن أي مُضرٍ ثَلمَك
~~۷٣- وتشـهد النعمـة بالسرورِ   في يوم عـرض الخلـق والنشـورِ
~~٧٤- ومشـهد الأسـوة بالرسـولِ   والأَمْثَلينَ دونـما نُكـولِ
~~۷٥- حرصـاً عـلى سـعادة العبـادِ   وحثهم للخير والرشـاد
~~٧٦- مـع اصطباره عـلى الإيذاءِ   في حالـة السـراء والضراءِ
~~۷٧- ومشهد التوحيد وهو الأرفعُ   هـو الـذي يـوم الزحـام ينفعُ
~~۷۸- فيـؤثر الله عـلى سـواهُ   مـع اشـتياقهِ إلى لقـاهُ
~~٧٩- في غاية الأنس به والذكر لَه   وقـرة العـين وشـدة الوله
~~۸۰ - ولم يعـد في قلبـه مُتَسَعُ   لكـل مـا الشرع لـه يستبشع
~~۸۱- لأنه في حب ربـه فَنِيْ   وعـن مراضيه جميعـاً مـا وَنِيْ
~~۸۲ - ولا يكـون الاعتداء والضَّرر   إلا بقلـب فـارغ مـن ذا الأثَر
~~۸٣- ولا تـتم هـذه المشـاهدُ   إلا لشخص في المعـالي رائدُ
~~٨٤- مُحَسَّـناً أخلاقـه وظنَّه   بربـه لكـي ينـال منـه
~~۸٥ - أفعالَـهُ للاعتـذار توجِــبُ   والشكر واجـب عـلى مـا يهـبُ
~~٨٦- لأنه للخـير لـيس يُحْصِيْ   وبره معرض للنقصِ
~~۸۷ - فيستحي مـن نقصه الأكيـدِ   لحبـه لربـه الشـديدِ
~~۸۸ - من أجل هذا کان کل صادق   في وجـل للعلـم بالحقـائِقِ
~~۸۹- معظـماً لربـه الغفـورِ   معترفـاً بـالعجز والقصـور
~~٩٠- وإنـما مـدار حسـن الخلـقِ   مع الـورى جمـيعهم والخـالقِ
~~٩١- في كُنْ مَعَ الحـقِّ بـلا خلائـقِ   تفز بتجريدٍ وفضـلِ سَـامِقِ
~~٩٢- وكن مع الخلق بدون نَفْسِ   تعـش براحـةِ وخـير أنْسِ

PageV03P183

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0184.png)

~~۱- تواضعُ العبـد مع الَخْـلَّاقِ   مـن أفضـلِ السَّماتِ والأخـلاقِ
~~٢- والله قـد أثنـى عـلى أصحابِهِ   فهـم عبـاده ومـن أحبابه
~~٣- وهم أولوا العَطف على الإخوانِ   ومشيهم هونا مع الإحسـان
~~٤ - وصح عـن نبيّنـا المختـارِ   بـأن أهـلَ الكـبر أهـلُ النـارِ
~~٥- وإنـما الكـبر رداءُ البـاري   كـما أتـى عـن ربنـا الجبّـارِ
~~٦ - وكـل مـن نازعـه في عِزَّتِه   عذبـهُ بعدلـه وحكمته
~~٧- والمصطفى مـن دونـما مُنازع   أعـلى الـورى في خُلُقِ التواضع
~~۸- مشـى مع الأيتـام والصـبيانِ   وخَـدَمَ الأهـل مـع الْحنَـانِ
~~۹- ورقع الثـوب ونعـلاً خصـفا   وحلَب الشـاةَ بعيراً عَلَفَا
~~١٠ - وركـب الناقـةَ والحـمارا   ورضي الزمـان كيـف دَارا
~~۱۱- يبـدأ بالسـلام مـن لاقـاهُ   کما یجیب کل من دعاه
~~۱۲- تواضعاً مـن غیر ذل أبـدا   ورحمـة بهـا الـورى قـد سَعِدَا
~~۱٣- وما لحسن عِشْرَة الهـادي مَثَل   ولا لجـوده ولا أي عَمَـل
~~١٤- صـلى عليه خـالق الكـمال   وتـابع وصحبهِ والآل
~~۱٥- قد عاد كل من أصيب بالمرض   وما له غير هـدى الناس غرض
~~۱٦- ولم يدع من مات حتی شَهِدَه   يدعو له الرحمن كي ما يسعده

PageV03P184

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0185.png)

~~۱۷- وهـذه دوائـر التواضع   لكـل عبـد مـؤمن وَطَـائع
~~١٨ - يخضع للحـق وينقـادُ لَهُ   يقبله مـن أي شخص قَالَـهُ
~~۱۹_ ومـالنفسه لديه قيمة   وهي لـدى بارئهـا عظيمـة
~~۲٠- خفضُ جناحه وحسنُ اللينِ   أوصـله للعز والتمكين
~~٢١- وهـو سبيل الشرف المنشـودِ   وكـل خير شـاع في الوجـودِ
~~٢٢ - وعمر الفـاروق حينما شعرْ   بنخوةٍ في نفسه خَـافَ الضردْ
~~۲٣ - حـين أتى الوفـودُ طائعينـا   مُسَـلَّمين الأمـر أجمعينـا
~~٢٤- فقال يا نخوة نَفْسِي- انكسري   فلسـت أرضى عـزة في خَطَـر
~~۲٥- وحمـل السـقاء للتأديـب   مـن أجـل دفع الهـاجس المريـبِ
~~۲٦ - وهو بريء والذي لنـا فطر   لكنـه يخشـى الفسـاد والضرر
~~٢٧ - وهكـذا الَحبْر (أبـو هريـرَة)   يخـاف مِـن تَـأمِيره شروره
~~٢٨ - والَحسَـن العظيم صبيةً عـزم   بغايـة الإكرام والجـود الأتـمّ
~~٢٩ - لما استضافوه على بعض الكسر   وهم أولـوا فقر فسر وانبهر
~~٣٠- ثـم كسـاهمُ عقيب الأكـل   وقـال: شكراً يـا أهـالي الفضـل
~~٣١- لأنكم جـدتم بكل ما وُجِد   ونحـن جـدنا بيسيرِ إن عُـدِد
~~٣٢- فـانظر إلى تواضع الكـريم   ورأيـه في جـوده العظـيم
~~٣٣- أمـا (أبـو ذر) فـألقى الخـدِّ   عـلى الـتراب حيـنما تَعَـدَّى
~~٣٤ - عـلى (بـلال) بمقـالِ أثَّرَه   إذ بسـوادِ أمه قـد عَـيَرَه
~~۳٥- و(عمـر) الخليفـة المجـدَّدُ   إخلاصـه كـان لـه يُسَـدِّدُ
~~٣٦- لما اشتری ابنه بألف دِرْهَم   فِصَّـاً جمـيلاً زينـةً للخـاتَم
~~٣٧- فإنـه صـاغ لـه كتابـاً   نصـائحاً ممزوجـةً عتابا

PageV03P185

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0186.png)

# ١٨٥)
~~۳۸- وقـال: یا بنيَّ بعْهُ مسرعا   أطعـم بـه ألفـاً جياعـاً مشبِعَا
~~۳۹- وقـال خـذ فِصَّـاً بدرهمَينِ   مـن الحديـد دونـما تـزيِينِ
~~٤٠ - واكتب عليه: «رحـم الله امرءا   يعرف قـدر نفسه» فَوَاطَـاً
~~٤١- روح تواضع التقـي المسـلم   بالانقيـاد الكامـل المَـتَمَّم
~~٤٢ - ينقـاد لله وللرسـولِ   مسـلماً بكامـل القبـولِ
~~٤٣ - ولا يـرد الحـق كِـبْراً أبـدا   ولا يكـون للحقـوق جاحـدا
~~٤٤- ولم يعـارض وارداً بالنقـل   بفهمـه ولا بـرأي العقـل
~~٤٥ - أو أي أمـرٍ مـن أمـور الـدينِ   بقـول ذي سياسـة مـأفونِ
~~٤٦- فعيبـه في ذهنـه العَليـلِ   ولـيس في الحكـم أو الـدليلِ
~~٤٧ - وربما الإخـلاصُ كـان قـاصِرَا   أو لم يكـن لـه الـدعاء نـاصِرَا
~~٤٨ - والـرأيُ والأقـوال للرجـالِ   تخضع للحـقِ بــلا جِـدَالِ
~~٤٩- وسـنة النبـى ليست تُـتْرَكُ   لقـول إنسـان لهـا لا يـدْرِك
~~٥٠ - بل قوله يترك، لا قول النبي   فكـن مع الحـق دوامـاً تُصِبِ
~~٥١ - ولا يَـتِمُ ذَا لمِـن لا يعلـمُ   إن النجـاةً فضـلُ ربي الأكـرمُ
~~٥٢ - وإنَّ أنـوار ذوي البصـيرة   مـن ربهـم عطيـة كبـيرة
~~٥٣- ولا ينـال المـرء نـور القلـبِ   إلا إذا كـان شـديد الحـبَّ
~~٥٤- قد جرد الـنفس مـن الأهواءِ   لربـه في سـائر الأشـياءِ
~~٥۵ - مع استقامةٍ وحسـن حـالِ   وثقـة بـالله ذي الجـلال

PageV03P186

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0187.png)

~~٥٦- وعلمه بأن هَدْيَ المصطفى   به يتم الانسجام والصـفا
~~٥٧ - مَـنْ رَضِيَ اللهُ بِـهِ عَبـداً لَـهُ   نَـرْضَى بـه أخـاً ولا نُذِلُّهُ
~~٥٨- فننصف العـدو فيما هـو له   فالـدين هاهنـا هـو المعاملـة
~~٥٩- ولا نرد العـذر ممـن اعتـذَر   وذاك دأب المصطفى خـير البشر
~~٦٠- وهـذه محاسـن التواضُعِ   لكـل عبـد صـادق وطـائع
~~٦١ - ولم يصـل إلى ذرى التواضع   مـن لم يكـن للحـق غير خاضع
~~٦٢ - وإنـما تمامـه أن لا نـرَى   حقـاً عـلى الله لسـائر الـوَرَى
~~٦٣ - لكـن نـرى فقـراً بهـم وذُلاً   مـع انكسـارِ في القلـوبِ حَـلاً
~~٦٤ - والأمر هذا لا ينـافي ما وَعَدْ   رَبُّ الـورى بـه لمـن لـه عبـد
~~٦٥ - لأن مـن رأى لـنفس حقاً   لم يـك للإحسـانِ مسـتحِقًا
~~٦٦ - واحـذر مـن الشوائب المـؤثرة   لتَجْنِـيَن بالحـب أحـلى ثمـرة
~~٦٧ - وكـل مـن لما سوى الله تَرَك   ولم يكـن في سُبُل الغـي سلكْ
~~٦٨- يفوز بـالأعواضِ من باريهِ   وكل حـظ نـافع يعليهِ
~~٦٩- لعلمه بأنه لیس لهُ   حـق عـلى بارئـه يلزمُـهُ
~~٧٠- وإنـما تَفَضُّـلاً وَمَنَّـا   يعطيه مـن أحسـن فيـه الظنا

PageV03P187

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0188.png)

~~١- فُتُـوَّةُ الإنسـانِ بالإحسَـانِ   إلى الـورى مـن دونـما امتنَـانِ
~~۲- وكفَّـه الأذى بكـل حَـالِ   عنهم عـلى صـبر وبـاحْتمَالِ
~~٣- أي أنهـا استعمالُ حسـن الُخلُـقِ   بكامـل اللطـف وعطف المُشفِقِ
~~٤ - وإنهـا مـن أشرف المنـازِلِ   يسمو بهـا المـرء إلى الفَضَـائلٍ
~~٥ - وهي مـن الأحـوال والأذواق   ومـن أعـالي أحسـن الأخـلاقِ
~~٦- وهـي التـي تمَّمهـا الرسـولُ   صـلى عليـه ربنـا الجليـلُ
~~٧- وإنهـا الصـفح مـع الإحسَـانِ   عـن عثـرات سـائر الإخـوانِ
~~۸- و(أخمـد بـن حنبـل) يقـولُ:   ترك الـذي تَهْـوَى لمـايَهُـولُ
~~٩- أمـا (الجنيـد) قـال كَفُّكَ الأذى   وزاد بعد الكف بذلك الندى
~~١٠ - وقـال سـهلٌُ باتبـاع السنَّة   فيـا لهـا مـن عصـمةٍ وَجُنَّـةِ
~~۱۱- وإنهـا فضـيلة تأتيهـا   ولا ترى نفسك قطٌّ فيهَـا
~~١٢۲- وقيـل: أن لا تَكُ بِالمحْتَجِبِ   عـن قاصـد ولاتكـن بهـاربِ
~~١۳- وقيـل أن تظهـر كـل نعمـة   وأن تسرما جـرى من غُمَّةِ
~~١٤ - وقيل مَنْ كان فتى لا يَدَّخر   شيئا ولا مـن سائليه يَعْتَـدِر
~~۱۵٥- ورُبَّما استَرْسَلَ بَعْضُ الناسِ   في عـرضِ واصلٍ لهـم مواسيْ
~~١٦- نالوا مِنَ الجواد ذي الإحسانِ   وهـو ينـيلهم بـلا امتنـان
~~١٧- فيأخذ العفـو اقتفـاءَ بـالنبيْ   ولم يقل إني عظيم الرتب

PageV03P188

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0189.png)

~~١٨ - بـل يخفِضِ الجناحَ رحمةً بِهِمْ   وحَظَـهُ مِــنْهُمْ قَبيحُ فعلهمْ
~~۱۹_ قـد وَسِعَ الأنـامَ بـالأخلاقِ   بـلا تكـبر ولا شِـقَاقِ
~~٢٠ - يوافـقُ الشرعَ بـلاتَعَـدِّي   ولم يُقِرَّ واقعـاً في حَـدِ
~~۲۱ - يهربُ مِنْ مَكائِدِ الشيطانِ   لـيحفظ القلـب مـن الأدران
~~۲۲- ونكتـةُ الفتـوةِ العليـة   أن لا ترى للـنفس أفضـلية
~~٢٣- وإنـما قلـبُ فُتُـوَّةِ الفتـى   غيابُهُ عـن كـل مـا بِهِ أتى
~~٢٤- يشـهَدُ حَـقَ غَـيْرِهِ عَلَيْهِ   ولا يرى حقـا لـهُ لَديهِ
~~٢٥- والناس في هـذا عـلى مَرَاتِب   وهي ثلاث عنـد كـل حاسب
~~٢٦ - أشرفهـا الفـوز بهـذا الخُلُقِ   وضـده فاقـده ذو الَحَمَـقِ
~~٢٧- ثالثهـا: الشـاهد للأمـرين   لكونه الأوسط بـين ذين
~~٢٨ - وإن تُـرِدْ مَظَـاهِرَ التوسُطِ   لتتقي الشروفحـش الغلط
~~٢٩- تـرك خصـومةِ مَـعَ التغافُـلِ   عـن زلـةِ مـن عـالم أو جَاهِـلِ
~~٣٠ - وبعـده نسيان أصناف الأذی   بالحِلْم وَالعَفْـوِ وَبَـذدْلِ للنَـدَى
~~٣١- وإنَّ مـن مظـاهر الفتـوَة   تَقْريبَ مُقْصِـينا بكـل قُـوَّة
~~۳۲- وهكذا إكرام مـن آذانـا   والصـفح عمـن بالأذى رمانا
~~۳٣ - وإنَـهُ أولى بـدون شـكّ   بالعـذر فالـذنب له سيبكي
~~٣٤ - أيضـاً ومـا تَسْـلِيطُهُ علينـا   إلالـذنب سره لـدينا
~~٣٥- وإنـما الجـاني بُـِلِيْ بجـاني   فيَلْـزَمُ العـذرُ بـلاتَـوانِي
~~٣٦- مـن ربنـا بتوبة نَصُـوْح   ومـن مسيء فاعـل القبيح
~~۳٧۷- مـن دونما عتبِ ولا تأنيْبِ   ولا عقوبـة ولا تعـذيب

PageV03P189

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0190.png)

~~۳٨- ولا تَكُـنْ لليشْرِ عنـه طاويـا   كَيْ لا تكـون في الأذى مُسَـاوِيا
~~۳۹- أمـا إِذا سَـاوَيْتهُ فــأنتُم   بـالخزي والشر العظيم بُؤيُما
~~٤٠- ولا تؤمـل منـه في اعتـذار   تغدو الفتى السامي إلى الفَخَـارِ
~~٤١ - والصـبرُ تكليـفٌ مع المشـقة   وذاك إحسـان بكـلَّ دقـة

PageV03P190

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0191.png)

~~۱- عَـرَّفْ إرادةً بِـتَرْكِ العـادةُ   وفعـل مـا يفضي إلى السعادة
~~٢ - وهـي أسـاسُ الخير والرشـادِ   وحـارس القلب مـن الفسـاد
~~٣- بصحبة العلـم وصدق المقصِـدِ   وخلع كـل شـاغلِ ومبعـدِ
~~٤ - مـن شهواتِ وصـديقِ عَـائقِ   وسـائر الأهـواء والبوائـق
~~٥- حينئذٍ ترتاحُ نفس السالكِ   لِبُعْـدِهِ عَـنْ سُـبُلِ المَهَالِـك
~~٦- ويرتقـي في سـلم الإيـمانِ   حتى ينـال قمـة الإحسـانِ
~~٧- فَنَفْسُهُ للحَـقَّ خَـيُرُ طَـائع   برغم كـل عـائق ومـانع
~~٨- يَقْبِضُهُ الخـوفُ مـن الجبـارَ   وخوف وعـده وخـوف النـار
~~۹- وبالرجـا في ربـه ينبسط   فهـو لـذاك دائـماً لا يقـنط
~~١٠- وربما القبض مـن الزلات جـا   فاحذر صنوف الشر تحظ بالنجا
~~۱۱- حینئذ لابـد أن يَتُوْبَـا   مستغفراً مـن ذنبه قريْبَا
~~١٢- ويجعل الأحوال وفق الشَّرْعِ   بـدون تقصـير ولا تَنَطَع
~~۱٣- فـؤاده يَـأنَسُ بـالمعبود   ويستلذ البذل للمجهـود
~~١٤- ولايرى مشـقة ولا عنَـا   بل كُـلُّ طاعـةِ سرورٌ وَهَنَـا
~~۱٥- وقـرة للعين وانشراحُ   للصَّـدْرِ والقلبُ بهـا يَرْتَـاحُ
~~١٦- وهكـذا كانت حيـاة السَّلَفِ   عـلى طريـق المصـطفى المُشَرَّف
~~۱۷- وهـي سبيل أتقيـاءِ الَخلَفِ   من كل من هدي الرسول يقتفي
~~۱۸- صـل عليه يا إلهـي كرما   والآل والصحب وأعـلِ الهمـما

PageV03P191

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0192.png)

~~۱- قـد أمر الله العبـاد أن يقـوا   أنفسـهم والأهـلَ ناراً تُحـرقُ
~~٢- بـالأدب الجـمَّ وبـالعلوم   وكـل مـا يـدعو إلى التكريْم
~~۳- وإن ترد مسـالكَ الآداب   خـذها مـن السـنة والكتـاب
~~٤ - أربعـةٌ تأتيكَ بالتفصـيل   مـن غير إخـلالٍ ولا تطويـلِ
~~٥- الأدبُ العـالي مع العـلام   فشرعـه والرسـل الكـرام
~~٦- ثـم مـع الخلـق بوِفـق اللائـقِ   بكـل مخلـوق مِـنَ الخلائقِ
~~٧- فـأدبُ المـرءِ مع الـرحمنِ   يصـونُهُ مـن أيـما نقصـانِ
~~۸- ويحفـظ القلـب مـن التفلِّتِ   ويحفـظ المـرء مـن التشتّتِ
~~٩- كـما يصـون عِنـده الإرادة   مـن كـل مـا يقـدحُ في العبادة
~~۱٠- لكي ينـال حبه تعـالى   ويكسب الإكرام والإفضـالا
~~١١- من أجـل ذا كـان قليلُ الأدبِ   أهـمَّ مـن علـم رفيع الرتب
~~١٢- و(الحسن البصري) حينما سُئلْ   عـن أنفع الآداب قال: ما نقل
~~١٣- عـن ربنا والمصطفى الرسولِ   مـن فقـه ديـن الله بالتفصـيل
~~١٤- والزهـد في الـدنيا لنيـل الخـير   فيهـا وفي الأخـرى بـلا تقصيرِ
~~۱٥- وقبـل ذا معرفـة الإنسـانِ   بربـه ذي الجـود والإحسَـانِ
~~١٦ - وَمَنْ على مراد مولاه صبر   في حليـة الآداب فـاز بـالظَفَرْ
~~١٧- والأدب الظاهر عنـوان الأدَبْ   البَـاطنٍ بـه المعـالي والرتَنْ

PageV03P192

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0193.png)

~~۱٨- وقيـل لا يخلص إلا ذو أدَب   لأنـه كُـلَّ صـنوفِ الشرذَبّ
~~١٩ - فَعَرَفَ النفس وجانب الزلل   بلا رعونـات وزيغ وخلَل
~~۲٠- وكـل مـن قـد فـاز بالمحبّة   ينـال في الآداب أعـلى رتبَة
~~۲۱ - وكـل نـاظر لحـال الرُسـلِ   يشهدُ أنهـم بـأعلى مَنْـزِلِ
~~٢٢ - في أدب الأحـوال والسـؤالِ   وهمـة الـنفس وفي الأعـمالِ
~~٢٣- فاسمع إلى المسيح حينما اعْتَذَر   من مالك الملك ومجـري القـدَر
~~٢٤ - حَـاوَرَهُ بالحـبَِّ والإجـلالِ   ولم يكـن نوعـاً مـن الجـدالِ
~~٢٥ - (إن كنتُ قلْتهُ فقد عَلِمْتهُ)   ولم يقـل لِرَبـهِ مـا قلتـهُ
~~٢٦ - وقـد أتى الحـوار ذا في المائِـدَة   فَافْقَـهُ معانيـهِ تَفُـزْ بالفائـدة
~~٢٧- وانظر إلى الخليل في حال المرض   يَشْكُرُ مولاه ولم يَشْكُ العَرَضْ
~~۲۸- فقال (يشفيني) بفضله الأعَمّ   ولم يقـل أصـابني مِنْـهُ السَّـقَم
~~۲۹- وقـال (موسى) إنَني فقيرُ   ولم يقـل هَـبْ أيهـا القـديرُ
~~٣٠- ولم يقل (أيوب): يا رب اشفِني   بـل قـال: ضرُّ يـا إلهـي مَسَّـني
~~٣١- (يوسفُ) لم يأتي بذكر الجب   مراعيـاً حـق الإخـا والقـرب
~~۳۲- ولم يُـذَكَّرْهم برعـي الغـنم   ومـا تـلاه مـن صـنوف الـنقم
~~٣٣- بل شَكَرَ الرحمن إذ أحسن به   أخرجـه مـن سجنهم لمنصـبه
~~٣٤ - وقـال لا تثريب يـا إخـواني   فـانظر إلى آداب عـالي الشـان
~~٣٥- والمصطفى بالسَّتْرٍِ دوماً أَمَرَا   حتى ولـو كنـت خفيـاً لا تُرَى
~~٣٦- تأَدُباً مع السـميع المبْصرِ   وذاك شـأن العـارف المُـوَقّر
~~٣٧- ونسب الإعابة الخضر له   فيـا لهـذا الـذوق مـا أجملـه

PageV03P193

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0194.png)

~~٣٨- وكـل مَـنْ قَصَّرَ في الآدابِ   يُمْنَـى مـن الحكـيم بالعقـابِ
~~٣٩- فيُحـرم السـنةَ في تـرك الأدب   وَتَرْكُهَا يَحْرِمُه مـا قَدْ وَجَب
~~٤٠- والمستهين بـالفروضِ يُحْرَمُ   معرفـةً بهـا الإلـهُ يُـنعِمُ
~~٤١- والأدب الكـائنُ في الأعـمالِ   دَلَّ عـلى قبـولِ ذي الجـلال
~~٤٢ - وهـو بأن تَسْتَعْمِلَ الأخلاقا   وأن تكـون للعـلى تواقـا
~~٤٣- والله قـد هيأنـا للأكمـل   وحثنـا لـه بكـل السـبل
~~٤٤- ألهمنـا سـبحانه وأرشـدا   ودلنـا بفضـله إلى الهُـدَى
~~٤٥ - وقال (قـد أفلح مـن زَكَاها)   وبعدها (قد خاب من دساها)
~~٤٦ - وهـو الذي بفضـله سَوَّاها   ومِـنْ صـنوف جوده حبَاهَـا
~~٤٧ - وللفجـور والتقـى ألهمهـا   من أجلها عـن الفجور قد نَهَى
~~٤٨- محمد المختـار خير مـن صَـغَى   ولم يَزِغْ عـن أدبٍِ ومـا طَغَى
~~٤٩- مـن أجـل هـذا ربه لَهُ مَـدَحْ   والمكرمـاتِ كلَّهـا لـه مَـنَحْ
~~٥٠- فالقلب والعينان من دون مِرَا   کلاهمـا مراد ربـه یَـرَی
~~٥١- لَم يَلتَفِتْ لغَـيْرِ مَـا أراهُ   فزادَهُ مِـنْ فضـلِهِ مَـوْلاٰهُ
~~٥٢- حتى رَقَى السَبْعَ الطَبَاقَ كلها   ونـال في العليـاء أعـلى المنتهَى
~~٥٣- وفـاز بالحـبِّ لـدى الرحمنِ   ونـال قربـاً مـالَـهُ مُـداني
~~٥٤- فهـو عـلى الصراط في الحيـاةِ   وهـو عـلى الصراط في المَماتِ
~~٥5 - ثم خلاصـة الكـلام في الأدب   قيا منـا لربنـا بـمأَحَــبّ

PageV03P194

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0195.png)

~~٥٦ - وَشَرْعنا وديننا هو الأحب   فيـه الجـمال والنقـاء والأدَب
~~٥٧ - كالستر والوضوء والأغسال   وغيرهـا مـن سـائر الخصـالِ
~~٥٨- حتى يصلي طاهراً من الدنَس   مـن دون إخـلالِ بهـا ولا خلَس
~~٥٩- بَـلْ سَـاكناً لله في اطمِئنـانِ   بكامـل الإنصـات للقـرآنِ
~~٦٠- وخاشعاً في غايـةِ الإطْـراقِ   وقلبـه يَهْفُـو إلى الخـلاقِ
~~٦١ - يعظـم الرحمن في الركـوع   بغايـة الذلـةِ والخضـوع
~~٦۲- ولم يكـن مسْـتَقْبِلاً للقبلـةِ   في أي حـال بقضـاء الحاجـةِ

PageV03P195

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0196.png)

~~۱- الله وَحْـدَهُ الغنـيُّ المَالِـكُ   وما سوى الله فقير هالك
~~۲- والفقـر قـد جـاء عـلى معـاني   كـالنقصِ والحاجـةِ في الإنسـانِ
~~۳٣- وعفـة الإنسـان تخفـي الفقـرا   فكم عفيف فقره ما ظهرا
~~٤- كـما حكـاه الله عمـن أحصروا   إشـادة بفقـرهم إذ صـبروا
~~٥- فـالخلق في فَقْـرِ بِـلا خِـلافِ   لمسـبل الإنعـامِ والألطـافِ
~~٦- والكـل عبـد المـنعم الخـلاق   لفقـرهم لـه عـلى الإطـلاق
~~٧- والفقـر أن تكـون في افْتِقَـارِ   إلى الكـريمِ المـنعمِ الغفـارِ
~~۸ - حتـى وإن كنـت كثـيرَ المَـالِ   فإِنَـهُ لله ذي الجـلالِ
~~۹- ولـيس معنى فقرنـا هـو العـدم   وإنما التسـليم لله الأتَـم
~~١٠- والفقر ذا لم يك ضِـدَاً للغنَى   فَافْهَمْهُ فَهْماً عَنْكَ يَـدْفَعُ العَنَا
~~۱۱- والفقرُ ذاتيُ لكـل عَبْـدِ   ومنكـر الفقـر عظـيم الجحدِ
~~١٢- والفقرُ قَدْ قَـامَ عَـلَى أَرْكَـانِ   يسمو بها العبد لـدى الرحمنِ
~~١٣- علم يسوسه وترك للبدع   والـذكر واليقين أيضا والورع
~~١٤- وإنـه لأحسـنُ التوسـلِ   إلى إلهنـا الكـريم المفضِـلِ
~~۱١٥- مـع التـزام سـنة البشـير   مـن دون إخلالِ ولاتقصیرِ
~~١٦- أوَّلُـهُ ذلٌّ وَعِـزٌ آخره   والاحتيـاج للأنـام ظـاهره
~~١٧- لكنه حقيقـةً خـيرُ غِنَـى   يَقُودُنـا إلى مـراضي ربنـا

PageV03P196

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0197.png)

~~۱٨ - فالمرءُ يستغني به عن الورى   ويعـتلي بـه إلى أعـلى الـذرى
~~۱۹- يطلب من مولاه لا من غيره   ولم يكـن منحرفـاً في سَـيْرِهِ
~~٢٠- والفقر هـذا للمعـالي يَرفَعه   وإن غـدا يتعبه ويُدْمِعْهُ
~~٢١- والصبر والشكر شعار المتقي   وآيـة الإخـلاص للموفـق
~~۲٢ - لكونه استغنى بـذي الجـلال   ففـاز بـالغنى وحسـن الحـال
~~۲۳ - وقال يحيی بـن معاذ مُعلنَا   لا يـوزن الفقـر غـدا ولا الغنـى
~~٢٤- وإنما يـوزن صبر المُعْدَم   وشكر من أغناه مسدي النعم
~~٢٥ - وأول الفقر خروج العابـد   عـن نفسه لـذي الجـلال الماجِـدٍِ
~~٢٦- يُسَـلَّمُ الـنَفْسَ إلى مولاهـا   فَمَن سوی خلاقها یرعاها؟
~~٢٧- ولم يكـن نُخَاصِماً مـن أجلها   مجـادلاً محاجِجـاً لنصرها
~~۲۸ - أيضـاً ولا يكـون ذا توكُّـل   مـن أجلها فاحـذر سبيل الزلـلِ
~~۲٩- وسَلَّم النَّفْسَ لَمـنْ لهـا ملَكْ   ولا تكـن مِمَّـنْ بحظَّهـا هَلَك
~~٣٠ - واقْبِضْ يداً عن هذه الدنيا تَفُز   ولا تقـل إني فقـير لم أَحُـز
~~٣١- وأَسْكِتِ اللسانَ عن مدح لهـا   ولا تكُـنْ مُعلَـقَ القلبِ بهـا
~~٣٢- ليصبح القلبُ سليمً صالحاً   ولا يكـون للمخـازي طامحـاً
~~٣٣- وَأَدَّ حَـقَّ ذي الجـلال وافيـا   وحـق غـيره وكـن مواسيا
~~٣٤- فكل خيرٍ فيك جودُ الخالِقِ   سبحانه مـن منعم ورازقِ
~~٣٥- والتـزم الطاعـات لله العـلي   ولا تكـن بنـاظر للعمـل
~~٣٦- فـذاك يحميـك مـن الإشراك   والعجب والوقـوع في الشَّـبَاكَ
~~٣٧ - ثم الغنى نوعـان في التقسيم   همـا: الغنـى بربنـا الكـريم

PageV03P197

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0198.png)

~~۳۸- يزید من عاش به جمالا   ويصبحن أعـلى البرايـا حـالا
~~٣٩- إن الغنـى بربنـا هـو الغنـى   وغـيره هـو الشـقاء والضَـنى
~~٤٠ - والله يغنينـا بنيـل المـال   وعفـة تقـي مـن السـؤالِ
~~٤١- فيصبحُ القلـبُ غنيـاً راضيا   والمـال مهما قَـلَّ يغـدو كافِيَـا
~~٤٢ - والنفس تستغني إذا القلبُ اغتنى   ويذهب الهـم ويـذهب العنـا
~~٤٣- ولم تعـد تَجْنَحُ للريـاء   لكونهـا بـالله في اسـتغناءِ
~~٤٤ - ثم الغنا عـن غير ذي الجـلال   فلـم تـرده مطلقـا بحـال

PageV03P198

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0199.png)

~~١- ذكـر الإلـه أعظـم المنـازلِ   وزادُ كـل عـالم وفاضـلِ
~~٢- والـذكر منشـور الولايـة التي   ينالهـا الأبـرار أهـل الَحظْـوةِ
~~٣- وإنَـهُ نـور القلـوب النَـافِع   وصـارم للملهيـات قـاطع
~~٤- ومسـعد الأرواح والقلـوب   يقودهـا لِعَـالِمِ الغيـوبِ
~~٥- ينجي مـن الآفـات والشرورِ   ويجعـل الفـؤاد في سرورِ
~~٦- وإنـه لروضـةُ الجِنَـانِ   وجنَـةُ العبـد مـن الشـيطانِ
~~۷- ورأسُ مَالِنـا لَـدَى الـرحمنِ   ودافع الهمـوم والأحـزانِ
~~۸- والذكر مطلوب بـلا تَوْقِيتِ   في السـوق والمسجد والبيـوتِ
~~٩- وسـائر الأوقـات والأحـوالِ   والضيق والرخـاء والأشـغال
~~١٠ - يخلص السمع مـن الأوقَـارِ   ويقشع العمـى عـن الأبصـار
~~۱۱- وإنـهُ البـاب الـذي لا يغلـقُ   في وجـه مـن يدخلـه ويَطْرُقُ
~~۱۲ - وروحُ كـلِّ صـالح الأعـمالِ   ولـيس في ذا الأمـر مـن جـدالِ
~~۱٣- وقـد أتى عـلى وجـوهِ عَشَرَة   جميعهـا معروفـة محـرَّرَة
~~١٤- أولهـا الأمـر بـه، والثـاني   نهـيُ عـن الغفلـة والنسـيانِ
~~١٥ - ثالثهـا أن الفـلاح يحصُـلُ   بالذكر وهـو للتقى موصل
~~١٦ - رابعهـا: ثنـاء ذي الجـلالِ   علـيهمُ بأحسـن الخصَـالِ
~~١٧ - خامسها: الإخبار عن خسران مَن   لهى عن الذَّكر فَعَاشَ في حَزَن

PageV03P199

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0200.png)

# ١٩٩)
~~۱٨- سادسها: أن الإلـه يَـذْكُرُ   ذاكــرَه وذكـر ربي أكـبرُ
~~۱۹- وهـو قرين سـائر الطاعـاتِ   يـلازم العبـد إلى المـماتِ
~~٢٠ - والـذاكرون يسبقون غيرَهُمْ   به يزيدُ عَـزْمُهُمْ وَخَـيْرُهُمْ
~~۲۱- وأنـه خاتمـة الأعـمالِ   وهـذه ثَامِنَـةُ الخصـال
~~۲۲ - وأنـه خير العبـادات لنـا   أيضـاً وأزكاهـا لـدى مليكنا
~~٢٣ - وإنـه والله أسمى مُـبْهِج   يسمو به الـذاكر أعـلى الأوْج
~~٢٤- شيء عظـيم دونما أي تعـب   يفوق إنفاق اللَّجَـيْنِ والذهب
~~۲٥- أفضـل مـن لقائنـا الأعـادي   وضربهـم في سـاحة الجهـاد
~~٢٦- وإن أهلـه أولـو الألبـاب   والاتَّعَـاظِ بهـدى الكتـاب
~~٢٧- تغشـاهم الرحمـة والسكينة   كرامـةً مِـنْ رَبِّهـم مُبينَـة
~~۲۸- تحفهـم بـأمره الملائكـة   وهـي لهـم في ذكرهم مشـاركة
~~٢٩- والله فيمن عندَه يذكرهم   هذا جزاء الـذاكرين ربهم
~~۳٠- رواه مسـلمٌ عـن الرسـول   وكلُّـما رواه ذو قَبُـولِ
~~۳۱- صـلی علیه ربنا وسلما   وَكُـلِّ مَـنْ مِـنْ نهجـه تعلما
~~٣٢- وأفْضَـلُ الأعــمالِ أن تُفَارِقَـا   الـدنيا وأنـت للمعـالي تائقـا
~~۳۳- رطب اللسان دائماً بالذکر   مـن غير مَـا عَـدِّ لَهُ أو حصرِ
~~٣٤- ولا دَوا لمـن غـذا مُشَتَّتَا   كالذكر فاستمسك به تَشَـبُثٰا
~~٣٥- وعـن رسـول الله عـالي المنـة   مجـالس الـذكر ريـاض الجنـة
~~۳٦- قال: ارتعـوا فيهـا لتستريحوا   واغـدوا إليهـا دائماً وروحـوا
~~۳۷- والـذكر قـد يكـون بالثناءِ   أو برعايـة وبالـدعاءِ

PageV03P200

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0201.png)

~~٣٨- أولـه كالحمـد والتهليـلِ   وقـول كـل طيـب جميـلِ
~~۳٩- ومـن رعى الفؤاد بالأذكارِ   يكـون في أمـن مـن الأخطـارِ
~~٤٠- والـذكر بالدعاء لـيس خافيـا   وقـد أتت به النصـوص وافيـا
~~٤١- فيـا أخـا الإسـلام والإيـمانِ   سـبح لغـرس سـاحة الجِنَـانِ
~~٤٢ - وأَرْدِف التسـبيح في تشـميرِ   بالحمـد والتهليـل والتكبـيرِ
~~٤٣- تكون حي القلب غير مَيَّتِ   وأسـعد النـاس بظـل الجنَّـةِ

PageV03P201

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0202.png)

~~١- أمـا اليقـين فهـو ذروة الـذرى   وقلب كـل مؤمن به يرى
~~۲- وهـو مـن الإيمان مثـل الروح   في قلب كـل مـؤمنٍِ صحيحِ
~~۳- وأهلـه أهـل الفـلاح الـدائم   والنفـع بالآيـات في العـوالم
~~٤- ولـيس في العبـاد مـن صِـدَّيق   غـير أولى اليقـين بـالتحقيقِ
~~٥- بِنُـورِهِ يُشْرِقُ قَلـبُ المُـؤمِنِ   وتَنْتَفِـي عَنْـهُ جَميعُ المحـنِ
~~٦- وإنَّـه علـم بمَـنَّ رَبَّي   ينالـه أهـل صـفاء القلب
~~٧- وهـو عـلى ثلاثـة أقسـام   معروفـة لـدى أولي الأفهـام
~~۸- سكون قلب العبـد نحـو المُخْبرِ   لكونـه في الصَّـدْقِ لم يقصرِ
~~۹- وَبَعْـدَهُ اليقين بالدَّلالَةٌ   وأن يقيمـه عـلى مـا قالَه
~~۱۰- وبعـده مشـاهدات القلب   كرؤيـة العين بدون حُجب
~~١١- فَيْتْبُتُ الإيمان بـالغيوب   مـن قـوة اليقـين في القلـوبِ
~~١٢- أركانه قبـول حـق ظَهَرا   وغائب عـن العيـون لائرى
~~١٣- ثـم وقوفه مـع التوحيـدِ   عـلى صـفات ربـه المجيـدِ
~~١٤- وَأَنْسُ أهـل الله بـالقرآنِ   هـو الغـذاء النـافع الربـاني
~~١٥- تُجنى صنوف العلـم والمعارفِ   مِنْـهُ لِكُـلِّ مـوقنٍ وَعَـارِفِ
~~١٦- فتستلذ روحه وتفرَحُ   ويستنير قلبـه ويشرح
~~۱۷- حتى يزيـد في الفـؤاد النـور   وتـنجلي أمامـه الأمـورُ

PageV03P202

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0203.png)

~~۱٨ - يكـون عَبْداً كالملاك الطـائع   لأنسـه بـالله والتواضع
~~۱٩- والنـاس إمَـا قلبه كَنَفْسِهِ   مع الهـوى يجـره لِتَعْسِهِ
~~۲٠- اُو نَفْسُهُ كقلبه تستجلبُ   كُلَّ معـاني الخير حتـى تَغْلِبُ
~~۲۱- تتـوق للخیرات والكمالِ   مَحبَّـةَ لله ذي الَجـلالِ
~~۲۲- وبعضهم مابين ذین واقعُ   بينهما الحـروب والوقـائعُ
~~٢٣ - فالقلب قد يغلب شر النفس   بِكَثْـرِةِ الَخَـيْرِ وَصِـدْقِ البـأسِ
~~٢٤- وقـد تقـوده لِشَرَّ الحـال   وتكسبُ الجولـة في السجال
~~٢٥ - ومنهج الله لدى الناس عُرِف   والفقـهُ والفَهْمُ لَدَيْهِمْ مُحْتَلِف
~~٢٦ - ومـن هنـا تَفـاوُت الأحـوالِ   في العلـم واليقـين والكـمالِ

PageV03P203

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0204.png)

~~١- الله يجتبـي ذوي الإيـمان   إذا غـدوا في قمـة الإحسـانِ
~~٢- والأنبيـا فـازوا بـأعْلَى رُتَبِـهْ   وغيرهم قد نال حظاً فازَ بِهْ
~~٣- فـإنَّ رَبِّي اختـارَ طـه مرسـلا   مـن دون أن يكون قط أملا
~~٤ - وهـولموسى باصطناع كَرَّمَه   وإنَـهُ في طـور سينا كلمه
~~٥- وكـل شخص ربـه اجتبـاهُ   فإنـه بفضـله حَبَاهُ
~~٦- فلـم يكـن بِكَسْـبِهِ إطلاقـا   ولم ينلـه مَـنْ إِلَيـهِ تَاقَـا
~~۷- فكـل مـن نبـأه الله اجتُبـيْ   وقـد يكـون المجتبـى غـيرَ نَبِيْ
~~٨ - وإنـما يَخُصُّـهُ بحفظهِ   بِمَنَّـهِ وَجُـودِهِ وَفَضْـلِهِ
~~۹- يحفظه مـن كـل مـا يُخْزِیهِ   وكـل شيء ضـار يؤذيهِ
~~۱۰- وربما يصـاب بالتکـدیرِ   في بعض ما يهوى من الأمورِ
~~١١- فلـم يجـد لِزَلَّـةِ طريقـا   بـل كلـما مـال لهـا أعيقَـا
~~١٢- ولم ينل أعـلاه في الورى أَحَـدْ   سوى الحبيب المصطفى داعي الرشد
~~١٣ -صلى عليه ربنا الفرد الصمد   وآلـه وصحبه بـلا عـدد
~~۱٤-قد کان جامعاً جمال عیسی   وضَـامَا لَـهُ جـلال موسـى
~~١۵- مـن أجـل هـذا فـاز بـالكمالِ   في سـائر الأمـور والخصَـالِ
~~١٦-فَشَرْعُهُ عزمٌ وعدلٌ وهُدَی   وقـوة رادعـةٌ من اعتَـدَى
~~١٧- يأمُرُ بالعـدلِ وللفضـلِ دعـا   وحرَّمَ الظَلْمَ وبالحسنى رَعَى

PageV03P204

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0205.png)

~~١٨ - فهـو النبي ذو الكـمال المُطْلَقِ   ولم يَزِغْ عن شرعه سوى الشَّقي
~~١٩ - وأمـة المختـار أمـة اجْتبَـا   سوی ظلوم فضـل ربه أبى
~~٢٠ - فـإنهم أتبـاعُ خـيرِ مرسـلِ   وشرعهـم أفضل شرع منزل
~~۲۱ - وكل ما يَضُرُنا قَـدْ حَرَّمَه   وكـل نـافع لنـا قـد حتَمَـه
~~٢٢ - لكـي ينـال المجتبـى سـعادة   ويترك الـدُنيا عـلى شهادة

PageV03P205

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0206.png)

~~۱- منزلـة الإحسـان لَـبُّ دينِنـا   وروحه حقـاً وسر فوزنا
~~٢- وهـوجـزاءُ كـل ذي إحسـانِ   مـن ذي الجـلال المـنعم الـديَّانِ
~~۳- وهـو بأن نعبـد مـن هـدَانا   كأننـا نبصـرهُ عَيَانَا
~~٤ - وكـل مـن أحسـن في التوحيـدٍِ   يفـوز في الجنـات بـالخلودِ
~~٥- وذاك إحسـان العبـاد فـاعلم   ثم جـزاء ذي الجـلال الأكـرم
~~٦- ونحسـن القصـد بعلـم وعمل   ونقصـد الله تعـالى في وَجَـلْ
~~٧- قصـداً مٔخَلَّصـاً مـن الشـوائب   ومن حظوظ النفس والرغائب
~~۸- بوفـق شرع ربنـا الحكيم   بالحـب والتعظـيم والتسـليم
~~۹- بِـلاتـوانِ وبـلا فتـورِ   بـل رغبـةً للخـيرِ في حبورِ
~~١٠- وَمُظْهِرُ الأحوالِ عِنْدَ مَنْ صَدَق   فِيْـهِ رُعُونَـة وَعَجْـز وَحمَـق
~~۱۱- وعند مَن عادى وأرباب الحسد   يَجُـرُهُ إلى الـبلاءِ والنكـد
~~١٢- فـاكتمْ عطـاء الله ذي الجـلالِ   ككَنْـز أربـابِ الغنـى للـمال
~~۱٣ - وكـن مهـاجراً إلى الـرحمن   بـلَا تَوَقُّـفِ بكـل آنِ
~~١٤- بالصدق والإخلاص في إحسانِ   حتـى تحـل وارف الجِنَـانِ
~~١٥- وأعلـم بـأن أعظـم الإحسَـانِ   أن تحفـظ الوقـت بـلا تـواني
~~١٦- مَهَـاجِراً بالحُحبِّ والتَوحيدِ   والخـوف نحـو البـارئ المجيـدِ
~~١٧- ثـم إلى رسـوله العظـيم   بكامـل التسـليمِ والتحكـيم
~~١٨- مـع انْقِيَـادٍِ كَامِـلٍ لحُكْمِهِ   في بَاطِنٍ أو ظـاهَرٍ مِـنْ أَمْرِه

PageV03P206

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0207.png)

~~۱- كل امريٍ ما لم يكنْ مصاحبا   للعلـم يغـدو في الحيـاة خائبـا
~~۲- ولم ينـلْ بسـيره وصـولا   ولم يحقـق أبـداً مـأمولا
~~٣- ولم يكـنْ عـن العلـوم نَـاهِي   إلا الـذي غـدا عـدو الله
~~٤ - مثـل العـدو المـاردِ الشيطانِ   وجنـدِه في سـائر الأزمـانِ
~~٥- ولم تكـن طريقـةٌ موصّـلة   مثل طريـق العلـم نعـم الفاضلة
~~٦- فتُقْتَفـى بهـا طريـقُ الرسُـلِ   ويفلحُ العبـد بهـا ويَعْـتَلي
~~٧- لأن مـن لم يَحْفَـظِ القرآنـا   وسـنةَ الهـادي التـي أَبانـا
~~۸ - لا يقتـدى بـه ولا يُتَّبعُ   ولا يطـاع أمره ويسمع
~~٩- فعلمنـا قُيَّـدَ بالكتـاب   وسُـنة المبجّـل الأوَّابِ
~~۱٠- صلى عليه مجـرى السحاب   من دونما عد ولا حسـاب
~~۱۱- فالسـنةُ الميـزان للأحـوالِ   وسـائر الأفعـال والأقـوالِ
~~۱۲- وکل ما کان بلا اقتداءِ   فمـن حظوظ الـنفس والأهواء
~~۱٣- وشـأنه الـبطلانُ والفسـادُ   لأنـه لله لا يراد
~~١٤ - فكـن مع الله بحسـن الأدب   مراقبـاً لله في تَهَيُّـبِ
~~۱٥ - مقتـدياً في أحسـن اتبـاع   مِـنْ دونـما زيـغِ ولا ابتـداعِ
~~١٦- محترمـا للأوليـاءِ الـبرَرَة   مـن دون أن تنهجَ نهج الفجـرَة
~~١٧ - بتركك الإجحافَ والذمَّ لهم   وتركِ تقديسِ بماليسَ لهُمْ

PageV03P207

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0208.png)

# (٢٠٧)
~~۱۸- وإن تَزُر قبورهم فادعُ لهُم   وَسَـلْ مِـنَ الكـريم أن يرحمهم
~~۱۹- وصاحبِ الناس بحسن الُخلُقِ   جمـيعهم ولا تخـص المتقـي
~~٢٠ - وكـن مع الجهـال بالدعاءِ   أن يتركـوا مخـاطرَ الأهـواءِ
~~٢١- مـع الكـرام الكـاتبين في أَدَب   كيما تنـال دائماً أعـلى الرتَب
~~٢٢ - مخالفـاً للـنفس والشـيطانِ   كـي لا يَجُـرَّاك إلى الخسـران
~~۲۳- ومن تكُنْ سُنّةُ أفضل البشر   أميرَه يفـز بـأعظم الظَفَـر
~~٢٤ - إن قـال بالحكمـة حقـاً ينطـقُ   وفعلـه لقولـه يُصَـدَّقُ
~~٢٥ - وعكسه من کان أَمَّرَ الهوى   فإنـه لكـل بدعـةٍ حـوى
~~٢٦- فـالعلم قائـدٌ إلى المعـالي   والخـوف سـائق إلى الكـمالِ
~~۲۷ - والـنفسُ في جموحهـا والُخدَع   رَوَّاغَـةَ في شرهـا لم تَـدَعِ
~~۲۸- ما لم تكن سِيْسَتْ بعلم وَهُدَی   وأصْلِحَتْ بالخوف كيما تَسْعَدا
~~۲٩- ومـا رواه البعضُ مـن كـلام   مُزَهَّـداً في العلـم للأنـامِ
~~٣٠- كقولهم ممَّن يموتُ عِلْمُكُم   وعلمنا مـن ربنـا وربكم
~~۳۱- وقول من قيل له: اتعب وارحلِ   وحقـق العلـم بـلاتكاسـل
~~۳۲- فقـال مـا نصـنع بالسماع   ممـن تقولـون طويـل البـاعِ
~~۳٣- مثل (البخاري) أو (الصنعاني)   مِمَّـنْ روى عـن أحمـد العـدناني
~~٣٤- وقـال سَمْعُنا عـن الَخـلاّقِ   يكفي بـلا شـكٍ ولا شـقاقِ
~~٣٥- وقـال أي ذي العلـوم راقي?   سماع مخلـوق أم الخـلاق؟
~~۳٦- فهـذه مكائـد الشیطانِ   يطلقهـا بمنطـق الإنسـانِ
~~٣٧- يدعو إلى الجهل مع التضليلِ   مخادعـاً بمنطـقٍ رذيـلِ

PageV03P208

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0209.png)

~~٣٨- وكل من عن أشرف الخَلْقِ روَى   لـولاهمُ لطمّنـا بحـر الهـوى
~~۳٩- ومـن أحالنـا لغـير حَـدَّثًا   فإنـه في ديننـا قـد أحـدثا
~~٤٠ - وإنـه ضـل السـبيل الأقومـا   وفي طريـق الشـبهات خـيَّما
~~٤۱- ولا دليـل موصـل للجنـةِ   مثـل كتـاب ربنـا والسنة
~~٤٢ - والعلـم وصف كـل أهل الله   وهـو عـن الشر وخـزي نـاهي
~~٤٣ - والعلم مثل الغيث حين ينهمر   والحـال نفعه بشخص منحصرْ
~~٤٤- فهـو شفاء الصدر والضمائر   والنـور للقلـوب والبصـائر
~~٤٥- ولـذَةُ الأرواح والعقـولِ   وسلم الصعود والوصـول
~~٤٦- والحكـم العـادل والمفـرقُ   مـا بين حـق وضـلال يُغْرِقُ
~~٤٧- فـالله بـالعلم تعـالى عُرِفَـا   ونـوره لكـل سر كشـفا
~~٤٨- وإنـه بـالعلم حقـاً يُعْبدُ   ولم يكـن بغـيره يوحَّـدُ
~~٤٩- وذكـره بـالعلم والتحميـد   أيضـا وبـالإجلال والتمجيـد
~~٥٠- وإنـما معرفـةُ الأحكـام   بـالعلم كـالحلالِ والحـرام
~~٥١- وهـو إمـام الفضـل والمكـارم   مـن أجـل هـذا بـان فضـل العـالمِ
~~٥٢ - واستشهد الله عـلى التوحيـدِ   بأهلـه لفضـله المديـدِ
~~٥٣- لأنهـم حقـأًهـم العـدولُ   وقـولهم تقبلـه العقـول
~~٥٤ - وقدرهم في الفضـل والمناقبِ   كالشمس فاقت سائر الكواكب
~~٥٥- (موسى) رسول الله للعلم رحل   وفي الـبراري والبحـار قـد نَـزَل
~~٥٦ - والمصطفى محمـد قـد ألزمـا   أن يطلب المزيـد منـه دائِـما
~~٥٧ - وسائر الأملاك قد تواضعَتْ   لأهله وبالرؤوس طَأطَـأَتْ

PageV03P209

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0210.png)

~~٥٨ - هـو الغنى والقائـدُ المُسَـدَّدُ   وهـو الـذي بـه الأنـام تسعد
~~٥٩- والصـاحب الـوفي في التغرُّبِ   والمنقـذ العظـيم عنـد الكُـربِ
~~٦٠ - والكاشف الأقوى لكـل شبهةِ   وخير حرز عنـد كـل ضَيْعَةِ
~~٦١- والبحثُ فيـه مطلقـاً جهـادُ   ولـيس كـالعلم لعقـل زاد
~~٦٢ - وإنـه والله أفضـل القرب   في ندبه فكيف بالذي وَجَـبْ
~~٦٣ - وحاجـةُ النـاس إلى العلـوم   تفـوق حاجـةَ إلى المطعـومِ
~~٦٤ - بل حاجةُ العلـم لكـلِّ الناسِ   تفـوق حاجـةًَ إلى الأنفـاسِ
~~٦٥- والعلـم نوعـان: جـليُّ وخفي   فاسلك طريق العلم حقا واقتف
~~٦٦ - وهكـذا الجـلي أيضـاً قُسّما   إلى ثلاثـة بهـا العبـدُ سَـما
~~٦٧- فـالأول: الحاصـل للعَيَـان   فحاصـل بالسـمع كـالقرآن
~~٦٨- ثالثهـا: تَجَـارُبُ العقـول   علومهـا مـن أنفع المحصـولِ
~~٦٩- ثـم الخفي لا يكـادُ يظهـرُ   إلا لمـن بـه غـدا يُنَـوَّرُ
~~٧٠- لأنـه يَنْبُـتُ في القلـوب   بفضـل ربي عـالم الغيـوبِ
~~٧١- في البـدن الـذي غـدا زَكَّيـا   ولم يكـن بسـعيِهِ شَـقِيّا
~~۷٢- فمَـنْ مِـنَ الأدران قـد تطهَّرا   حتی غدا بنور ربه یری
~~٧٣- وقلبـه اطمـأنّ في انشـراحِ   وطـار نحـو مـوطن الأفراح
~~٧٤- فهو كمرآة صفت مـن الكدر   في كـل مـا يفعله ومـا يَذَر
~~٧٥- وَرُوحُهُ لاحَتْ بِهَـا الأنْـوارُ   وكُشِـفَتْ في حقـه الأسرارُ
~~٧٦- لكونه غُـذَّيَ بـالحلالِ   وجَــدَّ في الخـير بـلا إخْـلالِ
~~٧٧- فأنبت العلـمُ لـه المعارفـا   إذ لم يكـن لمنكـرٍ مُقَارِفـا

PageV03P210

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0211.png)

~~٧٨- بل قد سقى القلب بنور المصطفى   وكلما سقاه بـالنور صـفا
~~۷۹_ وهـذه البصـيرة التـي دعـا   لهـا النبـي المصـطفى مَـنْ تَبِعَـا
~~٨٠- وإنهـا التَنْـويرُ للأنـام   مـن ذي الجـلال المـنعم العـلام
~~۸۱- أو قل: هي الحكمةُ يُؤتاها الفتى   لكونه عـلی الهـدى قـد ثَبَتا
~~۸۲- وفُسرت بـالفهم للقرآنِ   والفقـه في الـدين عظـيم الشـآنِ
~~٨٣- أو أنهـا إصـابةُ الإنسـان   في القـول والفعـل وفي المعـاني
~~٨٤- وفسرت أيضاً بتحقيق الوَرَع   في ديـن ربنـا الـذي لنـا شَرَع
~~۸۰- وحينما تُقْرَنُ بالكتـاب   فَسُنَةُ الهـادي بـلا ارتيـابِ
~~٨٦ - وقيل بل معرفة الحـق الأجـلّ   ثـم إصـابة بقـول وعمـل
~~۸۷_ بهمـة نافعـة وعائـدة   بكـل خـير فـالعلوم رائـدة
~~۸۸ - وخير هِمَـةِ هـي المعلقـة   بربنـا في حبـه مشـوقة
~~۸۹ - وصاحب الحكمة دوماً يفلحُ   لوضعه الأشياء حيث تصلح
~~٩٠- بالجـد والعـزم بـلا تَعَـدِّي   وبَذْله الحـق بقـدر الحـدِّ
~~٩۱- بـلا تقـدم ولا تـأخر   ولا تفـاخر ولا تبخـتُرِ
~~٩٢- وهـي إلى علميـة تنقسـمُ   فالعمليـة التـي تتمم
~~٩٣- وأكمل الناس نصيباً مطلقا   مـن كـان بالحكمـة قد تحقَّقا
~~٩٤ - وربنـا بهـا العبـادَ يكـرمُ   تبـارك الله العـلي الأعظم
~~٩٥ - أركانهـا ثلاثـةُ وَتحْصَرٌُ   حلـمٌ، أنـاة، ثـم عِلْـمٌ ينصرُ
~~٩٦- فلا يكـون جـاهلا ذا حكمةِ   ولا عجـولا طائشـا ذا خِفَـةِ
~~٩٧- وتكمـل الحكمة فيمن شهدا   مـن ربـه في خلقـه مـا وَعَـدا
~~٩٨- وَعَدْلَـهَ في حكمه تعـالى   وَبِرَّه في المنع مهـما طـالا

PageV03P211

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0212.png)

~~۱- فراسـة المـؤمن ممـا أَكَّـدَا   والمصطفى بها لهـم قـد شَهِدا
~~٢- وهي التوسـم الـذي قـد وردا   في محكم القرآن مصدر الهـدى
~~۳- صـاحبها يَـری بنـور الله   ولـيس عـن مراده بلاهي
~~٤ - فـإن أنـوار القلـوب الصـادِقَة   تنيلهـا فراسـة مطابقـة
~~۵- وسـميت فراسـة لأنهـا   خواطر القلـوب ليست ظنّها
~~٦- وإنهـا تـأتي كَوَثْبِ الأسدٍِ   عـلى الفريسـةِ التـي لهـا هُـدي
~~۷- وكونهـا فَعِيْلَـةَ مفعولـة   فـاحفظ هـديت هـذه المقولـة
~~٨- قُوَتُهـا بطاعـة الـرحمن   ونقصـها بالضـعف في الإيـمانِ
~~۹- يحظى بها من غضّ عنْ مَحـارِم   وحَفِظَ النَفس مِـنَ المَـآثمِ
~~١٠- مِـنْ شهواتها التي تُضِـلَّها   وكلـما يـوم اللقـايَغُلُّهـا
~~١١- وكل ذي حرصِ على المحاسبة   قـد عمـر البـاطن بالمراقبـة
~~۱۲- ظـاهره يعمـره بالسنةِ   من هدي خير الخلق عالي المنةِ
~~١٣- ويأكـل الحـلال في كِيَاسَـة   فمثـل ذالم يخطـئ الفِرَاسَـة
~~١٤- وكـل خـاطر لـدى الإنسـانِ   لم يُجْـنَ مـن مغـارس الإيـمانِ
~~۱٥- دَعْـهُ ولا تقـلْ: هُـوَ الفِرَاسَـة   فـربما جـرّ إلى انتكاسـة
~~١٦- وأعظمُ الأَمَـةِ بَعْـدَ المصطفى   فراسةً صِـدَّيقُها عـالي الوفَا
~~۱٧- وبعـده الخليفـةُ الثـاني عُمَـرْ   فأمره في الباب هـذا قـد زخَرْ

PageV03P212

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0213.png)

~~١٨ - أيضـاً وإنَّ مِـنْ ذَوي الفراسَة   عزيـز مِصْرَ صـاحب السياسة
~~۱٩ - (فَأكُْرمِي مَثْوَاهُ) دلَّتْ جِدا   عـلى فراسـةٍ تفـوقُ الَحـدَّا
~~٢٠ - وإنَّ في ابنتيْ شُعَيبِ ما بَهَر   إذ قالـت: (استأجره) إنـه الأبـرّ
~~٢١- وأصـلها حيـاةُ قلب المـؤمن   ونـوره مـن ربنـا ذي المِـنَنِ
~~۲۲ - بـالعين والقلب وأذن تحصلُ   وربـما في الحالكـات تَفْصِـلُ
~~۲۳- وجـودة الـذهن لهـا مسـاعدة   وحـدة القلـب إليهـا رائـدة
~~٢٤- وحسـن فطنة الفؤاد تُسعِفُ   تُجـلَى بهـا حقـائقٌ وتُكْشفُ
~~۲٥- وقـد روي أن (إياساً) كانـا   مـن أحسـن العبـادِ فيهـا شـانا
~~٢٦ - وهكذا الحبر العظيم (الشافِعِيْ)   من کان للدنيا کنور ساطع

PageV03P213

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0214.png)

~~۱- تعظيمنا لربنا الأعـلى وَجَب   وهو الذي نعلو به أعلى الرتب
~~٢- وأنـهُ روحُ العبـاداتِ التـي   تُسـعدُ كـالإجلال والمحبـة
~~٣- وأول التعظـيم لله الأجـل   تعظـيم أمره بجـدٌّ ووجـل
~~٤- بلا تشـدد يقـود للخطر   ويجلبُ الشرَّ علينـا والضرَر
~~٥- وكـل أمـر فيـه نزغتـانِ   يدعو بهـا الشـيطان للخسرانِ
~~٦- إن مِلْتَ للتفريط سوفَ يَقْبَلُ   أو جئت بـالغلو فهـو الأفضلُ
~~٧- والنهي عن هذين مطلقاً ورد   كالدّين لـن يُشَـادِدنه أحـد
~~۸- وسـددوا وقاربوا ویسروا   وبعـد هـذا الاعتـدال أبشروا
~~٩- وأمـره بـالرفق في الإيغـالِ   وفعـل مـا نُطيـق مـن أعمال
~~١٠ - وَمَنْ تَنَطَّعُـوا يشَرِ باؤوا   لأنهـم بفعلهـم أسـاؤوا
~~١١- وأعظم التعظيم يا من يفهم   تعظيمنالله وهـوالأعظـم
~~۱۲- فلا نرى حقاً عليه قدْ وجب   أيضـاً ولا مـن دونه أيّ سبب
~~۱۳ - فلـم يقربنـا لـه سِـواهُ   سبحانه القـادر والإلَـهُ
~~١٤- وهـو الـذي يمنحنـا رضـاهُ   وقـد عنـت لذاتـه الجبـاهُ
~~١٥ - وكلـما يُقَـالُ: ذا حـقُ المـلا   سماه حقـأربنـا تَفَضُّـلا
~~١٦ - ومـا لهـم عليه حَـقٌ أبَـدا   وإن غـدا وصـوله مؤكـدا

PageV03P214

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0215.png)

~~١- سكينة القلـبِ بـلا اضطرابِ   عطيـةٌ مـن ربّنـا الوهـابِ
~~۲- أنزلهـا الله عـلى الرسـولِ   في شـدة الأمـر وضـعف الحـولِ
~~٣- في الغـار، في بدرٍ، وفي الأحزابِ   وبيعـة الرضـوان للأصحاب
~~٤ - وغيرهـا ولا تـزال نازلـة   وهـي لكـل المخلصـين حاصـلة
~~٥- وأصـلها الوقـار في اطمئنـانِ   إلى العظـيم المـنعم المنـانِ
~~٦- فـلا يكـون القلـب في تخـوفِ   لأنـه بـاللّه خـير عـارفِ
~~٧- وفي الصحيحين عن (ابن عازبِ)   كـان لهـا النبـيُّ خـيرَ طالبِ
~~٨- فيـوم أن خنـدق للمدينـة   أنالـه إلهـه السكينة
~~٩- وأنه وصـف لـه قـد ثبتـا   في الكتـب الأولى عـن الله أتـى
~~۱٠- والأمر ذا يُنـال بـالتجردِ   ورغبـة القلـب مـن الموحّـدٍِ
~~١١- فإنهـا نـورٌّ وقـوةٌ لِمـنْ   أنِيلَهـا وروحُ روح فـاعْلَمَنْ
~~١٢ - تنير للقلب الطريـق المظلِما   وتجعـلُ النشـاطَ دومـاً أعظَـمَا
~~۱٣- بهـا تُـرَی حقـائق اليقـينِ   في كـل أمـرٍ مـن أمـور الـدِّينِ
~~١٤ - ويُعْرَفُ الحـقُّ مـن الضـلالِ   مـن دونـما لَـبسِ ولا إشكالِ
~~١٥- والقلبُ يبقى دائـم التأهب   إلى لقـاءِ ربـه المحبَّـبِ
~~١٦- لكونه حَيّـاً بنـور الله   ولم يكـن بغافـلٍِ أو لاهِ
~~١٧ - وتوجب القوة صدقَ المعرفِة   وقهر داعي الغي حتى تصرفه

PageV03P215

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0216.png)

~~۱۸- وضبط نفسه عـن النقـائصِ   من كـل ممقوتٍ وفعـلٍ بَاخِسِ
~~۱۹- وكلهـا تزيـد في الإيـمانِ   وتحفـظ العبـد مـن الخسرانِ
~~۲٠- وإنـما يسكن للمعـاصي   كـل ضـعيف نـادر الإخـلاصِ
~~۲۱- ومـن يعش بلـذة السكينة   فـلا تكـون نفسـه مهينـة
~~۲٢- بـل إنه عـن أنْسِهِ لا يَحْرُج   وهـو إلى الطاعـات دوما أَهْيَج
~~۲۳ - وقلبـه لنفسه يقـودُ   وروحه بنورها تسودُ
~~٢٤- ولم يجـد إبلـيس مَـدْخلَّا لَـهْ   بـل كلـما استشرفه أَنَلَّـهْ
~~٢٥- لأنه قـد جـد في المحاسـبة   وأَحْسَـنَ السـير مـع المراقبـة
~~٢٦ - ولاطَفَ الخلـق بـلا تعـالي   علـيهم في سـائر الأحـوالِ

PageV03P216

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0217.png)

~~۱- أمـا الطمأنينـة في العبـاد   فهـي عطيـة مـن الجـواد
~~۲- وهي سكون القلسب دونما جَزَع   لـذاكرٍ في روضة الحب رَتَعْ
~~۳- وذكر ربي يـورث اطمئنانا   ويرفع الإيـمان والإيقانَـا
~~٤ - لسـائر الأذكـار طـراً يشـملُ   ويشمل القرآن وهـو الأكمـل
~~٥- ولم يَفُـز بنفعـه الربـاني   سوى الـذي قـد فَقِـهَ المعـاني
~~٦- وكـل مَـنْ يَعْشُ عـن القـرآنِ   يَعِش مَعَ الشيطان في هَـوَانِ
~~٧- ويلقَ ضـنكاً مرهقـاً مُحَطَّما   وحظَّـهُ في يـوم حَشْره العَمَـى
~~۸ - وقـد أتـى التبشـيرُ بالجنـانِ   لكُـلَّ مَـنْ يعـيشُ في اطمئنـانِ
~~٩- والمطمـئن عَيْشُـهُ بـلا قَلَـقْ   الحُسْـنِ ظَنَّـهِ بِخَـالِقِ الفَلَـقْ
~~۱٠ - لأنـه فعـال مـا يريـدُ   ومبـدئْ لخلقـه معيـدُ
~~١١- فهـو لمـا قُدِّرَ في اطمئنـانِ   بالحـب والإجـلال والإذْعَـانِ
~~۱٢- بـلا تضـجرِ ولا تقهقـرِ   عن دفع ما یمکنه من ضَرَرِ
~~۱٣- ويستلذ بـالبلاء النـازِلِ   لأنـه مـن الحكـيم العـادِلِ
~~١٤- بـل إنه يراه مـن خير النَعَم   لأنـه بـأمرِ ذي الجـلال تَمّ
~~١٥- فهـو مع الله عـلى اطمئنـانِ   في كـل حـال وبكـل آنِ

PageV03P217

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0218.png)

~~١- ذو الهمـةِ العليـا كمثـل الطّـائرِ   وغـيرُه كَمُثْقَـلٍ وحـائرِ
~~٢ - وأولُ الهمـة أن تصـونا   قلبك كي لا يصبحن مفتونا
~~۳- وقيمـة الإنسـان حقـاً همته   وإنهـا مـن كـل شيء غايته
~~٤- وإنهـا لمَبـدأ الإرادة   وهي طريـق الفـوز والسعادة
~~٥- وهمـةُ العبـد إذا تعلقـتْ   برَبَّهِ فـإن روحـه رَقَتْ
~~٦- وهـذه الهمـة أعـلى الهمَـم   يسموبها العبـدُ لأعـلى القِمَم
~~۷- ونفسُـه تـزداد في التعلُّـقَِ   بربـه الـبر الكـريم الـرازق
~~۸- ويرغب المـؤمن في الجِنَـانِ   ولم يَمِـل لزائـلٍ وَفَـانِي
~~٩- وإنـما الفـاني هـو الـدنيا فَع   فدعكَ من أطماعهـا والهلعِ
~~١٠ - فإنهـا مثـل السراب الظَـاهِرِ   أمـا تـراه خادعـاً للنـاظرِ
~~۱۱- ومـا لعاقـلِ بهـا مـن فرحةِ   بـل زهـده فيهـا دليـل الهمَّةِ
~~١۲- يزهد فيها دون أدنی رغَبِ   لأنهـا الطريـق نحـو التعب
~~۱۳- وحبهـا نـوع مـن النقيصـة   يلهـو بهـا ذو الهمـة الخسيسَـة
~~١٤- تحول بين قلب كـل مـؤمنِ   وبين مـا يبغيـه مـن ذي المنَنِ
~~۱۹- وإنها نصیب کل خاسرِ   يعرفهـا حقـأَ ذووا البصـائرِ
~~١٦- الراغبون في رضا الفرد الصـمد   وداره الأخـرى التـي بـلا أمـد
~~١٧- همتهم تقـودُهم نحـو العُـلى   فصـدق حبهم عـلا واكتملا
~~١٨- وهكـذا يعلـو بهـا الإنسـانُ   وتذهب الأوسـاخ والأدران
~~١٩- ويُحفـظ المـرءُ مـن التفريطِ   وسـائرِ الإخـلالِ والتخليط
~~٢٠- أيضاً ويغـدو لا يبالي بالعِلَلْ   لأنَـهَ ذوتقـةِ وذواَمَـلْه

PageV03P218

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0219.png)

~~۱- محبـة الـرحمن تـاج الحـب   وهي طريـق فوزنـا بالقرْب
~~۲- العـامِلُون شـمّروا إليهـا   وأقبلـوا برغبـة عليها
~~٣- نسِـيمُهَا روح لكـلَّ عابدِ   وزادٔ كـلِّ راكع وسـاجدِ
~~٤- وبلسـم القلـوب والأرواح   ومصـدر البهجـة والأفراح
~~٥- والنـور والشـفاء للأنـام   مـن ظلمات الجهـل والأسقام
~~٦- ولـذة اللـذات للعبـاد   وخير إكرام وخير زادِ
~~٧- وَمَعْقِـدُ النسـبة بـين العابـدِ   وربـه في اليُسْرِ والشـدائدِ
~~٨- تـالله مـا آلـت إلى كَسَـادِ   ولم يصـبها أئما فَسَـادٍِ
~~٩- لا تُشترَى بالمـال والفلـوسِ   بل تُشترَى بأفضـلِ النفـوسِ
~~١٠ - ولم تُصَبْ بالضعف والهـزالِ   فيشـتريها مُفْلِـسُ الرجـالِ
~~۱۱- ولم تُبَعْ مـن معسرِ نسـيئة   بـل إنهـا في عَرْضـها رَفِيعَـة
~~١٢- يـا خيبة البَطَّال ذي الأمـاني   وفـوز أهـل الحـب بالجنـانِ
~~۱۳- يـا سلعةً بالحب نشتریها   وأنس أهْـلِ الحُحبَِّ طَـابَ فيهـا
~~١٤- قالوا لأهـلِ الحبِّ: ما الدليلُ   قـالوا: صدوقُ الحـب لا يميـلُ
~~١٥ - فهـو عـلى الكفار يستطيلُ   لكـن عـلى إخوانـه ذَليـلُ
~~١٦ - فقيـل: هـذا الأمرَ يَدَّعِيهِ   قـوم وقـد لا يصـدقون فيه
~~١٧ - قالوا: دليل الصدق في المحبة   بحبّ مـن رب الـورى أحبه

PageV03P219

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0220.png)

# (۲۱٩)
~~١٨- وذاك شرطٌ سَـاقَهُ إلهـي   لـدفعِ إيهـامِ أو اشـتباهِ
~~۱۹- فمـن يكـن للمصطفى محبّا   فإنـه لله قـد أحبا
~~٢٠ - قالوا: ومـا التعـديل للـدليل؟   وهـل إلى التعـديل مـن سبيلِ؟
~~٢١- قلنـا: نعـم، تعديله الجهـادُ   هذا دليل الحب يا عبادُ
~~٢٢- فالنفس مـن أمـلاك مشتريها   فافهم وكن يا صاحبي نبيها
~~٢٣ - نفوسنا من ذي الجـلال مِنَّةْ   ونحـن بعنَاهـا لـه بجنة
~~٢٤- فباعهـا الصـدوق باشـتياقِ   لربـه الموفـق الخـلاقِ
~~٢٥- بـلا إقالـة ولا خِيـارِ   يرجـو رضـا المهـيمن الغفّـارِ
~~۲٦_ فردهـا عليهم المنَّـانُ   وافـرةً ليس بهـا نقصـانُ
~~٢٧- فـإنهم أحيـاء عنـد ربهمْ   في فرحـة بأنسـهم ورزقهـمْ
~~٢٨- وكـل حب سَقْيُهُ الإخـلاصُ   بوفـق نهج المصطفى يُسَـاسُ
~~٢٩- ثـماره دومـاً إلى المزيـدِ   وما لِنّبْتِ الحبِّ مِـنْ حُدُودِ
~~۳۰- وحدُّها مِـنْ ذَوْقِهَا قَـدْ عُلِمَا   ولا يذوقها سوى مـن فهـما
~~٣١- آثارهـا الميـلُ عـلى الـدوام   إلى الـذي تهـوى بـلا انفصَـامِ
~~۳۲ - وقيـل: أن يمتـاز بالإيثـارِ   مـن دونما قيد أو انْحِصَـارِ
~~۳۳- كـذا الموافقـات للحبيب   في حالـة الشـهودِ والمغيبِ
~~٣٤- وقيـل: أن تستكثر الجنَايـة   ولا ترى الطاعـات مِنْكَ غايَة
~~٢٥- وقيـل: أن تُبـاين المعـاصي   في طاعـةِ لمالك النَّواصي

PageV03P220

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0221.png)

~~٣٦- إِن المحب ذاهب عَـنْ نَفْسِهِ   متصـل بالـذكر سر أنسهِ
~~۳۷- وقـائم لله بـالحقوقِ   ونـاظر بقلبـه العشـوق
~~۳۸٨- فنطقـهُ بـالله إن تكلـما   وصـمته بـذي الجـلال دائـما
~~٣٩- ويَجلِبُ الُحبَّ خِصالُ عَشْرُ   وليس في التعـداد هـذا حَصْرُ
~~٤٠- أولهـا: قـراعة القـرآنِ   وهكـذا تَـدَبُّر المعـاني
~~٤١- ثـم التَقَرُّبـاتُ بالنوافـلِ   بعـد الفروض كلهـا بالكامـل
~~٤٢- ثـم دوام ذكـر ذي الجـلالِ   بالقلب واللسـان كـل حـال
~~٤٣ - رابعهـا: إيثارنـا مَحَابَه   ودفعنـا مـن الهـوى مَثَالِبَه
~~٤٤- مطالعـاً أسـماءه بقلبـهِ   وراتعـا في روضها بحبه
~~٤٥- مشـاهداً بِرَّ وفَضَـل الربَّ   مع انكسـارِ قلبـه في حُبَّ
~~٤٦ - والثـامن: الخَلْوَةُ في الأسحارِ   بـذي الجـلال المـنعم الغفّـارِ
~~٤۷ - تاسعها: مجالسـات البرَرَة   ليجتني أحـلى المعـاني النضرة
~~٤٨ - والعـاشر: البعـاد عمّا حـالا   قلَيْبَـهُ عـن ربه تعـالى
~~٤٩- وهـذه الأسباب منهـا وصـلا   كـم مـن محـبِ لمنـازل العـلى
~~٥٠ - ودخلـوا عـلى الحبيب مِنْهَا   ويـا لبـؤس المعرضـين عنهـا
~~٥١ - مِلَاکُها ثنتان من خصالِ   أن تسـتعد الـروح للأعـمالِ
~~٥٢ - وأن تـرى بصـيرةُ الُحِـبِّ   طريقَهـا لموجبـاتِ الحـب
~~٥٣ - وربُنا يحب مـن أحبَّه   وحبنـا لله خـير قربـة

PageV03P221

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0222.png)

~~٥٤ - وإنها الحـق الـذي قـد رُفِعَتْ   به السموات وأرض بسطتْ
~~٥٥- وأمر معروفٍ ونهي منكر   مِنْ ضِمْنٍ هَذا الحَق فافْهَمْ وابصِرِ
~~٥٦- والسرفي التوحيـد والتأليـهِ   وفي قبـول النـاس للتوجيـهِ
~~٥٧- والحب والتعظـيم في التوحيـدِ   سرُّ نَجَـاح سَـائر العَبيـدٍِ
~~٥٨- وآيـةُ المحنـة للقلـوبِ   تُبِيْنُ ذا صِدقِ مِـن الكـذوبِ
~~٥٩- قد کشفت أحوال مُدَّعِيها   وبينـت كيـف الأنـام فيهـا
~~٦٠- توحيـدها شـهادة الحـق التـي   بهـا نجـاة الخلـق يـوم الحسرة
~~٦١- وليسُ مثلُ زَعْم مَنْ منها أقَرّ   بأنه الرب الـذي لـه فطـر
~~٦٢- وفاته توحيـده بالحـبِّ   وربما يعبـد غـير الـرَّبَّ
~~٦٣- وكـم بهذا الأمر مـن غـويّ   يجهـل نصح المصطفى السويًّ
~~٦٤- لمـا رأى عَـدِياً بَـنَ حـاتِم   في مظهـرٍ لم يـك بـالمُلائمِ
~~٦٥ - ولم يكُ الإنسـان بالمحـبِّ   إلا إذا نَفَّـذَ أَمـرَ الـرَّبَّ
~~٦٦ - وتـابَعَ المختـار في إحسـانِ   وذلـة عـلى ذوي الإيـمانِ
~~٦٧- مجاهـداً بنفسـه والمـالِ   للكفـر والفسـاد والضّـلاَّلِ
~~٦٨- ودافعـاً باليـد كـل مـا لَـزمْ   عليه أن يَدْفَعَـهُ مِمَّـاحُـتِمْ
~~٦٩- وكاشـفاً بـالفكر واللسـانِ   كـلَّ صُـنُوفِ الشرُّوالطغيـانِ
~~۷۰- محارباً آثارهـا بعقلهِ   وقوله ورأيـه ونقله
~~٧١- ولومـة اللائـم لا تـؤثره   لأن رب العـالمين نـاصِرُه
~~۷۲- وكـل مـن يعمـل فيه اللوم   فحبـه مُزيَـف مزعـومُ
~~٧٢- وصاحب الحب الصدوق يُغْرَى   وهـو بكبت اللائمينَ أدرى

PageV03P222

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0223.png)

~~۲۲۲)
~~٧٤- فإنها الروح لأصناف العملْ   فإن خلـت منهـا يبـوء بالفشل
~~٧٥- بـل إنهـا حقيقـةُ الإخـلاصِ   والدين كلـه بـلا منـاص
~~٧٦- وكـل عقـلِ لم يكـن مقـدِّما   محبـة الله العظـيمَ دائـما
~~۷٧- عـلى محبـةِ لـنفس وولـدْ   والأهـل والمـال فعقلـه فَسَـدْ
~~٧٨- وشرعنـا والعقـل يُوجِبَـانِ   محبـة العبـاد للمنَـانِ
~~۷٩- من أجله جاءت إلينا الرسل   والأمر هـذا واضحٌ لا يجهـلُ
~~٨٠- فـإنهم دعـوا إلى التوحيـدِ   في الحـب والتعظـيم والتفريـدٍِ
~~۸۱- ومـا العبوديـة إلا الحـبُّ   ثمارهـا إنابـة وَقُـرْبُ
~~٨۲- ولـيس يـرضى بالإلـه ربَّـا   ولا ينيبُ غير مـن أحبـا
~~۸٣- ولا يكـون حامـداً وشـاکرا   وخائفـاً وراجيـاً وصـابرا
~~٨٤- ولا يكـون زاهـداً حَييّا   ولا صـدوقاً مخلصـاً تقيا
~~۸٥- إلا محـب ذاق طعـم الحـبُّ   ونال أنس القرب عند الرب
~~٨٦ - والفقـر فقرُ الحب في العِبَادِ   إلى الكـريم الواسع الجـوادِ
~~٨۷- بالقلب والروح وكل جارحة   بِهِمَّـةٍ إلى المعـالي طَامحَـة
~~۸٨- ومـا الغنـى إلا غنـى المحـبِّ   والشوق لب لب كل حب
~~۸۹- وينبني الحب عـلى مراتبِ   تُظْهِرُ كـل صـادقِ وكـاذبِ
~~۹۰- علاقـةٌ إرادةٌ صـبَابَة   ورابع غَـرَامُ مَـنْ أصـابه
~~٩۱- وبعـده الـودادُ ثم الشَّغَفُ   والعشق مـن إفراطه التخوف
~~٩٢- تَتَـيُّمْ تَعَبُّـدٌّ وخُلَّـة   مـن دون أي خصـلةٍ مُحِلَّة

PageV03P223

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0224.png)

# (۲۲٣)
~~۹٣- وكـل قلب عـاش في تعلّقِ   مـا بـين هِمَـةٍ وأنسِ صـادِقِ
~~٩٤- منجدباً لله بـالتمام   في حالـة اليَقْظَـةٍ والمنـام
~~۹٥- قد قطع الوسواس والخواطرا   ولم يكـن إلى سـواهُ نَـاظِرَاً
~~٩٦- فذلك القلب المحـب الصـادقُ   إلى مـراضي ذي الجـلال تـائقُ
~~۹٧- بالحب هـذا تُعرف الفـوارقُ   وتظهـر الزيـوفُ والحقـائقُ
~~٩۸- وأصل حب الله نـور يُقـذَفُ   في قلب من عن رَبَّهِ لا يُصْرَفُ
~~٩۹- مطالعـاً لفضـله والمـنن   وثابتـاً عـلى اتّبَـاع السُّـنَنَ
~~١٠٠ - فإنـه أَهَّلَـهُ وعَظَمَهْ   وهـو الـذي بحبه قد أكرمه
~~۱٠١- فانْقَشَعَتْ عَنْ نَفْسِهِ العَوَائقُ   ووجهت لربـهِ العلائق
~~١٠٢ - وامتلأ القلب بنورِ ساطِع   مبـدداً للظّلَـمِ القَواطِعِ
~~١٠٣- فيملأ الكـونَ بنـور الحـبِّ   ويعـتلي عـلى رفيع الشَّهبِ
~~١٠٤- والناس في الأنوارِ في تَفَاوُتِ   كالشمس والبدر وضوء خافت
~~١٠٥- فكل ذي قلب تقي سامي   متـابع لأشرفِ الأنَـامِ
~~١٠٦ - یـزداد أنـواراً وحباً وعـلا   ففي اتّبَاع المصطفى سرُّ العـلى
~~١٠٧- ومن يكـن في الاتباع قَصدَّرَا   ما صَـدَقَ الحبَّ ولاتنَّـورَا
~~١٠٨ - والشوق من آثار حب صادِقِ   برغم كـل مـانع وعـائق
~~١٠٩- وهـو مطيـة إلى الجِنَـانِ   وخـير قائـدٍ إلى الـرحنِ
~~١١٠ - والشوق يحدو أَنفُس العشاق   إلى الكـريم المـنعم الَخــلاقِ
~~١١١- فالقلب مُهْتَاجٌُ وكـل جَارِحَة   إلى لقـاء ذي الجـلال طَامِحَـة
~~١١٢- وسفر القلب إلى المحبـوبِ   ذلك شـوقُ الصادق الرغوبِ

PageV03P224

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0225.png)

~~۱۱٣- يشـتاق للجنـةِ غَايَـةِ المِنَحْ   ويـدفع الأحـزانَ طـراً بـالفَرَحْ
~~١١٤- حينئذٍ ينـالُ رُوحَ الظَفَـرِ   بفضل ذي الإحسـانِ ربَّ البشرِ
~~١١٥ - وتعظم الأشواق في إحسانِ   إلى العظـيم المـنعم المنَّـانِ
~~١١٦- وهـذه أعـلى ثمارِ الحُبّ   وغايةُ الأنسٍ وأشمى القُربِ

PageV03P225

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0226.png)

~~۱- وَمن أحب صـادقاً يغـارُ   وهـو الـذي المـولى له يختـارُ
~~۲- يحفظـه الله مـن الأغيـار   فلـم يكـن عبـداً لغـير البـاري
~~٣- في سـائرِ الأقـوالِ والأفعـالِ   وَسَـائِر الأوقـاتِ والأحـوال
~~٤ - يغضـب إِن تُنْتَهَـك المحـارمُ   فهـو بحـق الله دومـا قـائم
~~٥ - يـأمر بالمعروفِ كـي يحققـا   ولا يُقِرُّ المنكـراتِ مُطلقـا
~~٦- فَتَرْكُـهُ بَـابْ إلى العـذاب   وَمُوقِـعُ العبـادِ في العقـابِ
~~٧- وَتَرْكـه يُسَـلَّطُ الأشْرَارا   ويُوجِـبُ اللَّعْنَـةَ والأضرَارا
~~۸- ويَمْنَـعُ اسـتجابة الـدعاءِ   وَيُوقِـعُ الأمَّـةَ في الـبلاءِ
~~۹- ويجعـل القلـوب في تخَـالُفِ   كـذا الوجـوه وهـي في تعـارفٍ
~~۱٠- من أجل هذا شدَّدَ الرسولُ   في فعلِـهِ والحـقُ مـا يَقُـولُ
~~۱۱- تغشـاه مـن ربي عـلى الـدوام   صلا تـه العظمـى مع السلام
~~١٢ - وَغَـيْرَةُ استدراكِ كـلَّ عابدِ   لِـرَدّ فائـتٍ ونيـل زائدِ
~~۱٣- فيجـبر التقصـيرَ فـيما فاتـا   وَيَطْلُبَنْ مِـنْ رَبَّهِ الثَباتا
~~١٤- وَيَنْثَنِـي لِطَاعَـةٍ في شَـغَفِ   ويغـنمُ القـوَّة قَبْـلَ الُضْعِفِ
~~١٥- أعـز شيء وقتنـا إن حُفِظـا   لأنـهُ إن فـات لـن يعوضا

PageV03P226

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0227.png)

~~۱٦- من أجل هذا غَارَ کُلِّ عَاقِلِ   خوفاً عليه من خَسَارِ كاملِ
~~۱٧- والمصطفى الأمين خيرُ البَشَرِ   نَبَهَ مَـنْ أَفْطَـرَ اِنْ لَم يُعْـذَرِ
~~١٨- بـأنَّ صَـومَ الدَّفرِ لا يَقْضِيهِ   لأنـه لـيس أداء فيه
~~١٩ - فَـالنَفَسُ الذاهب في صعودِ   والأمسُ لا يَعُـود للوجـود
~~٢٠- وصاحبُ الغَـيْرَةِ لـيسَ يَفْتُرُ   أَنفَاسُـهُ وَوَقْتُـهُ لا تهـدر

PageV03P227

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0228.png)

~~١- الوَجْـدُ مـن ثمارِ حُبِّ المـؤمن   وشَـوْقِهِ لربـه المهـيمن
~~۲- وَحُبَّـهِ للمصـطفى المختـارِ   وبُغْضِ أهـلِ الكفـر والأشرار
~~۳- وَحُبَّـه للمِسْـلِمِينَ قاطبْـة   وبغض مـا جَرّ لسوء العاقبة
~~٤- وذم مـا كـان عـلى تكلف   وقيـل: محمـود إذا لم يُجْحِفِ
~~٥- ولـيس كـالقرآنِ ذُو تَـأثيرِ   ودافعٌ للخـاطرِ الخطـيرِ
~~٦- فيعمـل القلـوبَ والأفكـارا   والسمع والأبـدان والأبصـارا
~~۷- حينئـذٍ حـلاوةُ الإيـمانِ   يـذوقها العابـدُ للـرحمنِ
~~۸- وَرُبَـما ذَا الوجـدُ لا يـدومُ   لعـارض أو حـائم يحـومُ
~~٩- إلا إذا مـا حَـلَّ في الفُـوَادِ   وَازْدَانَتْ الرُّوحُ بِخَـيرِ زادِ
~~١٠ - وَوَاعِظُ القلب الـذي حَبَـاهُ   إلهُـهُ بنُـصْحِـهِ أتَـاهُ
~~١١- يَـأْمُرُهُ بِخَیرهِ وينذره   يرشـده إلى الهـدى يُبَشُرُه
~~١٢- كما أتى عـن أحمـد في المسـند   عـن النبـي المصـطفى محمـد
~~۱۳- صـلى عليه خـالق الأكـوان   مع السـلام سـائر الأزمـان
~~١٤- فالوجد هذا خير وجد يُنْعَتُ   صاحبُه عـلى الطريـق يَْبُتُ

PageV03P228

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0229.png)

~~١٥- وموت حظ النفس يحيي الروحا   فيصـبح القلبُ بـه مشروحا
~~١٦- وكـل نفس للحظوظ فاقـدة   فإنهـا لـذي الجـلال عابَـدَة
~~۱۷- وأيُ قدرٍ من حظوظ النفس   بقـدره يكـون قـدر التعْس
~~١٨ - والُحُرُّ مَنْ لِشَهْوةِ النَفَسِ مَلَكْ   وذا الـذي بـاهى بـه الله الملَـك
~~۱٩- والعبد مَـنْ لا زال في استعبادِ   لشـهوةِ كالأكـل والرُقَـادِ
~~٢٠ - والحـر عبـد الله فـافهم واعلَم   والعبد مـن في الشهوات مرتمي
~~۲۱- ولـيس كالغفلـة مـن بَلاءِ   جالبـة للخـزي والشّـقَاءِ
~~٢٢- فجانب الأطماعَ تَحْظَ بـالظَفَرْ   وجاهد النفس وكن ممن شكر
~~٢۲٣- وسر باخلاصِ وعزم دائمِ   تنل رضا الـبر الكريم الراحم

PageV03P229

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0230.png)

~~١- البرق قـالوا مبـدأ الولايـة   نـورُ يَشُـدَّ القلَـبَ للهدايـة
~~٢- لنـاظر آلاءَ ذي العطـاءِ   بالشكر والعرفـان والثنـاءِ
~~۳- يعـيش بين الوعـدِ والوعيـدِ   يخـاف مـن تقصـيره الشـديدِ
~~٤- مستشعراً للمـوت والقـدوم   عـلى الكـريم المـنعم العظـيم
~~٥- مستصـغراً في طاعـة القـدير   لكـل عِـبءٍِ مِتْعِـب كبـيرِ
~~٦- بَـرْقُ الهـدى نـورُ بـلا انقطـاع   ولم يَنَلْهُ غـير ذي اتبـاع
~~۷- والبرقُ هـذا لم يكـن بِخُلَّبَْ   بل إنه للمكرمـات قرّب
~~۸- فكن مع المـولى بصـدق حـبِ   يـزدك مـن إِفْضَـالِهِ وَيُـرِْبِي
~~۹- ويـا صـدوقَ العـزم للوصـولِ   إلـزم طريـق المصطفى الرسولِ
~~١٠ - فما لنـا بـابُ سِـواهُ قَطَّ   وما سوى نهج الرسول خَبْطُ
~~۱۱- واشكر على البلوى مع اصطبارِ   تنـل عَظِـيمَ الأَنـس والفخـارِ
~~۱۲- وافرح بفضـل الله في انكسـارِ   مستعطفاً إيـاه في افتقـارِ
~~١٣ - وَعِشْ بِـلا بغي ولا اختيَـالِ   في عـزةٍ بـالله ذي الجـلال
~~١٤- حينئذٍ تَُحْظَـى بِكـل خَيْرِ   مِـنْ ذي الجـلال المنعمِ الخبيرِ

PageV03P230

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0231.png)

~~۱- الـذوق إحساسُـك بالمُنـافرِ   ملائـمًا في بَـاطِن وظَـاهِرِ
~~٢- وليس هذا الذوق خصّ بالفم   بـل بجميع المـدْرِكَاتِ فـافْهَمِ
~~٣- فـالله قـد أذاق أهـل الكفْـر   لبـاس جـوع منـذرا بالخسْرِ
~~٤ - كـما أتـى بِأوْضَـحِ البيـانِ   في سـورة النحْـلِ مـن القـرآنِ
~~٥- فـإنَّ للإيـمان ذوقـاً حاليـا   يغدو بـه المـؤمن شخصـاً عَالِيـا
~~٦- ولم يفـت إلا ذوي المـروقِ   لأنهـم لم يُكْرَمـوا بالـذَوْقِ
~~۷- ومـا سعوا فيما لـه يحقـق   بل قصروا وفَرَّطُـوا فأخفقوا
~~٨- وذائق الإيمان عَبْـدٌ لايَنِـيْ   أو يرتدد عـن عزمه وينثني
~~٩- بـل إنـه يَجِـدُ في ثَبَـاتِ   مجـدداً للعـزم والنيَـاتِ
~~١٠ - ولم يُعِقْهُ عَـائقٌ عـن ربه   لصـدقه في قَصْـدِه وَحُبَّـهِ
~~۱۱- وماله تَعَلَّقٌّ بغیرِهِ   إلا بـما يعينـه في سـيرِهِ
~~۱٢- ولم يعلـق نفْسَـه بِفَـاني   بـل جَـدَّ في السـيرِ إلى الرحمن
~~١٣- مطلوبه المفـاز بالجِنَـانِ   ورؤيـة المهـيمن المنَّـانِ
~~١٤- برغبةِ ليس لهـا من صارفِ   بـل باشتياقِ مـؤمنِ وَعَـارِفِ
~~١٥- وقـوة الرغبـة في المطلـوبِ   ثُيَسّرُ السـير بـلا لُغُـوبِ
~~١٦- وَتقطَـعُ الآمـالَ إلا فـيما   به يكـونُ قَصْـدُهُ قَـوئما
~~١٧ - لأنـه راضِ بـذي الجـلالِ   ربـاً ومعبـوداً بكـل حَـالِ

PageV03P231

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0232.png)

# (٢٣١)
~~١٨- أيضـاً وبالإسـلام في امتثـالِ   دينـأَ بِـهِ يسـمو إلى المَعَـالي
~~۱٩- وبـالنبي المصطفى رسُولا   خير الورى من أوضح السبيلا
~~٢٠- مِـنْ أجـل ذا أصـبح للإيمانِ   ذوقُّ لمـا للـذوقِ مـن بُرْهَـانِ
~~۲۱- والمصـطفى المختـار قـد سََّاهُ   حـلاوةً لذوقـه إيـاهُ
~~۲٢- ولم يكـن في الـذوقِ مثله أحَـدْ   صلى عليه ربنا الفرد الصمد
~~٢٣- فإنـه اسـتغنى عـن الطعـام   بذوقـه عبـادةَ الصـيام
~~٢٤- وإن تـرد شهادة الأعَـادِي   فضلاً عـن الرسـول والزهـاد
~~٢٥- بـما لهـذا الـدين مِـنْ حَـلاوة   ومـا عـلى القـرآن مـن طـلاوة
~~٢٦- في قصـة الوليـد حين قـالَ   هذا کـلام ربنا تعـالی
~~٢٧- أيضاً وفي قول هرقل إذ سَألْ   هـل ارتـدادهم لسخطةٍ حَصَـلْ
~~٢٨- فقـال ذي حـلاوة الإيـمانِ   قـد خالطـت بشاشـة الجنَـانِ
~~٢۹- وأول الـذوق لكـل مـن عبد   بـأن يَـذُوقَ مـا به الله وعـد
~~۳۰- عندئـذٍ يثبـت في اسـتقامة   مشـمّراً للعـز والكرامـة
~~٣١- من دونِ أي حـابسِ أو عـائقِ   بل ذَوْقُـهُ يكـونُ خيرَ سـائقِ
~~۳۲- وهكـذا حقيقـة الإيـمانِ   تقـود للثبـات والإحسـان
~~۳۳- تقود مـن آمن نحو الرَّب   حين حلولهـا بلب القلب
~~٣٤- وربنـا قـد قـال للأعـراب   (لمـا) كـما في محكـم الكتـاب
~~٣٥- عـنهم نفـى حقيقـةَ الإيـمان   وأثبـت الإسـلام بالأركـان
~~٣۲- مفرقـاً مـا بـين ذوق الـذائق   ومـدع مخـالف الحقـائق
~~۳٧- واكبر العوائـق الـدنيا فع   فإنهـا غَـريمُ كـل ضـائع

PageV03P232

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0233.png)

~~۳۸- فهي كظلِ زائلٍ وبئس هي   وخسرمـن أحبهـا لا ينتهـي
~~٣٩- أو أنهـا كرؤيـة المنـام   تفنـى مـع اليقظـة بـالتمام
~~٤٠- فهـل يليـق باللبيـب العاقـل   أن يُشْـغَلَنْ بهـا عـن الفضـائل
~~٤١- ومـا أعـد الله في الجِنَـانِ   ووعـده بـأكبر الرضـوان
~~٤٢ - والبؤس كل البؤس والخسران   لـذي الهـوى والعجـز والأمـاني
~~٤٣- والأنس بالرحمن أسمى المنن   وهو دليـل الـذوق عنـد المـؤمن
~~٤٤- وهـو الـذي يحثّ للمسـير   في طاعـة المهـيمن الخبير
~~٤٥- بـلا تعلـقِ بـأي شـاغل   ولا تبـاطؤ ولا تكاسـل
~~٤٦ - والأنسُ حالـةٌ مـن الوجـدان   ومـن مقامـات أولي الإحسـانِ
~~٤٧- يزيـد بالـذكر لربنـا الأجَـلّ   والصدق في الحب وإحسان العمل
~~٤٨ - وقـوة الأنس بقـرب العابـد   والضعف بالتقصير والتباعـد
~~٤٩- فتكثر الوحشة حين يضعُفُ   بعـارض به الفـؤاد يُصْرَفُ
~~٥٠- ممـا يُكَـدِّر الصـفا ويُشعِثُ   قلـوب مـن بالمكرمـات يعبثُ
~~٥١ - وما سِوَى الرحمن فهو عارِضُ   والحكـم هـذا مـا لـه معـارِضُ
~~٥٢ - وقـوة الرغبـة في الله الأجـلّ   تقطع كـل ما سواه مـن أمـل
~~٥٣ - فما سوى الحق خيالُ الطَّيفِ   أو كسحاب طـالع في الصَّـيفِ
~~٥٤- وهـذه الـدنيا كظـل زائـلِ   أو قائـل في ظلهـا وَرَاحِـلِ
~~٥٥- أو واضع أصبعه في السيم   فافهم مثال المصطفى الأتمَّ

PageV03P233

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0234.png)

~~٥٦- وعُمَـرُ الفـاروق ذو الإلهـام   مَثَلهَـا برؤيـة المنـام
~~٥٧- فـلا تُردْ سوى الإله مطلقـا   لكي تكـون فائزاً مُوَفَقَا
~~٥٨- ولا تكون في عداد مـن حُجِبْ   ولم يُبَالـهْ ربُـهُ ولم يجـب
~~٥٩- بل كن على الإقبال تلق الكرمـا   ولا تكـنْ باللهو ممـن حرما
~~٦٠- حينئذٍِ تَـذُوقُ مـا لا يُعْلَمُ   إلا لمـن يعرفـه وَيَفْهَــمُ
~~٦١- لكون قلبك اشتَنار بالهدی   حتی غـدا موفقاً مسددا
~~٦٢- وإِنَهُ عـلى عكـوف دائم   عـلى مـراد ذي الجـلال العِـالِمِ
~~٦٣- لم يلتفـت عنـه ولا يميـلُ   وعـن طريـق الحـق لا يُحُـولِ
~~٦٤- بـل نفسـه بِهِمَّـةِ الإيـمانِ   ألْقَتْ عصى السير لدى الرحمن
~~٦۵- وسـاجدة بين يديه شـاکرة   لكي تنـال حَظْـوَةً في الآخـرة
~~٦٦- راضـية بمنـة الـرحمن   فـائزة بـالقرب في الجنـانِ
~~٦٧- مَرْضِـيَةً تعـيشُ في اطمئنـانِ   تُجزى عـلى الإحسان بالإحسانِ
~~٦٨- تكثـر في الـدعاء والسـؤالِ   تـذللأً لله ذي الجـلالِ
~~٦٩- لوعـده الـداعين بالإجابـة   وكون مـن يرجونه أحبابَـه
~~۷۰- بوفق مـا علمنـا الرسـولُ   صـلى عليـه ربنـا الجلِيـلُ
~~۷۱- وجمعنـا بين السرور والحـذر   ينيلنـا مـن ربنـا كـل وَطَر
~~٧٢- وفَرَحُ الإنسـان قـد يجـرُّهُ   لِكْـرٍ ربـه الـذي يَضُْـرُهُ
~~٧٣- وإنما المحمود منه ما انْضَبَطْ   وَمَـا بِفَضْلِ ربنا الأعلى ارتَبَطْ
~~٧٤- والله قـد أكرمنـا بالنعم   وشُكْرِها وذاك أقصى الكَرَمِ
~~۷٥- وهـو يحب الشـاكرين مطلقَا   وكـل مَـنْ بِشُـْرِهِتَحقَّقَا

PageV03P234

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0235.png)

~~٧٦- والسَّـالكُ التقـي حينَ يفْتَرُ   يعيـدُهُ لعزْمـهِ التـذَكُرُ
~~۷٧- يَـذْكُرُ جِـدَّهُ بِبَدءِ السيرِ   وكيـف كـان راغبـاً في الخـيرِ
~~۷۸- وكيف أضحى القلب ذا فتورِ   مقصراً ولـيس ذا قصُـورِ
~~۷۹- وذاك إدبـارُ بـه جـاء الَخـبَر   عـن مُلهَـم الأنـام للحـق عُمَـر
~~٨٠ - فالقلب من شرّ النفوس يدبر   ونحـن مـن شرورهـا لا نحذَرُ
~~۸۱ - وكـاذب الإقبـال قـد ينقلبُ   لشرحـالٍ تاركـاً مـا يجِـبُ
~~۸۲- متبعـاً أهـواءه الذميمة   وتاركـا للسنة العظيمـة
~~٨٣- والصادق التقي يرقب الفَرَجْ   وهو مـن الفتـور جـداً في حَرَجْ
~~٨٤ - مُفْتَقِراً ومستكيناً خائفا   يطلب فضـل ربه مُضَـاعَفَا
~~۸۵- يلقي بنفسه طريحـاً خاضعا   ببابه لحاله مراجِعَـا
~~۸٦ - فـإن أمـده فتلك مِنَّـة   وتلك بـاب فـوزه بالجنـة
~~٨۷- والمصطفى الهادي عظيم المرَّة   قـال لكـل العـاملين شرة
~~۸٨- تجـر للهـلاك ذا الإدبـار   والمتقـي تحـدوه نحـو البـاري
~~۸۹- وانما يصیبهم ربي بها   لحكمـةٍ فـاعلم وكـن منتبهَـا
~~٩٠- ومـن يردْ ذو الجـودِ أن يرفعَهُ   يجره دومـأً لمـا ينفعـهُ
~~۹۱- ومـن أراد الله أن يضـلّه   يوقِعُـهُ في الفِـيْنَ المُضِـلَّة
~~٩۲- ولا يكـون وقتُه مسـاعدا   ولم يجـد مَؤْيِّـداً مُسَـانِدَا

PageV03P235

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0236.png)

~~٩٣- وإن يكُ الصَّـفاء قـد تَـأَتَى   والشكر عنـه لم يكـن مُنْبَتَـا
~~٩٤- يمتلئ الوقت بِوَجْدٍ صادقِ   ويمنح الأنس بنـور بارق
~~٩٥- فيطمـئنُ القلـب في سكينة   وتـنجلي الغياهـب المُشِينَة
~~٩٦- ينـالُ فضـلاً ليس يستَحِقه   لكـن ربـه بـه يُحِقَّـه
~~٩٧- عندئـذٍ يزيـد في المحبـة   وفعـل كـل طاعـة وقربة
~~٩٨- كـما يزيـد الشـوقُ للَّقَـاءِ   إلى عظـيم الفَضْـلِ والعَطَـاءِ
~~٩٩- وَجْـدُ رجـاءِ لا يشوبه كَدَرْ   وَقَـلَّ مَـنْ يَعْرِفُهُ مِـنَ البَشرْ
~~۱٠٠- له صـفاء ناصع وفـائقُ   مَـنَّ بـه الـبر الكـريم الرازق
~~١٠١ - فالفَضل منه وهوذو الإحسان   والشكُرُ واجـب عـلى الإنسـان
~~١٠۲- ووجد خوفِ السالك الصدوق   ينجيـه مـن غوائـل المُرُوقِ
~~١٠٣- فـذاك بالرجـا وذا بالخشيةِ   والكـل موصـل إلى المحبـةٍ
~~١٠٤ - فإن تكن قد قويت واشتعلتْ   نيرانهـا في القلب حقـاً أثْمَرَتْ
~~١٠٥- فالحب والخوف مع الرجاءِ   تحفـظ أهلهـا مـن الـبَلاءِ
~~۱۰٦- وتبعث العبـد عـلى العـمارة   لوقتـه بـالخير في غـزارة
~~١٠٧- وهي أساس السير بل قطب الرّحی   لكـل عابـدٍ إلى الحـق نَحَـا

PageV03P236

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0237.png)

~~١- إن الصـفا هـو البراءةُ التـي   تسلم القلب مـن الكـدورة
~~٢ - أَسَاسُهُ عِلْـمُ النبيّ المصـطفَى   لا علمَ مـنْ لغير نهجه اقتفى
~~۳- فعلمنـا مُقيـد بالسنة   بعـد كتـاب ربنـا ذي المنَّـةِ
~~٤ - ولـيس أصـفى منـه للبريـةِ   وهـو سبيل العـزة القويـة
~~٥ - فاجعل رسولَ الله سيد البشَر   ميـزانَ مـا تفعلُهُ وَمَـا تَذَر
~~٦- فأنت لله العظيم تعبد   وباتبـاع المصـطفى مُقيَـدُ
~~۷٧- وكـل علـم مَـالَـهُ دليلُ   فليس عنـدنا لـه قبـول
~~٨- بـل لم يكـن علماً عـلى الإطـلاقِ   وربـما يجـر للإِخفـاقِ
~~٩- فكـن مع الله عظـيم المـنَّ   لكي تنـال علمـه اللـدني
~~۱٠- ودعك مـن باطل مُدَّعِیهِ   مـن كـل مـا ليس الـدليل فيهِ
~~۱۱- فذاك من لدنه لا من ربه   وهودليـل بعده لا قربهِ
~~۱٢- وما لنا غير طريق المصطفى   تُوصِـلُنا لِرَبّنـا عَـلى صَـفَا
~~۱۳- وما سِوَاها مسلكُ مسدود   تضـيعُ في أثنائـه الجهـودُ
~~١٤- وإن أتبـاعَ النبـي في القِمَـمْ   يحدوهم العـزم القـوي والهمم
~~۱٥ - وذو انحرافِ عَنْ طَرِيقِ المصطفى   عـلى شَـفَانَـارِ الجَحِـيم أَشْرَفَا
~~١٦- وَمِنْ صَفاء العلـم تعلو الهِمَمُ   وهـو الـذي بـه العبـاد تكرم
~~١٧ - وإن أعـلى هِمَـمِ العبـادِ   مـا اتصـلت بربنـا الجـوَادِ

PageV03P237

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0238.png)

~~۱٨- وإنْ تُرِدْ مَرَاتبـاً للهِمَـم   فانظر ربيعة بن كعب الأسلمي
~~۱۹- قـال لـه نبينـا الكريمُ   صـلّى عليـهِ ربنـا العظـيمُ:
~~٢٠- (سَلْني) فَقَالَ في كـمال البِشِْ   وكان من أسمى الورى في الفِكر
~~۲۱- إني أريـد أن أنـال رفقتـك   في جنـةٍ بهـا تنـال رفعتَك
~~٢٢- والأنبيـا جمـيعهم في القِمَـم   وفي ذرى أعـلى أعـالي الهِمَـم
~~۲٣- وبعـده يأتي صـفاء الحـالِ   مـن علمنـا بـالله ذي الجـلالِ
~~۲٤ - فمن صفا مـن سائر الأكدارِ   يفوز بـالقرب لـدى الغفـارِ
~~۲٥- ويستلذ حيـنما ينـاجِي   إلهـه في الظُلَـمِ الـدواجي
~~٢٦- بـما حبـاهُ الله مـن إعطـاءِ   والعلـم بالصـفات والأسماءِ
~~۲۷- ونيـل حظـه مـن الآثـارِ   ممـا بهـا مـن سـاطع الأنـوارِ
~~۲۸- حتـى صـفا في حاله تَعَبُّدُه   والله أضحى بالسرور يسعده

PageV03P238

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0239.png)

~~۱- ولـذّةُ القلب تسمى الفرحـا   فيصبحُ القلبُ بِهـا مُنْشَرِحا
~~۲- بفضـل ربي وعظـيم رحُمَتِه   نفرح وهي مـن جزيـل منَته
~~٣- ففضـلُه الإسـلامُ والإيـمانُ   والرحمـة العلـوم والقـرآن
~~٤ - وأنه قـد جـاء في القـرآنِ   عـلى معـانٍ وهمـا نَوْعـانِ
~~٥- أولهـا المطلـقُ فالمقيـدُ   وهـو عـلى نـوعين أيضـاً يُوجَدُ
~~٦ - فـالأول المـذموم إذ تقيَّـدا   بهـذه الـدنيا وجـر النَكـدًا
~~۷- ثـم مقيـدّ بفضـل الله   ورحمـةِ منـه بـلا مضَـاهِي
~~۸- والفـرحُ النـافع بـالرحمنٍِ   والمرسـل الهـادي وبـالإيمانِ
~~٩- والسـنة الغـراءِ والقـرآنِ   وكـل مـا يـدني مـن المنَّـانِ
~~۱۰ - وبعده استبشار کل مؤمنِ   بكـل مـا يرجـو إذا لَمْ يَكُـنِ
~~١۱- فانظر لوصف الشهداء بالفَرَح   بما حبـاهم ربهـم ومـا منح
~~١٢ - أيضاً وباستبشارهم باللاحِقِ   فهـذه مـن أوضح الحقَـائقِ
~~١٣- وَفَرْحَةُ القلـوبِ أعـلى النَّعَم   من أجل هذا وهبت للمسلم
~~١٤- وفرحُ الـدنيا إلى إبْـلاسِ   يجـر أهلـه إلى انتكـاسِ
~~۱٥- والـذوق والسروريُـذْهِبانِ   ثلاثـةً مـن أخطـرِ الأحـزانِ
~~١٦ - الحزن من خوف انقطاع مَنْ عَمِلْ   والحزن مـن ظلمةِ جاهـلِ جَهِل
~~١٧ - والحـزن مـن تـوحُشِ التفرُّقِ   فهـذه الأحـزان شَرُّ مُغْـرِقِ

PageV03P239

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0240.png)

~~۱٨- فيـذهب الأول بالتـذوُّقِ   لطَعْم إيمانٍ مـن العبـد التقـي
~~۱۹- فلا يُعَـاقُ بعـد ذاك الـذوق   بـما حُبِيْ مـن لـذةٍ وشـوقِ
~~٢٠ - ثم سرور الذوق يمحو الجهلا   ويصـلح الحـال يحـث للعـلا
~~٢١- فليس كالعلم به الجهل اضمَحَلّ   وليس مثل العلم للجهل قتل
~~۲۲- يبعث فيها الأنس ينشر الهـدى   ويبعـث الحيـاة فيمن اقتَـدَى
~~۲۳ - وحـزن وحشـةِ التفـرق التي   تقـود قلـب المرء للتشَـتتِ
~~٢٤ - يزيلهـا الإقبـال بامتِثَـالِ   عـلى عظيم الجـود ذي الجـلالِ
~~٢٥- ثـم سرورُ أنسـه والمعرفَـة   وكون صدقه غدا أسمى صفة
~~٢٦- ثـم فـرارُه إلى بارئـهِ   وبـذل وسعه لمـايرضيهِ
~~۲۷- مع الرضـا بـأمره ونهيهِ   وكـل مـا ينالـه في سَـعْيِهِ
~~۲٨- مع اصطباره عـلى الـلأواءِ   وشـدة الـبلاءِ والضراء
~~۲۹- بفاقـةٍ عظيمـة لا تَشْـبَعُ   وهمـةٍ بالـدون ليسـت تَقنعُ
~~۳٣٠- ولم يكـن لحزْنِهِ أيُّ سَـبَب   غـير فراقـه لِّالَـهِ أحَـب
~~٣١- ثـم سرور السـمع والإجابة   بالقلب والأعضـاء في إصَـابَة
~~٣۲- ونقصهُ يـودي إلى التـوحُشِ   وباكتمالـه النفـوسُ تَمْتَثوِيْ
~~۲٣- ثم شهود القلب باستتباب   مـن دون غفلـة ولا غيـابِ
~~۳٤- وهكذا تتم مِـنْ رَبي المِـنَحْ   والعبـدُ يغـدو في سرورٍ وفرخ
# 292» 2» 2)a)

PageV03P240

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0241.png)

~~١ - الأتقيـاءُ الأخفيـاءُ في البشـرْ   وُجُودُهم في الناس جداً قد نَدَرْ
~~٢ - يحـبهم ربي لمـا هـم فيهِ   مـن التقـى وفعـل مـا يرضيهِ
~~٣- وحرصهم دوماً عـلى الصفاءِ   وبعدهم عـن باعث الريـاء
~~٤ - فهم أولو الزهـد، أولو التخفي   وأفطن الورى وأهـل الظرف
~~٥- والأشعثُ الأغبر ذو الطمرين   بـلاتَجَمَّـلِ ولا تـزيين
~~٦ - يـبر ذو الجـلالِ ربي قَسَـمَه   لأنـه أحبـه فأكرمه
~~٧- وأنـه يعلـم مـا في الأنفسِ   وفضُـله عـن أهلـه لم يحـبسِ
~~۸ - والناس حد علمهم في الظاهرِ   وربنـا العلـيم بالسرائر
~~٩ - همتهم مـن دون ربي لا تقـفْ   علوهـا يفوق كل ما وصفْ
~~١٠ - ومالهـا مـن عِوض سواه   ولا بَـدِيلِ غـيره ترضـاه
~~۱۱ - ولم تبع حظوظهـا مـن قربِهِ   وفوزهـا بأنسـه وحبه
~~١٢- بقـاطع مـن الحظـوظ فـاني   من كـل ما يلهي عـن الرحمنِ
~~۱۳ - مقصدهم خال من الشوائبِ   مجـرد لله ذي المواهـبِ
~~١٤ - وليس في سلوكهم من عائقِ   بل حبهم والشوق خير سائق
~~١٥ - فهم على درب النبي الأعظـم   مَـنْ دَلَّنـا عـلى السـبيل الأقـومِ
~~۱٦- منهج کل عـازم ورائدِ   أي واحـدٍ لواحـد في واحـدِ
~~١٧- قد خَلَّصَ النفس من العوائقِ   ملتمسـاً لأنصَـع الحقـائِقِ

PageV03P241

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0242.png)

~~۱۸- وغـاب عن عاداته جمیعاً   حتـى غـدا موفقـاً مطيعا
~~۱٩- ونفسه قـد أذعنت إذعاناً   جانبـت العقـوق والعصـيانا
~~۲۰- وقـد أزال آفـة الركـونِ   إلا إلى مـولاه رب الكـونِ
~~۲۱- لا يركَنَنْ لنفسه ولا العملْ   ولا إلى حـالٍ حميـدٍ قـد حَصَـلْ
~~۲۲- فالنفس قـد توقع في المهالِكِ   والعلم قد ينسـاه غير تـارك
~~٢٣- فـذا الركـون أخطـر الأخطـار   لصرفه العبـد عـن الغفـار
~~٢٤- من أجـل هـذا لا تَكُنْ براكِنِ   إلا إلى مـولاكَ رَبَّ المـننِ
~~۲٥- فأنت بـالله ولست بالسبب   فلاتكـن ممـن عـن الله انحجب
~~٢٦- فإنـه مـن أشـنع العـذابِ   كـما أتي في محكـم الكتـابِ
~~۲۷- وإنـما الفـائز بالسرورِ   مـن فـاز بـالنظرة للغفـورِ
~~۲۸- لصـدقه في قصـده وسيرهِ   وتركـه لكـل شيءٍ غَـيْرِهِ
~~۲٩ - وحُصِرَتْ حواجبُ العبـادِ   عـن ربهـم في عَشْرِ بالتعدَاد
~~٣٠- أولهـا: التعطيـل للأسـماءِ   ولصـفات الله ذي الآلاءِ
~~٣١- وبعدها: الشرك بذي الجـلالِ   وبِـدَعُ الأقـوال والأفعـالِ
~~۳۲- ثـم کبـائر بـلا متاب   كـالكبر والريـاء والإعجـابِ
~~۳٣- وانقسمت لبـاطنِ وظـاهرِ   فبـاطن أعظـم في المخـاطرِ
~~٣٤- وبعـدها صـغائر الـذنوب   تحجب عـن مقلـب القلـوب
~~٣٥- والفضـلات والتوسعات   فـيما أبـيحَ هُـنَّ حاجبـاتُ
~~۳۶- وبعدها حجاب ذي اجتهادِ   مخـالف في القصـد والمـرادِ
~~۳٧- تحـول بـين القلب والـرحمنِ   كـما أتـى في محكـم القـرآنِ

PageV03P242

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0243.png)

~~۳۸- وأصـلها أربعـةٌ عنـاصرُ   النفس والشيطان بئس الفاجر
~~۳٣٩- فعنصر الـدنيا وعنصر الهوى   وكم مـن النـاس بهذين هوى
~~٤٠ - تُفْسِدُ قولهَم، وتُفْسِدُ العمل   وتفسد الطريـق، تدعو للخطل
~~٤١ - وتَحرم القلب مـن الوصولِ   لـذي الجـلال غايـة المـأمولِ
~~٤٢- وكـل مـن سلمه مـولاهُ   فإنـه بفضـلِهِ يَرْعَـاهُ
~~٤٣- يزيـد في يقينـه وعقلِهِ   وجهـده وبذلـه وفعلهِ
~~٤٤- وفي صفات الخـير والأخـلاق   وكره أهـل الكفـر والشـقاق
~~٤٥- كـما يمـده بجنـد مـانع   مـن كـل عـائق وكـل قـاطع
~~٤٦ - ويصبح الزهدُ سلاحاً ذا أثر   يحميـه شر المغـريات والبطـر
~~٤٧ - وبـاليقين يطـرد الشـيطانا   فـلا تراه تائهـا حيرانـا
~~٤٨ - ثـم الهـوى يطـرد بـالتحكيم   لأمـر مـولاه مع التسـليم
~~٤٩- مجاهـداً للـنفس بـاحتراس   كي لا يكـون مـن أولي الإفلاس
~~٥٠ - وبعض أهـل السّرَّ أمره بَهَر   لكنـه تواضعاً له سَتَر
~~٥١ - يُرسِبُهُ في الترب سامي الأدب   وهـو رفيع القـدر عـالي الرتـب
~~٥٢- يعامـل العبـاد بالظرافَـة   وربه يمنحـه ألطافه
~~٥٣- يـأنس بـالخلق ويأنسـون به   وينهلـون مـن معـالي أدبـه
~~٥٤- أحبَّـه النـاسُ لجـم لُطْفِهِ   واستأنسوابِـهِ حُسْـنِ ظُرفهِ
~~٥٥- ونفـرة النـاس مـن الكثيـفِ   لا مـن حميـد الطبع والظريـف
~~٥٦ - والنـاس طراً للثقيـل تبغض   لأنـه يرهقهم ويُجهضُ
~~٥٧ - ويَثقُـل المـرءُ لآفَـةِ بِـهِ   ولم يَكُنْ عـن فعلهـا بِمُنْتَهِ

PageV03P243

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0244.png)

# (٢٤٣)
~~٥٨- وكـل مَـن خَفَّ ينال الُحبَا   وهـو مـن الله أشـد قربا
~~٥٩ - فكـن مع الله بقلبِ صـافي   تَفُـزْ بِفَصْـلِ الله ذي الألطـافِ
~~٦٠ - فليسـت السَـلْوَةُ بالأشباح   وإنـما بالقلـب والأرواح
~~٦١- آثارهـا تثبت في النـواحي   كأنهـا نسـائم الصـباح
~~٦٢ - فعش مع الناس بقلبِ ذي تقى   ولا تكـنْ مُشـتَّتأ مُفَرَّقَا

PageV03P244

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0245.png)

~~١- الغُرَبـاءُ روح هـذا الـدينِ   وسر نصر الله والتمكين
~~٢ - هـم غـرَّةُ الصـلاح في العبـادِ   لنهـيهم عـن سـائر الفسـاد
~~٣- بَشَّرَهُمْ نَبِيُنَـا بطـوبی   وقـال في تعـريفهم مجيبَـا
~~٤- هـم الذين يصلحون حالهم   وغَـيْرَهم إذ الفسـاد طـالهم
~~٥- وهم يزيدون بِرَغْمِ الُحسَّدِ   كـما رواه أحمـد في المسـندٍِ
~~٦ - أي في التقـى والخـير والإيـمانِ   وغيرُهم في الـنقص والخسرانِ
~~٧- وقـال إنهـم هـم النـزاعُ   وذا جَـلِيُّ مـا بِـهِ نِزَاعُ
~~٨- أي أنهـم مـن أنـدر القَلائـلِ   وهـم خيـار سـائر القبائـل
~~٩- وهـم قليل صالحون في البشر   كـما أتـى عـن النبـي في الخـبَر
~~١٠ - وإنَّ مَـنْ يَعْصُـونَهُمْ لأَفْثَرُ   مِـنَ المطيعـين لهــم وأوفَـرُ
~~۱۱- وهم أحب سـائر الأشياءِ   لله ذي المنـةِ والآلاءِ
~~١٢ - يُخيُونَ سُنَةَ النَبي المُصْطفى   محمـد بِكُـلَّ حـبِّ وَوَفَـا
~~۱٣- ثـم يعلمونهـا للنـاس   بهمـة فاقـت عـلى القيـاسِ
~~١٤ - الأخفيـاءُ الأتقيـاء الأبريـا   أَكْرِمْ بِهِـمْ مِـنْ أوليـاءِ أصـفيا
~~١٥ - لا يُعْرَفُونَ عند أكثر الوری   ومن يغب فقلّ من به درَی
~~١٦ - قوم قلوبهم مصابیحُ الهدی   وهم ألو العزم وأرباب الندى
~~١٧- من فتنِ عمياء حقأ خرجوا   وفي سبيل المصطفى قد دَرَجُوا

PageV03P245

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0246.png)

~~۱۸- يجتمعـون حـول روح الله   عيسى بحب ماله مضاهي
~~۱۹- وإنهم بـدينهم فُرَار   إذا طغـى الـدجال والكفـار
~~۲٠ - فالمسـلمون كلهـم في غربـةِ   بـين جميـع سـائر البريـةِ
~~٢۱- والمؤمن الحـق غريب بين مـن   قد أسلموا في كل أرض وزمن
~~٢٢ - والعـالم التقـي بـين الفجـرة   ممـن لهـم علـم عـديم الثمـرة
~~۲٣- وحامـل السـنة في أهـل البدَعْ   وهكـذا الغربَـةُ في النَّـاسِ تَقَعْ
~~٢٤ - ومن دعا الناس بصبرِ واحتمل   أذى المخـالفين شـأنُه اكتمـلْ
~~۲۵- وسیعود دیننا غریباً   كبدئه فاصبرُ تَفُـزْ بِطُـوبَی
~~٢٦- وربـما الغربـة في مكـانِ   دون سـواه أو عـلى أحيـانِ
~~۲۷_ وربـما تكـون في أقـوام   وغـيرُهُمْ في غايـة السَـلامِ
~~۲۸ - فأهلهـا أوَوْا إلى بَـارِيهِمْ   ولم يـؤَثرَّ أي كيـد فـيهمْ
~~۲۹_ مـا انتسـبوا إلا إلى محمـدِ   وهـم دعـاة نهجه المسـدّدِ
~~٣٠- وفارقوا الناس مع احتياجهمْ   لهم لمـا رأوا مِنَ اغوِجَـاجِهِمْ
~~٣١- ينتظـرون ربهـم في المحشَرِ   والفـوز منـه بِـالنَّعِيم الأكبرِ
~~٣٢- ولـيس في غربتهم مِنْ وحشةِ   لأنسـهم بـالله رب العـزة
~~٣٣- وهـم ملـوكُ في أعـالي الجنـةِ   كما أتـى بيانـه في السُّـنَّةِ
~~٣٤- دنیاهم لم يجزعـوا مـن ذُلَا   وما لهُــمْ تنـافسٌّ في نيلها
~~٣٥ - وما على الأناس منهم مِنْ تَعَبْ   لكن على نفوسهم جرى النصبْ
~~٣٦- أكـرم بأهـل الله أهـل الصـبر   والفـوز والنجـاة يـومَ الحشرِ
~~٣٧- فهـم ألو التوحيـد والتجريدِ   وسـنة الهـادي عظـيمِ الجـودِ

PageV03P246

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0247.png)

~~(٢٤6
~~۳٨- فصبرهم يُشْبِهُ قبضَ الجمرِ   لكثـرةِ السـوءِ وهـول الأمـر
~~۳٩- يلومهم جُلُّ الورى ويعذُلُ   لأنهـم لنكـرهم قـد أهملـوا
~~٤٠ - وَجَانَبُوا أهواءَهم والبـدعا   والتزموا الـدين عـلى مـا شَرَعـا
~~٤١- وَ النفس من شهوتِها قد حرسوا   أكـرم بمـن لدينـه يحترس
~~٤٢ - فهم أولوا الثباتِ أهلُ الحبّ   وأجرهم قد فاق أجر الصحب
~~٤٣- واحـدهم في الأجـر والثـواب   كمثـل خمسين مـن الأصحاب
~~٤٤- عـن النبيٍّ قـد رواه ثَعْلبَة   وَسرُّ ذا الأجـر الأمـور المتعبـة
~~٤٥- وأكثـر النـاس لهـم يُعَانِـدُ   ومـا أقـل مـن لهـم يسـاعدُ
~~٤٦ - لكونهم عن نكرهم قد زجرُوا   وكل معروف به قـد أمروا
~~٤٧ - والنـاس طـراً كلهـم في غربةٍِ   في هـذه الـدنيا بـدونِ مِرْيَـةٍ
~~٤٨- لأنهـا لَيْسَـتْ لهُـمْ بِـدَارِ   ومـا عـلى ذي الـدار مـن قَرَارِ
~~٤٩- وقـد أتى الأمر عـن الحبيـبِ   في قولـه كـن مـثلما الغريـبِ
~~٥٠ - أو فَلْتَكُنْ كَعَـابِرِ السَّبيلِ   ذي الجـد في منـازل الرحيـلِ
~~٥۱- وصـاحب الجـد أو التقصـير   يحـط في أسـافل القبـورِ
~~٥۲- وبعـده يسير نحـو الـدارِ   في جنـة الخلـود أو في النَّـارِ

PageV03P247

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0248.png)

~~١- المُتَمَكّنُـونَ في الهداية   همْ خير مـن تبـوأ الولايـة
~~٢- لكـون مـن مُكَّـن لا يبـالي   بشـاغلٍ أو غافـلٍ بَطَّـالِ
~~٣- لم يسـتفزه أولـو الظَّنـونِ   ولم يكـن بـالجزع المفتـون
~~٤ - موفـق لأحسـن التَصَرُّفِ   وكـل أمـر طيب مشرف
~~٥- وهـو تَفَعُّـلٌ مـن المكـانِ   كـما أَفَـادَهُ أولـوا اللسـانِ
~~٦- وهـو المكانـة التـي في المصحفِ   فاعلمْ بمعناها العظيم واغرف
~~۷- وقـد أتت في هـود والأنعـام   فمـن وعاهـا فهـوذو إكرام
~~۸- بقلبـه تبـوأ المقامـا   وزاد في إلهـه اعتصـاما
~~۹- وکل ذي تمکـن قـد فاقا   مـن رام باطمئنانِـهِ سِـبَاقا
~~١٠ - وربما اطمئنانُـهُ يَـؤْولُ   إلى تمكـنٍ وقـدْ يَــزُولُ
~~۱۱- لكنَّ مَـنْ مُكَّنَ حَـازَ الغايَة   ونـال في اسـتقراره النهايَـة
~~۱۲- معتصماً بـالله ذي الجـلالِ   في كـل أمـرٍ وبكـل حَـالِ
~~۱۳- والاعتصـام بالإله الواحـد   نوعـان ما فوقهما مـن زَائـدِ
~~١٤- أولهـا تسليم هـذا المُعْتَصِـمْ   لله في توكـلٍ لايَنْفَصِـمْ
~~١٥- ثم اعتصـامُ المرءِ بـالقرآنِ   بـلا تخـاذلٍ ولا نُكْصَـانِ
~~١٦- بِزَلَـةِ الأذواق والأهـواءِ   والوجـدٍ والكشـفٍ أو الآراءِ

PageV03P248

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0249.png)

~~١٧- والمـرءُ لا يكـون ذا تمكَّـنِ   إلا بِصِـدْقِهِ مَـعَ المَهَـيْمِنِ
~~۱٨- في صحة القصـد وفي التَّعْيينِ   وفي اتّبـاع أمـره المبـينِ
~~۱۹_ یعبده بوفق ما به أمَرْ   متبعـا للمصطفى خير البشر
~~۲٠- مقصـده الله تعـالی وَحـدَه   وقصـده تنفيذ مـا أراده
~~۲١- في نفسِـهِ وسـائرِ الخلائـقِ   ليسـلموا مـن خطـر البوائـق
~~٢٢- وخـير خلـق الله في التمكُّن   نبينـا المختـار خـير مُـوقِنِ
~~۲۳- والصحب کانوا خیر من به اقتدی   فأكرموا بكـل خـيرٍ وهُـدَى
~~٢٤- والتـابعون ثـم مـن لهـم تَبِعْ   وبعـدهم متبع ومبتدغ
~~٢٥- فبعضهم خـالف في المقصـودِ   وهـم ذوو الإشراك والجحـودِ
~~٢٦- وبعضـهم خـالف في الطريـقِ   فعـاش في شـدائدٍ وضِـيق
~~٢٧- وبانقطـاع القلـب للجبـارِ   عـن سـائر الأغيـار والأكـدارِ
~~۲٨ - يفـوق مَـنْ مُكَّـنَ في الأعمالِ   لكونـه يُمكَنـاً في الَحـالِ
~~٢٩- وما له عـن ربه مِنْ قَاطِع   فَفَازَ بـالنور العظـيم السَّـاطِع
~~٣٠- نور اليقين فاض فوق قلبهِ   فَـزَادَ في إِيمانِـهِ وَحُبَّهِ
~~٣١- يُحِسُ بـالقرب مـن الرحمنِ   ونفسـه تزيـد في الإذْعَـانِ
~~۳٢- ويرفع الحجـاب بـين قلبِهِ   وبين روحـه وبين ربَّهِ
~~۳٣- وكـل إنسـانِ بنفسه حُجـبْ   مـا لم يكـن هـذّبها كـمٰا يَجِـبْ
~~٣٤- ويعبـد المـولى بإحسـان كَمَـنْ   يراه شـاكراً لـه كـل المـنَنْ
~~۳٥- وكـل مـن عظَّـم ذا الآلاءِ   في سـائر الصـفاتِ والأسماءِ
~~٣٦- يكـون في الشـهود في الكـمالِ   معظـماً لله ذي الجـلالِ
~~۳٧- بموجب العلم الذي به اهتدى   والاقتـداء بـالنبيٍّ أحَمَـدَا

PageV03P249

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0250.png)

# (٢٤٩)
~~٣٨- فإنه قد قال: لا نخصِيْ الثنا   عليك يـا إلَهَنَـا وَرَبَنَـا
~~۳۹- لكـن کما أثنيتَ أنت نُثْنِي   فنحن أهـل الجهل أهل الوَهن
~~٤٠ - نعلـم مـا علَّمنـا إِفضـالا   ولم نُحِـطْ علـماً بـه تعـالى
~~٤١- ونعلـم الأسماءَ والصـفاتِ   مـن الأحاديـثٍ أو الآيـاتِ
~~٤٢- فإنهـا بـاب العلـوم الجمّـة   والفـوز والنجـاة يـوم الغمـة
~~٤٣ - وذي طريـق وارثـي النبـوة   ومـن عـلى منهـاجهم بقـوة
~~٤٤ - وكل مـن بالعلم ذا يتصفُ   فهـو بربـه العظـيم أعرف
~~٤٥- وصـادق التوب يفوز دائما   ويجـد الله غفـوراً راحِمَـا
~~٤٦- وهكـذا الصـادقُ في التوكُّـلِ   يلقـاه كافيـاً وخـير مَوئـلِ
~~٤٧ - ومـن دعاه صادقاً رَغُوبَا   يجده معطيـاً لـه مجِيبا
~~٤۸ - ومـن أحـبَّ ربه بِصِـدقِ   يجــدْ ودوداً منعماً ذا رِفْقِ
~~٤٩- والمستغيث رَبَّـهُ ممـا دَهَـمْ   يكشفُ كربه ويكفيـه النقم
~~٥٠ - وذو اضطرارِ ضَـيَّقاً يُنَاجِي   يـؤول أمـره إلى انفـراج
~~٥١ - واللاجيُ الصدوق حال الخوفِ   يجـد أمـان الراحم الـرؤوفِ
~~٥٢- والله عنـد ظـن عبـدهِ بهِ   سبحانه مـن عـالم بقلبِهِ
~~٥٣- وصـاحب الحـب مـع الإرادة   يمنحـه إلهـه السعادة
~~٥٤ - وطاعة النفس مع الإذعـان له   لأنه قـد عـاش بالله وله
~~٥٥ - فـالمرءُ ذا يشهدُ بالتوحيـدِ   كمال ربـه عظـيم الجـودِ
~~٥٦ - قـد جَمَعَ الهمَّ عـلى بَارِیهِ   وسار مسرعاً لمـا يُرْضِـيهِ
~~٥٧ - واستفرغَ الطاقـة في النَّوافِـلِ   بَعْـدَ أداءِ فَرْضـه بالكَامِـلِ

PageV03P250

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0251.png)

~~۱ - إن معاينـات كـل مسـلم   بقلبـه لا بـالعيون فـاعلم
~~۲- یحظی بها کل تقي عابد   حتـى يـرى البـارئ في الشـواهد
~~٣- وإنهـا تقـوى بتقـوى الله   ولم تكـن لغافـل ولاه
~~٤- فقلب مـن آمـن بـالله يری   بنور ربه کما قد أخبرا
~~٥- في كـل دال عـلى الجبَّـارِ   بقـدر مـا في القلب مـن أنـوارِ
~~٦- مُسْتَبْصراً شَاهِدَ نورِ العظمة   وهـذه للعبـد أعـلى مكرمـة
~~٧- أمـا تجـلي ربنـا تعـالی   فالجبـل انْـدَكَ لَـهُ وانهَـالا
~~۸- وخر موسی صَـعِقاً لذاکا   فَعَظَّـم الله يَـزدْ علاكا
~~۹- وشـاهد الجنـة والنـيران   تَشْـهَدهُ سـواطِعُ الجَنَـانِ
~~١٠ - فَابْنُ حرام شَمَّ ريح الجَنَّةِ   بفضـل مـولاه عظـيم المنَّـةِ
~~۱۱- مـن أُحُدِ وخلفها قد شمها   فـأنعم الله لـه أتمهـا
~~١٢- لمـا أتـى بروحـه يحملهـا   في كفـه يرجـوه أن يقبلهـا
~~١٣- والمصطفى قـال لنـا مُرَغَّبـا   وداعيـاً أمَّتـهُ محببّـا
~~١٤ - إذا مـررتم بريـاض الجنـةِ   فيها ارتعـوا فافهم معـاني السنة
~~١٥ - وقوله حَثَّـأَ عـلى الجهـادِ   عـن الجنـان يـا أولي الرشـاد
~~١٦- بأنهـا تَحْتَ ظـلالِ الساطعة   مـن السيوف المرهفـات القاطعة
~~١٧ - وأفضـل الشـواهد المـؤثرة   أن يستقيم القلب نحـو الآخرة

PageV03P251

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0252.png)

~~۱۸- محتقـراً دار الفنـا معتبرا   إلى مـراضي ربـه مشَـمَّرا
~~۱٩ - ينظر في عشـاق هـذي الـدارِ   ومـا أصـابهم مـن الأخطـار
~~۲٠ - وسرعـة انقضـائها وفتكهـا   بكل مغرور ومفتـون بها
~~۲۱- ومـا تذيقهم مـن العـذاب   ومـنْ أمـرّ أقبح الشراب
~~۲۲- سُـمُومُهَا تدار بعد خَْرِهَا   وأهـل حُبهـا ابتلـوا بهجرهـا
~~٢٣ - فـإن أقـام العبد هـذا الشـاهدا   یعش تقیا مستقیما زاهدا
~~٢٤- وبعـد ذا يشهد دار الآخِـرَة   ومـا بهـا مـن الأمـور الفـاخرة
~~۲٥- مثل دوامهـا بلا انقضاءِ   بكامـل المتعـة والآلاءِ
~~٢٦ - وأنهـا دار القـرار الخالـدِ   ومنتهـى السـير لكـل عابـد
~~۲۷_ ولم يجـد حينئذٍ من نِسْبَةِ   مـا بَيْنَهـا وَبَــيْنَ دار الحِسَّـةِ
~~۲۸- ثـم يقـوم شـاهدٌ للنـارِ   مـن قلبـه وحالـة الكفـار
~~۲٩ - وسـوقهم إلى شـديدِ حَرِّهـا   وكـبهم إلى سحيق قعرِهـا
~~٣٠- ومـا أصـابهم بـأرض المحشَرِ   وقـبح حـالهم وسـوء المنظرِ
~~٣١ - تُشْوی بِهِ وجوههم وتنضُجُ   ومـا لهـم عـن الجحـيم مخـرجُ
~~۳۲- يصطرخون من شدید الألمِ   ومـن دوام الُكْثٍِ في جهـنَّمِ
~~۳٣- ولا يموتـون وينتهـي الأَلمْ   ولم يُخَفَف حرهـا الـذي انضرم
~~٣٤- فإن أقـام القلب هـذا الشـاهدا   فلا يكـون عاصياً وجاحـداً
~~٣٥- بـل إنَّه يخلع ثـوب المعصية   ويقتفي كـل سبيل منجيـة
~~٣٦ - ويخضب الخدَّ مـن الأجفـانِ   بدمع تـوبِ صادقِ هتَّـانِ
~~۳۷-_ ومـا یصیبه فذو تهوینِ   مـا لم تكـن مصـيبة في الـدينِ

PageV03P252

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0253.png)

~~٣٨ - وقـوة الشـاهد في ذا الشـانِ   مبعـدة عـن سـائر العصـيانِ
~~۳۹- حتی يُذیب الفضلات كُلَّها   مـن قلبه مُخْتَرِسـاً منتبها
~~٤٠- ثـم يقـوم شـاهد الجِنَـانِ   وَمَـا لأهلهـا لـدى المنَّـانِ
~~٤١ - مِنْ كُلِّ مَا لا عَيْن مبصرِ رأتْ   ولم تكـن أذنُ سـميع سمعتْ
~~٤٢ - أيضاً ولم يكـن على قلب بشر   شيءٍ مـن الإنعـام ذاك قـد خَطَر
~~٤٣- سـوى الذي يُعْلَـمُ بالـدلائلِ   مـن طَيَّبِ الشرابِ والمآكـل
~~٤٤- واللـبس والبهجـة والسرور   وأكمـل اللـذات والحبـورِ
~~٤٥- حينئذ بقلبه يقـوم   شاهد دار کلهـا نعـیمُ
~~٤٦ - وهـو نعـيم دائم لا يَنْفَـدُ   ومثـل ذا النعيم ليس يوجد
~~٤٧ - تُرْبَتُهـا المسك كـما قـد وردا   عـن الرسول في الحـديث مسنَدا
~~٤۸ - صـلى عليـه ربنـا وسـلما   والآل والأصحاب ما غيث همـا
~~٤٩- بناؤها من فضةِ وَمِنْ ذَهَب   وقصب من لؤلؤ فيه العجب
~~٥٠- حصباؤها درُّ إليـهِ يُرْغَـبُ   وريحهـا مـن ريح مسك أطيبُ
~~٥١- شرابها أحلى لهـم مـن العسل   ولم تصبهم عِلَـة ولا كسَـلْ
~~٥٢- وإنه أَبْرَدُ مـن كـافور   كـما أتـى في الخـبر المـأثور
~~٥٣- عـن النبـي المصـطفى الأمـين   صـلى عليـه الله كـل حـين
~~٥٤- أمـا نسـاؤها فما أدراك مـا   نسـاؤها يـا مـن يحب الأنعـما
~~٥٥- لـوبرزت واحـدة ستغلب   بنورهـا شمس السـما وتحجب
~~٥٦- لباسهم حريرهـا المشـوقُ   والسـندس الجميـل والإستبرق
~~٥٧- وخـدم كلؤلـؤ منثـورِ   ولحم مـا اشتهوهُ مِـنْ طُيُـورِ

PageV03P253

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0254.png)

~~٥٨ - أيضـاً لهـم فواكـهٔ لاتُقْطَعَ   بـل إنهـا دائمـةٌ لا تمنـعُ
~~٥٩- وفـرش وثـيرة مرفوعـة   والحـور زوجـاتٌ لهـم مطيعـة
~~٦٠- فَهُـنَّ مثـل لؤلـؤ مصـونِ   ومثـل بَـيْضِ طَيَّبِ مكنـونِ
~~٦١- وهـم عـلى أرائك الجنـانِ   وفي حُبُـورٍ مـالَـهُ مـداني
~~٦٢- وَمْنْ هُـدي إلى الجنـان يخلـدُ   وكلـما اشـتهاهُ فيهـا يجـدُ
~~٦٣ - وإن يك انضـم إلى ذا الشـاهدِ   مـا قبله مـن جملـة الشـواهدِ
~~٦٤- فحينهـا القلب يسير مسرعا   إلى إلـه العـرش دومـأ طائعـا
~~٦٥ - وفوق هذا شاهد يفوق ما   قـد مر مـن شواهد فليعلما
~~٦٦ - يَغِيْبُ فيه العبد عنهـا كلها   ولم ينلـه غافـلٌّ ومَـن لهـا
~~٦۷_ وهـو جـلال ربنـا تعـالی   فيشـهدُ الجــمالَ والكـمالاً
~~٦٨- والعـز والعلـو والسـلطانا   ثم خِطَابَـهُ کـما أَبانا
~~٦٩- لأنبيائـه وللملائكـة   مـن كل ما يزيـل كل حالكة
~~۷۰- بقلبـه يشـهده قيومـا   فرداً عزيـزا مالکـاً عظيما
~~۷۱- وآمـراً وناهيـاً ومرسـلا   وموحيـا أحكامـه ومُنـزلا
~~۷٢- وإنـه الـرحيم والغفـور   وإنـه الكبـير والشكور
~~٧٣- وإنـه الأعظـمُ والأعـزُ   وإنـه المـذلّ والمعـزّ
~~٧٤- وإنـه الأعلـم جـل ربنـا   وهـو الـذي مـن فضـله أمـدنا
~~۷٥- يعلـم بـالجهر وبالإخفـات   وبـاختلاف القـول واللغـات
~~٧٦- ولا يضيق الله مِـن إلحـاح مَـن   يـدعوه في إسراره أو العلـن
~~۷٧- والسر عنـد ربنـا علانيـة   والله لا تخفـى عليـه خافيـة

PageV03P254

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0255.png)

~~۷۸- وكـل غيب عنـده شهادة   وأنـه فعـال مـا أراده
~~۷٩- فمن إلى الشاهد هـذا قـد رقى   يكـون مـن أهـل اليقين والتقـى
~~۸۰- سلو که بین الوری یمیز   وغيره عـن ذا السـلوك يعجـز
~~۸۱ - وسائر الشواهد التي مضت   فيه جميعـا کلهـا قـد دخلت
~~٨٢- والناس في هذي الحظوظ تختلف   فالبعض في ضيق وبعض يغترف
~~٨٣- وأعظـم النـاس مقامـا فيهـا   مـن قـال لا أحصي الثنـا نبيهـا
~~٨٤ - لأن قـدر ربنـا المجيـد   فـوق الثنـا والحمـد والتمجيـد
~~۸٥ - وإنما كرسيُ هـذا الشـاهد   طهـارة القلـب مـن المفاسـد
~~۸٦- مثـلُ تعلـقِ بغـير الله   سبحانه جَـلَّ عـن المضـاهي
~~٨۷ - وكـل مملـوءٍِ مـن الخبائثِ   فمالـه إلى العـلا مـن باعِـثِ
~~۸۸- لكونه بالمخزيـات قـد مُـلي   وعـاش في الخـزي وفي التسـفل
~~۸۹ - وروح كـل عابـد رشـید   تحفهـا أشـعة التوحيـد
~~٩۰- تهفـو إلى بارئهـا كـي تعـتلي   تطلب فضـله بـلا تكاسـل
~~۹۱- وإنـما بالصـدق والإخـلاص   لكي يكـون طيب الخـلاصِ
~~۹۲- منـتقلا مـن منـزل لمنـزلِ   مـن العبوديـة لله العـلي
~~۹۳- وقلبـه بـالحق في استيقاظ   بـلا تخـاذلِ ولا إعـراض
~~٩٤- تُوقِظُـهُ شـواهد الصـفات   ومُحْكَـمُ البيـان في الآيـاتِ
~~٩٥- فـلا يـرى الأمـر لغـير الله   سبحانه مـن آمر ونَـاهِ
~~٩٦- مشتَشْعِراً تَصَـاعُدَ الأعمال   إلى رفيع العـرش ذي الجـلال
~~٩٧- أشـدٌّ حُبَّا صـادقَ المتـابِ   وراجيـا لأفضـل الثـواب

PageV03P255

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0256.png)

# (٢٥٥)
~~٩٨- محترسـاً مِـنْ سـائرِ المعـاصي   مراقبـاً لمالكِ النـواصي
~~۹۹- وشـاهد الرحمـة يحيـي فيـهِ   رحمـة ربه بما يوليهِ
~~١٠٠ - بل وعلى الوجود طراً كله   بمنـه يشهده وفضـله
~~۱٠١- وإنْ يَقُمْ بقلب ذي التبصُّرِ   شـواهد العـزة والتكـبر
~~۱٠۲- وجبروت ربنا ذي العظمة   فشـأنه في الأمـر ذا مـا أعظمـه
~~۱٠٣- وهكـذا بقيـة الصـفاتِ   فـافهم هـداك الله للثبـات
~~١٠٤ - ومـا ذکرنـاه فللتنبیهِ   عـلى سـواه للفتـى النَّبيـهِ
~~١٠٥ - والكشف والعيان والمشاهدة   لم تتجـاوز شـاهداً إن شـاهَدَه

PageV03P256

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0257.png)

~~١- الله سمّى الجهلَ موتـاً والهـدى   نـوراً به حيـاة عبدٍِ سعدا
~~٢- فـالعلم روح لقلـوب الأتقيـا   والجهـل مـوتٌ لقلـوب الأشقيا
~~٣- في الجسـم روح وبهـا حياتُـهُ   وإن تغـادره فذا مَمَاتُهُ
~~٤- لكنهـا ليست مرادةً هُنا   بل قصـدُه الحيـاة في قلوبنـا
~~٥- وربنـا قـد قـال (أحْيَيْنَـاهُ)   ولم يرد مفارقـاً دُنْيـاهُ
~~٦ - بـل قـد أراد الله كـل جَاهـل   وراتع في ظُلَـمِ الرذائـلِ
~~۷- أحيـاه بـالعلم وبـالإيمان   فصـار بين النـاس عـالي الشـان
~~۸- فـالوحي نـور الله في القلـوبِ   وروحهـا وكاشفُ الغيهـوب
~~۹- وفاقـد النـور حبـيسُ الظُّلَم   حياتـه شر مـن البهـائم
~~١٠- يعيش في الضَّنكِ الشديد المؤلم   ثـم مصـيره إلى جهـنَم
~~۱١- والله في محكم ذکره وَعَـدْ   من عمل الصالح من أهل الرشد
~~١٢- أنْ سوف يحييه حيـاة طيبة   فيـا لهـا مـن نعمـةٍ ومنقبـة
~~۱٣- أتاحهـا الله لهـم ومـا حصَرْ   تَعُمٌُ أنثَـى المـؤمنين والـذَّكَر
~~١٤- تفسيرها قناعةٌ مَعَ الرَّضَا   ولا يَنَـالُ الخـيرَ ذٰا مَـنْ أعْرَضَا
~~١٥ - وطيب الرزق وسائر النعم   وغير ذاك مـن عطايـا ذي الكرَمْ
~~١٦- وأصوب الأقوال فافهم واعلم   بأنهـا حيـاة قلـب المسـلم
~~١۷- وأنهـا السرور بـالإيمانِ   وبهجـة القلـب بـذا الإحسـان

PageV03P257

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0258.png)

~~۱۸- فهـي لهـم في هـذه الـدار كما   أخبرنـا إلهنـا وعلَّـمَا
~~۱٩ - وهي هـم في برزخ الأمواتِ   وفي أعـالي غـرف الجنـاتِ
~~۲٠- وإن تـرد طريقـةَ الفـوزِ بهـا   فاسمع لمـا أمـلي وكـن منتبهَـا
~~۲۱- أولهـا: استغفاره تعـالی   وتوبـة تفكـك الأغـلالا
~~٢٢- والحـب والـذكر مـع الإقبـالِ   على رفيع العـرش ذي الجـلالِ
~~٢٣ - والضَّنكُ بالغفلـةِ والإعراض   ومـا به الرحمن غـير راضِيْ
~~۲٤- وللحيـاة هـذه مراتـبُ   والعلم نور كالشهاب ثاقب
~~٢٥- أولهـا حيـاةُ عِلمِ مَـنْ عَلمْ   بأن يميت الجهل حتى يَنْعَـدِمْ
~~٢٦ - فـإن نـور الحكمـةِ المعظَّمَـة   يحيـي بـه الله القلـوبَ المظلمـة
~~٢٧- كمثلما يُحْيِـيْ بوابـل المَطَرْ   أرضاً من الجفاف أضحَتْ في خَطَرْ
~~۲۸- وعـن معاذٍ خبرٌ قـد أثرا   ورفعه ووقفه قـد ذكرا
~~٢٩- بَيَّنَ فَصْـلَ العلـم تبيينا كَفَى   ومن ظلام الجهل والغي شَفَى
~~۳۰- تعلمـوا العلـم فمـن تعلمه   يخشى إلهـه الـذي قـد أكرمـه
~~۳۱- طلبـه عبـادة تـريح   مذاکراتنا له تسـبيح
~~۳۲- وبحثنا عنه جهاد أکبر   به الضـلال والفسـاد يـدحر
~~۳۳- تعليمه للنـاس نعـم الصـدقة   آثارهـا محمـودة ومشرقة
~~٣٤- وبذلـه لأهلـه مـن القـرب   وحفظه ممـا به تعلـوا الرتب
~~٣٥- معـالم الحـرام والحـلال هُوْ   وَهُوَ الذي يدرى بـه المشتبه

PageV03P258

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0259.png)

~~٣٦- أيضـا منـار السـبل السـوية   إلى جنـان ربنـا العليـة
~~٣٧- وإنـه أنيسـنا في الوحشـة   والصـاحب الـوفي حـال الغربة
~~٣٨- دليـل سراء وفي الضـراء   وهـو سـلاحنا عـلى الأعـداء
~~۳۹- زيـن لنـا عند الأخـلاء به   يرفع قدر الشخص بين صحبه
~~٤٠- ويرفـع الله بـه أقوامـا   ممـن عـلى منهاجـه اسـتقاما
~~٤١- يجعلهـم أئمـة وقـادة   وخـيرة بـين الـورى وسـادة
~~٤۲- وتقتفی آثـارهم ويقتـدی   بفعلهـم فهـم نجـوم للهـدى
~~٤٣- ويهتدی برأیهم فیما رأوا   لأنهـم لشـرع ربهـم رعـوا
~~٤٤ - خلـتهم ترغبهـا الملائكـة   تمسحهم مُحِبَـةً مباركـة
~~٤٥ - والرطب واليـابس والبحـار   والـبر والسـباع والأنهـار
~~٤٦ - وهكـذا الحيتـان والأنعـام   وكـل مـا يـؤذى بـه الأنـام
~~٤٧ - ألهمهـم إلهنـا وسخرا   فكلهـم للعلـماء اسـتغفرا
~~٤٨ - لأنهـم أحيـو قلـوب الأمـة   بعلمهـم وَالحِكَـم المنـيرةِ
~~٤٩ - فهم مصابيح لأبصار الورى   مـن ظلـم تقـودهم إلى الـورا
~~٥٠ - ويبلـغ العبـد بفضـل البـاري   بعلمـه منـازل الأخيـار
~~٥١- والدرجات العاليـات الفاخرة   في هـذه الـدنيا ودار الآخـرة
~~٥٢ - والفكـر فيـه يعـدل الصـياما   ودرسه يعـادل القياما
~~٥٣- بالعلم حقا توصل الأرحام   ويعـرف الحـلال والحـرام
~~٥٤- فهو إمـام وهو قائد العمل   والعمـل المـبرور بـالعلم اتصـل
~~٥٥- یلهمه کل سعید وفقا   وإنـما يحرمـه أهـل الشـقا

PageV03P259

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0260.png)

~~٥٦- وبعـدها إحياؤنـا الإرادة   والهمـة التـي بهـا السعادة
~~٥٧ - فلا يكون فاتراً عـن الطلبْ   بل إنه يكون في أقصى الرَّغَبْ
~~٥۸- حتـى ينـال أكمَـلَ الحيـاةِ   بالعلم والأذكـار والإخبـات
~~٥٩- ولا يميت القلب كالذنوب   فإنهـا مـن أشـنَعِ الُخُطُـوبِ
~~٦٠ - وكـل قلبِ للمـمات يسرعُ   إذا غـدا في المنكـرات يَرْتَعُ
~~٦۱- وذاك حقـاً ميـت الأحيـاءِ   وصاحب الغمـوم والعناء
~~٦٢- وإنما الذَّكيُّ مـن يخشـى على   فـؤاده لا جسـمه أن يـذبُلا
~~٦٣ - فمتْ بِقَمْعِ الشهواتِ تَحْيَا   ولا تكُـنْ مَيْتـاَ بِهَـا فَتَعْيَا
~~٦٤- فالقلـب ذا لله في تفرُغِ   وما سوی باریه منه قد لُغِيْ
~~٦٥ - وحيـنما يأتيـه مـوت الجسم   يكـون في الجنـة في تَـنَعُم
~~٦٦- ثـم حيـاة أحسـن الأخـلاقِ   بـابُ العـلى حقـأًبـلا شِـقَاقِ
~~٦٧- فالجود والحيـاء فيه راسخُ   وهـو إلى خـير السجايا طَـامِحُ
~~٦٨ - كالصـدق والعفـةِ والوفـاء   وغيرهـا مـن مُوجِـبُ الثنـاءِ
~~٦٩ - وقـوة الأخـلاق في الإنسـانِ   وفْقَ حَيـاةِ القلبِ في الإيمانِ
~~٧٠- من أجـل ذا كـل رسولِ ونبيْ   نال بها في الفضـل أعـلى الرُّتَبِ
~~۷۱- وكـل حـلاَّفِ مَهِين أدنی   فيهـا بـلا شكٌّ لهـذا المعنـى
~~٧٢- ومِـنْ أَجَـلَّ هـذه الأخـلاقِ   البَسْـطُ وهـو في ذُرَى الأذْوَاقِ
~~٧٣- وذاك مـا كـان عليه المصطفَى   وآلـهُ وَصَـحْبُهُ أهْـلُ الوفـا
~~٧٤- من سعة الصدر ودوم اليشر   واللين والَمزْحٍ وحسـن الصثْرِ
~~٧٥- يَبـدأ بالسـلامِ مَـن لاقَـاهُ   وهكذا يجيب من دعـاهُ

PageV03P260

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0261.png)

~~٧٦- والناس منهم من لِذا توفَّقَا   ونحو منهـاج رسوله ارْتقى
~~۷٧- فيقتدي بهم سواهم في الهُدى   مـن حـائرٍِ وجاهـلِ طول المـدى
~~۷٨- هـم خلفاء المرسـلين الكُرَمـا   مـن وَرِثُـوا خيرهم المعظـما
~~۷۹- وإنه علـم الهـدى الـذي سـما   وليس دينـارا ولیس درهمـا
~~٨٠- وهم أولو الصبر أولو اليقين   وهـم أئمـة الهـدى المبـينِ
~~٨١- والعلـما ثلاثـة: أخـا الرَّشـد   فاسمع إلى تقسيمهم كـما وَرَد
~~۸۲- أولهـمْ خليفـةُ ووارثُ   لرسـل لهـم إلهـي باعـث
~~۸٣- وذا الـذي بعلمـه استنَارا   ونـوره بين البرايـا طَـارا
~~٨٤- ثم الذي استنار دون غَـيْرِهِ   ومـا أفـادَ غَـيرَهُ بِخَـيْرِهِ
~~۸٥- ثـالثهم: لم يسـتنر بنُـورِهِ   ولم يكـن بنـافع لغَـيْرِهِ
~~٨٦- فعلمـه هـو الوبـال المـاحِقُ   وبسطه للنـاس شرّ سَـاحِقُ
~~٨٧ - والبسْطُ في الأَولِ رحمـةٌ لهمْ   لأنَـه لِكُـلَّ خـيرِ دَلهَـمْ
~~۸٨- ثالثهـا: السرورُ بالإنعـام   مـن الجـواد الـبر ذي الإكـرامِ
~~٨۹- وقـرة العـين بـه مع الفرَحْ   بـما أمـده بـه ومـا مَـنَحْ
~~۹۰- وهذه دَنْدَنَ معظمُ الـوری   لنيلهـا وجلهـم منهـا برا
~~۹۱- لأنهـم قـد أخطـأوا الطريقَـا   واستخدموا معيقهـا رفيقا
~~٩٢- ينالهـا عَقْـلٌُ إلى الخـير حُبِي   وليس مـن للشهوات قد سبي
~~٩٣- يعـيش في خسـائسِ اللـذَّاتِ   وأسـوأ العـادات والصـفات
~~٩٤- قـد ركب المخالفـات أجَمعَـا   ولا استنار بالهـدى ولا وَعـى
~~٩٥- لم يستفد مـن مرشدِ وناصِحِ   بـل ذمـهُ بـأقبح القبـائح

PageV03P261

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0262.png)

# (٢٦١)
~~٩٦- فهو عن الخيرات جداًنَائمُ   وقلبـه في كـل وادِهَــائِمُ
~~۹۷- فالشخصُ ذا لـو أنَّه تجرَّدا   والتـزم الحـق وأسبابَ الهُـدَى
~~۹۸- وصـار يهفـو لفضـاءِ الكَرَم   وَفَرَّ مِنْ سَجْنِ الضَّلالِ المظلم
~~٩٩- وَفَرَّ مِنْ سِجْن الهوى إلى الهُدى   کیما يكـونَ مـن عبادِ سُعَدا
~~١٠٠ - وأبصر الحال الذي مضى قَذَى   وقـال يـا اللهُ لا أرِيـدُ ذَا
~~۱٠١ - و في سـؤال العلماء اجتهـدا   مستهدیا بعلمهم مسترشدا
~~۱٠٢- فبشروه بحيـاة قَلبِهِ   وفـوزه المـأمول عِنْـدَ ربَّـهِ
~~١٠٣- وأرشـدوه للتُقى والمعرفـة   وتركـه كـل الأمـور الصـارفة
~~١٠٤- حتى يزيـلَ الظلماتِ كلَّها   نـورُ البصـيرة التـي لهـا انتهـى
~~١٠٥- ثم يقـوم شـاهد بقلبِهِ   يدعوهُ للأخرى وَحُـبَّ رَبَّهِ
~~١٠٦- فعنـدها يَجِدُ للمتـابِ   ويفعـل الأمـر بـلا ارتيـاب
~~١٠٧- ويترك المنهي تركـاً كـاملاً   ولا يكـون سـادراً وغـافلا
~~۱٠۸- ثم يقـوم حـارس بِقَلْبِهِ   يحميه مـن مُنَغَّصات قُرْبِهِ
~~١٠٩- فيعـتلي القلب إلى بَارِيهِ   ولم يمـل إلالمـايُرْضِـيهِ
~~۱۱۰ - ولم يعد للقلب ذا من خَاطِرِ   إلا إلى الـبر الكـريم الغـافرِ
~~۱۱۱- فهو حديث النفس والترياقُ   وهو الذي الروحُ لهُ تشتاق
~~۱۱٢- ويمتلي القلب بِحُسبِّ الهادِيْ   نبينـا المبعـوث بالرشـاد
~~١١٣ - فهـو إمامـه هـو المعلـمُ   والقدوة العظمى الأعز الأكرم
~~١١٤ - مطالعـاً سِيرَتَهُ المعظَّمـة   ودارسـاً حياتـه المنظمـة
~~۱۱٥- مـن مبـدأ الأمر إلى نهايته   مهتـدياً بـذا لنيـل غَايتـه

PageV03P262

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0263.png)

~~۱١٦- مقتفيـاً أخلاقَـهُ والأدَبَـا   في واجـب الأمـر وفيما نُـدِبَا
~~۱۱۷- حتى يصير مثل مَنْ قد صَحِبَه   لأن حبـه الشـديد قربه
~~۱١٨ - ثم ينال فَتْحَ فَهْم الوَحْي   وهـو الـذي للمتقـين يحيـي
~~١١٩- فيشهد القلبُ مقاصدَ السور   ومـا هـو المقصـود منهـا للبَشَر
~~١٢٠- وحَظَّهُ مِنْ نَهْيهِ وما أمَرْ   مجتهـداً لكـي يفـوزَ بـالظَفَرْ
~~١٢١- فـإن يكـن وُفَّقَ للتكميـل   وفـاز بـالإكرام والتفضـيْلِ
~~١٢٢ - يَفْتَحُ ربُّه لـه في قلبِهِ   عينـاً بهـا يدنيهِ نَحْـوَ قُرْبِهِ
~~۱۲۳- مشاهداً بها صفات الباري   سبحانه ذو العـز والجـلال
~~١٢٤ - فيشهد القلب إلهـاً قـاهِرا   بلا شريك ناهيـاً وآمِـرَا
~~۱۲٥ - وقـائماً بـالأمر والتـدبيرِ   سبحانه مـن عـالم خبيرِ
~~١٢٦- وبعد أن يشهد ذي الصفاتِ   يشـهد منهـا صـفةَ الحيـاةِ
~~۱٢٧- فإنهـا كـل الكمال تجمَّعهٔ   وكل نقص عن إلهـي تدفعه
~~۱۲۸- تستلزم السمع له مع البَصَرْ   وقـدرةٌ إرادةٌ كـما ذَكَـرْ
~~۱٢٩- وصفَة الكلام حسبَما أتى   في محكـم الـذكر الحكـيم مثبتَـا
~~۱٣۰ - وكل أوصاف الكمال مطلقا   فافهم هـديت للرشـاد والتُّقَـى
~~۱٣۱- وصفة القيـوم أيضاً جَمَعَتْ   أفعـالَ ربنـا جميعـاً وَحَـوَتْ
~~١٣٢- فـالحي والقيـوم ذو الكـمال   كَمَالُـهُ جَـلَّ عـن المثـالِ
~~۱٣٣- وأنَّهُ فَعَّـالُ مـا يريدُ   فَـافْهَمْ هَـدَاكَ رَبُـك المجِيـدُ
~~١٣٤ - وبعـد أن يرسخ فيما سَبَقَا   لَشْهد القُرْب يكـون قَـدْ رَقَـى
~~١٣٥- وذلك القـربُ هـو المعيَّـة   ويـالهـا والله من عطيـة

PageV03P263

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0264.png)

~~۱٣٦ - فيحصل الأنس بهذه الصّفَة   فالله قـد أحبـه وشرفه
~~۱٣۷- وفي حديث (لا يَزَالُ عَبْدِي)   بيانٔهـا فـافهم بـلاتعـدِّي
~~۱۳۸_ وهـذه خیرُ حيـاةِ مطلقا   يا سُعْد مَـنْ بِنَيْلِها تحققا
~~۱٣٩- واستفرغَ القَلْبَ لصِدْقِ الحبِّ   وَبَذْلِـهِ الجهـد لأمـرِ الـرَّبَّ
~~١٤٠ - حتى تُرَى الآثـارُ للصّفاتِ   عـلى المحـب صـادِقِ الإخْبَـاتِ
~~١٤١- وإن يك العبـد بفترةِ دَخَل   فَتَخْتَفِي آثارُهـا لمـاحَصَـل
~~١٤٢- وتلك معنى (الشَّرَّة) التي عَنَى   نبينـا محمـد وبَيَنَا
~~١٤٣- فكم بهـا لعابدٍِ من الحكَم   من ذاك أن يدري بها قدرَ النَّعَم
~~١٤٤ - إن جَـدَّدَتْ في قلبه الأشواقا   وَحَوَلَتْـهُ تائقـاً سَـبَاقَا
~~١٤٥- ولم يـزل تكرُّرُ الشـواهِدِ   في قَلْبِهِ الحَـيَّ مَـعَ التزايُدِ
~~١٤٦- حتى يكون قلبه بها انْصَبَغ   ومن سوی آثارها حقأ فَرَغ
~~١٤٧ - ولا يكون في انقطاع إِنْ فَتَر   بَـلْ اِنَـه يقـودُه إلى الظَفَـر
~~١٤٨- يَجِدُّ بالقلبِ وبـالجوارحِ   وبِاللَّسَـانِ بـاهتمام طَـامِحِ
~~١٤٩- وإن يك القلبُ إلى الله انْجَذَب   يكـونُ ممـن ربه له أَحـبَّ
~~۱٥۰ - وحينما يرقى إلى الإحسـانِ   كأنـه يـراهُ بِالعَيَـانِ
~~۱٥۱- متحـد القَلْبِ بـلا تـواني   طوعاً لكي يفوزَ بالغفرانِ
~~۱٥۲- وبعـد هذا يَكْثُرُ التقرُّبُ   وينشطُ القلبُ لـه ويرغـبُ
~~۱٥٣- فيما يحب ربنا مـن العمَل   مـن غير مـا تكلف ولا كسل
~~١٥٤ - منبعثًا من بطن قلبه العَجَب   كبـذل روحـه لربـهِ الأحَـبّ
~~١٥٥ - يجـود بالمال وروح والعمل   لربه سبحانه عـزّوجـل

PageV03P264

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0265.png)

~~١٥٦ - تقرباً من باطن القلب وهل   يفوز شخص بسوى هذا العمل
~~۱٥٧ - فيا لحظ مَنْ لذا الحال وَجَدْ   وَخُسْرِمَنْ للأمْرِ هـذا قَدْ فَقَدْ
~~١٥٨ - فإن وجدته فَزِدْ واشْكُرْ لَمن   أولاك فَصْـلاً مِنْهُ هَـذِهِ المِـنَن
~~۱٥٩- وحيث لم تظفر به فأنتَ في   جهـدٍ كبـير لم يُفِـدْ وَلَمْ يَفِ
~~١٦٠- لكـن إذا لازمتـهُ فَـرُبَّما   تفـوز بـالقرب الـذي تقـدَّما
~~١٦١- أيضاً ومـن وراء ذا التقرُّبِ   ما لم يُطِقْ وَصْفاً له سوى النبي
~~١٦٢- صلى عليه الله ما الغيث هطل   ومـا انقضى عهـد لظلـم وبطـل
~~١٦٣- فيما روى عـن ربه إلى البشَرْ   وأطلق البشرى لهـم ومـا حصر
~~١٦٤ - وإنـما مَثَلَـهُ بِالبَـاع   والشَّبْرُ كَـيْ يُفهـم في إشرَاعِ
~~١٦٥ - وهذه مراتب القرب كما   بيَّنهـا إلهنـا وأفْهَـمَا
~~١٦٦ - فـإن يزد فالله مِنْهُ أزْيَدُ   وجـود رب العرش لا يقيد
~~١٦٧- وانظر إلى الحديث تَلْقَ العَجَبَا   وتسْـتزِدْ إلى المعـالي رَغَبَـا
~~۱٦٨ - وَمِـنْ مراتبِ الحيـاةِ أنَّهـا   باقيـةٌ ليس لهـا مـنْ مُنْتَهـى
~~١٦٩- وإن هـذه الحيـاةُ قَبْلَهـا   كـالنوم فافهم ذا وكـن مُنْتَبِهـا
~~١٧٠ - وذلك القرب هو الوصول   وهـو لكـل عابـد مـأمول
~~۱۷۱- وإنَّه سِرُّ مَفَـازِ مَـنْ عَبَـدْ   حَـقَّ العبوديـةِ حقـاً واجتهـدْ
~~۱٧٢- وَلَيْسَ هذا القُرب حِسيًاً فَلا   تهدم عـلاك بعـدما أن كمـلا
~~۱۷٣- وحوله دَنْدَنَ مَـنْ يُدَنْـدِنُ   وقـلَّ مـن يذوقُـهُ ويُحْسِـنُ
~~١٧٤- مَلاكُهُ تقَرُّبُ العبـد فَعِ   تَقَرُّبـاً مـن دونِ أي قَـاطِعِ
~~١٧٥ - يليه حال القرب حتى يَنْبَوثْ   بكله إلى الحبيـب كي يَـرِفْ

PageV03P265

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0266.png)

~~۱۷٦ - مَعْنَاهُ أن يفنى هوی الفؤادِ   عـلى مراد الملك الجــوَاد
~~۱۷۷- تقربـاً لم يبـق منـه باقيـة   لغـيرهِ فَعِـهْ بِـأذنٍ وَاعِيـة
~~۱۷۸ - والمرء هـذا حسبُه باريهِ   يحبه یکفیه مـا يؤذیهِ
~~۱۷۹ - وكيف لا وصاحب التقرُّبِ   عَبْدٌ صَدُوق قَدْ عَـلا في الرتَبِ
~~۱۸٠ - يعطيه مِـن إنعامه أضعافا   فضـلاً ولا يحرمُـهُ الألطَافَـا
~~۱۸۱ - إِذَنْ فَمَنْ فَازَ بِحَـال القُرْبِ   يجزيهِ ربُـهُ جَــزَاءَالُبِّ
~~۱۸۲ - لأنـه لربه قـد جـادا   حبَـأَلـه وحقَـقَ المُرَادا
~~۱۸۳- وكان حظه بِوِفْقِ مابَذَل   فربه يجزيه مـن جِـنْسِ العَمَل
~~١٨٤ - من ذاك أن الله يجزي الشُّهدا   تفضـلاً منـه حيـاة أبـدا
~~۱۸٥ - فبـذلهم أرواحهـم لتُزهقَـا   هـو الـذي بهـم إلى العليـا رقى
~~۱۸۶ - وكلما العبدُ لربه بَـذَلْ   جازاه ربه بـأَعْلَی وَأَجَــلّ
~~۱٨۷ - يحيـا حيـاةً ما لهـا قطٌ مَثَل   تفضلاً من ربه عز وَجَلّ
~~۱۸۸ - وكل من سواه بالنسبة لَهْ   مثل جنينِ عيشه قد طَابَ لَهْ
~~۱٨٩- ولم يـذق مـا بعـده لِجهْلِهِ   بِالحُجُبِ التي غَدَتْ مِنْ حولِهِ
~~۱٩٠ - والله قـد حـذرنا مـن نفْسِهِ   من بعد أن أَكْرَمنـا بأنسهِ
~~۱٩۱ - وذو الْتِفَاتِ لسواه بَعْدَ أن   ذاق هـدى الرحمنٍ واهِبِ المنَن
~~١٩٢ - يُصَابُ بِالإبْعَادِ بعدَ القُرْبِ   والبغضٍ بعـد وَصْـلِهِ والحبَّ
~~۱٩٣ - يُبلی بعکس ما به قد أکرما   ويلبس الـذل ويُسـبى النَّعما
~~١٩٤- وبعد ضربه بسوط البُعْدِ   والحـزن والـذل وشـؤمِ الطَرْدِ
~~۱٩٥ - تطرُقُـه طـوارق الأحـزَانِ   ولم يَزَلْ مـن عِبْيهـا يعـاني

PageV03P266

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0267.png)

~~١٩٦ - إذ بَاعَ أطيبَ الحيـاةِ فَاغْتَبَنْ   بـأبخسِ الأثمانِ بـل بـلا ثَمَـن
~~١٩٧ - وَمَنْ يَبِعْ أُخْرَاهُ بالدنيا فَقَدْ   صـار إلى شَرّ عَـذَاب وَنَكَـدْ
~~۱٩٨- ومن مراتب الحياة فَاعْلَمَن   ما جاء في الـذكر الحكيم والسُّنَن
~~١٩٩- وهي حياة الروح بعد فَصْلِها   من بَدَن قد کان کالسّجْنِ لها
~~٢٠٠ - تسمو إلى رَوح ورئحَان کما   أخبرنـا إلهنـا وعلَـمَا
~~۲٠۱- وهـذه هي الحيـاةُ الطيبـة   وعكسها هـي الحيـاة المتعبـة
~~۲٠٢- وإنما حياتنـا مَبْدَؤها   مِـنَ المَمَاتِ فهـو لـيس المنتهـى
~~٢٠٣- وإنـما الـدنيا جميعـاً كلُّها   كسـاعة مـن النهـار عمرهـا
~~٢٠٤ - والحسرة الكبرى على من أبصرا   فرق الحيـاتين ولكـن قَصَّرا
~~٢٠٥- فـآثرَ الفـاني عـلى مـا يبقى   وغلبَ الجهـلُ عليـه والشَّـقَا
~~٢٠٦- ووفقت قلوب أرباب التُقَى   وآثروا الأخرى فكـانوا الأسبقا
~~۲٠٧ - وليس نفسّ بالممات انتقَلَتْ   وهي لهـا خير له قـد عملت
~~٢٠٨ - يَسُرُّها الرُّجْعَى إلى ذي الدار   كـما أتـى عـن أحمـد المختـار
~~۲۰۹- حتى ولو كانَتْ جميعها لَها   وكـل مـا فيهـا يَكُونُ حَظُّها
~~۲١٠ - سوی شهيدِ لجزاء القَتْلِ   يطلب عَـوْداً لمزيـد الفضـل
~~٢١١ - لمـا رأى بالقَتْـلِ مـن كرامة   وكيـف أعـلى رَبُـهُ مقامـهْ
~~٢١٢ - وبعض أهل الزيغ والتزنٔدق   قـد شكَكُوا في هـذه الحقـائقِ
~~٢١٣ - فـرَدَّ زَيفَهُمْ رجـالُ العلـم   بواضح البرهـان سهل الفهـم
~~٢١٤ - مستنبَطا مـن محكم القـرآنِ   وسـنة الهـادي عظـيم الشـانِ
~~٢١٥- وكل مـن ينظر في الأشياءِ   خيرٌ مـن النـاظر للأشـياءِ

PageV03P267

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0268.png)

~~٢١٦ - أولهـم بعين قلبه عَـبَر   إلى حقيقـة المـراد في الصـور
~~۲۱۷ - وما اقتضى وُجُودُهًا من الحِكَم   فانضبط الأمـر لديـه وانسَجَم
~~۲١٨ - وجَـدَّ في تهيئـةِ الأزوادِ   وكـل مـا يفيـد في المَعَـادٍِ
~~۲۱۹- وكـل موجـود يـدل أنَّ   مَعادَنَـا حَـتْمٌ بــما قـد عَنَـاَ
~~٢٢٠ - وأن ذي الحيـاة كالمنـام   ومنكـرِي المعـاد كالأنعـام
~~۲۲۱- وأنهـا نـادَتْ بقـول الغـافرِ   في خامس الآيات أي من فَاطِرِ
~~۲۲۲- ويـونس والكهفِ والحديدِ   وهـل كقـول ربنـا الحميـدِ
~~۲۲۳- وكـل مـن ينظر للأشياءِ   يحَـارُ فيهـا كـذوي العـماء
~~٢٢٤ - تستفرغ الذهن وَحِسَّ مَـن نَظَرْ   وتقـذف الفكـر إلى شر خَطَـرْ
~~۲۲٥- ولا تفيـده اعتبـاراً أبـدا   ولم يكـن في فعله مسـدَّدا
~~٢٢٦- ومـن مراتب الحيـاة الطيبـة   تلك الحيـاة ذي الـدوام المُعْجِبَة
~~۲۲۷_ بعد فنا الـدنيا وطي العالم   وهـذه مقصـد كـل فـاهم
~~۲۲٨- نـادت إليهـا كتب العَـلاّم   والرسـل الـداعون للإسـلام
~~۲٢٩- (يَا لَيْتَني قَدَّمْتُ) قولُ الخاسِ   لأنـه قـد عـاش في المنـاكرِ
~~٢٣٠- وانظر بإمعـانِ إلى الآيـاتِ   فإنـه قـال لهـا (حيـاتي)
~~۲٣١ - ولا يُعـذب مثلـه ويوثَـقُ   والروح تنكيلاً بـه لا تزهق
~~۲٣٢- وهـذه الـدنيا هي الغرور   وخيرهـا تَشُـوبُهُ الشـرورُ
~~٢٣٣ - ولَعِبُ وصفٌ لهـا ملازمُ   واللهـو فيهـا قـائم ودائم
~~٢٣٤ - وبالحيـاة فوق هذا وُصِفَتْ   لكنهـا كنوْمـة ومـاكفتْ
~~٢٣٥ - والزهد في الأخرى من الإنسانِ   للضعف في العقـل وفي الإيـمانِ

PageV03P268

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0269.png)

~~۲٣٦ - أو أنه مـن اشتداد الغفلـةِ   عـلى قلـوب أكثـر البريَـةِ
~~٢٣٧ - فكـم مـن الأيقـاظ في مَنَـام   وذاك حـال أكثـر الأنـام
~~٢٣٨ - واليَقِظُ اللبيـب جـداً قَـلاًّ   ومـن حيـاة الغـافلين مـلا
~~۲٣٩- يؤاثر الأخرى على دنيا الفنا   بهمـةِ بـلا فتـورِ ووَنـى
~~٢٤٠- مقـدماً لأفضـل الخـيْرَيْنِ   مرتكبـاً لأيسـر الشـرَّيْنِ
~~٢٤١- خوفاً من الوقوع في أعلاهُمَا   لكونـه محققـاً وَفَاهِمَـا
~~٢٤٢ - باطنـه أجمـل ممـا ظهـرا   وظـاهر الأخـلاق فيـه بهرا
~~۲٤٣ - وسره خـير مـن العلانيـة   ولم يـزاحم في الأمـور الفانيـة
~~٢٤٤- بل يمتطي الحيـاة باستمرار   بهمـة للفـوز عنـد البـاري
~~٢٤٥- مُقْتَبِساً مـن الحيـاة التافهة   أنـوارَه إلى الحيـاة الفارهـة
~~٢٤٦- والنور في تلك الحياة ينطفي   المنْ غـدا للظلـمات يَقْتَفِـي
~~٢٤٧ - وقَدْرُ نور العبـد في أخراه   بقـدر مـا استنار في دنيـاهُ
~~٢٤٨ - وإن تَقُلْ كيف اقتباسُ الأعظم   مـن الأقـلَّ خُـذْ جـوابي وافهـم
~~٢٤٩- أليس أصل النور دوما يوجد   مـن الأقـل مثـل عُـود يُوقَـدُ
~~٢٥٠ - وهكـذا سر الحيـاة يُكْشَـفُ   ومصدر الأنـوار فيهـا يعـرفُ
~~٢٥١ - فكن حصيفاً وتقياً يلتمس   أنـواره مـن ههنـا ويقتـبِس
~~٢٥٢ - فإن فهمت ذا فسوف تعرفُ   نوعاً مـن الحيـاة ليست توصفُ
~~۲٥٣- أيضـاً ولا تـدركها العبـارة   لغايـة الرفعـة والغـزارة
~~٢٥٤ - ولم نشرلهـا بغـير أنهـا   حيـاة حب فاز قلبه بها
~~٢٥٥- فهو محب الله والمحبوب له   والله بـالإكرام هـذا فضـله

PageV03P269

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0270.png)

~~٢٥٦- فـلا قِـوام مُطلقـاً لقلبِهِ   وروحـه وفكـره إلابـه
~~۲٥۷- ولم یکن آلَمَ من حِجَابِهِ   عنـه ولا أشـد في عذابِـهِ
~~٢٥٨ - وليس في النعـيم كانكشـافِهِ   والأتقيـا تـاقوا إلى استشرافهِ
~~٢٥٩- أَعْظَمُ حتى من نعيم الجنةِ   وحورهـا العـين وكـل منة
~~٢٦٠ - وهو زيـادة الوجوه الناضرة   ولا تنالـه الوجـوه البـاسرة
~~٢٦١- فاعمل لهـذه الحيـاةِ واجتَهِدْ   واسلك سبيل كل من بها وُعِدْ

PageV03P270

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0271.png)

~~١- واعلَمْ بِقَـولِ العلـما في المعرفةْ   لكـي تكـون في ذراهـا المشرفة
~~۲_ فقد تکلموا علی آثارها   وذكر مـا يرفعُ مـن خصـالها
~~۳- مثـل شعور عـارفٍِ بـالقربِ   وأنسـهِ بِرَبَّـهِ والحـبٌّ
~~٤- وكُـلُّ شيءٍ غيره يخشاهُ   لخوفه الشـديد مـن مـولاهُ
~~٥- ولا تقرُّ عينُـهُ إلاّبهِ   فغاية الغايـات نيل قربه
~~٦- مـن أجـل ذا فهـو عـلى تأهُبِ   إلى لقـاءِ ربـه المحَبَّـبِ
~~۷- دنياه مثل منزل امریِٔ غَـدَا   مسـافراً عـلى الحبيـبِ وارِدا
~~۸ - وقيـل للجنيـد قـوم ادَعَـتْ   معرفـة الله وقالت وصلت
~~۹- وزعمـوا أن لهـم مقامَـا   قـد أسـقط الصـلاة والصـياما
~~١٠ - فقال هم قد واقعوا الضَلالا   فمن زنى أحسن منهم حالا
~~١١- والعارفون حافظوا على العمل   بوِفْقِ أمـرٍ ربهـم عـز وجـل
~~۱۲ - وقـال لـو بقيت ألف عام   لَـدُمْتَ في الأعـمال بانتظـام
~~۱٣- مـن دون أن أسـقط أي ذَرَّة   مـن كـل مـا إتيانـهُ مَــبرَّة
~~١٤ - هذا هو الطريق نحو المعرفَة   وغيرهـا طرائـقٌ مُنْحَرِفَـةْ
~~١٥- وكـل مـن لم يعرف الله خَسِرْ   وقَلْبُـهُ لِكُـلَّ بَاطِـلٍ أسِرْ
~~١٦- وَمِنْ عَلاماتِ التقيِّ العارفِ   البعد عن سوء وعن سفاسف
~~١٧- يـترك حقـه لكـي يُثَابا   ويتركُ الخصَـامَ والعتابَـا

PageV03P271

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0272.png)

~~۱۸ - ولا يرى فضلاً له عـلى أحَدْ   حتـى ولا تلميـذه ولا الولـد
~~١٩- أيضاً ولا يأسَى عَلَى مـا فَاتَا   ويشكر الله عـلى مـا آتـى
~~٢٠ - لأنـه ينظـرُ للأشيَاءِ   بأنهـا تصـير للفَنَـاء
~~۲۱- وأنـما يوجـد كالخيـالِ   أو أنـه كـالغَيْم والظـلال
~~۲٢ - ولم يكـن بعـارفٍِِ من لم يَكنْ   كالأرضٍ وهو رغم خَفْضٍِ لم يَهُنْ
~~٢٣- أو مثل غَيْث عم أصناف الورى   لم يـدع الفاسـقٍ أومـن كفـرا
~~٢٤ - يقابـل الجميـع بالرَّحَابَـة   يحـثُّهم للحـق والإصـابة
~~٢٥ - أوطـاره لم تُقْضَ في دُنيـاهُ   مثـل ثنائـه عـلى مـولاهُ
~~٢٦ - ومثل أن يبكي عـلى التقصيرِ   خوفـاً مـن المهـيمن الخبـيرِ
~~٢٧- أيضـاً ولم يشـغلهُ جمع المـال   عـن ربـه المـنعم ذي الإفضـالِ
~~۲۸ - حتى ولو فاقت على الحدودِ   لكونه يرجـو رضـا المعبودِ
~~۲٩- بـل شُـعْلُهُ بِـهِ على مرادِهِ   وذاك قصـد الله مـن عبـاده
~~۳۰- مستأنسـاً بربه تمامَـا   مستوحشاً من خلقه دوامَا
~~۳۱- مستغنياً بالله عنهم مطلقَا   في عِـزةٍ إلى أعاليهـا ازْتَقَـى
~~۳۲- مفتقـراً لربـه ذَلِـيلا   مكتفيـاً بربَّـهِ وَكِــیلا
~~٣٣- أعـلاه بالتواضـع الحكـيمُ   فشـأنه بـين الـورى عظـيم
~~٣٤- والنـاس تحتـاج إليـه وهـو لا   لأنـه لِـا أحبـوا أهمَـلا
~~٣٥- یُرَی مصلیاً وحینا ذاکرا   وقارئـاً وداعيـاً وشَـاكِرا
~~٣٦- کمائرَی معلماً مجاهدا   ومحسناً مواسياً مسـاعِدَا
~~۳٧- مـن کلِّ مغنمِ ينال أشهما   لأنه في مـنهج التقـوى سـما

PageV03P272

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0273.png)

~~٣٨ - معبودُهُ خلاَّقُه الفرد الصمدْ   له بـأنواع العبـادات عبد
~~٣٩- وَمَـالَـهُ مـن نُقْلَـةِ لغيرهـا   لعلمـه بِفَضْـلِهَا وَخيرِها
~~٤٠- فإنـه بـين الأنـام كـائنُ   لكنـه عـنهم بعيـد بَـائنُ
~~٤١- لم يعتقـد مخـالف الأحكـام   والسـتر لم يوقِعُـهُ في الحـرام
~~٤٢ - لأن من خالف حكمًا انحَرَفْ   ولم يكـن لمقصِـدِ الشرعِ عَـرَفْ
~~٤٣ - ومـن يجالس عارفاً حقاً يَفَزْ   ومـن يلازِمُهُ لخيرات يحُزْ
~~٤٤ - يـدعوه مـن شكٍ إلى اليقـينِ   بعلمـه وفهمـه الرصـينِ
~~٤٥- ومـن رياءٍِ ومـن انتكـاصِ   إلى سُـمُوَّ القَصْـدِ والإخـلاصِ
~~٤٦ - أيضـاً ومـن غفلتـه الُحَطَّمَـة   للـذكر فـالله تعـالى عظَّمـهْ
~~٤٧ - ومـن رغـوبِ المـرء في دُنْيَاهُ   إلى رغـوبِ المـرءِ في أخـراهُ
~~٤٨ - ومـن تكـبرٍ إلى التواضَع   والنصح والصفاء فاسْتَوْعِبْ وع
~~٤٩- قـد عرفوا الله بما عَنْهُ أتى   ومـا نفـى نبيُـهُ وأثبتـا
~~٥٠ - لأن جـاهلاً صـفات ربّهِ   لـيس بعـارف لجهلـه بِـهِ
~~٥١- وجاهـلٌ لربِّـه أيَّ صـفة   لـيس لـه مـن قـدم في المعرفـة
~~٥٢ - هـذا هـو الأسـاس في الإيمانِ   وسـلم الإحسـانٍ والعرفـان
~~٥۳- وكـل منكر صـفات ربّهِ   يجزی عـلى سوءِ ظنونه بِهِ
~~٥٤- مصـيره العـذاب في جهـنم   كما أتانـا في الكتـاب المحكـم
~~٥٥- ورسل الله جميعـاً قـد دعـوا   عباده لدینه حتـی وعـوا
~~٥٦ - وبيَّنـوا الطريقـةَ الموصَّـلة   إلى رضـا خلاقهـم مفصـلة
~~٥۷ - وبيّنـوا حـال العبـاد كلهـمْ   من بعد أن بانت طريق سَيْرِهمْ

PageV03P273

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0274.png)

~~٥٨- ووصـفوا الله لهـم كـما أمـرْ   حتى غدا ما غاب مثلما ظَهَرْ
~~٥٩- ليعبـدوا الله كمـن يَراهُ   ولم يخـافوا أحـداً سِـوَاهُ
~~٦٠ - كـأنهم يعـاينون البَـارِي   يـدبر الأمـور باقتـدارِ
~~٦۱ - وهو على العرش كما يليق بِهِ   يا سعد من قد أحسن الإيمان بِهْ
~~٦٢- قـد عَلِـمَ الظـاهر والبواطنـا   وغـابراً ومـا سيغدو كائنا
~~٦٣- ويكرم العباد يقضي الوطرًا   وينشر الرحمـة يكفي الضررًا
~~٦٤- يفـرج الهمـوم والكروبـا   ويغفـر الـزلات والـذنوبا
~~٦٥- لـه مقاليـدُ الأمـورِ كلّهـا   سـبحان ربي وإليـه المنتهـى
~~٦٦ - صراطُـهُ بِعَدْلِهِ قد نَصَـبَهْ   وأوجب اتباعـه وحببهْ
~~٦٧ - وهو امتثـال أمره الـذي أمَرْ   وترك ما عنه نهانـا وزَجَـرْ
~~٦٨- هـذا مع الإيـمان بالوعيـدِ   ووعـده المحقـقِ الأكيـدٍِ
~~٦٩- وحـال أهـل جنـة وَنَـارِ   وسـابق الإنعـامِ والأخطَـارِ
# بالحـب والتعظـيم والإثبـاتِ
~~٧٠- فكـل مـن يـؤمن بالصفاتِ بالحـب والتع
~~۷۱- کأنه بعینـه يشهدُها   والقلب في تعلـقٍ سـامِ بِهَـا
~~٧٢- يكـون أهـلاً لحصـول المعرفةُ   والعـيش في ظـلال أنسٍ وارفة
~~٧٣- والأمرُ هـذا مبـدأ الطريـق   للغايـة العظمـى عـلى التحقيـقِ
~~٧٤- وروحُ روحِ السالكين کلهـمْ   لأنـه الهـادي لهـم في دربِهِـمْ
~~٧٥- وهـو مثيرُ العَزماتِ والهِمَمْ   وهو الذي يسمو بهم إلى القِمَمْ
~~٧٦- وأعظـم الشـواهدِ المرئيـة   صـفات ربي خـالق البريـةِ
~~٧٧- وإن تكُنْ شـواهِدُ الصفات   قـد عطلت فـأي خـيرٍ آتي

PageV03P274

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0275.png)

~~٧٨- والعبـد لا يَزال مِمَّنْ يَكْسَـلُ   ولا يجـدُّ للعـلى بـل يُهْمِـلُ
~~٧٩- أو أنه يكـون ممـن قـد قَعَـدْ   عـن المعـالي وتـولى وجَحَـدْ
~~٨٠ - مَـا لَمْ يشـاهِدْ عَلَـمَا فينطلـقْ   وللأمـور الصـالحات يخْـتَرقْ
~~۸۱- لأن أوصـاف الإلهِ تجـذِبُ   كـلَّ تقـيٍّ في رِضَـاهُ يَرغَـبُ
~~۸۲- حينئذٍ ينهضُ في اشتياقِ   كـيما ينـال الفـوز في السـباقِ
~~٨٣- إلى إلهِـهِ ويلتَـدُّ بِما   يدْنِيـهِ مِنْـهُ طامعـاً أن يكرما
~~٨٤ - وذكـره يحييـه في اطمئنـانِ   أيضـاً ويعليـه لـدى الرحمنِ
~~۸٥- فمثـل ذا قلَّ لـه الُمـدَاني   لكونه قـد فـاز بالعرفـانِ
~~٨٦- ولم يكن عن ذلك الأمر حُجِبْ   لعلمـه لربـه بـما يجـبْ
~~۸۷- لا مـا يقولُه ذوو التعطيـلِ   ولا ذوو التشـبيه والتمثيـل
~~۸۸- وأنت ذو علـم وذو تـدبيرِ   تفضـلاً مـن ربك القـديرِ
~~۸۹_ ففضـله دل بـلا جدالِ   عـلى صـفاته بـلا إخـلالِ
~~٩٠- وهكذا دلَّ وجودنـا عـلی   وجود ربي جـل ربي وَعَـلا
~~۹١- فربُنـا لـه الكـمال المطلقُ   ونحـن في تأويلنـا قـد نخفِـقُ
~~٩٢- مـن أجـل هـذا نتركُ التأويلا   ونتبَعُ الاسـلافَ فـيما قَـيلا
~~٩٣- وأعـرف النـاس بـه الرسـولُ   فلنلتـزم حـتماً بـما يقـولُ
~~٩٤- ونحـن لا نحتـاج للتـدليلِ   عـلى كـمال ربنـا الجليـلِ
~~٩٥- لأن هـذا الكـون خير شَـاهِدِ   ومـا لمـا قرَّرهُ مـن جَاحِـدِ
~~٩٦- وكلـما في الكـون مـن خلائـق   تـدلنا عـلى كـمال الخـالقِ
~~٩٧- وأنت أنت عَـالَمَ قَـدْ أَفْرِدَا   فكيف بـالله تكـون جاحـدا

PageV03P275

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0276.png)

~~۹۸- وقـد دعانـا الله للتفکیر   في كل مـا في الكـون مـن أمورِ
~~٩٩- لـنعلم الآيـات بـالتَفكُّرِ   في صنع ربنـا العظـيم الأكبَرِ
~~۱٠٠ - وقـول ربنـا (وَفي أَنْفِسِكُمْ)   أي فدليلکم غدا منکم لَكُمْ
~~١٠١- في أقرب الأشياء نَفْسُكَ التيْ   لم تـدْرِ كُنْهَهَـا عـلى الحقيقـةِ
~~١٠٢- فـالعجزُ ذا يجعلنـا نعـترفُ   بكـل مـا المـولى به يتَصِـفُ
~~١٠٣- ويجلب التـوقير والتعظيما   لربنـا ويوجـب التسـليما
~~١٠٤ - وهـذه المعرفـةُ المعتـبرة   وهـي مـن الإيـمان أحـلى ثمـرة
~~١٠٥- وهي التي قامت على أركانِ   أربعـةِ عنـد ذوي الإيقـانِ
~~١٠٦- أولهـا: الإثبـاتُ للصـفاتِ   وبعدها الوقـفُ عـن الـزلات
~~١٠٧- والثالث: الوقف عن التشبيهِ   لكـى ننـال ذروة التنزيـهِ
~~۱٠۸ - والرابع: العلـم بـذات ربنا   وبصـفاته كـما علمنا
~~١٠٩- فَعِلْمُنَـا بعجزنـا وقدرتهٔ   وعلمنـا بضـعفنا وقوتـهْ
~~۱۱٠- وعلمنـا لله بالصـفَاتِ   وكـل ما في الكـون مِنْ آيـاتِ
~~۱۱۱- وبوجودنا الذي ليس لنَا   وليس مِنابـل بـأمر ربنا
~~١١٢- حينئذِ يعـرف قلبُ المسلِم   مولاه مـن صـفاته والأنعـم
~~۱١٣- ويُسْقِطُ العارف ذكر غَيْرِهِ   عـن قلبه وباله وفكره
~~١١٤ - لأنه عـن ذكر غيره فَنِي   بحبـه الشـديد لله الغنـي
~~۱۱٥- ففـاز بالمعرفـة المنشـودة   وحقـق الله لـه مقصـوده
~~١١٦- وأضحت الروح إليه تهفُو   ۱۱۷- وصـار لايُـدْرَكُ في السباقِ   وقلبه بـالنور منـه يصفُو   إلى رضـا إهـه الخَـلاَّقِ

PageV03P276

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0277.png)

~~۱۱۸ - وروحه تجـول في اطمئنـانِ   في ملكـوت ربهـا الـديَّانِ
~~۱۱۹- ولم تعـد سجينة الآثـام   وحـب دنيـا أكثـر الأنـام
~~١٢٠- يَرَى عظيماً عَـزَّ في تفرُّدِهٔ   فالخلق والأمـر جميعـاً بيـدِهْ
~~۱۲۱- فعقله يكسى بَهَاء العلم   وقلبـه يرزق نـور الفهم
~~١٢٢- تـراه في نهايـة الخشـوع   والحب والإجـلالِ والخضـوع
~~۱۲۳- يوحـد الله بعلـم وهدَی   لأنه بأحمـد الهـادي اقتـدى
~~١٢٤ - ثـم إذا رَقَّـاهُ في العرفـانِ   ذو الجـودِ والإنعـام والإحسـانِ
~~١٢٥ - يُشْـهِدُهُ قيـام كـل عـالمِ   بـالله وحـده بفهـم حاسم
~~۱۲٦ - فإنـه أقامهـا بحكمتـهٔ   وإنه يمسكها بقدرته
~~١٢٧ - فيمسك السماءَ عَنْ أن تقعَا   والأرض أن تزول أو تقطعا
~~۱۲۸ - والبحر أن يغيض أو يفيضا   والجـو أن يـبرد أو يقيضَـا
~~١٢٩- والطير في السماء عـن أن تسقطًا   والقلب أن يزيغ أو أن يفرطا
~~١٣٠ - فالكـل بالأفعـال والصفاتِ   قامـت، وهـذا لازم للـذاتِ
~~۱۳۱- ولـيس شيء قـائمٌ بنفسه   طرفـة عـين بـل بـأمر ربَّـهِ
~~١٣٢ - وَيُشهِدُ العَبْدَ بأنَّ مـا فَعَلْ   مـن خلقه سبحانه عـز وجـل
~~۱۳٣ - وبشهودهِ قيـام البـاري   عليـه في الليـل وفي النهـارِ
~~١٣٤ - يرفعـه الله إلى المعـالي   لصـدقه في سـائر الأحـوالِ
~~۱٣٥- ثم یرقیهِ علی ما قد رقَی   لكونه بالصـدق قـد تحققـا
~~١٣٦- فطالمـا في طاعـة الله يُـرَى   مكابـداً مرابطـاً مصـابرا
~~١٣٧ - أي صابراً في نفسه بلا ونَى   مصـابراً عَـدُوَّهُ ومـا انْثنَـى

