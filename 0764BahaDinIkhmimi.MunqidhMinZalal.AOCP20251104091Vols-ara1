# (٢٨٣)
~~٢٥١ - قـال ابـن تيميـة: إنهـا تجي   كالحر والبرد وثم تنقضي
~~٢٥٢ - فكـل عـالم بهـا لا يغضـب   بل نحـو ربه الكريم يرغب
~~۲٥٣ - ولم يصب منهـا بهمّ وحـزن   وإنـما يصـبر في حـال الفتن
~~٢٥٤ - فمثل ذا يرقى إلى التحقيـق   بقـدر دفع عـارض التعويـق
~~۲٥٥ - ونفسه تهـذبت لمـا اطمـأن   وعاش في مرضات واهب المنن
~~۲٥٦ - وغمـرت محبـة المنـان   فـؤاده فعـاش في إحسـان
~~۲٥۷ - وروحه قد غمرت بالحب   فكان من أهل التقى والقرب
~~٢٥٨ - ينسى الذي لاقى مـن الأذية   لأنـه يعـيش في المعيـةِ
~~۲٥٩- وبعد هذا تصبح الجوارح   تتـابع الأمـر بـه تكـافح
~~۲٦٠ - لأنه بـالله لا بنفسه   وربه یکرمـه بأنسه
~~۲٦۱ - عندئذٍ يشهد قَيُومِيَّتَهُ   مـدبرًا سبحانه بَرِیَتَه
~~۲٦٢- حينئذٍِ يمسك بـالحق الجلي   ولا يكـون واقعَـا في باطـل
~~۲۶۳- ويعلمـن بأنه لیس به   حتمًا وإنـما بفضـل ربه
~~٢٦٤ - ويبرأن من حوله أيضًا ومِنْ   قوته مُخالفَّـا مـن قـد فُـتِنْ
~~٢٦٥ - فيرسخ القلب بـذا المقـام   ويعـتلي دومَـا إلى الأمـام
~~٢٦٦ - حتى يصير من أولي التحقيق   به وفیه دونما تعویق
~~۲٦٧- مسـافرًّا بقلبـه إليه   مسـافرّا بـه لمـا يرضـيه
~~۲٦۸ - مسـافرًا فيْه بما له فتح   مـن حبه وقربه ومـا منح
