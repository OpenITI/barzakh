# ٢٧٧)
~~۱۳۸ - مرابطـاً عـلی ثغـور قلبِهِ   مـن أي أمـر مغضـب لربهِ
~~۱۳۹- والشـهوات كلهـا يمنعها   والشـبهات كلهـا يـدفعها
~~١٤٠- حينئذِ يصـفو لـه الإقبـالُ   ولا يـداني الحـالَ هـذا حـالُ
~~١٤١- ثم يفيضُ النور من باريهِ   عليه كي يسمو لمـا يعليهِ
~~١٤٢- نـوراً به يحقـق المراقبـة   وتصـلح الأحـوال عنـه قاطبـة
~~۱٤٣- والقلب يغدو مستنيراً مشرقا   لكـل خـيرِ دائـماً موفقـا
~~١٤٤- أيضاً ويسري النور ذا من قلبِهِ   لظـاهر الجسـم بفضـل ربَّـهِ
~~١٤٥- فالروح والقلب به قد أنسا   وأدركـا جمـال ربي الأقدسـا
~~١٤٦- وتصـبح العبـادة القلبيـة   قائمـة بقلبـه قويـة
~~١٤٧ - تفيـده حتماً ولا تشـغِلُهُ   عـن مشهد الروح ولا تفصلهُ
~~١٤٨- ملاحظاً رضا الكريم المنعمِ   وحقَّـه عـلى العبـاد الأعظـم
~~١٤٩- والأمر والنهـي بفضـل ربي   لديـه حـاضران جـذر القلب
~~۱٥٠ - ملاحظـاً بعقلـه الأسرارًا   وحكمـة تكسـبه الأنـورا
~~۱٥۱ - وكل هذا لم يكـن بحاجبِ   عـن العبوديـة والتَـأَدُبِ
~~۱٥۲ - فروحه تلاحـظ التفرّدا   ثم الجـلال والكـمال الأوحـدا
~~۱٥٣ - مستغرقاً في الحب والتشوقِ   وأكمـل اللـذة والتـذوق
~~١٥٤ - ملاحظـاً لحكمـة التـوابِ   مراعيـاً معـاني الخطَـابِ
~~١٥٥ - قد صار عبداً للإله مَحْضَا   لحرصه دومأً على مـا يَرْضَى
~~١۵۲- بروحه وقلبه وعقلهِ   وجسمه وقوله وفعله

PageV03P278

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0279.png)

~~١٥٧ - ولـيس يرتقي لـذى المقـام   إلا المُوَحِّـدُونَ للعـلَام
~~۱٥۸_ وهو بأمرین بلا نزاع   فاسمع، وكـن للحـق في اتبـاع
~~١٥٩ - أولهـا: شـهودنا للخـالق   حـق الربوبيـةِ في الخلائـقِ
~~١٦٠- فإنه سبحانه هـو الأحـدْ   وإنه القيـوم والفرد الصمد
~~١٦١- وُإنـه مـدبر الأمـر كما   خاطبنـا سُـبْحَانَهُ وَعَلَّـما
~~١٦٢ - وإنَّهُ معطي الـورى والمـانعُ   والضـارّ العـدل القـوي النـافع
~~١٦٣- وكل موجودِ فقل ذا منفعل   لا فاعـل فـاعلم بهـذا وامتثـل
~~١٦٤ - وما له فعـل فأيضاً منفعل   في فعلـه فـلا تكـن ممـن ذُهِـلْ
~~١٦٥ - بـل إنه محـل جَرْي الحِكَم   لمـا أراد الـرب فـافهم واعْلَم
~~١٦٦- وهكذا كـل الإرادات التـي   بهـا يـتم الفعـل في البَرِيَّـةِ
~~١٦٧- والمـرء غـير مالكِ لنفسِهِ   فهـل يكـون مالكـاً لغـيرهِ
~~۱٦۸- يرجو الوصول نحوه ليعتلي   بـالفرض والواجـب والتنفُّـل
~~١٦٩- منه به إليه أضحى ينظرُ   وفي سـوى رضـاه لا يفكَّرُ
~~۱۷٠- فـإن يك العبـد بـذا تحقَقَا   يُخْمِدُ كل خـاطرِ مَهْـكَا رَقَى
~~١٧۱- ثـم الإلهيـةُ أن يشـهدها   بوفق شرع الله لا وفق النهـى
~~۱۷۲ - وأن يريد وجه ربه الأجلْ   عـلى توكـل وحـب وخجـل
~~۱۷٣- والحب ذا يغنيه عـن سواهُ   وهـو الـذي ينيلـه رضـاهُ
~~١٧٤- ثـم حقيقـة الشهود هـذا   أن لا يـرى في غـيره مـلاذا

PageV03P279

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0280.png)

~~۱۷٥ - منتفعـاً بالوعظِ من عليم   والخـوف مـن بارئـه العظـيم
~~١٧٦ - وبالرجـاء الجـمّ والإجـلالِ   لربَّـه العظـيم ذي الجـلالِ
~~۱۷٧ - وأن يكـون القلب ذا خُلُوّ   مـن حب دنيـا الناس والعلوّ
~~۱۷۸- مـن دونما تعلقِ بالمالِ   ومـا بـذي الـدنيا مـن الخصـالِ
~~۱۷۹- بـل جعـل اهتمامه بـالآخرة   لكـي يفـوز بـالأمور الفـاخرة
~~۱٨٠ - يَفُـزْ مِـنَ الرحمن بـالفتوح   وبالهـدى وبـانشراح الروح
~~۱۸۱ _ تراه مشغوفاً بما یرضیهِ   وَحُبُّـهُ بـه لـه وَفيهِ
~~۱۸۲ - وهـذه دلائـل الشـهادة   بأنـه قـد أخلـص العبـادة
~~۱۸۳- والعبد هذا خير عبد موقِنِ   حتميـة اللقـاء بـالمهيمنِ
~~١٨٤ - وأنـه سَـائِلُهُ عـما عَبَـدْ   وما أجاب المصطفى داعي الرشدْ
~~۱٨٥ - فلا يميل عن طريق الاهتدا   ويستزيد في التُقَـى والاقتـدا
~~۱٨٦ - حينئذِ يـدخل بـاب الأنسِ   بروحـه وقلبـه والـنفس
# بمالك الملك عظـيمِ المنَّـةِ
~~۱٨۷ - ولا يرى شيئاً كمثل الخَلْوَةِ بمالك
# أبـواب إعـلاء بهـا يرْفعـهُ
~~۱۸۸- وبعـد ذا يفتح ربُّهُ لَـهُ ا
~~۱۸۹ - من ذلك استحلاؤهُ العبادة   والشـوق للجنـة والزيـادة
~~۱٩۰- ويجـد اللـذة حين يعبدُ   وراحـة كمثلهـا لا يوجـد
~~۱٩۱- ولـذة قصوى بذكر الباريْ   في سـائر اليـوم وفي الأسحارِ
~~۱۹۲- وقلبه بالذکر في اطمتنانِ   وروحـه تهفـو إل الـرحمن

