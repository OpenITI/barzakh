# ٢٨۱)
~~٢١٣ - وَيُخْرَمُ الوصـولَ مُدَّعِيهِ   إذليس للنفـوس حـظٌ فيهِ
~~٢١٤ - لكنـه إن دام في امتثَـالِ   مشـاهداً أنـوارَ ذي الجـلالِ
~~۲۱٥_ یزیده من فضله کثیرا   حتـی يصیر قلبه منیرَا
~~۲١٦ - ويعـتلي ذاك الفـؤادُ حقـا   فهـو بـإكرام الإلـه يرقـى
~~٢١٧- أيضاً ومن نور الجمال يُكْسَى   لأنـه بالمصـطفى تأسَّى
~~۲۱۸_ فيـا لحب يلهب القلوبا   يزيـدها في ربهـا رُغُوبا
~~۲١٩- بمايراه القلبُ مِـنْ جَمَـالِ   وَمِـنْ جـلال الله ذي الكـمالِ
~~۲۲۰- فقلبـه لربّـهِ أسيرُ   وهـو لـه مـن ذلـه كسيرُ
~~۲۲۱- فاعجبْ لمأسورِ غدا حَبِيبَا   مـولاه قـد أضحى له مُجِيبَا
~~۲۲٢_ هـذا وليُ الله ذا الحبيـبُ   هذا الذي آثـارُهُ تطيب
~~۲٢٣- فهـو إليـه بالخضـوع داني   وهـو بحـب الله في امتحـانِ
~~٢٢٤ - المـال في عينيـه كـالتراب   وكـل دنيـا النـاس كالسراب
~~۲۲٥ - وغیره قد صـار ذا افتتـان   بالمـال والجـاه وبالمبـاني
~~۲۲٦ - وبالرياسـات وكـل فاني   معـذَّباً في الفكـر والَجَنَـانِ
~~۲٢٧ - وإنَّ أعلاهم مقاماً مَنْ غَدا   بالحور مفتوناً لکیما یسعدا
~~۲۲۸- أو عـاملاً من دونما تواني   للأكـل والنكـاح في الجِنَـانِ
~~۲۲۹- ومـن غـدا في ذروة المحبـة   أعـلاه مـولاه الـذي أحبـه
~~۲٣٠ - يرقی على کل الوری دواما   لأنـه لربـه اسـتقاما
~~۲٣۱- وفي جنـان الخلد يَنْظُرُونَهُ   كالكوكبِ الـدرّي يُبْصرُونَهْ
~~٢٣٢ - هـذا علـو الحب قـد تجـلّى   لكـل مـن بالصـدق قـد تحـلَى

PageV03P282

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0283.png)

~~۲۳٣- فـالله قـد أدنـاه واصطفاهُ   إذكـان لا يبغِـي سِوى رضـاهُ
~~٢٣٤ - والله يجـزي مـن أحب حُبَّا   ومـؤثر الأخـرى لديـهِ قربـا
~~۲۳٥- وإنـه في موقـف القيامـة   في الأنـس والإنعـام والكرامـة
~~٢٣٦ - والنـاس في أهوالهـا تُعَـاني   وهـو بِظِـلَّ العـرش في أمـانِ
~~۲٣٧- منتظراً خَلاَقَـهُ العظـيما   فـإن رآه اسـتكمَلَ النَّعِـيما
~~٢٣٨- هذا الذي قد فاز بالوصول   وفـاز بالرضـوان والقبـولِ
~~۲٣٩ - يكفيه في دنيـاه أن أحبه   وأنـه في الخلـد نـال قربه
~~٢٤٠ - وعاش في الروضات والحبور   وفـاز بالإنعـام والشعورِ
~~٢٤۱ - وفاق في مقعـد صـدق أكبر   عنـد مليك مـنعم مقتـدرِ
~~٢٤٢ - لأنـه لم يتخـذ كفـيلا   عـن ربـه کـلا ولا وكـیلا
~~۲٤٣ - تعريفه إن شئت أن تفهمه   مِـنْ حقَّـق الـشيء إذا أثبتـه
~~٢٤٤- والَحَـقُ: ربي جـل في عـلاه   وكـل مـا يـدني إلى رضـاه
~~۲٤٥- يصحب منه العبد قدر حبه   وقصـده أيضـا لوجـه ربه
~~٢٤٦ - ومـا يعيْنـه عـلى الوصـول   لنيـل مـا يرجـوه مـن مـأمول
~~٢٤٧- مخلصّـا لقلبه مـن قـاطع   ومـن مشـوش وأي مـانع
~~٢٤٨ - وللمعارضـات قط لا يقـف   بَـلْ يُهمِلنَّهـا وَعَنْهـا يَنْصـرفْ
~~٢٤٩- لأنهـا تمــر بالتغافـل   وتنتهـي بحكمـة التجاهـل
~~٢٥٠ - وتعظمن على الذي يوسعها   لجهله الحكمـة في تقـديرها

