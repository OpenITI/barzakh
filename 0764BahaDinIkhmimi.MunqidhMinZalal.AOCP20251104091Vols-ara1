# ٢٧)
~~۱۷- وإن مِـن أحسنِها تحقيقـا   مـدارجاً أنـارتِ الطريقـا
~~۱٨ - للعـالم الشهير بـابن القـيَّم   أنعِـمْ بـه مـن عـالمِ وأَكْرِمِ
~~١٩ - وأَصْـلُه المحشـوُّ بالمعـاني   للهـروي العـالم الربّـاني
~~٢٠ - فزانـهُ بالشرحِ والإيضـاح   حتـى بـدا كغُـرّة الصـباح
~~۲۱ - مستنبطاً مـا للفؤاد یسعدُ   مـن (نستعينُ) ربنـا و(نعْبـد)
~~۲۲ - مـدارجاً للسالکین هادیةٔ   ومـن جميـع المخزيـات واقيـة
~~٢٣- فَقَـام عبدُ المـنعم بـنُ صالِحِ   مهَـذَّباً لهـا بشكلٍِ واضح
~~٢٤ - لكي تكون صحوةُ الجيـل على   نهج النبـيٍّ المجتبـى خَـيْرِ المـلا
~~٢٥ - وكي ينال القلبُ حظاً وافيـا   من سَمْتِ طه كاملاً وصافيا
~~۲٦- وهاکهـا نظماً بقـدرِ حـالي   ربِّ اكسُـه بحلـةِ الجـمالِ
~~۲۷- وارحـم جميعَ المسلمين قاطبة   وامنن بتوفيق وحسـن العاقبـة
~~۲۸ - ووفـق اللهـم مَـن دعـا لي   وكـن لـه في سـائرِ الأحـوالِ
~~۲۹- واجعله بـالقرآن ربي دائماً   معتصـماً وعـاملاً وقـائماً
~~٣۰- فكلِّ علم نافعِ منه اقتبس   وكـلّ فعـلٍ صالح به التمس
~~٣١ - والمـرأ لا ينجـو من الخسرانِ   إلا بإقبـال عـلى القـرآنِ
~~۳٢- وإن في أمّ الكتـاب لـبَّ مـا   حوى الكتابُ عند مـن تفهّـما
~~٣٣- فاتحـةُ المطالـبِ العـوالي   لكـل خـيرٍ نـازلٍِ وعـالي
~~٣٤ - عَرَّفَتِ العبـادَ بـالمعبودِ   ذي البر والإحسـان رب الجـود
~~٣٥- وبينت أن لا معـين غيرهُ   يُسْـدِيْ إلينـا فضـلَهُ وخـيرَهُ

PageV03P028

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0029.png)

~~٣٦- وأنـه الهـادي إلى الصراطهِ   فاعبـده في حـبِ وفي اغتبـاطِ
~~٣٧- وبيّنتْ أمـر المعـاد الـلازم   كـذا النبـواتِ لَخـيْرِ العَـالَم
~~٣٨- وأن الاستعلا مَنُوطٌ بالهـدی   والخـزي حـظٌ كـل مـن تمـردا
~~۳۹- وبيّنت مراتب الهدایةٔ   مـن مطلع العمـر إلى النهاية
~~٤٠ - وحَذَّرَتْ من طرق الضلالِ   والسير في مُغضِب ذي الجـلالِ
~~٤١ - وربُّنا عـلى الصراط الأقـوم   فيما علمنـاه ومـا لم نعلـم
~~٤٢ - وهـو إلى الصراط قـد دعانـا   سبحانه مـن راحم مولانا
~~٤٣ - وبـيّن الله لنـا الرفيقـا   وذاك ممـا زادنـا تشـويقا
~~٤٤- وضمّنا في سلك كل مهتدي   فلم نخف من وحشة التفرد
~~٤٥- علّمنـا ذو الجـود للتوكـل   وأن حمـدَه مـن التوسّـلِ
~~٤٦ - وأن مـا نرجـو مـن الآلاءِ   ينـال بالذلـة والثنـاء
~~٤٧ - وإنهـا فاتحـةُ التوحيـدِ   والمرشـدُ الأعظـمُ للتمجيـدِ
~~٤٨- دلّت عـلى العلمـي والإرادي   فـيما لربنـا عـلى العبـادِ
~~٤٩- بـاللهِ والـربِ وبـالرحمنِ   وبـالرحيم المالـكِ الـديّانِ
~~٥٠ - نوحّـدُ الأسماَءَ والصـفاتِ   بالحـب والتعظـيم والإثبـاتِ
~~٥١- فهـذه الخمسةُ فيهـا دلّت   على صفات ربنا ذي العـزة
~~٥٢ - ونفينـا الشـبيهَ والمثـالا   بـالعلم عـن إلهنـا تعـالى
~~٥٣- وافهمْ لوازم الصفات كلّها   بوفق مـا حققهـا أولـو النهـى

PageV03P029

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0030.png)

~~٥٤ - وخُصرت مراتبُ الهدایةٔ   عـدَّاً بعشرِ فاحـذرِ الغوايـة
~~٥٥- أوها التكليم يا من قد سلك   يَلِيْهِ وَحْيُّ ثـم إرسالُ الملَـكْ
~~٥٦- وهـذه للأنبيـاءِ والرُّسلْ   ولم ينلهـا غـيرُهُمْ مهـما كَمُـلْ
~~٥٧ - وَرَابِـعُ المراتـبِ التَحْـدِيثُ   وهـذه جـاء بهـا الَحـديثُ
~~٥٨- خامسُـها مَرْتَبَـةُ الإفهـام   والفهـم مـن عظـائم الإنعـام
~~٥٩- ثـم يليهـا عَـامٌ البيـانِ   أي حجـةُ الله عـلى الإنسـانِ
~~٦٠ - وَخَـاصُّ تصحبه العناية   والعـون والتوفيـق والهدايـة
~~٦١ - وبعـدها سماعُ قَلبِ المـؤمنِ   لكـل مـا يحييـهِ يـا ذا الفطـنِ
~~٦٢ - وتاسع المراتـب الإلهـامُ   وصـادق الرؤى هي الختـامُ
~~٦۳ - واشتملت فاتحـةُ القرآنِ   عـلى شِـفاءِ القلـبِ والأبـدانِ
~~٦٤- فالعلم والقلب إذا ما فسدا   يفسُدُ قلبُ المـرء يغـدو أَسْـوَدَا
~~٦٥ - وذي مـلاكُ عِلَـةِ القلـوبِ   ومُسخطاتُ عـالم الغيـوبِ
~~٦٦ - فيوصلان للضلال والغضب   والخزي والعار وأَعْظَم العَطَبْ
~~٦٦ - ثـم شـفاؤنا مـن الضـلال   بالسـير في طريـق ذي الجـلال
~~٦٧- لـذاك كـان أفرضَ الـدعاءِ   في النَفْلِ والفرض عـلى السواءِ
~~٦٨- وإنَّ في (إِيَـاك نعبـدُ) الهـدى   علماً وحـالاً والشـفاءَ المسعدَا
~~٦٩- أيضـاً وفي (إيـاك نستعينُ)   دَلِيْـلُ أنَ قصـدَنا مبـينُ

PageV03P030

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0031.png)

~~٧٠- وقصـدَ غَيْرِنا إلى انحطـاطِ   لأنهـم مـالوا عـن الصراطِ
~~۷۱- وأنهـم للحـقِّ قـد تنكّـروا   وبـالغوا في حربـه ونفُّـروا
~~٧٢- فهـم أعاديـه وإنَّ شـأنَهم   إِذْعَــانُهُمْ لَـهُ إذا كـان لهـم
~~۷٣- فيـا لهـذا المـرض المريـبِ   ويـاخواء هذه القلـوب
~~٧٤- قلـوبِ أهـلِ الزيغِ والنفاقِ   في سـائر الأنحـاءِ والآفـاقِ
# وخـزيِهم في سـاحةِ المعـادِ
~~۷٥- ويـا لَخسران ذوي الفسـادٍوخـزيِهم في
~~٧٦- وأنهـا ردَّت عـلى مـن أبطلـوا   وابتـدعوا وغيّروا وبـدّلوا
~~٧٧- لفظ (الصراط المستقيم) تُعْلَمُ   مَعْرفَـةُ الحـق به وتُفهـم
~~٧٨- والحقُّ ما كان عليه المصطفى   وصحبه الأخيـارُ أربـاب الوفا
~~۷۹- قد أجملت منازلُ السيرِ بها   يعلمهـا مـن حـاز علـماً ونُهى
~~۸۰ - وكـل مـا جـاء مـن الأعمالِ   والعلـم والأقـوال والأحـوال
~~۸١- ما لم يكن عن النبي المُرتضَى   فمنكر وباطـل لا يرتضى
~~٨٢ - وليس للناس طريقٌ غيرُ ما   بيّنه خير الـورى وعلـما
~~۸٣ - وانقسـم النـاس إلى طوائـفِ   موفـقٍ ومبطـلٍ مخـالفٍ
~~٨٤- والحقُّ مثلُ الصبحِ في انبلاجِ   سبيلُ كـلَِّ خـائفٍ وراجـي
~~۸٥- والشرُّ في طريق أهل الغضبِ   وكلّ مـن ضل وخالف النبي
~~۸٦- صـلى عليه ربُنـا وسلّما   وآلـه وصحبه وعظَّـما
~~٨٧- والحقُّ واضح وحين يعرف   يعلـمُ كـلُّ باطـلٍ ويُكشفُ

PageV03P031

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0032.png)

~~۸٨- وفي ربوبيـة مولانـا الأحـد   ردٌ عـلى كـل غـوي قـد جحـد
~~۸٩- والعـالم السـفليُّ والعلـوِيٌّ   يقـول ربي صـانع قـويٌ
~~۹۰- وهكذا ردّت بعلم حاسم   عـلى ذوي التعطيـلِ والتجهّم
~~۹۱- فالحمدُ قـد دل عـلَّ الكـمال   لربنـا مـن دونـما إخـلال
~~۹۲- وصفةُ الرحمـةِ منهـا قـد لـزم   إرادةُ الرَّحمن عنـد مـن فهـم
~~٩٣- ومِـن ربوبيّته تعـالَی   ما کان مـن صـفاته أفعـالا
~~٩٤- ومـن ألوهِيَته قـد ظهـرا   صـفات ذاتـه بـلا أي مرا
~~٩٥ - كالسـمع والقـدرة والحيـاة   وغيرهـا مـن سـائر الصـفات
~~٩٦- وكونـه الإلـهَ والمعبـودا   وكونـه الـرحمن والمحمـودا
~~٩٧- لكـل وصـف خبري أثبتـا   مثل الرضـا وغضـب كـما أتـى
~~۹۸- فكيف تنفي زمـرة التعطيـل   قيامهـا بـه بـلا دليـلِ
~~۹۹- وأنهـا رَدَّت عـلى الجَجَبْرِيَّـةْ   بحجـةِ بالغـةِ قويـةٌ
~~١٠٠ - وتمّ ذاك مِن وجوهِ ذي عددْ   نعلمهـا مـن قول ربنا الصمد
~~١٠١- ( الحمدُ) فهو مقتض لِعدلهِ   وأن يعاقب امرو بفعلـه
~~۱٠٢ - كم اقتضت (رحمتُه) أنْ يرحما   مـن لم يطـقْ أمـراً وأن يسـلَّما
~~١٠٣ - فلا عقاب في الـذي لا يُقْدَرُ   عليـه بـل رحمـة ربي أكـبرُ
~~١٠٤ - فإنهـا تثبـت فعـلَ العبـدِ   من دونما تعسفِ أو جَحْدِ
~~۱٠٥- وهـذه حقيقـة لاتُجحـدُ   بـأن أفعـال العبـاد ترصـدُ

PageV03P032

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0033.png)

~~۱٠٦_ نعبدُ ربنـا ونستعينُ   بهـا صـلاحُ أمرنـا يكـونُ
~~۱٠٧- فَنِصْـفُها لِرَبّنا تعـالی   ونصـفها الثـاني لنـا إفضـالا
~~١٠٨ - عبـادة بالحب والخضـوع   والخـوف والذلـة والخشـوعِ
~~۱٠٩ - لأن مَن أحَبَّ غير خاضعِ   لم يكُ عنـد ربـه بطـائعِ
~~۱۱٠- وخاضعٌ مِن دون حبِّ ما عبدْ   وإن يكن حج وزكى وسجد
~~۱۱۱- ثم استعانةُ بربنا الأحدْ   قد جمعت أصلين فيهما الرَّشَدْ
~~۱۱٢- وُثوقُنا والاعتماد مطلقا   رجـاء أن تكـون ممـن وفقا
~~۱۱٣- نعبده حقـاً ونستعينُ   لأنـه الإلـه والمعينُ
~~١١٤- وكونها غايةً كل من خلق   وهي علامة امتثال مـن صدق
~~۱۱٥- وأنهـا حق له علينـا   والعـون مـن إحسـانه إلينـا
~~١١٦ - وأنهـا شكر عـلى الإنعـام   والعـون إفضـال عـلى الأنـام
~~۱۱٧- وكـلُّ مَـنْ بِرِقَّها تحققاً   ينـال عونـاً كـاملاً ومطلقـا
~~١١٨ - والنقص في العون وفي السعادة   بقَـدْرِ نقص العبـد في العبـادة
~~۱۱۹- وللعبوديـة عونان بهَا   يكـون كـل عابـد في المنتهَـى
~~۱٢٠ - إعانـةٌ مـن قبلهـا تُسَـهَّلُ   وبعـدها إعانـة تكمـل
~~۱۲۱- وهکذا حتی یلاقي رَبَّهُ   ويترك الـدنيا ويقضي نحبه
~~١٢٢- وهـذه خلاصـة الأسرار في   تقديمه (نعبد) فافهم واعرف
~~۱٢٣ -وَقُـدَّمت إياك للإرشـاد   لـلأدب اللائـق بالعبـاد
~~١٢٤ - وفيه إيذانّْ بالأختِصِـاصِ   ودعـوةُ العبـاد للإخـلاصِ

PageV03P033

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0034.png)

~~١٢٥ - وان في (إيـاك) بـالتَكْرَارِ   وهكـذا إعـادة الإضـمارِ
~~١٢٦ -مِـن شِدَّة الإجـلال والإكبارِ   ما ليس في حذفٍِ ولا اختصـارِ
~~۱٢٧-ثـم تعلُّـق الأمـورُ كُلُّها   بكـل فعـل منهما يـا ذا النُّهـى
~~۱٢٨ - انقسـم النـاس إلى أقسـام   في طلـب العـون مـن العـلام
~~۱۲٩ - اَوَّهُم بَرَبَّـه استعاناً   عـلى العبـادات كـما أبانا
~~١٣٠ - لـذاك كـان أفضلُ السؤالِ   أن نسـتعينَ الله ذا الجـلالِ
~~۱٣۱- وخير إنعـام عـلى الإطـلاقِ   إسعافُنا بـذا مـن الخـلاقِ
~~۱۳۲ - وإِن ثـاني هـذه الأقسـام   مـن أعرضوا عـن ربنا العـلام
~~١٣٣ - لم يعبدوا المـولى ومـا أطـاعوا   بـل أوغلوا في بغيهم فضـاعواً
~~١٣٤ - وأنهـم بـالله مـا استعانوا   إلا لمـا للـنفس فيـه شـانُ
~~۱٣٥ - أمـا عـلى مرضـاة ربهم فلا   وهـو الذي يمـدهم تفضـلا
~~۱٣٦ - يجیب من ناجاه أو ناداهٔ   أجـاب إبلـيسَ وقـد أخـزاهُ
~~۱٣٧ - ولم يكـن هـذا مـن العطـاءِ   بـل غايـةَ الإبعـاد والإقصـاءِ
~~۱٣٨ - وليس كل من اُجِيب أُكْرِما   بل قـد تكـون للهـلاك سُـلَّما
~~۱٣۹- والله قـد يمـنح مَـن أهانـا   والمُتقـي يَحرِمـه امتحانـا
~~١٤٠ - وليس يدري حكمةً العطاءِ   والمنع إلا اللهُ ذو الآلاءِ
~~١٤١- ورُبَّما يظـن شخص يجهلُ   لمـا يـراه أنَ ذا لا يَجمُـلُ
~~١٤٢ - يقول يقضي للشرار الوطرا   ونحن لا تعصي ونحيا الضررا
~~١٤٣- فـلا تعاتبْ مُجْرِيَ الأقـدارِ   فإنـه العـالم بـالأسرارِ
~~١٤٤- بَلْ عَاتِبِ النفسَ وقل لا تجزعي   وسَلِّمي لذي الجـلالِ وافجَعي

PageV03P034

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0035.png)

~~١٤٥- فالعاقل الحصيف خصم نفسهِ   يعـيش في جـو الرضـا وأنسهِ
~~١٤٦- ولا تسل مُعَيَّنـاً تجهـل مـا   عاقبـةُ الأمـر بـه فتنـدما
~~١٤٧- بـل فوّض الأمـر إلى باريكـا   يمنعك المطلـوب أو يعطيكـا
~~١٤٨ - علقه بالعلم الإلهي واستخر   فكل شيء عند ذي العرش قُدِرْ
~~١٤٩- وكـن بهـا في غايـة التسـليم   تسعد بـالخيرات والتكـريم
~~١٥٠ - وإن حبـاك الله مـا لم تَسْـأَلَِ   فاجعل عطاء الله خير موصل
~~١٥١ - مُبلَّغاً إلى رضا مَـن أَكرَمكْ   فإن حبـاك ذاك حقـاً نعَمكٌ
~~۱٥٢- فليس بالمـال ولا بـالفقرِ   إكرامـه النـاسَ وَوَضْعُ القـدرِ
~~١٥٣ - وإنما المنـع أو العطـاءُ   مـن ربنـا لخلقـه ابتلاءُ
~~١٥٤ - وذاك واضحْ بآي الـذكرِ   كما أتـى مبيّنـاً في (الفجـرِ)
~~۱٥٥ - فكم کفـورِ ربُنا أغناهُ   وكـم تَقِـيّ مفلسـاَ تراهُ
~~۱٥٦ - فليس من أعطاه مالاً أكرمهٔ   ولا أهـان مـن لفقـر أسـلمهٔ
~~١٥٧ - وإنـما الـذي الإلـه أكرمـه   أرشـده لحبـه وفهَمهْ
~~۱٥۸ -حتی غدا موفقاً وشاکرا   وعارفـاً لربـه وذاكـرا
~~۱٥٩- وكل من أعرض عنه اللهُ   فقـد أهانـه وقـد قـلاهُ
~~١٦٠-وان تـوفرت لـه الأمـوالُ   وحُقَّقت لنفسـه الآمـالُ
~~١٦١- لأنـه في لجـةِ الشـقاءِ   وأشنع البأسـاء والـبلاء
~~١٦٢ - وثالث الأقسام قسم عبدا   بـلا استعانةٍ ففي الـنقص غـدا
~~١٦٣- وهـؤلاء في الـورى قسـمانِ   مـن شكّكوا في قـدرة الـرحمنِ
~~١٦٤ - قـالوا بأن ربنا قد فعلا   جميع مـا يقـدره وأكمـلا
~~١٦٥ - وأنـه لم يبـقَ بالإمكـانِ   إعانـةٌ لأيَّـما إنسـانِ
~~١٦٦- أعـانهم بخلقه الآلاتِ   سـليمة التعويـق والآفـاتِ

PageV03P035

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0036.png)

~~١٦٧ - ودلّهم على الطريـق الواضح   بكـل مرسـل أمـين ناصح
~~١٦٨ - ومكَّن الإنسان مـن أن يعملًاً   ليس لـه مـن بعـد ذا أن يسـألا
~~١٦٩ - قالوا استوى في الأمرذا من والى   ومـن يعـادي ربّه تعـالى
~~۱۷۰_ فعـونهم متحـد المقـدارِ   إيمانهـم والكفـر باختيـارِ
~~۱۷۱ _ ولـيس للتوفيـق دخل فيهِ   فـانظر إلى ضـلالهم والتيهِ
~~۱۷۲ - وناقضوا التوحيد بالتكذيبِ   بالقـدر المحـتَّم المصـيبِ
~~۱۷٣_ ثـانيهما مـن لزمـوا الأورادا   واتخـذوها للقلـوب زادا
~~١٧٤ - والنقص في استعانة منهم ظهرْ   وفي توكـلِ فهـم عـلى خطرْ
~~١٧٥ - لهـم مـن التوفيق حظ وبهمْ   شيء مـن الخذلان قَدْرَ نقصهمْ
~~١٧٦ - ولـو توكّلوا على الله الأَجَلْ   أعـانهم ولـو عـلى نقـل جبـل
~~۱۷۷ - والعلماء عَرَّفـوا التـوكّلا   بأنَـه حـالُّ لِقْلـبِ امْـتَلاَ
~~۱۷۸ - معرفـةً بمـن لـه التفرهُ   بـالخلق والأمـر العظـيم الأحـدُ
~~۱۷۹-مـا شـاءه الله تعـالی کانـا   ولم يكـن مـا لم يشـأ مولانـا
~~۱٨٠ -واِن هذا مُوجِبْ لمـن عَبَدْ   تفويضه الأمـرَ لربه الصـمد
~~۱٨۱ - معتمـداً في أمـره عليهِ   ومطمئنـا راغبـا إليه
~~۱۸۲ - وموقنـاً بأنـه کافیهِ   وصارفاً عنـه الـذي يؤذيـه
~~۱۸۳ - فحاله کمثل طفلِ قد غدا   للأبـوين كـلّ أمـر مسـندا
~~١٨٤ - فالقلب هذا زانه التجردُ   لأنـه لربـه موحـد
~~۱٨٥ - هـذا مثـالُ صـادقِ التوكـلِ   في حالـه وقولـه والعمـلِ
~~١۸٦ - ورابع الأقسام قسـم شهدا   لربـه بأنـه تفردا
~~۱٨٧ - بـالنفع والضر ومـا يشـاءُ   تبـارك اللهُ لـه البقـاء
~~۱۸٨ - ولم يَدُزْ مع الـذي يرضـاهُ   ثـم اسْـتَعان للـذي رجـاهُ

PageV03P036

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0037.png)

~~١٨٩ - من شهوات النفس والأغراضِ   وعن سواها عـاش في إعـراضِ
~~۱٩٠ - فنـال مـا يرجـو به النفاسةٔ   كالجـاه والأمـوال والرياسـةٌ
~~۱٩۱- وربما نـال مـن الأحـوالِ   كالكشـف والتـأثير بالأفعـالِ
~~۱٩٢-لکنها من دون أي عاقبةٔ   لأنهـا مـن الأمـور الذاهبـة
~~١٩٣- من جِنْسِ بَهْرَج الحياة الظاهرِ   ولم تكـن حقـاًَ مـن المفـاخرِ
~~١٩٤ - لأنـه لم يحصـل القـرب بهـا   ولا ولايـة لمـن خُص بهـا
~~۱۹٥- بـل إنها تُعطـى لكل کـافرِ   ومـؤمن ومـارق وفـاجر
~~١٩٦- ومـن یكن بمثل ذا استَدَلاً   لحب ربه لـه قـد زلاً
~~۱٩٧ - وصاحب الملك الذي ما آثَرَهْ   يلحقـه بالعـادلين البررة
~~١٩٨ - ومُـؤثِر الأهـواء والأمـوالِ   إلى هـلاكٍ وإلى وبـالِ
~~١٩٩- وإن في (إياك نعبد) انحصرْ   حقيقـة اتبّاعنـا لمـا أمـرْ
~~٢٠٠- بكامـل الإخـلاص للغفـار   وباتبـاع المصـطفى المختـار
~~۲٠۱- (صلی عليه الله ما نورٌّ بدا   بضـوئه في الظلـمات يُهْتَـدَى)
~~۲٠٢ - وانقسم الناس هنا لأربعة   فـا لأول المخلـص في المتابعـة
~~٢٠٣ - أعمالهم مـن باطنِ وظاهرِ   جميعهـا لوجـه ربي الشـاكرِ
~~٢٠٤حلم يطلبوا الجـزاء مـن أي أحد   إلا مـن الـرحمن ربنـا الصـمدْ
~~٢٠٥- أو يعملـوالمـدح أي مـادح   أو هربـاً مـن ذم أي قـادح
~~٢٠٦- بـل إنهم قد نظروا للناسِ   كـأنهم في بـاطن الأرمـاسِ
~~٢٠٧- لايملکون نفعهم أو ضرّهم   بل ربما کان احتياجهم لهم

PageV03P037

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0038.png)

~~٢٠٨ - وكـل عامـل لأجـل النـاس   يعـيش في حبائـل الخنّـاسِ
~~۲٠٩- وعارف بالناس يخلص العمل   ينزل كل واحدٍِ حيث نـزلْ
~~۲١٠ - يـؤثر ربـاً مُجْزِيـاً يوفق   ويحـذر النـاس لكـي لا يُخفقُ
~~۲۱۱_ فهـو موافـق لمـا أرادا   وطالـب مـن ربـه الإمـدادا
~~۲١٢ - والله لا يقبـل إلا الأحسـنا   الأصـوب الأخلص ممـن آمنـا
~~٢١٣- عـلى طريـق المصطفى الأواب   ونهجـه السـديد والكتـاب
~~٢١٤- مـا لم یکن کذا یکون رداً   كـما أتـى عـن النبـي مسـندا
~~٢١٥ - وثاني الأقسام قسم ما اهتدی   ولم يكـن بمخلـصٍ ولا اقتـدى
~~٢١٦ - وهـؤلاء هـم شرار الخلـقِ   وأمقـتُ النـاس وأهـل المحـقِ
~~٢١٧- بـلا مفـازةِ مـن العـذابِ   كـما أتـى في محكـم الكتـابِ
~~۲١٨- قـد فرحـوا بسيء الأعمالِ   من بِدَع نُکری ومن ضلالِ
~~۲١٩- وقـد أحبوا الحمـد لا لِفِعـل   لكـن لـداء كـامن وجهـل
~~۲۲۰ - والقسم ذا يكثر فيمن انحرفْ   ممـن يُرائـي أو بدينـه احترفْ
~~۲٢١- ومـن إلى العلـم وفقر نُسبوا   لكنهم للحـق قـد تنكبـوا
~~۲۲۲ - وثالث الأقسـام قسـم أفلسا   لكونـه في الاقتـداء انتكسا
~~٢٢٣-مخالفـاً لسـنة وواجـبِ   يظـن في الحـرام بعض القـربِ
~~٢٢٤ - كتركه الجمعـةً أي مـن حالِ   وصـومه في العيـد للكـمالِ
~~٢٢٥ - والرابـع المتـابع المرائـي   بـدون إخـلاص ولا رجـاءِ
~~٢٢٦ - كقـارئ القـرآن والمجاهـدٍِ   لكي يقـال: يـا لهـذا الرائـدٍِ

PageV03P038

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0039.png)

~~۲۲٧- وأفضـل الأنـام في (إيـاك   نعبـدُ) يـا رَبَّـاهُ لا سـواكا
~~۲٢٨-أتـوا عـلى أربعـة أصـنافِ   خـذها بتفصـيل مفيـدٍ وافي
~~۲۲۹- فـالأول العُبَّـاد بالأشـقِّ   لكونـه يُصـلحُ أمـر الخلـقِ
~~۲٣٠ - وأجـره أرفع للمجتهـدِ   وأنه حقيقـة التعبـد
~~٢٣١- والنفس ان لم تكُ حقاً جوهدتْ   مالت إلى راحتهـا وأخلـدتْ
~~۲٣٢- فالتَزَمُوا بمتعبـات الأنفسِ   لتسـتقيم دونما تـنكسِ
~~۲۳۳ - دليلهم أفضـلها أحمزها   مرفوعـةً تروى ولا أصـل لهـا
~~٢٣٤ - وثـاني الأقسام قـالوا الأفضلُ   تجـردٌ والزهـدُ والتقلـلُ
~~٢٣٥- بـلا اهتمام وبـلا اکتراثِ   بـذاهب الـدنيا ولا بـآتي
~~۲٣٦_وَمِنْهُمُ عَـوَامُ تَنَسَّكُوا   لجهلهـم بما به تمسّكوا
~~۲٣۷- والعـارفون صرحـوا بالمقصدِ   مـن زهـدهم وسـائر التعبـد
~~۲۳۸- بأنـه عكـوفهم بالقلبِ   حقـأَ عـلى الـرب بكـل الحـبِّ
~~۲٣٩- وأنهـم في غايـة المراقبة   وَجَمِعِهـمْ للقلب والمحاسبة
~~٢٤٠- مـع اشتغالهم بما يرضيهِ   والصـدقِ في توكـلِ عليهِ
~~٢٤١- والذکرِ دائماً بكـل آنِ   بـالفكر والقلب وباللسـان
~~٢٤٢ - وثالث الأقسام في نفع الورى   مـن جـد في نفع لهـم وشمَّرا
~~٢٤٣- اشتغلوا بـنفعهم للنـاس   بهمـة المحسـن والمـواسي
~~٢٤٤- وبـذلوا الجـاه مع الأمـوالِ   ولم يقصـروا بـأي حـالِ
~~٢٤٥- واحتج هـؤلاء بالصريحِ   مـن حسَـن الحـديث والصحيح
~~٢٤٦- في أن خير الناس من لهـم نَفَعْ   ومـن لضبرِ نـازلٍ بهـم دفعْ
~~٢٤٧- وأن كـل الأنبيـاء أحسـنوا   نفع العبـاد كلّهـم وأتقنـوا

PageV03P039

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0040.png)

~~٢٤٨ - ورابع الأقسام قسم فَصَّلا   بمقتضى الوقت ومـا قـد نزلا
~~۲٤٩ - بوفـق مـا يريـده مـولاهُ   لـيس بقصـد العبـد أو هـواه
~~۲٥۰- فحيـنما يلزمنـا الجهـادُ   فإنـه الأفضـل والمـرادُ
~~۲٥١- فـلا یجـوز قط أن يُؤَخرا   ولـو عـلى شيءٍ سـواه أثّـرا
~~۲٥٢- وواجب الوقت إذا الضيف نزل   إكرامـهُ ولا يدانيـه عمـل
~~٢٥٣- وواجب الأوقـات في الأسحار   صـلاة خشـية مـع استغفارِ
~~٢٥٤- وحيـنما يـؤذن المـؤذنُ   ترديـدنا عـلى سـواه أحسـنُ
~~٢٥٥- ثم الصـلاة بعـده وما لها   مـن عمـل بـه يـتم فعلهـا
~~٢٥٦ - وواجب لطالب مسترشدِ   إسـعافه بـالعلم كـيما يهتـدي
~~۲٥٧- وان يکن شخص لعون طلبا   وكـان مضطراً لأمـر حزبا
~~۲٥٨ - فحقـه العـون بـلا إهمـالِ   بالجـاه والنصح وبـذل المـالِ
~~٢٥٩- وواجب التَالِين جمع القلبِ   لفهـم مـا حـواه خـير الكتـبِ
~~۲٦٠ - بهمـة حتـى كـأن التـالي   يخاطـب الـرحمن ذا الجـلالِ
~~٢٦١ - ورمضـان الموسـم الكبـيرُ   فحقـه الصـيام والتشميرُ
~~۲٦٢ - وإن أصـيب مسـلم بالسَّـقَم   زرزهُ اتباعـاً للنبـي الأعظـم
~~۲٦٣ - وإن يمـت بـادر إلى التشـييع   فـإن ذاك آخـر التوديع
~~٢٦٤ - والصبر عنـد الضيق والنـوازلِ   والاعتـداء مـن غشـوم جاهـلِ
~~٢٦٥ - وخَـالِطِ النـاسَ لخـيرِ يُؤمَـلُ   واعتزل النـاس إذا مـا جهلـوا
~~٢٦٦ - وكـن مؤاثراً لـذي الجـلالِ   في سـائر الأوقـات والأحـوالِ
~~٢٦٧ -تَرْتَـعُ في منـازل التعبـدٍِ   بـلا تقيـد بنـوع واحـد
~~٢٦٨ - فَنَفْسُ هـذا الشخص في إقبالهـا   إن رفعـت منزلـة مضى لهـا
~~٢٦٩ وهكذا حتى انقضاء العمرِ   ولم يكن من ضمن أهل الخُمدرِ

PageV03P040

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0041.png)

~~٤٠
~~٢٧٠ - أيضـاً ولا تملكـه الرسـومُ   ولا القيـود والهـوى المـذمومُ
~~۲۷۱- بـل إنه عـلى مـراد ربهِ   والمصـطفى ولم يزغ عـن دربـهِ
~~۲٧٢- وإن في (إيـاك نعبـد) اتضخْ   سلوكُ عبد صِـدْقُهُ بهـا طفحْ
~~٢٧٣- أيضـاً وفي (إيـاك نستعينُ)   دلائـلُ لفضـله تُبـينُ
~~٢٧٤- فهـو بـأمر الله في اشـتغالِ   ولـيس بـالنفس ولا بالمـالِ
~~۲۷٥- يدور حيث دار أمر الصمدِ   بالحب والإخـلاص في التعبـدٍِ
~~۲٧٦- مأكله والشرب ما تیسّرا   وَزِيـهُ أيُّ لبـاسِ سـتَرا
~~۲۷۷- فإنه كالغيث حقـاً نفعـا   ولـو عـلى سـباخ أرض وقعـا
~~۲۷۸- وإنه لله دومـاًوَبِهِ   وهو مع الله بكـل الولـه
~~۲٧٩- ان تنتهـك محـارم الإلـهِ   يكـون خـيرَ آمرٍ ونـاهي
~~۲۸۰ - قـد صحب الله بـلا خلائقِ   وعـاش لله بحـب صـادقِ
~~۲۸۱ - وصحب الناس بدون نفسِ   مستوحشاً منهم لأجـل الأنس
~~۲۸٢ - وإنما یلتذِّ بـالإيمانِ   وأنسـه بالواحـد الـديان
~~۲۸۳- ولـذة العُبَّـادِ شيء عَظُـما   لكـنما الجـبري منهـا حُرِمـا
~~٢٨٤ - لكونه ينفـذ الأمـر فقطْ   فيـا لسوء الفهـم منـه والغلط
~~۲۸٥- وليس للإله حب عنـدهمْ   وإنما المحبـوب مـا ينـيلُهمْ
~~٢٨٦- وعكس جبري نفاةُ القَدَرِ   وكلهـم مـن غيّهم في خطر
~~٢٨٧- الموجبـون أصـلح الأمـورِ   عـلى الحكـيم المـنعم الغفـورِ
~~٢٨٨- أمـا العبـادات فقـالوا: إنَّها   أثـمان أفعـال يجـازَون بهـا
~~٢٨۹- فهـؤلاء هـم مَجـوسُ الأمةِ   لم يـذعنوا لـربهم بالمنـةٍ
~~٢٩۰ - وغیر هؤلاء مـن تفلسفا   من أجل إصلاح اعوجاج وجفا

PageV03P041

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0042.png)

~~۲۹۱- قالوا العبادات رياضات لنا   حتبى نكـون للعلـوم معـدِنا
~~۲٩٢- وأفضـل العُبّاد في الطوائفِ   كـلِّ تقـي راغـبِ وخـائفِ
~~٢٩٣- مقتفيـاً نهـج النبـي المقتـدى   وآلـه وصحبه أهـل الهـدى
~~٢٩٤- من دون جبر موجب للخطرِ   أو انخـداع بنفـاة القـدرِ
~~۲٩٥ - عبـادة الله هـي الفـلاحُ   بهـا سـمؤُ العبـد والنجـاحُ
~~٢٩٦ - أركانُهـا أربعـة لا تـنقصُ   وإنما يقيمهـا مـن يُخلصُ
~~۲٩٧- القـولُ بالقلب وباللسـانِ   فـذانك اثنـان مـن الأركـانِ
~~٢٩٨- وعمـلُ القلـوب والجـوارح   والرابع الفعـل بعـزم طـامح
~~۲٩٩ - فـالقول بالقلب اعتقـاد العابدِ   فرديـةَ الله العظـيم الماجـدَ
~~٣٠٠- وباللسـان دعـوةُ العبـادِ   والذَّبُ عـن ديـن النبي الهـادي
~~۳٠۱-وذكرُه وشكرُه لربهِ   مبلغـا لنهيـه وأمره
~~٣٠٢ - ومُنكِراً إحداثَ أهـل البدع   محـذراً مـن كـل مـا لم يُشرعِ
~~٣٠٣- والقلـبُ مـن أعماله التوكـلُ   والحبُّ والإخـلاصُ والتـذللُ
~~٣٠٤- وغيرُهـا كالصـبر والخشـوع   والصـدقِ والرجـاءِ والخضوعِ
~~٣٠٥- وعمـلُ الجـوارح الصـلاةُ   والصـوم والجهـاد والزكـاةُ
~~٣٠۶- وغيرُهـا مـن سـائر الأعمالِ   كـالحجِّ والإنفـاقِ للأمـوالِ
~~٣٠٧ - إن العبوديـة ذروة الشرف   جزاؤُهـا جنـات عـدن والغرفْ
~~۳۰٨- وإنهـا أشرف وصـف وردا   لأفضلِ الخلق مصابيح الهـدى

PageV03P042

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0043.png)

~~۳٣٠٩- مِن مَلَك ومِن نبي مرسلِ   وعابـد وعـالم مبَجـلِ
~~٣١٠ - فالأمن والبُشرى بها قد وعدوا   من ربهم وأیدوا وسُددوا
~~۳۱۱- وليس للشيطان من سلطان   عليهم فضـلا مـن الرحمن
~~٣١٢- وإنهـا في الـدين أعـلى مرتبـة   يعلـو بهـا المـؤمن أعـلى عقبـة
~~۳۱۳- مطلوبة دوماً بکل حين   إلى وفـاة العبـد بـاليقين
~~٣١٤- فإنه المـوت كـما تحققـا   وهو مقامٌ عنـد مـن تزندقا
~~۳۱٥- تسقط كل الواجبات فيه   فيا له مـن ملحـد سفيه
~~٣١٦- ثـم العبوديـة في التقسـيم   نوعـان: ذو الخصوص والعموم
~~۳۱۷- يعـم کـلَّ مسلم وکافر   والكـون كلـه بـدون حـاصر
~~٣۱٨- وهـذه العبـادة القهريـة   ثم التي خصت هي الطوعية
~~۳۱۹- وهـي عبـادة امتثـال وورع   مـع التـزام كـلّ مـا الله شرع
~~۳۲۰- وأهلهـا حقـاً عبـادُ الله   طوعـاً وكَرْهـاً دونما مضاهي
~~۳۲۱- ولا يضـاف للإله غيرُهم   لأنهـا تشريفُه السـامي لهـم
~~٣۲۲- وللعبوديـة في العلـم رُتَـب   وهكذا في عمـلِ بهـا وجـب
~~٣٢٣- في كل نوع منهما ثنتان   يرقـى بهـا الإنسـانُ في الإيمان
~~٣٢٤- أمـا التي في العلم فهي علمُنا   بالله والدين الـذي ارتضى لنا
~~۳۲٥- ودينُه الشرعيُ أي بحما أمر   وبـالجزائيٍّ بخـيرٍ أو يشَرّ

PageV03P043

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0044.png)

# ٣)
~~٣۲٦- وبعد هذا العلـم يأتي العمل   مرتبتـان هكـذا تُفَصَّـل
~~۳۲٧- فالسـابقون أولُ الأقسـام   مَـنْ أكرمـوا بأفضـل الإنعـام
~~٣٢٨- اِذ فعلـوا مفروضَهم تمامـا   وتركـوا المكـروه والحراما
~~۳۲٩- والتزمـواسنة خير البشر   وجـانبوا كـل أمـور الخطـر
~~٣٣٠- ثـانيهما: أهـل اليمين فـاعلم   في غايـة البعـد عـن المحـرم
~~۳۳۱-وشدةِ الحرص على ما وجبا   وربـما قصَّرَ فـيما نـدبا
~~۳٣۲-ثم المباحات لدى القوم هيهٔ   من جملة الطاعات أضحت بالنيَهْ
~~۳٣٣-حتی غدت فيهم تُنَمَّي الخيرا   تزيـد في قلـوبهم تنـويرا
~~٣٣٤ - فيرتقـون في معـارج الهـدی   مـن جملـة الأبـرار أهـل الاقتـدا
~~٣٣٥- في كـل حـال يعبدون ربهم   بكـل أمـرٍ شرَع الله لهـم
~~٣٣٦- مـن حبه والـذلَّ والخضوع   وكامـل الإسـلام والخشـوع
~~٣٣٧- في الحقـل والبيـوت والمضـاجع   وفي متـاجر وفي المصـانع
~~۳٣۸ - ومـا حَبَا أو ابْتَلى أَوْقَدَرا   قد جعلوهـا لرضـاه مَعْـبَرا
~~۳۳۹-فسـائر الأعـمال منهم راجحة   أهـدافهم حميـدة وناجحـة
~~٣٤٠ - وأهـل هـذين المقـامين لهـم   من درجات الفضل ما يخصهم
~~٣٤١-وليس يحصيها سوى الله أحد   لأنهـم مـن خـير مَـن لـه عبـد
~~٣٤٢- إن العبوديـة خير قائـد   وإنهـا قامـت عـلى قواعـد
~~٣٤٣-خمسـة عشر بلغت في العـدد   يعرفهـا في النـاس أهـل الرشَـد
~~٣٤٤- بيانهـا في شرح أي شـارح   تقسيمها للقلب والجـوارح
~~٣٤٥- ثم اللسانِ يا عظيم الشان   هديت للإخـلاص والإيقـان

PageV03P044

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0045.png)

~~٣٤٦- فالقلـب واجباتـه قسـمان   محـتَّم الوجـوب ثـم الثـاني
~~٣٤٧-مختلَـف فيـه فأمـا الأول   إخلاصـنا لله والتوكـل
~~٣٤٨-محبـةٌ والصـبر والإنابـة   والخوف والرجـاء فاطرق بَابَهْ
~~٣٤٩- وجـازمُ التصـديق ثـم النيـة   فهـذه العبـادة القلبية
~~٣٥٠- والنصح أيضاً واجب تحتَما   وهـو مـدار ديننـا الـذي سـما
~~٣٥١- والصبر واجب كذا بلا مِرا   يعلمه الأميُّ مثـلَ مـن قرا
~~٣٥۲- وکلما قد مر ممـا وجبا   ذو طرفين زَكَيـا وهـذَبا
~~٣٥٣- أولهـا الواجـب ثـم الثـاني   العمـل المنـدوب للإنسـان
~~٣٥٤- فاجعـل لأصحاب اليمـين الأولا   وللمقربين مـا لـه تـلا
~~٣٥٥- ثم الذي فيه اختلاف كالرضا   أوجبَـه بعض وبعـض رفضـا
~~٣٥٦- والاختلاف في القضاء الكـوني   ولـيس في الرضـا بـأمرِ دينـي
~~٣٥٧- مثـل الرضـا بأنه الرب لنـا   فإنـه شرط لمـن قـد آمنـا
~~٣٥٨- فـلا يكـون مؤمنـاً إلا به   وبالرضـا بالمصـطفى وحبـه
~~۳٥۹- وكل ما فيه خلاف حصلا   فهاكـه مبيّنـاً مفصـلاً
~~٣٦٠ - خشـوعُنا لله رب النـاس   إعـادة الصـلاة مـن وسواس
~~٣٦١ - وان يك المرء رعـى الجوارحـا   وللعبوديـة أضحى طارحـا
~~٣٦٢- يكون قد عطَّل حظَّ الملِك   فمالَـه إلى العـلا مـن مسـلك
~~٣٦٣- ثم المعاصي بعضها الكبائر   وبعضـها الخسـائس الصـغائر
~~٣٦٤- وهـي على نوعين إما معصية   أو أنهـا كفر وهـذي القاضـية
~~٣٦٥- فالكفر مثل الشك والنفاق   والشـركِ بـالمهيمن الخـلاق

PageV03P045

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0046.png)

# ٤٥)
~~٣٦٦- محرمات القلب مـا بها فسد   كالكبر والعجب وحقـد وحسد
~~٣٦٧ - وأمنِ مكر الله فاحذر تسلم   وأن تُسَرَّ بـالأذى لمسـلم
~~٣٦٨ - واليأس مـن رحمـة ربي الغـافر   فهـذه مـن جملـة الكبـائر
~~۳٦۹ - وكل نُکر كان ينوي عمله   لكنـه لمِـانع مـا تـم لـه
~~۳۷۰_ یکون مأثوماً به کمن فعل   لأن عزمـه عـلى الفعـل حصـل
~~۳٧۱- لا يصلح القلب بدون تركها   أو توبـة منهـا إذا قارفهـا
~~٣٧٢- إن لم يكـن ذلك فالقلب فسـد   ثـم سرى فسـادُه إلى الجسـد
~~۳۷٣_ لجهلـه بواجبات ربه   وجهلـه بشرعه وحقـه
~~٣٧٤-ثـم العبوديـة باللسـان أن   ينطـق بالشهادتين بـالعلن
~~٣۷٥- ويتلو القرآن قدرَ ما وجب   لصحة الصـلاة يـا عـالي الرتب
~~٣٧٦- والنطـق بالأذكـار والتشهد   ونهيـه عـن منكر ومفسـد
~~۳۷۷- والأمر بالمعروف يا من اهتدی   وردُّ تسـليم عـلى الـذي بـدا
~~۳۷٨۸- وبـذلنا العلـم لأي جاهـل   والصدق في القـول وفي التعامـل
~~۳۷۹_ وهكذا أداؤنـا الشـهادة   فإنهـا مـن أفضـل العبـادة
~~۳٨٠- ثـم الـذي استحب للسـان   إكثارنـا تـلاوةً القرآن
~~۳۸۱- وذکر رب العرش ذکراًدائماً   مـذاكراً لكـي يكـون عالمـا
~~۳۸۲-حرامه النطـق ببدعـة غـدت   على خـلاف مـا به الرسـل أتت
~~٣۸٣ - والقذف والزور وسب والكذب   وكـل إيـذاء بقـول ارتكب
~~٣٨٤- وشرهـا القـول بـما لم نعلم   عـلى إلهنـا العـلي الأعظـم
~~۳۸٥- فهـذه حصـائد اللسـان   بهـا يكب المـرء في النـيران

PageV03P046

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0047.png)

~~٣٨٦- وكلما تـرك الكـلام فيه   خير غـدا مـن جملـة المكروه
~~۳۸۷- وكل ألفاظ اللسان تُكتب   وكلهـا مرصـودة وتحسب
~~٣٨۷- والله لا يظلـم أي نـاطقمثقـالَ ذرة مـن الخلائـق
~~۳۸۹- ثـم العبوديـة بـالجوارح   خمس وعشرون بِعَدٍ واضح
~~٣٩٠-خمس على السمع، وعين خمس   ومثلهـا ذوق وشـم لمس
~~٣٩۱- فـالأذن إنصـات عليها وجبا   لكـل مـا الله علينـا كتبـا
~~٣٩٢- والكف عن سماع كفرِ والبدع   إلا لمـن ينصحهم ومـن ردع
~~۳٩٣- أو لشـهادةِ عـلى مَـن قـالا   فَجانـب الضُّـلالَ والجهَـالا
~~٣٩٤- وهكذا سماع صوت النسوة   الأجنبيـات لغـير حاجة
~~٣٩٥- وآلـة اللهـو مـن المحظـور   كـالعود والمزمـار والطنبـور
~~٣٩٦- والمستحبُ نحو علم يسمع   وكـل مـا ينفع مـن يستمع
~~۳۹۷- وعكسه المكروه فاعرف واعلم   ثم المبـاح مـا سـوى ذا فـافهم
~~۳۹۸- وبعده فاعلم بما للنَّظرُ   ومن خطير اللحظ منه فاحـذر
~~۳۹۹- واجبه في مصحف وما غدا   مـن العلـوم واجبـاً مؤكـدا
~~٤٠٠ - وكلِّـما تمييـزه بـالعين   رؤيته حـتم وفرض عـين
~~٤٠١- لـيعلم الإنسـان بـالحلال   وبـالحرام دونـما إخـلال
~~٤٠٢- كمثـل مـا يأكلـه أو ينفـق   ومـا به استمتاعُه يحقـق
~~٤٠٣- ومـا تـولاه مـن الودائع   للـرد أو للحفـظ دون ضـائع
~~٤٠٤ - حرامـه بشـهوةِ إذا نَظَـرْ   للأجنبيـات فيـا لـذا الخطـرْ
~~٤٠٥- فـإن هـذا لا يجـوز مطلقـاً   ومـا يجـوز هاكـه محققا
~~٤٠٦ -لحاكم وشاهد ومشتري   معـالج وخاطب مستـبشر

PageV03P047

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0048.png)

~~٤٠٧ - هذا الذي استثني مما قد حَرُمْ   وفوق قـدر حاجـة فـلا تَرُمْ
~~٤٠٨- ومستحب في كتـاب نـافع   ومـا بهـذا الكـون مـن بـدائع
~~٤٠٩ - من كـل ما يـدعو إلى الإيمان   ويرتقـي بالعبـد للإحسـان
~~٤١٠ - مكروهه فاعلم فضول النظر   مـا لم يكـن يوقعنـا في ضرر
~~٤١١ - مباحـه مأمونـه في العاجـل   وسـالم مـن ضرر في الآجـل
~~٤١٢- ويجب الـذوق مع اضطرار   كالخوف مـن موت ومـن أضرار
~~٤١٣- فالأكـل والشرب لهـذا وجبـا   وما انتفى اضطراره قـد ندبا
~~٤١٤- مباحه طعام من دعاکا   والضيف آكلـه إذا أتاكـا
~~٤١٥-حرامه مـن سامَّ ومُسْكِرِ   وذوق صـائم لأي مفطـر
~~٤١٦ - مكروهه ذوقك ممـا اشتبها   وأكـل فجـأةً ولم تـدع لهـا
~~٤١٧ - والأكـل فوق حاجة قدكُرِهَا   إن كـان لا يلحقك الضـرُّ بهـا
~~٤١٨ - ووجب الشـم الـذي يـدلَّ   عـلى الـذي يحـرم أو يَحِـلَ
~~٤١٩- لعلمنـا بضـار كالسـم   وكـل شيء علمـهُ بالشـمِ
~~٤٢٠ - حرامه تعمـد التطيّـب   في حالـة الإحـرام يـا ذا الأدب
~~٤٢١ - ومثله المغصـوبُ والمسروقُ   وامرأة لعطرهـا عبـوق
~~٤٢٢ - مكروهه شـم لعطر الظلَمة   ومـن لديه شبهة مستحكمة
~~٤٢٣- ثـم المبـاح كـلَّ مـا لـيس بـه   شبهة تحـريم ولاعنـه نُهِي
~~٤٢٤ - ولمس مـن ليست تحل حُرَّمَا   لأنـه بـاب لشـرٍِ عَظُـمَا
~~٤٢٥ - ويسـتحب لمسـه للزوجـةِ   إذا رآه موصـلاً للعفـةِ
~~٤٢٦- وقـد يكـون واجبـاً إذا وقـى   مـن خطر حدوثه تحققا
~~٤٢٧ - لكنـه يُكـرَهُ في الإحـرام   وفي اعتكـاف العبـد والصـيام
~~٤٢٨ - مباحه ما ليس فيه مفسدة   خس وعشرون أتت مفندة

PageV03P048

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0049.png)

~~٤٢٩ - أهل السلوك بيّنوا وعدّدوا   منـازل السـير لمـن يسترشـد
~~٤٣٠ - فبعضـهم في مائـة أجملَهـا   وبعضهم للألـف قـد أوصـلها
~~٤٣۱-وكل شخص حسب فهمه وصف   وحاله وعلمه ومـا عرف
~~٤٣٢ - واصطلحوا أيضاً على أسامي   كالحـال والسـالك والمقـام
~~٤٣٣- وجعلـوالكـل سـائر صـفة   بحسب العلـم وقـدر المعرفـة
~~٤٣٤ - قالوا وقد ينسلخ الذي سلك   مـن المقامـات وربما هلك
~~٤٣٥ - فـلا يكُ الإنسـان في غـرور   بعلمـه وسعيه المـبرور
~~٤٣٦- والحال من ثمار علـم وجـدا   فـإن صـفا صـفا وإلا فسـدا
~~٤٣٧ - والعلـم مـن ثماره التوحيـد   والبر والإحسـان والتسـديد
~~٤٣٨ - على طريـق المصطفى المختار   وآلـه وصحبه الأبرار
~~٤٣٩ - وقال بعض القوم إنَّ المعرفة   أعـلى مـن العلـم وقـوم خالَفه
~~٤٤٠ - والفرق بينهـا وبـين العلـم   عند الألى فـازوا بحسـن الفهـم
~~٤٤١ - بأنهـا تشـابه التصـوُّرا   والعلـم كالتصـديق دونـما مِـرا
~~٤٤٢- والعلم في الإطلاق أضحى واسعا   وإنهـا بـالعكس عنـد مـن وعـى
~~٤٤٣ - والعلم نورٌ ضدُّه الجهل فكم   من غارق فيه يعيش في الظَّلَم
~~٤٤٤ - والله مـن أسـمائه العلـيم   وعلمـه المحـيط والعظـيم
~~٤٤٥- وأرشـد الرسـول للمزيـد   منـه لنرقى ذروة التوحيـد
~~٤٤٦ - صلى عليه ربنا وسلَّما   والآل والأصحاب مـا غيث هما
~~٤٤٧ - والسالكون انقسموا قسمين   حتی غدوا بین الوری حزبين
~~٤٤٨- فَلافِتُ لعلمـه بالحـال   والعكـس مـنهج الفريـق التـالي
~~٤٤٩ - وذاك من تقصير كل واحدِ   والحـال والعلـم سبيل الراشـد

PageV03P049

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0050.png)

# ٤٩)
~~٤٥٠ - وما سرى في الناس نقص وخلل   إلا بهـذا الفصـل جالـب الزلـل
~~٤٥١- ولـيس للمريـد مـن إرادة   في غـير مـا إلهـه أراده
~~٤٥٢ - وإنـما الواصـل مـن يـزداد   في العلـم والتقـوى فنعم الـزاد
~~٤٥٣_ وهـذه تسـمية اجتهـاد   من بعض أهـل العلـم والزهـاد
~~٤٥٤ - ومن يقل: للسير حد قد مرق   وإنه بـابَ الجحـيم قـد طـرق
~~٤٥٥- والأوّلـون مـن أئمـة السـلف   ممـن لمكنونـات ذا العلـم كشـف
~~٤٥٦ - قـد بيّنـوا وظـائف القلـوب   ومرضـيات عـالم الغيـوب
~~٤٥٧ - لكـن بـلا حصر ولا ترتيب   والحكـم بالأبعـد والقريـب
~~٤٥٨- واقتبسوا الأنـوار منه قبسـا   وأصلحوا القلب به والنفسا
~~٤٥٩ - والعلم بالتحقيق دون الحدس   عـن آفة الفعـل وعيب الـنفس
~~٤٦٠ - فافهم نصوصه بفهم صائبِ   وألـزم الـنفس بهـا وراقـبِ
~~٤٦١ - ودَعْكَ من تنطّع ممقـوتِ   واهـدٍ إلى الفـؤاد أشهى قوت
~~٤٦٢ - بوفـق سـنة النبي الأعظـم   والعلـم والتـدقيق والتفهم
~~٤٦٣ - وخذ مـن الأفهام كـل نافع   وعـن طريـق المصـطفى فـدافع
~~٤٦٤- صـلی عليه ربنـا وسلّما   وآلـه وصحبه وعظّما

PageV03P050

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0051.png)

~~١- وآنَ أنْ تشْـرَعَ في المنَـازِلِ   بعون ذي الطَّولِ الحكيم العادلِ
~~٢- أولهـا اليقظـة يـا ذا اللـب   وعرفوهـا بانزعـاج القلـب
~~٣- لروعـة انتباهـه لمـا عَـلا   ولم يكـن كالغـافلين سـافلا
~~٤ - بـل قـد أجـاب داعيَ الفـلاح   مشـمراً للخـير في انشـراح
~~٥- حتى غـدا يطـالع الأنـوارا   في أنعـم لربـه شكَارا
~~٦- لكونـه لا يستطيع عـدّها   كـلا ولا معرفـة بحـدها
~~٧- فَفَرَّغَ القلب لمـولى الكـرم   وأَلْزَمَ الـنَفْسَ بِحُـبّ المـنعم
~~۸ - للخير مـن رب العبـاد سـائلا   مستغفراً مـن ذنبـه وقـائلا
~~٩- أَبَوء يا رب الـورى بالأنعم   عَـلَيَّ يـا ذا الجـود يـا ذا الكرم
~~١٠- وبُؤتُ يا تواب بالذنوب   فاغفر إله العرش كـل حـوب
~~۱۱- قـد عـرف التقصير اِذ تَرَقَى   وأنـه لا يستحق حقا
~~١٢- واللهُ لو عَذَّبَ كُلَّ مَن خلَق   أو ابـتلاهم بالرزايـا وَمَحَـقْ
~~۱٣- فلـم يكـن بظـالم تعـالى   وإنـما يرحمهم إفضـالا
~~١٤- وَكُلُّ مـن أكرم بـالتنوير   ينظر للمنـة والتقصير
~~١٥- مُعْتَرِفاً بِكُلِّ ما قـد اقترف   وراجيـاً غفران ما منه سلف
~~١٦- مشمراً بعلمه والعمـل   مجانبـاً لموجبـات الزلـل
~~۱٧ - لكي يكون طيبـاً مؤهلا   الجنـة الـرحمن في أعـلى العـلى

PageV03P051

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0052.png)

# ٥١)
~~۱۸ - لأنهـا منـزل کـل طيب   ودار كـل مخلص مقـرب
~~۱٩ - وَكُلُّ مَنْ لَم يُحْسِنِ التَخْلِيصَا   وَلَمْ يَكُـنْ لِنُجْحِـهِ حَرِيصـاً
~~٢٠- يَنْقَـی بتوبـةِ أو استغفارِ   أو الرضـا بمـؤلم الأقـدار
~~۲۱_ وَرُبَما استفاد ذو تَقْصِـیرِ   بعـد المـمات مـن فِعَـالِ الغَـيْرِ
~~۲۲ - مثـل صـلاتهم عليـه والـدعا   ومـن لـه استغفر أو مـن شفعا
~~۲٣ - وقـد يكـون الجـبر للنقصـان   بضـمّةُ القـبر أو الفتـان
~~٢٤- والصـدقات والذي يهديه   أحبابه لنيـل مـا يعليـه
~~٢٥ - يليه هول الحشر حيث لم تفِ   وحين لم يكـف فبـؤس الموقف
~~۲٦ - وربما ذلك طُراً ما نفع   إلا بتعزيـز بشـافع شفع
~~۲۷_ وقد يكـون الكل غيرَ نافع   لشـدة العصـيان والشـنائع
~~۲۸- فعند ذاك ما له مُخَلَّصَا   إلا الجحـيمُ بعـد أن ينغّصـا
~~۲۹- فوجب العلـم بخـير الـزاد   ومـا بـه النجـاح في المعـاد
~~٣٠- والعلـم بالقـاطع والمـنكَّسِ   وحفظنـا للوقت بـل للنفس
~~٣١- وأنعـم الرحمن معطـي الجـزل   يعرفهـا المـرء بنـور العقـل
~~٣٢ - وَشَـيْمُ برقِ أنعـم العطـاء   مع اعتبـارٍ بـذوي الـبلاء
~~٣٣- وَهمْ ألو الغفلـة والذي ابتدع   فانظر إليهم لاتعاظ كي تدع
~~٣٤- فـذلك السر الـذي ينـير   قلبـاً إلى خلأَقِـهِ يطـير
~~٣٥ - وحـاصرُ النعمـة في الأبـدان   والأكـل والملـبس ذوخسـران
~~٣٦ - فَأَيْنَهُ مَـنْ نِعْمَـةِ العَـيْشِ مَعَ   طاعـة ربهِ ومـا قـد شرعا
~~۳۷- وذوقِـهِ لهـذه الطاعـات   والأنس بالـذكر مع الإخبات

PageV03P052

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0053.png)

~~۳۸- ومـن يكن بالنفس حقاً علما   والعجز والفقر الذي قـد لازما
~~٣٩- فإنـه يسـتعظم الجنايـة   والسـير في مسـالك الغوايـة
~~٤٠ - للعلـم بالوعيـد والإيمان به   والخـوف مـن مُحَرَّم ومشتبِه
~~٤١- والمـرء لا يعلـم بالنقصـان   ولا بـما قـد زاد في الإيـمان
~~٤٢ - إلا بتعظـيم لـذي الجـلال   وعلمِـه مراتـب الأعـمال
~~٤٣ - وأن يكـون طائعـاً لله   مصـاحباً لصـالح أوّاهِ
~~٤٤- وأن يجيـب داعـي التعظـيم   لكـل مـا حرم بالتسـليم
~~٤٥- ثُمَّمِـلاكُ هـذهِ الأمَورِ   أن يـترك المـألوف في سرور

PageV03P053

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0054.png)

~~۱ - يقظةُ من آمن حقَا ورقی   تنتج فكرة لقلب صـدقا
~~۲- والقلب هـذا للمعـالي التمسـا   ولم يكـن في الغفـلات انغمسـا
~~٣- بـل إنـه لله في تشـوُّق   ذو فكـرة بـالحق في تعلـق
~~٤ - مميّـزاً بـالعلم حقـاً وجبا   عن باطلِ في شرعنا ما كُتبا
~~٥- وكـلّ ثابت وكـل مـا انْتَفَی   بـلا التباس أو غموض أو خفا
~~٦ - وهكـذا إرادة لسـامع   وضـار وجالـب ودافع
~~٧- فإنهـا سـت مـع الطرائـق   وهـي مـدار فِكَـرِ الخلائـق
~~۸- وأصـلها الفكـرة في التوحيـد   ثـم ولاء الماجـد الحميـد
~~۹- ومحـوُ حبِ غيرِ حب الله   فكن مـن الصَّـارف في انتبـاه
~~١٠ - مفرِّقـاً بـين إِلَـهِ باطـلِ   وبين ذي الطول العظيم العادل
~~۱۱ - وجامعـاً تأليهـه وحبه   وخوفَـهُ وكـلّ واجب له
~~۱۲_ وهـذه حقيقـة التجریـد   لربنـا عـن سـائر العبيـد
~~۱٣ - ومـا لـه أيضـاً مـن التفريـد   بكامـل التعظـيم والتوحيـد

PageV03P054

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0055.png)

~~١- بصـيرةُ المـؤمنٍ نـورٌ قلبـي   ينالـه العبـد بفضـل الرب
~~۲- وينـتج المعـارف الكثـيرة   بما حبـاه اللهُ مِـنْ بَصِـيرَةْ
~~۳٣- فيشـهد الجنـةَ والنيرانـا   والوعـدَ والوعيـدَ والميزانـا
~~٤- ويشهد الـدنيا بقلـب نيّر   ومـا بهـا مـن كثـرة التَّغَـيُّر
~~٥ - وكـل مـا عـن رُسـلِ الله أتى   وهي مراحل ثـلاثٌ يـا فتى
~~٦ - أولهـا أن لا يصـاب القلـبُ   بشُـبَهِ تُفْسِـدُهُ وَتَحْجُـبُ
~~٧- وأن يكـون قلب هـذا المـؤمن   معتقـداً في ربـه المهـيمن
~~۸- بأنه كلّ الكمالاتِ حـوی   من غير نقص، وعلى العرش استوى
~~٩- وأنـه السـميع والبصـير   وأنـه الحكـيم والخبـير
~~۱٠ - يـرى دبيب النملة السوداء   بالليـل فـوق الصخرة الصماء
~~۱۱- سـبحانه الرقيب للضـمائر   وعـالم الإعـلان والسـرائر
~~۱٢ - قـد أمـر العبـاد بالتوحيـد   ودلهـم للمـنهج الرشـيد
~~۱۳- رحمتـه سـابقةٌ للغَضَـبِ   تفضـلاً لـيس لأمـرٍ وَاجِـب
~~١٤- والناس في التوحيد مخطئ ومـن   أصـاب والمقصر الـذي اغتـبن
~~١٥ - وأضعفُ النـاس بـلا مجـادلِ   أهـل الكـلام مـن دعـاة الباطـل
~~١٦ - فإنه قـد ذمّهم كـل السلف   وكـلِّ مـن لمـنهج الحـق عـرف
~~١٧ - ثم إليك ثـاني المراتـبِ   فكـن مع الحـق ولا تجانبِ

PageV03P055

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0056.png)

~~۱۸٨ - بأخذك الأحكام من نصوصها   وتستعين الله في عويصها
~~۱٩ - بقلبك الرافض كـل الشبَهِ   موافقـاً للأمر آخـذاً بهِ
~~٢٠ - ثالثهـا الشـهود في تقـديسِ   قيـامَ ربّنـا عـلى النفـوس
~~۲۱- بكل خیرِ کسَبَتْ أو شَرِّ   وجالب لنفعهـا والضر
~~۲۲- وأنـه إلهنـا وربنـا   قضـاؤهُ عـدلٌ وفيـه خيرُنـا
~~۲۳_ ومـن تمـام هـذه البصـيرة   مَحبَةُ الحـق وَصِـدْقُ الغَـيْرَة
~~٢٤ - وأن ربي عـالم بخلقـهِ   أَمَدَّهم مِـنْ فضـلهِ برزقـهِ
~~٢٥- وأفضـل الرزق هـو الهدايـة   وأتعـس الخلـق أولـو الغوايـة
~~۲٦ - فاشكر لمـولاك الـذي هـداکا   ومـن جزيـل فضـله أعطاكـا
~~٢٧- إذ لم تكن من ضمن من قد طُرِدَا   وضـل في سـلو كه وأبعِـدَا
~~۲۸ - فنحن لسنا نملك الهدایةٔ   لكنهـا سيقت لنـا عنايـة
~~۲٩- واعلـم بـأن هـذه البصـيرة   تُفَجَّـرُ المعـارف الكثـيرةْ
~~٣٠ - من غيرِ ما كَسْبِ مـن الإنسانِ   لكـنْ بتوفيـقِ مـن الـرحمنِ
~~۳۱- مـن أجـل ذا فراسـة الإيـمانِ   ثابتـة عـلى مـدى الأزمـانِ
~~۳٢- وهي مـن الرحمن نور يوهبُ   لقلب عبـدٍ في رضـاه يَـدْأبُ
~~٣٣ - فيـنجلي في غايـة النَّقـاوة   ولم تَعُقْـهُ أيُّـما غِشَـاوة
~~٣٤ - لأنهـا مبـددات الظُلَم   وسمّيَتْ في الذكر بالتَوَسُـم
~~٣٥- فاقـدها مـن جملـة العميـاَنِ   كـما أتـى في محكـم القـرآنِ
~~۳٦- وذا العمـى يزيـد بالعصـيان   كـما يزيـد النـورُ بـالإِيمانِ

PageV03P056

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0057.png)

~~۱١- العزم أن يَسْتَحْكِمَ القصدُ لدى   من رام فعلاً وله قد قصدا
~~٢- ويعـزم المـؤمن للمهـاجَرَةْ   لكـي يكـون فـائزاً في الآخـرة
~~۳- ويأخـذُ الأهبـةَ للمسـيرِ   بـلا تكاسـلِ ولا تقصيرِ
~~٤- وَيَستعِدُّ ايَما استعدادِ   بصـدق عـزم وبخـير الـزاد
~~٥- وَتَرْكِـهِ كـل عوائـق السَّفَرْ   في حـذرٍ مـن قـاطعِ إذا ظهـرْ
~~٦- يُجانِبُ الأهـواء والأغراضـا   يصبّر الـنفس لكـي ترتاضـا
~~۷- فلـم يعـد يجـنحُ للتوقّـفِ   ولا عـلى الحطـام في تأسُّـفِ
~~۸- بِقَطْعِ كـل عـائقِ وحائلِ   ملازمـأ للطهـر والفضـائلِ
~~٩- يجيب داعيْ الوحي للإيمان بهٔ   ولم يجـب أيَّ نـداء مشـتبِهْ
~~١٠ - فالعلم حقاً قد غدا منادياً   لحكـم ربي وإليـه هاديـاً

PageV03P057

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0058.png)

~~۱- صـلاح نفـسِ المـرءِ بالمغالبـة   ونُجْحُهـا في السير بالمحاسـبة
~~۲ - وتوبـة مـن قبلهـا وبَعْدَها   ولم يكـن صـلاحها إلا بهَـا
~~۳- وذاك معلـوم مـن القرآن   وسـيرة الهـادي عظـيم الشـانِ
~~٤ - عليه صـلّی ربنـا دواماً   ومـن عـلى منهاجـه اسـتقاماً
~~٥- والملهَمُ الفاروق قال: حاسِبوا   أنفسكم مـن قبـل أن تحاسبوا
~~٦ - وإن أردت نقطـة البدايـة   فَقَـايِس النَعْمَـةَ والجِنَايَةْ
~~۷- فتهتـدي بهـذه المقايسـةٔ   إلى نتـائج تكـون خالصـة
~~٨- الرَّبُّ رب وهـو عـالي الشـان   والعبـد عبـد ظـاهر النقصـان
~~۹ - وربنـا القـويّ ذو الجـلالِ   والـنفس قـد توقع في الضـلالِ
~~١٠ - إلا إذا أكرمهـا مولاهـا   حتی غدت من ضمن من زکّاها
~~۱۱ - لأنهـا ليس لهـا إلا العـدم   من ذاتهـا وهـو حباهـا بالنَّعمْ
~~۱٢ - لولا هـداه ما اهتـدت إطلاقا   ولا غَـدَتْ مَمْلُـوعَةً أشـواقا
~~١٣- فَـوَازِنِ الطاعـات والمعـاصِي   وانظـرْ إلى الـراجحِ بالمقيـاسِ
~~١٤- واعلم بـأن الله رب النـاس   يعذَّبُ الموْصُـوفَ بِـالإِفْلاسِ

PageV03P058

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0059.png)

~~۱٥ - مـن لم يُمَيَّزْ نِعَماً مـن الفِتَنْ   ولم يكـن في نفسهِ بالسـوءِ ظَنْ
~~١٦- وكـان فاقـداً لنـور الحِكَم   فلـم يقـسْ لكونِـهِ في الظلَـم
~~١٧- والمرءُ لا ينجح في المحاسبة   إلا بنـور الحـق والمراقبـة
~~١٨ - واعلم بأن سوء ظن المؤمنِ   بنفسِـهِ يَقِيـهِ شرَّ الفـتنِ
~~١٩- فلم يكن من شرِّها في خطرِ   ولم يَـرَ القبـيح زيـن المنظـرِ
~~٢٠ - ودل حسن الظن بالنفس على   جَهْلِ بها مِنْ كل مَنْ قد فَعلا
~~۲۱- وإن في تمييزنـا للـنعم   عـن فتن نفع عظـيم فـاعلم
~~۲۲ - كعلم إحسانِ وَلُطْفٍ قد قُضِيْ   ومـا به سعادة لا تتقَضي
~~۲۳ - وما به استدراجنا ابتلاءا   وليس إنعامـا ولا إعـلاءا
~~٢٤- فالعبـد بـين منَـةٍ وحجَّـةٍ   فكـن مع الله عـلى المُحَجَّـةِ
~~٢٥- فالحـال نعمةٌ إذا مـا صَحِبَهْ   نصْرَةُ دِيـن رَبُّنَـا قـد أوجَبَهْ
~~٢٦ - ودعـوةٌ إليـه في امتثـالِ   أو لا فحجّـةٌ لـذي الجـلالِ
~~٢٧ - كالمـال عند صاحب المطـامع   وعنـد بـاذلٍ لأمـر نـافع
~~۲۸- وهكذا بصيرةٌ وموعظةٌ   وكل إحسان وجالب عظة
~~۲۹- وكلـما يزيـد في الإيـمانِ   والعقـل والأخـلاق والعرفـان
~~٣٠- حتى الفراغ إن يكن قد اقترنْ   بمرضـيات ربنـا مـن المِـنَنْ
~~٣١- أولا فحجـةٌ بـه يُعَـذَّبُ   لأنـه للشـر أضحى يجلـبُ

PageV03P059

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0060.png)

~~٣٢- وإن تكـن يـا خِـلّ ذا توغَّلِ   في ذي القياسـات تفـز بالأكمـل
~~۳٣ - وتُمْنَحَنْ بابـاً مـن التَمْييز   تَـدري بـه الواجـب للعزيـزِ
~~٣٤- مـن العبوديـة والطاعـة له   وترك عصيان بحـب ووله
~~۳٥- مـن مسْتَحَقّ ربنا واللائقِ   ومـا بـه سعادةُ الخلائـقِ
~~۳۶- حينئذٍِ تعرف ما أبيح لَكْ   من فضل ذي الجـلال ممـا خوَّلَكْ
~~٣٧- ولم يكـن تـاركُ مـا أبيحـا   تقربـاً تنفيذه صحيحا
~~۳٨- مثاله ما صح عـن ذاك النفرْ   مـن الصحابة الأماجـد الغرر
~~٣٩ - فَصَـحَحَ النبيُ في أفهَـامهمْ   وردّهـم بـالحق عـن مَرامهمْ
~~٤٠- وقـام بـالتعليم والتَمْييـزِ   بنصحه المسـدَّدِ الـوَجِيزِ
~~٤۱ - علمهـم صـلى عليـه ربي   بعطفـه ولطفـه والحـب
~~٤٢- مصرحا مـن دونما تحرج   بأكلـه اللحـم وبـالتزوج
~~٤٣ - وأنـه ينـام لاستجمامه   وأنـه الـدؤب في قيامـه
~~٤٤ - الصـائم المفطـر في تـوازن   مـن رام أن يفعـل مثلـه وني
~~٤٥ - محـذرًا بـل إنـه تـبرأ   ممن عن النهج السوي قـد نأى
~~٤٦ - بقول (من عن سنتي قد رغبا   فلـيس منـي) فلتعـوا يـا نجبا
~~٤٧ - صـلی عليـه ربنـا وسلَّما   وَكُـلُّ مـن بِهَدْيِـهِ تَعَلَما
~~٤٨ - وكل من تَمْيِيْزُهُ قَـدِ اكتَمَـلْ   لم يرضَ عن نفسٍ ولا عَنِ العَمَلْ
~~٤٩ - وَيُحْسِـنُّ بنفسـهِ الظُنُونَـا   في حُفَر الجهـل غـدا مـدفونا
~~٥٠ - وذا دليـلُ جهلـه بـاللهِ   وَنَفْسِـهِ فكـن عـلى انتبـاه

PageV03P060

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0061.png)

~~٥١ - رضـاؤنا بصالح الطاعـاتِ   رُعُونَـةٌ تَجـرُّ للـويلاتِ
~~٥٢ - لأن جهـل العبـد شرَّ الـنفسِ   يـودي بـه لموجبـات التَّعسِ
~~٥٣- كـما يجـرُ المـرء للإعجـابِ   وعِلـل أخـرى بـلا حسـاب
~~٥٤- وربما فاقـت عـلى الكبـائرِ   لسـوئها في بـاطنِ وظـاهرِ
~~٥٥ - وانظر لأهـل العزم والبصائرِ   وخـوفهم مـن عـالم السرائرِ
~~٥٦- قـد شعروا بكامل النقصـانِ   وَعَجْزهِمْ عـن واجب الرحمن
~~٥٧ - رأوا كثـيرَهُمْ قلـيلاً واهيـا   ولم يكـن بحـقَّ ربي وافيـا
~~٥٨- فاستغْفَرُوا مَالِكَهُمْ عَزَّ وَجَل   عقيب ما قد أحسنوه من عمل
~~٥٩- تأسـياً بالمصـطفى العـدنان   أعـلى الورى قـدراً لـدى الرحمنِ
~~٦٠ - وذاك شـأن مـن لربه عرَفْ   ومن هدى أشرف خلقه اغترفْ
~~٦۱- صلى عليه الله ما غيثُ همـا   وآلـه وصحبه وسـلَّما
~~٦٢- وذو الرضا عـن نفسه وفعله   يهلك نفسـه بشرّ جهله
~~٦٣ - ايرتضي لله كـل نـاقصِ   ومصـدرَ الشـرورِ والخسـائس
~~٦٤ - وجُـلّ أعمال الورى لم تَسْلَم   والسوءُ في النفوس مـا لم تُرْحَم
~~٦٥ - ما لم تکن بحبله تمسکتْ   وبالعبوديـةِ والحـب رَقَتْ
~~٦٦ - لله درُّ مـن لهـذا عَلِـما   مثـل أبي مـدين فـيما فهـما
~~٦٧ - فَوَصْـفُهُمْ أجَمَلَـهُ إذ قـالا   عـين الريـا رأوا بهـا الأعـمالا
~~٦٨ - وأبصروا القولَ بعين الإفترا   والحـالَ دعـوى وبعينهـا يُرَى
~~٦٩ - وكلُّما المطلـوب كـان أكبرًا   في قلسبِ مَنْ لِذِيْ الجـلال وقَّرا
~~٧٠- تَصْـغُرُ نفسـه لديه أوَّلا   ثم يهـون عنـده مـافعلا

PageV03P061

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0062.png)

# ٦١)
~~۷۱- لأنـه قـد شـهد الحقائقَـا   وعـاش مخلصـاً تقيـاً صـادقاً
~~۷۲- وكلَّما جئنـا بـه مـن العمـل   لم يك صـالحاً لربّنـا الأجـل
~~۷٣- وإنـما يَقْبَلُـهُ تَكَرُّمـا   ولـيس حقـاً واجبـاً ولازمَـا
~~٧٤- ولم يكـن في سَيْرِهِ مُنَـوَّرا   معـيّرُ لمسـلم إن قَصَّـرَا
~~٧٥- فـربما التعيـيرُ كـان أعظـما   مـن ذنبـه فكنـت منـه أظلما
~~٧٦- إن كـان نادمـاً عـلى الإضـاعةُ   وأنت في صـولة فعـل الطاعـة
~~۷۷- مزكّيـاً للـنفس ثـم راضـيا   وهـو عـلى الزلـةٍ بـاتَ باكيا
~~۷۸- فـربما انْكِسَـارُهُ يُعْلِيهِ   وأنت في العُجب وقُبْح التَّيهِ
~~۷٩- فـلا يَمُـنَّ طـائعٌ ويفخَرُ   وهـل ذنـوب غيرهِ لا تغفرُ
~~٨٠ - اِدْلالُـهُ في المقـتِ قَـدْ يُوْقِعُهُ   وتوبةٌ مـن نـادم تَرْفَعهُ
~~۸۱- بكـاؤه مـن فعلـه القبيح   خير مـن القيـام والتسـبيح
~~۸۲- إن فارق العجبَ وعـاش تائبا   وَنَفْسَـهُ أضـحى لهـا محاسـبَا
~~۸۳ - وعكسه ذاك الذی قد أعجبا   ولم يكـن لنفسـه مهـذَبا
~~٨٤ - فقد یكون ما لدیه فيکا   لكـن أحوالـك لاتريكـا
~~۸٥- فذنبه خلَّصَـهُ حتی رَجَعْ   وأنتَ فعَـالٌ لـذنبِ لم تَدَعْ
~~۸٦- فـلا تكـن معیّراً مُثَرَّباً   محتقـرأً لمـن يكـون مُـذْنِبَا
~~۸۷ - بَلْ كُنْ شَفِيقاً نَاصِحاً وخائفا   مِـنْ أَنْ تَكُـونَ مِثْلَـهُ مُخَالِفَا
~~۸۸- وقل أيـا مـن كنت لي وكيلا   ثَبَّتْ فؤادي واهـدني السبيلا

PageV03P062

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0063.png)

~~۱- توبتنـا مـن الـذنوب واجبة   فاظفر بهـا تكن حميـد العاقبة
~~۲- ومـن يَكُنْ لنفسه محاسبا   لا بـد أن يكـون دومـاً تائبا
~~٣- لأنهـا في الخـتم والبدايـة   ومـا لهـا حَـدٌ ولا نهايةْ
~~٤- والنـاس إمـا تائـبٌ أو ظـالم   وربنـا للتـائبين رَاحِـمُ
~~٥ - وخير خلـق ربنـا المحبـوبُ   قـد صح عنـه أنـه يتـوب
~~٦- سبعين في اليوم وفي لفظٍ مائة
# ةفكـن مع الله ومـن خـير فئة
~~۷- وانتظمـت فاتحـة القـرآن   حقـائق التوبـة بالإيقـان
~~٨- لمـن عـلى صراط ربه غـدا   مُوَحّـداً يطلب عونـاً للهـدى
~~۹- قـد جانب الآثـامَ والأوزَارَا   وخالف اليهـود والنصـارى
~~۱۰- بعلمـه وفهمـه الصحيح   وفـوزه بالتوبـة النصـوح
~~۱١- وَاَنْتَ يا من للذنوب قد أحبْ   وكـان مسروراً بهـا وفي طربْ
~~۱۲- فعلتها من دونما تداركِ   بتوبـةٍ تُنْجِـي مِـنَ المَهَالِكِ
~~١٣ - أما الذي في طاعـة الله انسَجَمْ   هَدَاهُ للصراطِ إذْ بِـه اعْتَصَـمْ
~~١٤- ثم تـولاه کـماهداهُ   وهكذا بنصره حبـاهُ

PageV03P063

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0064.png)

# ٦٣)
~~۱٥ - فـالنفس والشيطان يَعْجَـزانِ   عـن جَـرَّهِ لُغضـبِ الـرحمنِ
~~۱٦ - وكل عبدِ نصرُهُ بقدر ما   کان بخالقِ الـورى مُعْتَصِـمَا
~~۱۷- والنقص قـد يوصل للخذلان   ونصرِ نفسِ المـرءِ والشيطانِ
~~١٨ - فمـن يُخَـلَي بينـه الإلـهُ   وبين ذنبـه فقـد قـلاهُ
~~۱٩- ومـن يكـن إلهـه قـد عصـمهٔ   فإنه مـن الـذنوب سـلمه
~~٢٠ - والعـارفون كلهـم قـد أجمعـوا   بـأن توفيـق الإلـه يرفع
~~٢١- وهـو بـأن لا يُتْرَكَ الإنسـانُ   لنفسـه فـذلك الخـدْلانِ
~~۲۲- ولا تـتم فرحـةٌ لمـؤمنِ   ولـذةٌ بذنبـهِ المسـتَهْجنِ
~~٢٣- فـإن أتـاه فهـو في أحـزانِ   يخـاف مـن عواقب العصـيانِ
~~٢٤ - وإن غدا القلبُ بلا إحسَاسِ   والـنفسُ في حبائـل الخنَّـاسِ
~~٢٥- فقلبـه أَشْـفَى عـلى المـماتِ   واسودّ بالعصيان والـزلات
~~٢٦ - وإن أصـيب المـرء بـالإصرارِ   يصـير مـن جملـةِ أهـل النـارِ
~~٢٧ - أنى لـه التوبـة وهـو آبق   ومـالـه إلى المتـاب سـائقُ
~~۲٨- بـل قلبـه في قبضـة الشـيطانِ   لجهلـهِ بِرَبَّـهِ المنَّـانِ
~~۲۹- فاعرف متی وکیف کان جهلکا   ومـا الـذي بـذي الجـلال غرَّكـا
~~٣٠ - واسلك طريق التوب والرجوع   وَعُـدْ إلى مـولاكَ في خضـوعِ
~~۳۱- واعرف شروطها على التدقيق   بحسبما قـال أولـو التحقيـقِ
~~٣٢- واندمْ إذا ما تبتَ ممـا قد مضى   ولا تقـل شيء يسـيرٌُ الْقَضَى
~~۳۳- بادِرْ بإِقلاعِ سريعاً واعزِمِ   عَزْماَ بِـأَنْ لا عَـوْدَ نَحْـوَ المـأثَمِ

PageV03P064

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0065.png)

~~٣٤ - وَتُبْ بِقَلبِ مخلصٍِ وصادقِ   واعلـمْ بما لهـا مـن الحقـائقِ
~~۳۰_ فهی ثلاثٌُ عَـدُّها يَنْحَصِرُ   وجهلهـا مِنْـهُ يَجـيءُ الضرَرُ
~~۳٦- تعظيمُ مَا جَنَيْتَ ثُمَ تَتَّهِمْ   توبتك التي بهـا الـذنب حسم
~~٣٧- ثالثهـا غَيْرَتُنَـا مع الغَضَـبْ   ممن عصى الله وللـذنب ارتكبْ
~~۳۸- وكـل مَـنْ للـذنبِ لَم يَسْتَعْظِمِ   أَعـادَهُ مِـنْ دُونِ أدنـى نَـدَم
~~۳۹- ولاتـتمُ توبـةٌ مِـنْ أَحَـدِ   إلا بتعظـيم الإلـه الصمد
~~٤٠- مُتَّهِمَاً لهـا بـأنْ لمْ تُكْمَـل   وخائفـاً مِــنْ أنَّهـا لَمْ تُقْبَـلِ
~~٤١ - وَهَـلْ لعلـةِ كحفـظِ الحـالِ   أَمْ أنَهَـا مِـنْ أجْـل ذِي الجـلالِ
~~٤٢ - أَمْ أنَهَـا لراحـةٍ مِـنَ التَّعَـب   ونيـل جـاهِ ومقـام ورُتبْ
~~٤٣ - أَوْ لاتَقَـاءِ الضُرُّ والأخطـار   أَمْ لحُصـولِ الـرزقِ ذي المقـدارِ
~~٤٤ - أو أَنَ دَاعِيـهِ إلى العصـيان   قدبَـاءَ بـالخمود والنكصـان
~~٤٥- أو أنهـاليسـتْ كَـمايُرِيـدُ   فهـيَ بـذا المقصـد لا تفيـدُ
~~٤٦ - مـا لم تكـن سليمةً مـن العِلَـلْ   عـلى مـرادِ ربنـا عـز وجـل
~~٤٧ - قـد شَـمِلَتْ تعظيمهُ تعـالی   والحـب والخشـية والإجـلالا
~~٤٨ - والخوف مـن حِرْمَانِنَا والطردِ   وَحَجْبِنا عـن وجهـهِ والبُعـدِ
~~٤٩- فـلا يكونُ واثقـاً بنفسه   بل خائفـاً مِـنْ رَدَّهـا وتَعْسِهِ
~~٥٠ - ومـن علاماتِ قبولِ التائبِ   تشـميرُه في الخـيرِ والمناقـبِ
~~٥١- منخلع القلـب عـن المعـاصي   ومقـبلاً في غايـة الإخـلاص

PageV03P065

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0066.png)

# ٦٥)
~~٥٢- في ذلـةٍ لله وانكسـار   وخَشْـية مِـنْ ربَّـه الجبَّـارِ
~~٥٣- وَغَـيْرةُ التائـبِ لله تُـرَى   عنـد المخالفـات فـيما أَمَـرا
~~٥٤ - ومـن يقل عصياننا قـد قُدِّرا   لم يك مقبـولاً كـما تقررا
~~٥٥ - فما لشخص أي عـذرِ أَبَـدا   عـن توبـةٍ تدخلـهُ في السُّعَدا
~~٥٦ - فَمَـنْ إلى العِصْـيَانِ قَـدْ دَعَـاهُ?   ومـا حجابُ قلبه سـواهُ؟
~~٥٧- أضحى ظهـيراً دونما تَـواني   عـلى إلهـهِ مـع الشـيطان
~~٥٨- يعاتِبُ الأقـدارَ فيما يعمـلُ   يَحْـتَجٌ رَبَـهُ بـما لا يُقْبَـلُ
~~٥٩- فيـا لَـهُ مِـنْ جَاهـلِ مُجَـادِلِ   وظـالم لنفسِـهِ وَخَـاذِلِ
~~٦٠ - هـذا مـع الإحسـانِ والإينـاسِ   مِـنْ ربَّهِ عـلى مَـدَى الأَنْفَـاسِ
~~٦١- فقـد أزاح عَنْـهُ كـل العِلَـل   كي لا يسـير في طريـقِ الزَّللِ
~~٦۲- ممکناً له مـن التَزَوُّدِ   إلى الجنـانِ والنعـيم السَّرْمَدي
~~٦٣ - أيضـاً وقد أَعْطَـاهُ مُؤنَةَ السَفَرْ   وَمَـا بِهِ دَفْعُ الشرورِ والخطَرْ
~~٦٤ - كالسمع والإبصـارِ والفـؤاد   وغيرِهـا مِـنْ نعـمِ الإمـدادِ
~~٦٥ - والذكر والفهم له قد يسرَه   وهكـذا بشرّهُ وأنـذره
~~٦٦ - أمـدَّهُ بجنـدهِ الملائكـي   لـدفع مـا يـدعوهُ للمهالك
~~٦٧- وَمَـنْ غـدا في فَخَّهِ محبوسـا   مشَتَتَ الحـال به منكوسا
~~٦٨- لَبِئسَـما استَبْدَلَ عـن مـولاهُ   والله عـن ولائـهِ نهـاهُ
~~٦٩- فالعقـلَ سَـلْهُ أيهـا المنحُـوسُ   اللهُ أوْلَى بِـكَ أم إبلـيسُ
~~۷٠- عصـيتَ خَلاقَـكَ والرسـولا   هـل لمْ تُرِدْ إلى الهـدى وُصـولا
~~٧١- واللهُ لا يَحْتَـاجُ للعبيـد   بـل إنـهُ يعطـي مـع المزيـدِ

PageV03P066

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0067.png)

~~۷٢- والله يُعطيك لكي تشكرهُ   فـإن شكرت الله نِلْتَ خَـيْرَهُ
~~۷٣- واِنْ عَصَـيتَهُ تَنَـلْ عقابـا   ما لم تكن مِنْ ضمن من قد تابا
~~٧٤- بـل إنـه في فرح بتويتـهْ   وإنهُ يقبلهـا بمنته
~~۷٥- وإن بُِليَ العبـد بمـوت همتهٔ   فالله مـا آیسه مـن رحمتهٔ
~~٧٦- وكم حديثٍِ سِيقَ في ذا البابِ   يدعو إلى الرجـوعِ والمتـابِ
~~۷٧- وَقَـدَرُ الله يُـرَدُ بالقَـدَرْ   وبالـدعا كما أتى بـذا الأثر
~~٧٨- مثَالُـهُ البنَـاءُ ضِـدَ الَحـرَّ   والحفـظُ مـن لصٍ ودفعِ القَرِّ
~~٧٩- وتَؤْبَةٌ تَـدفَعُ ذَنْبـاً والمـرَضْ   يُدْفعُ بالدَواءِ إِنْ يكـنْ عرَضْ
~~٨٠- فـلا تكـن مستسلماً لا تَـدْفَعُ   فالعجز عيب قـادح لا يَنْفَعُ
~~۸۱- ثـم سرائـر الحقيقـة التـي   قـد شرطـت حتمًا لفعـل التوبـة
~~٨٢- تمييـز توبـةِ عَـن التَقِيَّـة   ورؤيـة للتوبـة النقية
~~۸٣- وبعـدها النسـيان للجنايـة   وشـائبات توبـة البداية
~~٨٤ - وكـم مـن الأسرار واللطـائفِ   في توبـةٍِ لكـل عبـدٍ خـائفِ
~~۸٥ - من ذاك أن تعرف عزَّ الباري   وسِـتْرَهُ في الليـل والنهـارِ
~~٨٦- وبرَهُ والحلمَ والإمهَـالا   والعفوَ والغفرانَ والإفضـالا

PageV03P067

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0068.png)

# ٦٧)
~~٨۷ - ورحمـة المـولى تعـالى والكَرَمْ   فهـذه والله مِـنْ خير النعمْ
~~۸۸- وأنهـا حجـة عـدل الله   عـلى ذوي الوقـوع في المنـاهي
~~۸۹- وكـل ذي عَقْـل وذي بصـيرةُ   ينظـرُ في ذنوبـهِ الكثـيرة
~~۹۰ - بخمسةِ مِنَ الأمورِ كي يَدَعْ   وكي يكـون سالماً مـن الشَّنَعْ
~~٩١- أو لهـا يَنْظُــرُ بانْتِبَـاهِ   في أمْـرٍ مَــوْلاهُ وَفي النـواهي
~~۹۲- معترفـاً لرَبَّـهِ الغفـار   بِكُـلَّ مَـا قَـارَفَ مِـنَ أوْزَارِ
~~۹٣- ونـاظراً في الوعـدِ والوَعِيدٍِ   مُحَـاذِراً مِـنْ بَطْشِـهِ الشَّـدِيدِ
~~٩٤- وشـاكراً إحسـانَهُ إِذْ سَـتَرَهْ   لوشاء فضحهُ لأفشى خبره
~~٩٥- وكل من تابَ وعاد فورا   ولم يكـن بذنبـهِ مسرورا
~~٩٦- وعـرَفَ الأسرارَ في الأقـدارِ   وحكمـةَ المهـيمن الجبَّـارِ
~~٩٧- يُكْسَى لِصِدقِهِ ثباتـاً وتُقَى   ويرتقـي في الخـيرِ أعـلى مُرْتَقَى
~~۹۸- وَيَعْلَمَنْ بِضَـعْفِهِ بلا مِرا   وعـزة الحكـيم فـيما قَـدَّرا
~~۹۹- فالعبـدُ في قبضتهِ حقـيرُ   وربُـه المُمـدَبّرُ الخبيرُ
~~١٠٠ - يَقْبَـلُ مِنْـهُ عُـذْرَهُ تَفَضُّـلا   ويرزقُ المخلصَ فضـلاً وعُـلا
~~١٠١- بذُلَّـهِ لِرَبَّـهِ يُعْلِيهِ   والِخـزْيُ للمُصِرُ والسَـفِيهِ
~~١٠٢- وَالذَنْبُ قد يكونُ مثل الكابح   لِـرَدَّ مُحْطِـي عَـنِ القَبَـائِحِ
~~١٠٣ - والذُلُّ والكسرةُ بابُ واسِعُ   للمـذنبينَ رادعٌ وَنـافعُ
~~١٠٤- وأربعٌ مراتـبُ الـذلِّ فَعِ   أولهـا ذل افتقـار فاسْمَع
~~١٠٥- والذل ذا في الخلق طرَّا يوجـد   لكونهم في حاجـة لا تجحـد
~~١٠٦- وبعـدها ذُلَّ اختيـارِ الطـائع   فَـذُلُّ أهْـلِ الحـبَّ والتَّواضُعِ
~~١٠٧ - فَذِلَـةُ العُصـاةِ والجنَـاةِ   فافهَم وكنْ منْ خيرة الهداة

PageV03P068

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0069.png)

~~١٠٨ - وإن في التوبـة سِرَاً عَظُمَا   يَعْرِفُهُ قلبُ تَقِـيِّ سَـلِما
~~١٠٩- فَـزَادَ اِشراقـاً وزَادَنُورا   ولمْ يَكُـنْ بِرَبَّـهِ مَغْرُورا
~~۱١٠- وذلك السُّرُّ العظيمُ قَدْ وَرَدْ   عن أحمَدَ المُخْتَارِ خَيْرِ مَـنْ عَبَدْ
~~١١١- بـأنَّ رَب العـالمينَ يَفْرَحُ   بتوبـةِ بِهَـا رِضَـاهُ يُمْـنَحُ
~~۱۱٢- فَاِنَّهُ قَـدْ كَـرَّمَ الإنسـانا   حَتَـى غَـدا أعْـلى البرايـا شَـانَا
~~۱۱٣- وسَخَّرَ الأرضَ لَهُ ومَا انْطَوَى   فيها وما الكون له طرا حوى
~~١١٤- فليسَ كالإنسانِ في الخلائقِ   ومَـا لَـهُ إنِ اتَقَى مِـنْ لاحـق
~~۱١٥ - وفضْلَهُ أظْهَرَهُ اِذ أسْجَدَا   أملاكـهُ لآدم مُمَجّـدَا
~~١١٦ - وَنَفَخَ الروح بِهِ وَأسْعَدَهْ   وأبعد الشيطان لما حسده
~~۱۱۷- وكل من بنورِ رَبَّهِ اهْتَدَی   ولم يُطِعْ عَـدَوَهُ وَمَـا اعْتَـدَى
~~١١٨ - يُكْرِمُـهُ اِلُـهُ ذو الكَـرَم   بِفَضـلِهِ وَبرّهِ والنعم
~~۱۱٩- واللهُ يرضى حمْدَ عَبْدِهِ عـلى   إنْعامـهِ الـذي بـهِ تفضـلا
~~١٢٠ - فانظر إذا أعطاك شخصّ ذو كرمْ   فـإِنَّما سُرُورُهُ بالأخـذ تَــمْ
~~١٢١- يَفْرَحُ إِنْ أَعْطَى وَيُرْضَى اِنْ وَهَبْ   ولا يكـونُ سـائلاً عـَّا ذَهَـبْ
~~١٢٢- والمدحُ ذا في الجودٍِ من إنسانِ   فكيفَ جـودُ مَالِـكِ الأكُـوَانِ
~~۱۲٣- سبحانه للجُودِ فِيهِمْ خَلَقَا   وجودهم من فضـلهِ إذ رزقا
~~١٢٤- والَخلْقُ طراً كلهم لو سألوا   حتى أنيلوا مـا رجوا وأملوا
~~١٢٥- مـا أَثَرَتْ تِلكَ العَطايـا ذَرَّة   في ملكـهِ أو أعقبـت مضـدة

PageV03P069

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0070.png)

# ٦٩)
~~١٢٦- رَبَّي بِمَـنْ تَـابَ إليـهِ يَفْرَحُ   ينيلهم إفضـاله ويمنح
~~١٢٧ - لأنهُ الرحيم رب الكرم   فهل عَلِمْتَ السرَّأم لَم تعلم?
~~۱۲۸ - مثالهـا مسـافرٌ أضـلا   رحـلاً وفي دربِ الهـلاكِ حَـلاً
~~١٢٩- فأسلَمَ النفس وقال لا وَزرْ   وأغمض العين وللموت انتظر
~~۱٣۰- وبعد ذاك اليأس إذ بالرَّحْلِ   وزَادِهِ مـن مشرب ومأكـل
~~۱٣۱ _ فکـان من سروره جَـدْلانا   في فرح بـالنُجْحِ لَمـا كانـا
~~١٣٢ - فقـال یا رَبَّاهُ أنْتَ عَبْدِي   وإننـي الرب بغـير قصـدِ
~~۱٣٣ - مخاطبـاً لربّه تعـالی   ولم يكـن بمـدركِ مـا قـالا
~~١٣٤ - لكنهـا لِدَهْشَـةِ وللفرحْ   ولمْ يكُ العقـلُ بِهـا قَطٌ سَمَح
~~١٣٥ - وذا مثـالٌ مِـنْ نَبِـيَّ الرَّحْمَـةِ   لـذي الجـلال في قبـول التوبـةِ
~~۱٣٦- وَحُبَّهِ مَنْ تَابَ حَتَى طهرا   وَكُرْهِـهِ لِـنْ عَصَى أو كفَرا
~~۱۳۷- فما هـو الظـن بمـن أحبّكـا   إذا رأى العـدو رام أسرَكـا
~~۱٣٨ - ثم انْتَقَلْتَ من قیود أسْرِهِ   ولم تعش في خزيـه وقهـرِهِ
~~١٣٩ - والمثـل الأعـلى لذي الجـلالِ   فكـن معظـماً بـلا إخـلالِ
~~١٤٠- وذلك العبد الذي قد أذنبا   مُكّنَ مِـنْ ذنُوبِهِ فارتكبا
~~١٤١- لكي تكـون حجَّةُ الله عـلى   مقصرٍ ومخطـئٍ ومَـن غَـلا
~~١٤٢ - ولم يكن تعذيب من له عَصَى   إلا بـإجرامِ بـه قـد نكَصَـا
~~١٤٣ - لمـا غـدا يـؤاثر الضـلالا   ولَم يُطِغْ اِلَـهُ تعـالى

PageV03P070

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0071.png)

~~١٤٤- والنفس مصدر الشرور كُلَّها   ما لم تكن قد زُكَّيَتْ مِـنْ رَبَّهَا
~~١٤٥- وكلُّ ذي تقوی وکلُعابدِ   يعرفُ فضلَ ذي الجـلال الماجِدٍِ
~~١٤٦- مستغفراً من ذنبه وخائفا   لأنـه بـالله أضحى عارفا
~~١٤٧- اِذْ لِمْ يَقُـمْ لِرَبَّـهِ بـاللازم   بَلْ عَـاشَ في العِصْـيانِ والمظـالم
~~١٤٨- ومن يُرِدْ فوزاً لدى الرحمنِ   يَجِـدُّ في عـداوةِ الشـيطانِ
~~١٤٩- لأنه في غايـةِ الحرصِ عـلى   أن يَنْشُرَ الشـر وأن يُضَـلَّلا
~~١٥٠ - يريـد أنْ يَغْلِبَنَـا في عَقَبَـة   مِـنْ عَقَبَـاتِ هاكهـا مُرَتَبَة
~~١٥١- أولهـا الكفرُ وثانيها البـدغ   يريـد أن نَـتْرُكَ مـا اللهُ شرَعْ
~~١٥٢ - فـإن تَرَكْنَا سالفَ المخاطرِ   يجرُّنـا جَــراً إلى الكبـائرِ
~~۱٥٣- يريدُ سَـلَنَا مـن الهدايةِ   إلى سـبيل الْغَـيّ والغوايـةِ
~~١٥٤ - وَكُلُّ مَنْ نَجَا مِنَ الكَبَائرِ   يوقعـه في لجـةِ الصَّـغَائرِ
~~١٥٥ - مُهَوَنـاً أخطارَهـا لدَيْهِ   حتـى يغوصَ في الـذي يُشْقِيهِ
~~١٥٦- وحيثما لم يُخْظَ بالنجاحِ   أشـغله بكثـرة المبـاح
~~١٥٧ - مـا لم يكـن في طاعـةٍ مجتهـدًا   ولا بـما يُسْـعِدُهُ مـزوَّدا
~~۱٥٨- أيضا ويدعوه لترك السنن   والكفّ عنْ كل عظيم حسن
~~۱۰۹- حتی یکون راضیاً بالدُّونِ   فيا له مـن خـاسر مغبون
~~١٦٠ - فـإن نجـا مِنْهُ بنورِ وهُدَی   وأكثَر الطاعـاتِ كيما يَسْعَدا

PageV03P071

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0072.png)

# ٧١
~~١٦١- وضَنَّ بالأنفاسِ أن تَمضي سُدَی   بِـرَفْضِ مـا لا فيـهِ خـيرٌ أَبَـدا
~~۱٦۲- حينئذِ يَطْلُبُـهُ الشیطانُ   في كـل مـا لـيس لَـهُ رُجْحَـانُ
~~١٦٣ - من كل مفضولِ من الأعمالِ   ليكتسي بحلَّـةِ الإهمـالِ
~~١٦٤ - محسَّناً ذلك في عَيْنَيْهِ   مُزَيّنـاً تقصـيرَه لَدَيْهِ
~~١٦٥- كي لا يكون ساعياً في الأكملِ   ولا رَغُوْبـاً في فضـيل العمـلِ
~~١٦٦ - فِإنْ نَجَا بالفوز من ذي العَقَبة   بالفقـهِ والتمييـز حتـى غلبه
~~١٦٧- فَاِنَـهُ يطلبُـهُ في السَـابعَة   وهـذه في الخلـق طـراً شـائعة
~~١٦٨ - لم ينج منهـا مرسل ولا نبي   وما لنا مـن شرهـا من مهرب
~~۱٦۹- بل إنها تزداد فیمن اتقی   وكـان مخلصَّـا مجـدًا صـادقا
~~۱۷٠ - يغري به الشيطان كل ذي سفه   فـإذ بحـربهم لـه مكثفـه
~~۱۷۱- باليـد والقلب وباللسـان   بقـدر قربـه مـن الـرحمن
~~۱۷۲ - فینبري طودا یطیع ربه   مراغمًا شيطانهم وحزبه
~~۱۷۳_ وهـذه عبـادة المراغمة   لعسرهـا قلـت بهـا المزاحمـة
~~١٧٤ - فإن حبي من حازهـا التوفيقا   يغـدو بفضـل ربه صـدِّيقا
~~۱۷٥ - ينظر للشيطان في عصـيان   وهـو مع المنـان في إحسـان
~~۱۷٦ - مـراغمًا لكيـده المفضـوح   بصـدقه والتوبـة النصـوح
~~۱۷۷- وقـد حبتـه هـذه المراغمـة   أيضـا عبوديـة فـوز دائمة
~~۱۷۸- ينـازع الشیطان في جنـوده   لعلهـم ينجـون مـن قيـوده
~~۱۷٩- فإن نجوا فهي عليه الداهية   ولا تـزال الحـرب بعـد ماضـية
~~۱۸٠ - فيـا دعـاة الله حركوا الهمم   حـزب اللعـين مـا لـه أيّ قـدم

PageV03P072

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0073.png)

~~۱٨۱ - ومن لَطَائفِ المتاب أَنْ ترَى   حسـنَ الـذي اللهُ بـهِ قـد أمرا
~~۱۸٢- وَقُبْحَ ما عنهُ نَهَی وَحَذَّرا   بالسـمعِ والعقـلِ كـما تَقَرَّرا
~~١٨٣ - فكل ما في الكون ربي شَاءَهْ   فـاعلمْ بـلا زيغ ولا إسـاءة
~~١٨٤ - ولم يك الشيء الذي لم يَرْضَ به   معارضـا مـا شاءه فلتنتبه
~~۱۸٥ - لأنه لم يرض مِمَّـن عَقَـلا   أن يقصـد السـوء ولا أن يفعـلا
~~١٨٦- فالفرقُ واضحٌ لدی أولى النّهى   فَرَبُّنا عـن كـل سيءٍ نَهـی
~~١٨٧ - لحِكْمَـةِ في علمـه قَضَـاهُ   وقد نهى عنـه فـلا يَرْضَـاهُ
~~١٨٨ - فهو الذي لكل شيء قد خلق   مـن حـاضر ولاحـق ومـا سبق
~~١٨٩ - لم يَرْضَ بـالكفر وبالفساد   والسوءِ والفحشـاء في العبـادِ
~~١٩٠- ولا يكـون غيرُ مايريدُ   والكـل في قبضـته عبيـدُ
~~١٩١ - يُسَيِّرُ الكـونَ بعـدلِ مطلقِ   وحكمـةٍ بالغـة التحقـق
~~۱۹۲- وأهلُ جبرِ عنـدهم يشاءُ   تعنـيْ يحـبٌُ فهـما سـواءُ
~~١٩٣- والفهم ذا أوقعهـم في الزللِ   وباطـل القـول وسـوء العمـل
~~١٩٤ - ما شاءه في زعمهم قد رضيهٔ   مـن طاعـةٍ مـن خلقه ومعصية
~~۱٩٥- ولا تصـدق زلَـة التأويـل   منهم لمـا قـد جـاء في التنزيـلِ
~~١٩٦- کقـولهم أحبَّهـا وُجُـودا   ولم يكـن شرعـاً لهـا مريـدا
~~۱٩٧- فهـذه إبطالهـا لا يُحـوج   إلى بليـغ أيدتـه الحجج
~~۱٩۸ - لأنهـا تخـالف القرآنا   وحسبها خلافـهُ بطلانا
~~١٩٩- والأمر ذا في فطر الناس غدا   مسـلَماً مـن قبـل نهـي ورَدا

PageV03P073

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0074.png)

~~۲٠٠_ فهـم يقولون يُحِبُّ الخيرا   ويكرهُ الشر، فكـن بصيرا
~~۲۰۱_ وهـذه مسـألة مهمة   تربطُ مـن تـابَ بخـيرِ الأمـة
~~٢٠٢ - وراقب الـنفس وكـن محاسبا   مناقشـاً مفتشـاً معاتبا
~~٢٠٣ - لتعرفَ العيـوبَ والدسائسا   وَجَيَـدَ الأعـمالِ والخسائسـا
~~٢٠٤ - لأن مـن يجِـدّ في التخليصِ   يسلم مـن شـوائب التنفيص
~~٢٠٥ - مراعيـاً للفقـه والتـدبُّر   كذا خشـوع القلـب والتفكـر
~~٢٠٦- وعنـد ذاك تحصـل السعادةٔ   وينشـط المـؤمن للعبـادة
~~۲٠۷- يُكسِبه الإحسـان كـل نـورِ   والفـوز بالجنـات والحبـور
~~٢٠٨ - وَيُحْمَـدُ الإكثـار في الأعـمالِ   إن كـان سـالماً مـن الإخـلال
~~۲٠٩- وكم مصلِ كالذي ما صلى   لكونـه بفعلهـا أخـلا
~~٢١٠ - وإنما العـبرةُ بالإحسـانِ   فاحرص على الإخلاص والإتقـان
~~۲۱۱- واللهُ قـد أحب كـل طائع   لبذلـه والهجـر للمضـاجع
~~۲۱۲- والمصطفى صلى عليه الباري   دعـا إلى الإتقـان والإكثـار
~~٢١٣- في الحج والعمـرة والأذكـار   وفي صـلاة الليـل والنهـار
~~٢١٤ - وغيرِها مـن صالح الأعمالِ   ليرتقـوا إلى ذرى المَعَـالِي
~~٢١٥- ومـدَح الرحمنُ مـن تقرَّبـا   وخصـهُمْ بحبـه وأوجبا

PageV03P074

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0075.png)

~~۲١٦- والعارف التقي من يستصغر   طاعاتـه وزلـة يستكثر
~~۲۱۷- لأن مـايليـق بالحميـد   يعجز عنـه سـائر العبيـد
~~۲۱۸- ولا يـرى القليـل شيئاً جمـا   إلا الـذي عنـه الصـواب غما
~~۲۱٩- وكل من أضاع وقتاً خَسِرا   وقـد غـدا إلى الـورا منحـدرا
~~۲٢ - وكـل حـافظ لوقتهِ رَقَى   وفي الكمالات عـلا بـل سـبقا
~~۲٢۱- والحـي لا يكـون قط واقفا   فكـن بهـذا الأمـر جـدا عارفـا
~~٢٢٢- والذنبُ والشيطان مما أخَّرا   فاحـذرهما ولا تكـن مقصرا
~~٢٢٣- والتوبةُ النصوحُ مما يسعفُ   كُلَّ امرئ عـلى الهـلاكِ يشْرِفُ
~~٢۲٤- وقدمته بعدما تَـأخَرَا   وأنقدته مـن رجـوع للـورا
~~۲۲٥ - وأول الأحكـام أن تبـادرا   بتوبـة كي لا تكـون خـاسرا
~~۲۲٦- لأن تـأخيرَك ذنـب ثـاني   تُبْ مسرعاً منـه بـلا تَـواني
~~٢٢٧ - واختلفوا في توبةٍ تمَّتْ لَـنْ   عاد إلى الذنب ولو مع الزمن
~~۲٢٨ - هل تبطـل التوبةُ بالعودةِ لَهْ   أم أنه يجـزى بـما قـد جَـدَّ لَـهْ
~~٢٢٩- هذا الذي عليه جُلَّ العُلَما   والقـول هـذا بالـدليل دُعَّما

PageV03P075

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0076.png)

~~۲۳۰- من ذاك ما جاء جلياً ظاهراً   في مسلم قـد كـان قبـل كـافِرا
~~٢٣١- فإنه مـن خَـيْرِهِ لم يحرم   فكيف لا يحسب خـير المسـلم
~~۲٣۲ - وتوبةُ القلب مـن الإنسـان   عاليـةُ القـدر لـدى الـرحمن
~~٢٣٣- إن تابها مستكمل الأركـانِ   حتى ولو بالعجز عـن عصيان
~~۲٣٤ - فعجزه القهري للشر حَسَمْ   إن كـان قلبه عـلى الترك عَـزَمْ
~~۲۳٥ - ولم تكـن تَوْبَتُهُ مِثْل العَـدَمْ   لما غـدا بقلبـهِ مـن النَّـدَمْ
~~٢٣٦ - وإن مـن أحكامهـا التحلـل   من حـق من نَعْلَمهُ أو نجهلُ
~~۲٣۷ - فـلا تصحُّ توبةٌ من نادم   إذا تعلقـت بحـق آدمـيْ
~~٢٣٨ - إلا بِــرَدِّ حَقَـهِ إليهِ   والعفـو ممـن قـد جنـى عليـهِ
~~۲۳٩- ورد حـق میت لـوارثِ   ليسـلم الجـاني مـن الكـوارث
~~٢٤٠- والنـاس في تـوبتهم أقسـامُ   ثلاثـة تـدركها الأفهـام
~~٢٤۱ - مثالهم قومٌ مضوا للمسجد   فَـأوقِفُوا عـن المسير الأرشَـدِ
~~٢٤٢- فواحدٌ غالبَ حتى انتصرا   ولم يكـن مستسـلماً مُقَصّـرا
~~٢٤٣- فنـال فوق ما رجا وأمَـلا   وشكر اللهُ له مـا فعـلا
~~٢٤٤- وآخـرْ دافع بالتوسط   فلم يكن عن سيره بمحبط

PageV03P076

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0077.png)

~~٢٤٥- وَأَوقِفَ الأخـيرُ ثـم قُيّـدا   وبات محبوساً لدی من اعْتَدی
~~٢٤٦- فـذا مثـال ثابتِ لم يُغْلَبِ   وصَـاعِدٍ إلى رفيع الرتب
~~٢٤٧- لأنـه إلى الصَـوَاب عَـادَا   وترك الآثـام والفَسَـادا
~~٢٤٨ - بَراءةُ الإنسانِ خيرُ وأَجَـلّ   من توبةٍ من سوء قولِ وعملْ
~~۲٤٩- وصـاحبُ التوبـةِ ربَّما عَـلا   وصارَ عنـد الله مـن خيرِ المـلا
~~٢٥٠- ولـيس شَكاً أن في السَّلامةْ   سعادة الإنسـان والكرامة
~~٢٥١ - ولم يكـن حصـولها بالتوبـةِ   إلا لمـن أشـفى عـلى العقوبـةِ
~~٢٥٢ - أما البريء فهو من أهل النَجا   إن كـان مخلصـاً ولله رجـا
~~٢٥٣ - حقيقة التوبة فافهم واغمَلِ   رجوعنـا لله في تـذلّل
~~٢٥٤- والجِدُّ في التـزامِ مايُحِبُهُ   وترك منهـي فـلا نقربـه
~~٢٥٥- وإنهـا العـزم بـأنَ لا يرجعـا   للـذنب والإقـلاع عـما وقعـا
~~٢٥٦ - حـالًا وأن يتركهـا في نـدم   رابعهـا تَحَلُّـلٌّ مِـنْ آدمـيْ
~~۲٥٧ - وهذه بعض مسمی التوبةِ   بل شرطها الواقي من العقوبة
~~٢٥٨ - وفي كـلام الله والرسـول قـدْ   تضمنت عزْمـاً لفعـلِ مـا وردْ
~~٢٥٩- وحب أمره مع الأمرَ بِهِ   ومقت من يترك أمـر ربه
~~٢٦٠ - وحرصنا على رجوع التاركِ   مع امتثـال الأمـر والتـدارك
~~٢٦١ - لأن كـل مقلـعِ ونـادم   بدون عـزم صـادق وجـازم
~~٢٦٢ - لفعل مأمور وترك ما نُهِي   عنه فغير تائب ومنتهي

PageV03P077

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0078.png)

~~٢٦٣ - وهـذه التوبـة في الحقيقـة   فأدِّهـا بِهَـذِهِ الطريقـة
~~٢٦٤ - تكـن لأمـر الله ممـن امْتَثَـلْ   حتـى أنيـل حبـه عـز وجـل
~~۲٦٥ - وکان عابداً وکان حامدا   وسائحاً وراكعـاً وسـاجدا
~~۲٦٦ - بكل معروفِ وَخَیرِ آمرَا   وناهيـاً عـن منكر وزاجرا
~~۲٦۷ - وحافظـاً كـل حـدود الله   وسـالماً مِـنْ فِـتَنِ المنـاهي
~~٢٦٨ - لم يطـع الشـيطان إذ دَعَـاهُ   ولم يـرد إلا رضـا مـولاهُ
~~۲٦٩- وفي مسمى التوبـة الإيمانُ   أتـى كـذا الإسـلام والإحسـان
~~۲۷٠- لأنهـا غايـةُ كُـلَّ محسِـنِ   والبـدء والخـتمُ لكـلَّ مـؤمنِ
~~۲۷۱- مـن أجـل هـذا فَرِحَ الله بها   فهي جِمَاعُ الخيرِ دونَ منتهـى
~~۲۷۲- نفـارق الباطـل باستغفارِنا   والتوبـة النصـوح عـن أوزارنـا
~~۲۷٣- وإنَّ مستغفرَ رَبَّـهِ الأجـل   بدون ذكر توبـة عـن الزلـل
~~٢٧٤ - تَابَ وإن کـان لهـا لم يَدْكُرِ   إذ كـل لفـظٍ داخـل في الآخِـرِ
~~۲۷٥- وإن يكـن للفظتين جامِعَا   كـلٌّ لَـهُ معنـىَّ فكـن لي سَـامِعا
~~۲۷٦ - يستغفرُ اللهَ لـذنب سَـلَفَا   وتوبةً يمحو بها ما استأنفَا
~~۲۷۷- فيغفرُ اللهُ لـهُ الـذنوبا   حتی يَعُـودَ عِنْـدَه محبُوبَا
~~٢٧٨ - وذا جـزاء التوبـة النصوح   وهـاك معناهـا عـلى الوضـوح
~~٢٧٩- التوبـةُ النصـوحُ ممـن تابـا   أن لا يكـون للـذنوب آبا
~~۲۸۰ - مستغفراً مَـوْلاهُ باللسانِ   في نـدم عـن ذاك بالجنَـانِ

PageV03P078

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0079.png)

~~۲۸۱- محترساً عـن أیّما عِصْيانِ   بالقلـبِ واللسـانِ والأركـانِ
~~۲٨٢- وهـاجراً لسيء الإخـوانِ   خوفـا مـن السـؤ عـلى الإيـمانِ
~~۲۸٣- ونصحه للنفس بالتَوب فلا   تعـيشُ إلا في منـازلِ العـلا
~~٢٨٤ - والتوبة النصوح لا تُبْقى الأثَرْ   لأي ذنـبِ سـابقِ ولا تَـذَرْ
~~۲۸۰_ وإنما تَعمُّهـا جميعـا   فيصـبحُ العـاصي بهـا مُطِيعَـا
~~٢٨٦ - من غير ما شائبةِ ولا عِلَلْ   لكن لوجـهِ ربه عـز وجـل
~~٢۸٧- ولا تَـتِمُ توبـةٌ لصـادقِ   إلا بتـوبِ سـابق وَلاحـق
~~/٢٨- أولهـا التوبـةُ بالإهـام   فتركه للـذنب والآثـام
~~۲۸۹- وبعـدها توبـة ذي الجـلالِ   عـلى عبـادهِ مَـعَ الإفضـالِ
~~٢٩٠- وجاء ذا التقسيمُ في القرآنِ   في سـورة التوبـةِ بالبيـانِ
~~۲۹١- فانظر (لَقَدْ تَابَ) و(ثُمَّ تابَ)   ومـا به مـن فضـله أثابـا
~~۲۹٢- في قصـة الثلاثـة الأخيـار   من صَحْب خير خلقه الأبرار
~~۲۹۳- فتوبةٔ الله عليهم سـابقة   وبعـد أن تـابوا أنيلـوا لاحقـة
~~۲٩٤- وربنا بِفَصْلِهِ يُمِدُّ   ولُطْفُـهُ بـالخلق لايُحَـدُ
~~۲۹٥- مبدؤها بالکف عن أي زَللْ   إلى مراضي ربنـا عـز وجـل
~~۲۹٦- ومنتهاهـا عـودة العبـادِ   إلى صراط الله في المعـادِ
~~٢٩٧- فمحسـن المتـاب في أولاهُ   يكرمـه بجنَّـةِ مـولاهُ

PageV03P079

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0080.png)

~~۲۹٨- وان ترد تفسير لفظِ اللمم   فها كه يـا ذا التقـى والكرَم
~~۲۹۹- تعريفه المروي عن بعض السلف   أن لا يعـود ثانيـاً لمـا اقْـتَرَفْ
~~٣٠٠ - وَحَدَهُ الجمهـور بالصغائرِ   ممـا غـدا أدنـى مـن الكبـائرِ
~~۳٠۱- وقيـل ما ليس لَهُ حدٌّ ولا   عليه تعـذيبُ لمـن قـد فَعَـلا
~~٣٠٢- وإنـما يغفـرُ بالصـلاةِ   وغيرهـا مـن سـائر الطاعـاتِ
~~٣٠٣- وقيـل ما الَمَ يعني ما خَطَرْ   ولم يكـن ذنبـاً مـن العبـد صَـدَرْ
~~٣٠٤ - وقيـل نَظْـرَةٌ بـلا تعمُّدِ   فاحذر مـن العمـد تفز بالرشد
~~٣٠٥ - وقيـل مـا كـان مـن الأنـام   قبـل اعتنـاق ملـة الإسـلام
~~٣٠٦- أصحها مـا عرَّف الجمهورُ   والكـل في تعريفـه مشكورُ
~~٣٠٧- أمـا كبـائر الـذنوب الموبقـة   فاصـغ إلى تفصـيلها محققـة
~~٣٠٨ - الشرك والعقوق قتل النفس   ثم يمينٌ موجب للغمس
~~۳٠٩- وقولُ زورِ ليس أدنى ضررا   مما مضى بل قد يكون أخطرا
~~۳۱۰- من أجل ذا حذر منه الهـادِيْ   الحرصـه الجـم عـلى العبـادِ
~~٣١١- لأنه مـن أسـهل الكبـائرِ   وأيسـر الـذنوب والمنـاكرِ
~~۳۱۲- وقتل أولاد لكي لا يأكلوا   ممـا بـه المـولى عليهم يُفضِـلُ
~~٣١٣- ثم الزنى بزوجةِ الجـارِ التيْ   من حقها الصون عـن الرذيلة
~~٣١٤- والأكل من مال اليتيم والربا   ثم التـولي يـوم زحـفٍ وجبا

PageV03P080

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0081.png)

~~٣١٥- والقذف أي للمحصنات اللاتي   عـن مِثْل هـذا النكر غـافلاتِ
~~٣١٦- وهكذا السبّ لأصل فانتبهٔ   وهـذه واضحة لا تشتبه
~~٣١٧- ثم استطالة على عِرْضِ غدا   تكريمُه محـتماً مُؤكَـدا
~~٣۱٨ - وأمـن مكـر الله والقنـوطُ   مـن رحمـة الله التـي تحـيطُ
~~۳۱۹- وكل ذنبِ خَتْمُهُ بالنارِ   أو غضـبِ أو لعنـةِ الجبـارِ
~~۳۲٠- ومـا بِحَدِّ صار ذا تعلّقِ   فهـو كبـيرةُ فحـاذر واتَّقِ
~~۳٢١- ومـا بـأول النساء يُحسَبُ   منهـا إلى جملـة (إنْ تَجْتَنِيُـوا)
~~۳۲۲- وإن شخصاً لابن عباس سَألْ   أَهُـنَ سبع قـال عبـد الله بَـلْ
~~٣٢٣ - إلى المئينِ السبع عَدُّها وَصَلْ   والله غفـار لعبـد ذي وجـل
~~٣٢٤- فـلاكبيرةٔ مع استغفارِ   ولا صـغيرة مع الإصرار
~~۳۲٥- وقلة الحياء مِمَّن قد عصى   إلى العـذاب في الجحـيم أرْ كَسَـا
~~٣۲٦- لكونه استهان بالصَّغائرِ   فَألحِقَـتْ بجملـة الكبَـائرِ
~~۳٢٧- وربما كبيرة الـذي استحى   وخـاف ربـه لهـا الله محـى
~~٣٢۸- أو ألحقت بجملـة الصَّغائرِ   لخوفـه مـن عـالم السـرائرِ
~~۳۲۹- وربما مولاه فضلاً سامحا   لِكَونِـهِ مُثَـابراً مُكافِحَـا
~~٣٣٠- والصـالحات سـلم النجـاةِ   لِكُـلَّ مَـنْ أسْـلَمَ في إخْبـاتِ
~~٣٣١- فانظر إلى يونس كيف أنْجِيا   لكونـه مسـبحاً وداعيـا
~~٣٣٢- أشـعة التوحيـدِ لاتُحَـدَّدُ   وذنب من عصى بهـا يبدّد

PageV03P081

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0082.png)

# ٨١)
~~٣٣٣- فإنها كالشَّمسِ في قلبٍ وَفيْ   قلبِ بصيصّ باهتٌ أو منطفيْ
~~۳۳٤_ وکل عبدِ نوره في دربِهِ   بقـدر نـوره الـذي في قلبِهِ
~~٣٣٥ - هنا ويوم الوعـد والوعيـد   كما أتـى في سـورة الحديـد
~~٣٣٦- و کلما زاد علـواً ورقی   فإنـه للشـبهات أخرَقـا
~~٣٣٧- وذاك حال صـاحب التوحيدِ   مـن كـل مخلص مـن العبيـدِ
~~۳٣۸- سماؤه محروسة بالشُّهُب   ولم تفـز منـه العـدا بمطلـبِ
~~۳٣٩- توحيدنا حبٌْ مَعَ الإقرارِ   والسـيرُ في مَحَـابَ الجبـارِ
~~٣٤٠- والانقيـاد بـالكمال الـوافي   في طاعـةِ الكـريم ذي الألطـافِ
~~٣٤١- والذل والإخلاص في العبادة   مـن دونِ نُقْصَـانِ ولا زيـادة
~~٣٤٢ - وترك ما يدعو إلى المعاصيْ   وحبنـا للفـوز والخـلاصِ
~~٣٤٣- وهكذا نفهم قول المصطفى   بـأن مـن وحـد ربه كفَى
~~٣٤٤ - لأن لا إلَـه إلا اللهُ   من قالها يبغي بها رضاه
~~٣٤٥- حرمه الله عـلى النـار كـما   أتى إلينـا في الحـديث محكـما
~~٣٤٦ - لأنهـا قـول يليه العمـل   وهـذه حقـائقٌ لا تجهـلُ
~~٣٤٧- وليس في ذا الأمر من إشكالِ   لأنـه مــرتبط بالحـالِ
~~٣٤٨- وإنـما تفاضـل الأعـمالِ   بقـدر مـا في القلـب مـن إجـلالِ
~~٣٤٩- ليس بحجم أو بقدرِ أو عَدَدْ   وإنما صـدقُ الفـؤادِ المعتمـدُ
~~٣٥٠ - إن البغـي ثـم قاتـل المائـة   أضحو بصدق التوب من خير فئة
~~۳٥١- إخلاصـهم لله في التوحيـدِ   هيَـأهم لَخَّـةِ الخلُـودِ

PageV03P082

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0083.png)

~~۳٥٢- من فاز في القرب بأدنى مرتبة   عليه أن يرعى بـذوق أدبه
~~۳٥٣- وليس مَـن أحِبَّ لا يُعَذَّب   بل ربما الضَّعفُ عليه يُكْتَبُ
~~٣٥٤- لأن مـن أعـلاه ربـه العـلي   واجبـه الخـوف مـن التسـفل
~~٣٥٥ - فواجب عليه حفظ ما حبي   لكـي يزيـد في علـو الرتـب
~~٣٥٦- وكي يكون كامل الآداب   ومخلصّـا لربـه الوهـاب
~~۳٥۷_ فآدم بلقمة قـد أخرجا   مـن جنـة الخلـد التـي قـد ولجـا
~~٣٥٨- ويـونس النبـي لمـا غضـبا   بحبسـه في بطـن حـوت أدبـا
~~٣٥٩- والله قـد أنـذر أزواج النبي   بل أنذر الرسول عـالي الرتـب
~~٣٦٠- بالضَّعْفِ في العذاب والعقوية   إذا أتـوا بزلـة وهفـوة
~~٣٦١- فإن يكن جزاؤهم بالضِّعْفِ   وما بهم في دينهم مـن ضَعْفِ
# فإنهَ أوْلَى بـأن نحترسا مـن قبـل أن ننْحَطَّ أو ننتكسا
~~۳٦٣- وَكُلِّ من خَلَّصَ نَفسَه بما   يحفظهـا مـن أي شيءٍ حُرِّمـا
~~٣٦٤- فهو بهذا الفعل أضحى تائبا   يخشـى مـن الجبـار أن يعاقبـا
~~٣٦٥- وانحصر الحرام في اثني عشرا   معلومـةٌ لجاهـل وَمَـنْ قـرَا
~~٣٦٦- الكفرُ والشركُ مع النفـاقِ   والفسـق والعصيان للخـلاق
~~٣٦٧- والإثم والعدوان والفحشاء   ومنكرٌ آثـاره الشقاء
~~٣٦٨- وبعدها البَغْيُ وَقَولُ المُجرم   عـلى إلهـهِ بـما لم يعلـمِ
~~٣٦٩- والسير في غير السبيل الأقوَمٍ   سبيل كُـلِّ مـارق ومجرمِ

PageV03P083

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0084.png)

~~۳۷۰_ وهو مدار کل شيء حرما   يعرف هذا كل مـن قـد علما
~~۳۷۱- وهذه الأقسامُ سوفَ تذكرُ   وبالبيـان ذكرهـا يُحَـرَّرُ
~~۳۷۲- والكفر نوعـان فكفرٌُ أكبرُ   وبعـد هذا النـوع كفرّ أصغر
~~۳۷٣- فـالأول الموجِب للخلـودِ   في النـار مطلقـاً بـلا قيـودِ
~~٣٧٤- والآخَرُ الموجِـبُ للوعيـدِ   بالنـار تعـذيباً بـلا تخليـدِ
~~۳۷۵- وخسـة أنـواع کفـر أکبرِ   أولهـا التكـذيب جـمُّ الخطـرِ
~~٣٧٦ - لله والرسـولِ فـيما قـالا   وكفرُ مـن تكـبراً تعـالى
~~۳۷۷- وكفرُ معرض وكُفْرُ الشكِّ   كفـر نفـاق موقع في الـدَّرْكِ
~~٣٧٨- والشركُ نوعانِ فشرك أكبرُ   وإنه الـذنب الـذي لا يغفـر
~~٣٧٩- ثانيهما الأصغرُ وهـو يَكْثُرُ   في النـاسِ حتـى لا يكـادُ يحصرُ
~~٣٨٠ - مِثلُ اليسير في الرياء والحَحلِفْ   بغير ربي أو بغـير مـا وُصِـفْ
~~٣٨١- ثـم النفـاق محنةُ مـن المِحَـنْ   وشرُّه يـزداد في ذَيْلِ الـزَّمَنْ
~~٣٨٢- فإنه الـداء العضـال الباطن   وفي قلـوب المـارقين قَـاطِنُ
~~٣٨٣- وأكبرُ النفـاقِ شَرُّ مُـدْخلِ   للناس في قعْرِ الجحيم الأسفَلِ
~~٣٨٤- والأصغر الـذي به يتصف   مقصرٌّ وجاهـلٌ وَمُرْجـفُ
~~٣۸٥- لكنـه في النـار لا يُخَلَّـدُ   مـا دام للإيـمان أصـلٌّ يُوجَـدُ

PageV03P084

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0085.png)

~~٣٨٦- أهل النفاق هم أخَسُّ الناسِ   وأقـربُ الخلـق إلى الخنَّـاسِ
~~٣٨٧- فَهُمْ على ترك التقى قد أجمعوا   ولـيس في قلـوبهم مـا ينفعُ
~~٣٨٨ - لم يقبلوا الهدی ولم يَسْتَبْصِرُوا   أو يرفعـوا رأساً به فَيُشْكَروا
~~۳۸۹- قد أفسدوا قلوبهم وأمرضوا   لأنهـم عـن الصراط أعرضُـوا
~~۳٩٠- ولم يجيبـوا داعـي الإيـمانِ   ولم يـروا حقـائق القـرآنِ
~~٣٩١- أفعـالهم بهـا الريـاء سـائدُ   وعـزمهم عـن المعـالي قاعـدُ
~~۳۹۱- أركسهم نفـاقهم وأرهقـا   وزادهم عـلی شقائهم شقا
~~۳٩٢- والله للمنـافقين نغصـا   وكـل مـن وافقهـم ممـن عصى
~~۳٩٣- من أجل هذا کل بِرِّ يَثْقُلُ   علـيهم والخـير لـيس يحصـلُ
~~۳٩٤- مذبذبینَ بین هـؤلاءِ   وهـؤلاء دونما استحياءِ
~~۳۹٥- وكـل من لـدین ربي ينصر   تربصـاتهم بهـم لا تحصـرُ
~~٣٩٦- وإن يكـنْ فتحٌُ فيُقسـمونا   بـأنهم مـنهم وناصرونـا
~~٣٩٧- وإن يكـن للكافرين حَوَّلُوا   ولاءهـم وغيروا وبدلوا
~~۳۹۸- قد أشهدوا الله على أقوالهمْ   وفي الخصـام لا تسـل عـن حـالهِمْ
~~٤٩٩- إذا تولـوا في الـبلاد أفسـدوا   وأهلكـوا الحـرث ونسـلاً يولدُ
~~٤٠٠ - وإن دُعُـوالله والرسـولِ لم   يصغوا ويذعنوا فهمْ أهل الندم
~~٤٠١- قد طَبَعَ الله عـلى قلـوبهمْ   لمكـرهم وبغـيهم وكفـرهمْ
~~٤٠٢ - أجسامهم كالخشب المسندة   أقـوالهم بليغـة مُفَنَـدَة
~~٤٠٣- والحقد من قلوبهم لا يبرحُ   وَجُبْنُهمْ عـلى سـواه يطفحُ
~~٤٠٤- خروجهم إلى الجهـاد يعسرُ   وجيشـهم بالمسـلمين يغـدرُ
~~٤٠٥- وربنا قد کره انبعـاثهمْ   لوخرجوا لأوْضَعُوا خِلالَهُمْ

PageV03P085

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0086.png)

# ٥)
~~٤٠٦ - يمينهم أسبق مـن كلامهمْ   جُنَّـةُ تَسْـتِيرِ عـلى أحـوالهمْ
~~٤٠٧- يـؤخرون الصـلوات مهزلـة   وفعلهـم لهـا بـأعلى عجلـة
~~٤٠٨ - ولا تَرَاهمْ قَطَّ في الجماعـة   إلا للمـز القـوم والشناعة
~~٤٠٩ - يَسؤهم ما سَرَّنا إِذا حصل   ويفرحـون إن بنا شرّ نـزل
~~٤١٠ - قد كرهوا ما أنزل الله ومـا   أتـى بـه رسـولنا معلَّما
~~٤١١- يخططـون دائماً للفِـتَنِ   لا يرقبـون ذمَّـةً في مـؤمنِ
~~٤١٢ - فـأحبط الله لهـم أعمالهمْ   ولم ينـالوا أبـداً آمـالهم
~~٤١٣ - نفاقهم من لحن قولهم عُرِفْ   وحالهم بوصف ربهم كُشِفْ
~~٤١٤ - لو شاء ربي أن يسموا للوری   بِاسْـم لكَـانَ ذاك مِمَّـا قَـدَّرَا
~~٤١٥- لكـن سيماهم بهم مُعَرَّفَة   وَمـا لهَـم مـن صِـفَةٍ مُشَرَّفَة
~~٤١٦ - وهم أذلّ الناس يوم الحشر   ومـا لهـم مـن قيمـةٍ أو قـدر
~~٤١٧- تَرْهَقُهُمْ ذِلَةُ خِزْي واسعة   أبصارهم ممـا اعتراهم خاشعة
~~٤١٨ - فيجب احترازنا من ذا الخطرْ   كمثل ما كان أبو حفص عمر
~~٤١٩ - ومثلما كـان الصحابةُ الغُرَرْ   مـن النفـاق في احترازٍ وحـذرْ
~~٤٢٠ - وارجع إلى السّنةِ والآيـاتِ   تَجـدْ بهـا جمَّـأَ مـن الصَّـفَاتِ
~~٤٢١ - ويُقرن الفسقُ مع العصيانِ   وَرُبَّـما كـان بـلا اقـترانِ
~~٤٢٢ - فالمفردُ المخرِجُ من دينِ الهـدى   وعَكْسـهُ العصـيانُ مهـما وردا
~~٤٢٣ - لكِنَّـهُ إلى الجحـيم يـورِدُ   والتـوب منـه واجب مؤكد
~~٤٢٤- والنوع ذا قسمان عدُّها اكتمَلْ   فسق اعتقادٍ وكذا فسق عمل
~~٤٢٥ - أولُ قسم فسق أهل البدع   ثـانيهما العصـيان فـاترك وَدَعِ

PageV03P086

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0087.png)

~~٤٢٦ - يقـال فسق ويقـال معصية   وربما يـؤتی بهـا سواسية
~~٤٢٧ - والإثمُ والعـدوان في تغـايرِ   أو كـل واحـدٍِ بمعنـى الآخَـرِ
~~٤٢٨ - والبغي في الغالب في حق الورَى   مثـل استطالة امـرئ تبَخْـتَرا
~~٤٢٩ - وإن أتى البغيُ مع العدوانِ   فإنـه الظلـم بـذا البيـان
~~٤٣٠ - ويطلق العدوان في التجـاوزِ   في واجب وسـنة وجـائز
~~٤٣١- وتطلق الفحشاء فيما استُقذِرا   مـن كـل مـا لا ينبغي أن يـذكرا
~~٤٣٢ - من سائر الأقوال والأفعالِ   مثـل الزنـا وسيء الخصـالِ
~~٤٣٣- وكلـما العقـل لـه يستنكرُ   والشرع منـه مـانع مُحَـذَّرُ
~~٤٣٤- فَاِنَـهُ المُنْكَـرُ فَانْـهَ عَنْهُ   والقلبَ عـن فعـل القبيح صُنهُ
~~٤٣٥ - واعلـم بأن أعظم العصيان   قـولٌ بـلا علـم عـلى الـديّانِ
~~٤٣٦- تحريمُهُ في سـائر الأديـان   وسـائرِ الأوقـاتِ والأحيـانِ
~~٤٣٧ - فـلا يبـاح مطلقـاً بحـالِ   لأنَـه مِـنْ أقْـبَح الأقـوالِ
~~٤٣٨- وربما الخنزيـر حـلَّ أكلُهُ   ومثـل هـذا لا يبـاح قولهُ
~~٤٣٩ - لأنه للكفـر والشرك غدا   أصـلاً فمنـه الكفر والشربدا
~~٤٤٠- الحيوانيـون كالبهـائم   فـيما عـدا المنطـق والقـوائم
~~٤٤١- حيـاتهم مـن شهوةِ لشهوةِ   وَمَـالهُـمْ مِـنْ غايـةٍ عَلِيَّـةِ
~~٤٤٢ - فبعضـهم في الطبع كـالحمارِ   والسبع الضـاري ومثـل الفـار
~~٤٤٣ - وبعضهم يهتمٌّ بـالطقوسِ   والمظهـرِ الجِميـلِ كالطـاووسِ
~~٤٤٤- وبعضهم كالخيلِ والأغنامِ   وهـؤلاء أحسـن الأقسـام

PageV03P087

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0088.png)

~~٤٤٥- ومشهد الجَجبْريـةِ التي تَرَى   بأنهـا مجبـورةٌ فـيما جَـرَى
~~٤٤٦ - فهـؤلاء في اعتقـادِ فاسـدِ   ومشـهد مـن أقبح المشـاهدٍِ
~~٤٤٧- والقـدريون بعكسهم غـدوا   وكلهـم قـد أجرمـوا وأفسـدوا
~~٤٤٨- والمستقيمون بعلم راشدِ   قـد شهدوا حكمـة ربي الماجـدِ
~~٤٤٩ - وأنه لم يخلـق الكـون سُـدَى   مـن أجـل ذا علَّمَهُـمْ وأرشَـدَا
~~٤٥٠- فكـل نافذِ مـن الأمـورِ   بحكمـة المهـيمن الغفـور
~~٤٥١ - وكل شيءٍ للنفوسِ يُرْهِبُ   أو كـان ممـا فيـه فـوراً ترغبُ
~~٤٥٢ - لله في تقـديرهِ جَــمٌ حِكَمْ   نفـوذه بـأمره في الخلـق تَـمْ
~~٤٥٣ - والخـير في تقـديره بـلا مِرَا   وأي قـولٍ غيرِ ذا القـول افْتِرا
~~٤٥٤ - فليس غير الله ملجـأ لنـا   وكـل شيءٍ بقضـاء رَبَّنَـا
~~٤٥٥- أَبْعَـدنا عـن مسلك الضـلالِ   بمنـه العظـيم والإفضـال
~~٤٥٦- فنشكر الله بحمـدٍ دائم   سبحانه من مبتـل وراحمِ
~~٤٥٧ - ويشهد العبـد انفرادَ ربّهِ   في خلقـهِ وحُكْمِـهِ وحبَّـهِ
~~٤٥٨ - وأن كـل الخلق مقهورونَ في   قبضته من دونما تکلفِ
~~٤٥٩- ومـا أقامَ مِنْ قُلُوبِ الخلق   ومـا أزاغـه بمحض الحـق

PageV03P088

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0089.png)

~~٤٦٠ - ولا مُعَـانَ غيرُ مَـنْ أعانَـا   ولا مهـانَ غـيرُ مـن أهانـا
~~٤٦١ - وليس في الخلق مُوَفَّقٌ سِوى   مَـنْ وَفَـقَ اللهُ فللخـيرِ حَـوى
~~٤٦٢- مـا خاف غير ربه ولا رجا   به نجاحـاً مطلقـاً ولا نجَـا
~~٤٦٣ - فالعبد هذا في الحيـاة يسعدُ   محققـاً (إيـاك) ربي (نعبـدُ)
~~٤٦٤ - والعبـد في فقرٍ إلى التوفيـقِ   يحتاجـه في سَـعَة أو ضَـيْقِ
~~٤٦٥ - طرفةً عـين إن يكـن تخـلى   ذو الجـود عـن عبـد فقـد أَضِـلًا
~~٤٦٦- فيشهد العبـد بكـل حـالِ   إفضـالَ ذي الإحسـان والجـلالِ
~~٤٦٧ - وأنه الرب لكـل مـن خلق   وَكُل مقـدور بعلمـهِ سبَق
~~٤٦٨ - فالعبد دومأ بين توفيقِ رَفَعْ   وبينَ خذلان بعدل قد وَضَعْ
~~٤٦٩ - والعبدُ سـائر مـع الشـيئينِ   والحمـدُ لله عَـلَى الأمْـرينِ
~~٤٧٠ - والله للإيـمان فضـلاً حببـا   مزيَّنـاً مُشَـوَّقاً مرغَّبـا
~~٤٧١ -وَكَرَّهَ الكفرَ وفسقاً وهَدَى   وَلَمْ يَزَلْ لِكِـلِّ خَـيْرِ مرشِـدا
~~٤٧٢ - لكي يكون الرشد لا يفارقُ   والخـيرُ دومـاً سـابقٌ ولاحـقُ
~~٤٧٣ - وذاك فضل ربنا مُوْلِيْ النَّعمْ   ولم يكـن شيءٌ بجهـد العبـد تَمْ
~~٤٧٤ - ودعك من فهم نفاة القدرِ   وعصـبة الجـبر وكـن في حذرِ
~~٤٧٥ - وكن مع الحق بلا انحرافِ   ولا مغـالاة ولا تجـافي

PageV03P089

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0090.png)

~~٤٧٦ - وهـو أجـل مشهد وأوسع   لأنه عـما سـواه أرفع
~~٤٧٧ - يعلم منه ذو التقى وذو النهى   تعلـق الوجـود كلـه بهـا
~~٤٧٨ - فالخلق والأمر بها قد ارتبط   والكون من آثارها قد انضبط
~~٤۷٩ - تعطيلهـا مـن أقبح المحـال   بـل مقتضـاه سـائر الأفعـال
~~٤٨٠ - فاسم الحميـد والمجيد يمنع   ترك الورى من غير شرع يشرع
~~٤۸۱ - وتركهم من غير ما ثواب   ولا مجـازات ولا عقـاب
~~٤۸۲ - وتقتضي غفران ذنب من رجا   مـن ربـه التوبـة يطلب النجـا
~~٤٨٣ - أيضًـا ويـأتي ذاك في الحكيم   فاعرف صـفات ربك العظيم
~~٤٨٤ - وقـد دعـا المشهد للإخبات   وأخـذ حظنـا مـن الصـفات
~~٤٨٥ - تعبـدا لربنـا الأعـلى بهـا   علما وحـالا وفـق مـا تفيـدها
~~٤٨٦ - من دون أن يحجبهم ضدِّ کما   في المـانع المعطـي فـزد تفهـما
~~٤۸۷ - وربنا يحب موجباتها   من عبده بوفق وصفه بها
~~٤۸٨- يحب كـل عـالم وغـافر   وكـل ذي حلـم وكـل شـاكر
~~٤۸۹ - وكل ذي جود وكل صابر   وكـل ذي عفـوٍ حيي بـارّ
~~٤۹٠ - وغيرهـا ممـا اتصـافه بهـا   يجعلـه مـن التقـى في المنتهـى
~~٤٩١- وكـل مـا بعلمهـا تَعَلَّقا   أرشـدنا لعلمـه محققـا
~~٤۹۲- وکلما اقتضته من آثارِ   وسير هـذا الكـون بالأقـدار

PageV03P090

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0091.png)

~~٤٩٣- ومشـهد الإيـمان بالمعـاصي   يردنـا لمالـك النـواصي
~~٤٩٤- فإنـه مـن ألطـف المشـاهدِ   يخص كـل عـارفِ وعابـدٍِ
~~٤٩٥ - وربما بـادر بالإنكـار لـهٔ   من الورى كـل امرئ قد جهله
~~٤٩٦ - يقول كيف يُشهدُ الإيمانُ   بالـذنب والمـرء بـه يُـدَانُ
~~٤٩٧ - والعلماءُ كُلُّهُمْ قَـدْ أجمعـوا   بأنـه ينقصـه لا يرفعُ
~~٤٩٨ - نقول ذاك حاصل لمـن نظرْ   في ذنبـه وذنـب سـائر البشـرْ
~~٤٩٩ - وما لذي الذنوب من آثارِ   وإن غـدت بيّنـة الأضرارِ
~~٥٠٠ - كعلمـه بضـعفه في حالهِ   وجاهـه وَعِزَّهِ وَمَالِهِ
~~٥٠١ - وأن يرى القلـوب منه تنفرُ   وجفـوة المحـب أضحت تكثرُ
~~٥٠٢- فـإن يكـن بالشرّهـذا عَلِمَا   وتاب مـن أخطائـه واعتصما
~~٥٠٣- یقوی بذا إیمانه ويرتقيْ   والأمر هـذا واضح للمتقي
~~٥٠٤- فإِنَّهُ يَنَـالُ عِـزاً وَغِنَى   مـن بعـد ذلٍ وافتقـارٍ وضنَى
~~٥٠٥- فَشَـهِدَ الإيمانَ لمـا أَذْنَبَـا   بِفَضْـلِ مَــنْ زَيَنـهُ وحبّبا
~~٥٠٦ - والطـائع التقي لا يحب مَـنْ   عصى الإله فهـو مِنْهُ في حَزَنْ
~~٥٠۷- وربما دعا علیه بالضرر   أو بهلاكـه لينتهـي الخطـرْ
~~٥٠٨- فلم يكـن للمذنبين رَاحِمـا   بَـلِ ازْدَرَاهُـمْ نـاقماً ولائما
~~٥٠۹- حتی اِذا جری عليه القدرُ   أضحى ينـادي ربـه ويجـأرُ

PageV03P091

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0092.png)

~~٥۱۰ - ويستغيث ربَّـه ويلتجـيْ   يطلـب عفـو ربـه ويرتجِي
~~٥۱۱- مثـل سليم موجع تَملْمَلا   يَئِنُّ من آلام مـا قـد نَـزَلا
~~٥١٢ - فحيـنما زلَّ كَأَهْـلِ الزَّلَـلِ   فكـر في العصـيان في تأمـلِ
~~٥۱٣- فبـدلت غِلْظَتُـهُ بِـاللَّينِ   يـدعو لكـل غافـلِ مسكينِ
~~٥١٤ - وَلَمْ يَعْدْ يَقْسُو على من أذنبا   وإن أقـام الحـدَّ فـيمن وَجَبَـا
~~٥۱۰- ويسـأل الله لهـم أن يغفـرا   وأن يكـون راحمـأً وسـاترا
~~٥١٦- فيشهدُ العبـدُ تـلاشي قوّتِـهٔ   إلا بحـول ربـه وقدرَتـه
~~٥۱۷ - وأنـه أعجـز شىء مطلقـاً   عـن حفظه لنفسه مهما رَقَـى
~~۰۱۸- فقلبـه كريشـةِ تُقَلَّبُ   أو مُبْحـر بـهِ الرياح تلعـبُ
~~٥١٩ - ولم يَـزَل مُطَرِحـاً بِبَابِهِ   وَخَـدُّهُ عـلى ثـرى أعتابِـهِ
~~٥۲٠ - فالعبـد بين الله والشـيطانِ   كمثـل مـا أوضحتُ في بَيَانيْ
~~٥٢١ - فـإن تخـلى قـدر لمـح البصرِ   عـن عبده الربٌّ غـدا في خطرِ
~~٥۲۲ - فضـعفُه عرَّفَـه بقوتهٔ   وعجـزه عرفـه بقدرتـهْ
~~٥٢٣ - وذلُّهُ بِعِـزَّهِ وَسَـطْوَتِهْ   وجهلـه بعلمـه وحكمتـه
~~٥٢٤ - كمالُهُ المطلـق لـيس يحصرُ   لأنـه هـو العـلي الأكـبرُ
~~٥٢٥ - فالعبـد في فقـرِ بـلا حـدودِ   يعجز عـن نفع مـن الموجـودِ
~~٥٢٦ - فيعـرف الـنفس أتـمّ المعرفـة   ويعـرف الله بالاسـم والصـفة
~~٥٢٧ - للأمر ذا قال الحكيم إذ وَصَفْ   مـن عرف الـنفس لربه عرفْ

PageV03P092

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0093.png)

~~٥٢۸ - معناه مـن حـلأَك بـالکمالِ   أعـلى بـلا شكِ ولا إشكالِ
~~٥٢٩ - وإن عَرَفْتَ قَدْرَ ذي الجـلال   وأنما قـد حُـزْتَ مـن إفضـالِ
~~٥٣٠- أندرُ مـن قطرةِ بَحْرٍ وأقل   من جوده عرفتَـه عـز وجل
~~٥٣١- وقيل مـن يجهلُ نفسَهُ فلا   يمكـن أن يعرف مـن لـه العـلا
~~٥۳۲ - فجاهلُ بنفسه هـل يعلمُ   بمـن لـه الملك الكبـير الأعظـمُ
~~٥۳۳- فکل ذي تقوی بجهله ارتدع   فَعَظَـمَ الله تعـالى وخَضَعْ
~~٥٣٤- ليس لنا شيء مـن الأمر فع   ولا تقـلْ ذا لي ولا ذاك معـيْ
~~٥٣٥- فالعبد مقهور وبالعجز عُرفْ   والله بالقـدرة والعز وصـف
~~٥٣٦- وإنَّـما أحبّـه وكَرَّمَـا   لأنّـه غَـدَا لَـهُ مُسْـلَّمَا
~~٥٣٧- ويشهد العبدُ افتقارَهُ الأتمَّ   لربـه العظـيم واسع الكرم
~~٥٣٨- فإنـه مـن الضـلال مبعـدُهْ   وإنـه وليه ومسعده
~~٥٣۹- وقلبه منکسرّوربّما   يظـن نفسَـه كشيءِ حُطَّـما
~~٥٤٠ - وأنـه لا نفع فيـه مطلقـا   إلا إذا أصـلحه ووفقـا
~~٥٤١ - يستكثر الخير مـن الله العَـِلي   لعلمـه بنقصـه والزلـل
~~٥٤٢- وإنـما برحمـةِ الله حُبِـيْ   لأنـه لمـن أراد يجتبـي
~~٥٤٣ - طاعاته لربه استقلَّها   حتى ولـو كـلّ الـورى أجلها
~~٥٤٤ - واستكثر العصيانَ مهما ندرا   لأنـه بالانكسـار استبصـرا
~~٥٤٥- فجبر قلبه غـدا قريبا   وربـه أضـحى لـه حبيبا

PageV03P093

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0094.png)

# (٩٣)
~~٥٤٦ - فالخير كل الخير نحوه وصـل   ولم يزل متصـلاً ومـا انفَصَـلْ
~~٤٧ ٥ - فَنَفَسُّ من مثل هـذا العابِدِ   أحـب عنـد الله مـن مجاهِـدِ
~~٥٤٨-يُدِلِّ أو يعجبُ فيما يعمـلُ   ولم يـزل يسري إليـه الَخلَـلُ
~~٥٤٩- وإنَّ قلبـاً ذلـه تمكّنـا   لربه فعـاشَ عَبْـداً مُحْسِـنا
~~٥٥٠- أحب عنـد الله مِمَّـن يعبدُ   وقلبـه لربـه لا يسجدُ
~~٥٥١ - وبعض أهـل العلـم لما سُئلا   أيسجد القلب ? فقال: كيف لا?
~~٥٥۲ - وحينما يسجد لـيس يرفعُ   من ذلك السجود فهـو الأنفعُ
~~٥٥٣ - يدوم في سجوده مدی البقا   وينتهـي سجوده يـوم اللقا
~~٥٥٤ - هذا سجودُ القلب فاعْلَمْ واسجدٍِ   ولا تكـن بغافـلٍ وجاحـدِ
~~٥٥٥ - وأي قلب لم يكـن منكسرا   لیس بساجدِ فکن مستبصرا
~~٥٥٦- وكـل قلب لإلهـي سجدا   فكل عضـو منه حقـأ عبدا
~~٥٥٧ - لربه القيـوم وجهـه عنَـا   ومن خشوع صـوته تبيّنا
~~٥٥٨- خشـوعه في سـائر الجـوارح   وصار في الطاعـات خيرَ طَامِح
~~٥٥٩- وعـاش في ذلٍ بـه الترفعُ   مستَعْطفاً مـولاهُ فيما يطمع
~~٥٦٠ - مـن فضـله وبرّه وقربهِ   وعـزه ولطفـه وحبه
~~٥٦١ - فـأي خـير فهـو قـد أعطـاهُ   وهـل فلاح نِيْلَ منْ سواهُ
~~٥٦٢ - لا عـزَّ لا رضـا لنـا ولا غنى   إلا إذا الله بهـا قـد أَذِنَـا
~~٥٦٣ - والعبد لا يغضب من له ملك   وكـل مغضـبِ لمـولاهُ هَلَكْ
~~٥٦٤- بـل لـو أتـى بزلـة لا ينعم   يبكي عليهـا دَهْرَهُ وينـدمُ
~~٥٦٥- إذا فكيف القلب ليس يسجد?   وتارك السجود كيف يعبد?

PageV03P094

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0095.png)

~~٥٦٦ - وصاحب المشهد هـذا يعلمُ   بـما بـه المـولى عليـه يـنعمُ
~~٥٦٧ - وَطُرُقِ الشيطان كيما يَحخْرِمَهْ   مِمَّـا بـه الفـلاحُ أو يُنَدَّمَـهْ
~~٥٦٨ - يريد أن يبعده عن ذي الكرم   وكـل مـا يحفظـه مـن الـنقمْ
~~٥٦٩ - فحينها استبصَر ذل المعصية   وخـاف أن يسفعه بالناصية
~~٥٧٠- فبـات يستغيث: يـا ربَّاهُ   أنت الـذي لـيس لنـا سـواه
~~٥٧۱- يُمرَّغ الخـد وَدَمْعُهُ انْحَدَرْ   وهو بذل والتجـاء قـد جأر
~~٥۷۲- فما لنـا يـا رب مـن مَعَـاذِ   ومـا لنـا غَـيْرَكَ مـن مَـلاذِ
~~٥٧٣- فكيـف ظَنُنَـا بِرَبِ أرحـمُ   مـن أم طفـل حبـه معظـم
~~٥٧٤- فإنـه ملجـأ مـن أتَـاهُ   ومـن أحـب الله مـا قـلاهُ
~~٥٧٥ - يقبلـه بفضـله الأعَمَّ   مجازيـاً لـه بخـير جَــمَّ
~~٥٧٦ -فَـإِنْ يَكُ المَشْهَدُ ذا تمكنـا   مـن قلب مـؤمن لربي أذْعَنَـا
~~٥٧٧ - وَذَاقَ طَعْمه اللذيذَ فانْجَـذَبْ   ولم يكـن لمـا يشـينه ارتَكَبْ
~~٥۷۸- ففـي العبوديـة حقـاً يرتقـئ   بالحـب والإقبـال والتشـوقِ
~~٥٧٩- والابتهاج والسرور الأعظم   ونيـل فضـلِ ذي الجـلالِ المـنعم
~~٥٨٠ - فيسكن القلب إليـه دائماً   ولا تـراهُ في سـواهُ هـائماً
~~٥۸۱- وتطمـئن سـائر الجـوارح   بفضـل ربَّـه الكـريم المـانح
~~٥٨٢_ لسـانه في لَــج بربَّهِ   وقلبـه ممتلـئ بحبّـهِ
~~٥٨٣ - وموضع الـزلات والـذنوب   أشغل بالطاعـات للمحبـوب
~~٥٨٤- وأضحت الأعضاء في انقيـادِ   للملـك المهـيمن الجـوادِ
~~٥٨٥ - فانظر خضوع القلب بانكسارِ   ومـا لـه في الـنفس مـن آثـارِ

PageV03P095

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0096.png)

# ٩٥)
~~٥٨٦ - واطلب مـن الرحمن أن تَنَالَهْ   فإنه يعطـى لمـن سَـعَى لَـهُ
~~٥٨٧ - وكل طارق لذا الباب وَصَلْ   إلى رضـا خلاقـه عـز وجـل
~~٥٨٨ - وَلَمْ يَلِجْ مِنْهُ سِوَى من وُفَقَا   وأذن الله لـه في الارتِقَـا
~~٥٨٩ - وقال بعض العارفين لم أجِدْ   بابـاً كمثلـه بـه العبـد سعد
~~٥٩٠ - ففي سـواه يوجـد الزحـامُ   والبـاب ذا قلَّت به الأنـامُ
~~٥٩۱ - وأنه أسـهل مِـنْ سـواهُ   يُقَـرَّبُ العَبْـدَ إلى مـولاهُ
~~٥٩٢ - وكل مَنْ بالبابِ هذا وَقَفَا   أكرمـه رب الـورى وأسعفا
~~٥٩٣- وإنـما سر سـعادة الأبـدْ   في ذي العبوديـة لله الصـمد
~~٥٩٤- وكلَما يطـالع العبدُ المِـنَنْ   يذهب عنه كلِّ هم وحزنْ
~~٥٩٥ - وكلَّـما أَحـسَ بالإحسـانِ   تَهَـيَج القلـب إلى الـرحمنِ
~~٥٩٦ - فَـزَادَ في الحـبَّ وفي الأشـواقِ   إلى لقـاءِ رَبـه الخــلاقِ
~~٥٩٧ - فإنَـهُ أَمَـدَّهُ بــالنَعَمِ   فالحمـدُ للتَّـوابِ أهْـل الكـرمِ
# 2 2 a» a

PageV03P096

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0097.png)

~~۱- وكـل مَـنْ قَـدْ أحْسَـنَ المتابـا   فإنـه لربـهِ أنابا
~~۲- والله قَـدْ قَـالَ لنَـا أَنِيْبُـوا   وقـد أشاد بالذي ينيب
~~٣- وبَشّرَ المنيـبَ بِالجِنَـانِ   وأطلـق البشـرى بهـذا الشـان
~~٤- وهي عـلى قسمينِ: قسمٌ عما   لكنهـا لـدفعِ مـا ألَّـا
~~٥- في سائرِ الخلـق بـدون حـاصرِ   مـن مـوْمنِ وفـاجر وكـافرِ
~~٦ - يدعونـه لأي ضُرَّ مَسّـا   لأنَـهُ رب هُـمْ لا ينْسـى
~~٧- ثـانيهما: إنابـةُ الأبـرارِ   مـن أوليـاءِ المـنعم الغفـارِ
~~٨- لكونِـهِ سـبحانَهُ المَعْبُـودُ   صـدقاً فـلا يعقبهـا الجحـودُ
~~۹- وقـد تضـمنتْ أمـوراً أربعـة   مـن نالهـا فَرَبُـهُ قـد رفعـهٔ
~~١٠ - مَحَبَّـةَ الله مَـعَ الُخْضُـوع   والصـدقِ في الإقبـالِ والرجوع
~~١١ - وهكذا الإعراض عَنْ سِواهُ   فمـن حواهـا ربُه حبـاهُ
~~١٢- فيستحق اسمَ المنيب حقـاً   وفي مـدارج القبـول يرقَى
~~۱٣- وليسـتِ العِـبْرَةُ بِـالأقْوَالِ   وإنَـما بِالسَّـيْرِ والفِعَـالِ
~~١٤ - فَالقَوْلُ اِمَّا أَنْ يَكُونَ صِـدْقَا   أو كـذباً، كمَـنْ غَـدَا مُنَافِقَـا
~~۱٥- فما أناب من بعهدهِ غَدَرْ   بـل إنـه مـن النفـاق في خَطَـرْ
~~١٦ - في الحـال والأعـمال والأقـوالِ   وربـما صـار إلى الوَبَـالِ
~~۱۷- ومـن أراد أن يكـون مصلحا   كـلَّ فسادِ سالف ليفلحا

PageV03P097

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0098.png)

# ٩٧)
~~١٨ - فإنـه يحتـاجُ أن يحقَّقـا   ثلاثـةً يسـمو بهـا إلى التُقَى
~~۱۹- خروجَه من تبعـات ذَنْبهِ   بتوبـة مرضـيةِ لربهِ
~~۲٠ - ثـم توجع عـلى مـا صـدرَا   كـذا انصـداعُ قلبه لمـا جرَى
~~٢١- لأنَّ مـن لم يكُ في تـألم   مـن عثراتِـه ولا تنـدم
~~۲۲- فإنـه لربه قـد جحـدا   والقلب إمـا ميـت أو فسـدا
~~٢٣- والأصـل أن يكـون في توجع   مـن ذنب غـيره وفي تصدع
~~٢٤- كأنهُ هـو الـذي قـد عَثرَا   يبغي له العفو وَيخْشى الضررًا
~~۲٥ - وذا دَلِيـلُ رِقَّـةِ المُنِيـبِ   وفهمـه عواقـب الـذنوب
~~٢٦- أيضـاً ولا يكـونُ مُستَهينَا   بمـن غـدوا في النـاس غافلينـا
~~۲۷ - تخوفـاً علـيهم مـع الرَّجـا   لنفسـه لكي يفـوز بالنجـا
~~۲۸- مجاهداً للنفس کي تُخَلَّصَا   من لذة الذنب الذي به عصى
~~٢٩- لأنَّ مـن صـفت لـه الإنابـة   محققـاً بصـدقه متابَـه
~~٣٠ - ففكره في الـذنب يغـدو ألمـا   والشـوق خوفاً والتصابي نـدما
~~٣۱- وإن غـدت لذتهُ تلاحقهٔ   فالمـاردُ اللعـين لا يفارقـهٔ
~~۳٣٢- بـل قلبه في غيّه قـد غُمسا   ونفسه تقـوده ليتعسا
~~٣٣- إلا إذا جاهـدها مفتشـا   في كـل مـا تُسِرُّهُ ومـا فَشَا
~~٣٤ - مميـزاً حقـوق ربه العـلي   عـن حق نفسه بـلا تداخُلِ
~~٣٥ - إذ قد يكون الكـل أو مـا يكثر   لنفسـه وهـو بـذا لا يشعر
~~٣٦- فالنفس كم فيها من الأغراضِ   وعلـلٍ تُوقِع في الإعـراضِ
~~۳٣٧- فتجعـل الأعمالَ غيرَ خالصة   باطلـةً مـن أصـلها أو ناقصـة

PageV03P098

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0099.png)

~~٣٨- وإنَّ بـين القلـبِ والأعـمالِ   حـواجزاً تـودي إلى انفصـالِ
~~٣٩- كرؤيـة الإنسـانِ للأعـمالِ   والكبر والإعجـاب والإدلالِ
~~٤٠- وهكذانِسْـيَانُ مَـنّ الله   وَعِلَـلِ أخرى بِـلا تَنَـاهِيْ
~~٤۱- برحمـة الـرحيم عنـا تسترُ   فكشـفها أضراره لا تقـدرُ
~~٤٢- قد تجعل القلب كظرف خالِ   لم يستفد مـن صـالح الأعـمالِ
~~٤٣ - حتى وإن أكثر فيها واجتهد   وكـان في جـدٍ وعـزم لا يُحَـدٌّ
~~٤٤- فليسـت العـبرة بالإكثـارِ   وإنـما بـالنفع والإثـمارِ
~~٤٥- فمثـل هـذا لم يفـز في الآخـرة   بـل نفسـه مغبونـةٌ وخـاسرة
~~٤٦ - وإنما العبـد الـذي لا يخفِـقُ   من کـان قلبه بنـورِ يُشْرِقُ
~~٤٧- فيعـرف الحـقَّ بنـورِ قَلبِهِ   وبـاطلاً ومَـن مشـى في دَرْبِهِ
~~٤٨ - مميـزاً بـين ولي الله   وَمَـنْ يُعَادِيـهِ بـلا اشْتِبَاهِ
~~٤٩- ويمقـت العاصـين في الله ولم   يحـبَّ كـل مـن بعصـيانِ ألمّ
~~٥٠- لبيع حظهـم مـن الـرحمنِ   بِالبَخْسِ من أجـل الحطـام الفـاني
~~٥١- والحرص والأطماع والتفريطِ   والجهـل والغـرور والتَخْلِيطِ
~~٥٢- ومـا غـدا فيهم مـن الإقبـال   على سوى الوهـاب ذي الجـلالِ
~~٥٣- فهذه تـدعو إلى المقـت بـلا   حـدِ لمـن للأمـر هـذا فعـلا
~~٥٤- وكـل مـن لمثل هـذا يَمْقُتُ   مع الرضـا عـن نفسه لا يثبت
~~٥٥ - لکنّ من يرجو لهم أن يُرحموا   وخوفه مـن أن يزل أعظم
~~٥٦ - مجاهـداً مثـابراً لا يفترُ   فهـو الـذي بالفعـل هـذا يجـدرُ
~~٥٧- لأنه قد نال فقهاً یندُر   عـلى كثـير في الأنـام يعسُر

PageV03P099

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0100.png)

~~٥٨ - وعلمـه أن رجـوع الحـالِ   في اليـأس بالنجـاة بـالأعمالِ
~~٥٩- مـا لم يكـن مـن ربنا التَّغَمّدُ   برحمـةِ ننجـو بهـا ونسعدُ
~~٦٠- وفي حديث المصطفى قطعُ الأملْ   بأننـا ننجـو بصـالح العمـل
~~٦١ - لكنـه فرض علينـا يلـزمُ   نسمو بـه في جنـة ونكـرمُ
~~٦۲ - وبعد هـذا ينظر الألطافـا   وفضـلَ مـن أمـده وعـافی
~~٦٣- وأنّـه أمَـدَّه بـلا سَـبَبْ   ولا لحقِّ عنـده لـه وَجَـبْ
~~٦٤- وإن سـألت: أيُ حـال أفضـلُ   من جاهد النفس عساها تكمل
~~٦٥ - أو مـن أمات لذة الـذنب ولم   يعـد لـه مـن ذكره غير النـدمْ
~~٦٦ - وصـار في اطمئنانهِ يزيدُ   وغير حـب الله لايريـد
~~٦٧ - لا شكَّ أن حـال هـذا أرفعُ   لأن مـن جاهـد في ذا يطمعُ

PageV03P100

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0101.png)

~~۱- وكـل مـن أنـابَ قـد تَـذَكَرا   وقلبـه بالـذكر قـد تنـوَّرا
~~٢- فيثمـرُ المعـارفَ الكثـيرة   حتى يكـون مـن أولي البصـيرة
~~٣- ويرجـع المـؤمن بـالتفكرِ   عـلى الـذي نـال مـن التـذكرِ
~~٤- والعكس حتى قُفْلُ قلبِ يفتحُ   فَيَـنْجَليْ ظلامُـهُ وَيُشْرَحُ
~~٥ - والله قد سمى الكتـاب تذكرة   أيضاً وَذِكرَى وهـدى وتبصرة
~~٦- فإنهـا في المتقـينَ سَـاريةْ   ولأولي الألبـاب أيضـاً داعيـة
~~۷- وللمنيبـين غـذاء وهـدی   تَزْكُو به أرواحهم طُولَ المدى
~~٨- ثم القلوبُ: مَيَّتُّ أو ذو مَرَضْ   أو سالمُ مـن أي مكروهِ عَـرَضْ
~~٩- أولهـا ممتنـعُ التَـدْكُّرِ   وبعـده ذو غفلـة ومنْكر
~~١٠ - وثالثُ القلوب: قلب قد حضر   يقطف مـن جنى المعـاني والفِكَرِ
~~۱۱ - وقوله (ذکری لمن كان لَهُ   قلـبُْ) فَِلادَّكَـارِهِ يَرْفَعهُ
~~١٢- فالقلب هذا قد حوى كل العبر   وإنـه بفكره قـد ادكر
~~۱۳- مستنبطاً بنوره أزکی الحِکَمْ   وطامعـاً في جـود ربه الأَعَـمْ
~~١٤- یزداد نوراً إن تلا أو سَمِعَا   آيـات ربـه؛ لأنـه وَعـى
~~۱٥ - کاَنَّه مشاهدٌ مـا بَشَّرَا   به النبـي المصـطفى أو أنْـذَرَا
~~١٦ - هذا هو القلب الذي الله قصد   وغير هـذا فلقلبه فقَـدْ
~~١٧- وإنَّ (أوْ ألقـى) لهـا دلالـة   تخـالف الأولى بـلا مَحَالَـةْ

PageV03P101

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0102.png)

~~۱٨ - ف (أو) هنا ليست بمعنى الواو   لكن لنفي شبهة التسـاوي
~~١٩- فـإنَّ (أوْ أَلَقَـى) لمـنْ لَمْ يَحْضُرِ   لكـن بذا الإلقـا حظي بالظفر
~~۲٠- فنـال قلبُه حضـوراً وادَّکر   وصار مـن أهـل المعـالي والفكرْ
~~۲۱ - وينبني تـذكر الإنسـانِ   عـلى ثـلاثٍ فاسـتمع بيـاني
~~۲٢ - أولهـا: انتفاعـه بالموعظـة   لكونهـا هاديـة ومؤقظـة
~~۲۳_ وبعدها استبصاره بما اعتبَر   ثالثهـا: الفـوز بـإثمار الفِكَـرْ
~~٢٤- فيصبح القلب مليئاً بالرجا   والخوفِ مـن إلهـه يرجـو النَّجَـا
~~۲٥- مع الخلاص جاهـدًا بـلا كسَلْ   بهمـة تقـوده إلى العَمَـلْ
~~٢٦- متَّعِظـاً بِكُلِّ مَـا قَدْ سَمِعا   من الهدی مسترشداً منتفعا
~~٢٧ - في أمـرِ دِينِـهِ وَدُنْيَـاهُ ولا   تراه مختـالاً عـلى مـن جَهِـلا
~~۲۸- وهکذا اتَّعاظُهُ بِمَایری   مِـنْ آيـةٍ أو أي شيءٍ قُـدَّرَا
~~۲۹- وإن في استبصـاره بـما اعتَـبَهْ   زيـادةٔ عـلى الـذي به افْتكَرْ
~~٣٠- وأنـه يُصـقل بالتـذكُّر   كـل الـذي قـد نيـل بالتفكر
~~۳۱- بقـوةِ استبصارهِ الـذي حُبيْ   به مـن الرب لنيـل الرتب
~~٣٢- لأنـه يوجـب تجديـد النظـر   مقويـاً شعورَه نحـو الوَطَرْ
~~٣٣- وعنـدها تشـتد رغبـة السفر   بقلبه مفكـراً فـيما ادَكَـرْ
~~٣٤- والفكـرةُ الإثمارُ منهـا يُحْمَـدُ   وحيث لا فكرة لـيس يوجد
~~٣٥ - وأول الإثمارٍِ نيـل مـا رجـا   والعمـل الـذي بـه قـد أبهجا
~~٣٦- فالعمـل الصـالح للِعلْـمِ ثَمَرْ   والعلـم أيضـأ ثمـرات للفكر

PageV03P102

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0103.png)

~~٣٧- ولا ينـال المرء نفعـاً بالعظَـة   إلا بفقـرِهِ لِتِلْـكَ الموعظـةٌ
~~٣٨- فمن يك افتقارُهُ اشتدَّ انتفَعْ   وغفلـة النفس وشرها اندفع
~~۳۹- لخوف بطش ربه الشـديدِ   وكونـه مـدكر الوعيـد
~~٤٠ - ثم العمى عن عيب من لنا وَعَظْ   شرطٌ لنفعهـا وحسمِها المـرض
~~٤١ - فعيبُهُ فيه ونصُحُه لنَا   والخزيُ حظَّـهُ وليس حظَّنـا
~~٤٢- فهـذه شروط وعظ فـاعلم   وَفُزْ بِنُورٍ وَسْطِ ليـلِ مظلمِ
~~٤٣- شروط من أراد أن يستبصرا   حيـاةُ عقـل بالهـدی تنـوَّرا
~~٤٤- وبعـده معرفـةُ الأيـام   بكـل مـا يجـري عـلى الأنَـام
~~٤٥- ثـم سـلامةٌ مـن الأغـراضِ   ممـا يجـرّ القلـب للأمـراضِ
~~٤٦- إن ثمار الفكـر لـيس تحصُـلُ   إِلا لَـنْ يَقْصُـر منـه الأمـلُ
~~٤٧ - إن كـان دائبَـا بـلاتَـوَانِ   يُجِـدُّ في تـدبر القـرآنِ
~~٤٨- مجانبـاً لمفسـداتِ قلبهِ   مراقبـاً في سَـيرهِ لرَبَّـهِ
~~٤٩- وعلمنا قرب الرحيل والأجل   يلـزمُ منـهُ أن نقَصَّـرَ الأمـلْ
~~٥٠ - كذا انتهاز فرص العمر التي   مثـل سحابة أتت وولت

PageV03P103

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0104.png)

~~٥۱ - ومفسدات القلب جداً تكثرُ   وهي التـي بهـا العبـاد تعثر
~~۵۲ - فتجعل القلب مصاباً بالعمى   ذا صـمم عـن الهـدى وأبكَـما
~~٥٣ - وربما أمِيتَ موتـاً كـامِلاً   ولم يعـد لأي خـيرِ عـامِلا
~~٥٤- منقطعـاً عـن ربّه تماما   قـد حرم اللذات والإنعامـا
~~٥٥- مـن حب ربه وأنسِهِ بِهِ   وشـوقه إلى اللقـا وقربـهِ
~~٥٦- ومفسدات القلب خس تحصرُ   وهـي التـي بهـا الأنـام تخسَرُ
~~٥٧ - أولهـا: الخلطـة حـين تكثُـرُ   ولم يك العبـد لهـا يُقَـدَّرُ
~~٥٨ - فتملأ القلـب شتاتاً وألم   وتجلب الآفـات طُـراً والنَّقَمْ
~~٥٩- وكل خلطة على الدنيا انْبَنَتْ   كم عَطَّلَتْ خيراً وشراً أَنبتتْ
~~٦٠ - وكل من والى على غير الهـدى   إن لم ينـل مـا رام صـار حاقِـدا
~~٦١- فاحذر قرين السوء يا ذا الماجِدُ   فهـو إلى كـل بـلاء قائـدُ
~~٦٢ - عَـمُّ النبـيٍّ مَـنْ دَهَـاهُ فَـامْتَنَعْ   عن الهدى غير الرفاق ذي الشَّنَعْ
~~٦٣ - فَخَالِطِ الناسَ على الخير فَقَطْ   ولا تكـن موافقـاً عـلى غَلَطْ
~~٦٤ - محترزاً مـن أي أمـر قـاطِعِ   وكـن لـذي الجـلال خـيرَ طَـائعِ
~~٦٥ - لا تستجب للـوارد الشيطاني   ولا لمـا يـدعو إلى الخسـران
~~٦٦ - كي لا تكون عاضـاً مـن الندم   في يومٍ جمعِ الناس والهول الأعَمْ
~~٦٧ - لأنـه لا خـل إلا المتقـيْ   وغـيره شرُ عَـدُوّ فَـاتَقِ

PageV03P104

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0105.png)

~~٦٨ - وكل من خَالَلْتَهُ بلاهُدَی   يكون في أخراك مِن أعدى العـدى
~~٦٩- تـراه إن والاك في دنياكـا   مُوَظَفُـاً لنَفْسـهِ إخاكـا
~~٧٠ - وإن أتيـت مجلـس المعـاصِيْ   فـلا تكـن مجاريـاً لعـاص
~~۷١- بل إن قدرت أن تحيـل المجلسا   لطاعـة الله تكـون الأكيسـا
~~۷۲- وإن عجزت كـن لبيباً وابتعدْ   أو حـاضراً كغائب عمّا وُجِـدْ
~~۷٣- بِقَلْبِ مَنْ بحِبُّ مَوْلاهُ رَقَی   في المـلأ الأعـلى تَقِيَّـاً صـادقا
~~٧٤- معلـق القلـب عـلى الـدوام   بالخـالق العظـيم ذي الإنعـام
~~۷٥- ملتجئـاً إليه مـن أي خطر   مراقبـاً لأي خـاطرِ خطـر
~~٧٦- وإن قـدرت أن تزيـل المنكـرا   فلا تكن عن رفعه مقصرا
~~٧٧- والمفسـد الثـاني هـو الأمَـاني   ولم يزيَّنْهُـا سِـوى الشيطانِ
~~۷۸- بـه يتـاجر الـذين أفلسـوا   يَسُـوْقُهُمْ إلى لظـى ويُـرْكِسُ
~~٧٩- يُخيَـون في تخيـل المُحَـالِ   مـن دونما عـزم عـلى الأعـمَالِ
~~٨٠ - لكـنْ أمـاني الأتقيـاءِ طامحـةْ   تقـودهم إلى الأمـور الصـالحة
~~٨۱- والمفسـد الثالـث بـئس المنكرُ   أشـدُّها مضـرَّةً وأخطرُ
~~٨٢- تعلُّـق المـرء بغـير الله   فهو أسـاس الخـزي والـدواهي
~~٨٣ - وهو أساس الشرك فيمن يشركُ   يشـقى بـه وفي الجحـيم يَهْلِكُ

PageV03P105

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0106.png)

~~٨٤- يوكله الله لمـن بـه اعتصَـمْ   حتـى ينـالَ كـل قُـبْح ونـدمْ
~~۸۰- ومـا له شيء سوى الخذْلانِ   والـذم والمصير للخسـرانِ
~~٨٦ - والمفسـد الرابع في الطعـام   كـمْ جَـرَّ مِـنْ ضُرِّ عـلى الأنـام
~~۸۷ - فَمُفْسِـدّ بذاتـه إذا أكـل   ومفسـد بقـدره إذا فعـل
~~۸٨- فالمفسد الذاتي نوعـان انْقَسَمْ:   لحـق ربنـا كميتـةٍ ودَمْ
~~٨٩ - ثم لحقِّ الناس مثل: ما غُصِبْ   ومثل: مسروق، ومثل: ما نُهبْ
~~۹۰ - ومثل: مسلوب بقهرِ أو حيا   أو كـان في ذمَتِـهِ قَـد بَقِيـا
~~۹۱- وقسمه الثـاني هـو التَّعـدِّي   لكونـه جـاوز قـدر الَحـدِّ
~~٩٢- كمثـل إسرافٍ أو الإفراطِ   في الأكـل والشرب بـلا انْضِبَاطِ
~~٩٣- فهـذه مشـغِلة ومفسـدة   لأنهـا عَـنْ كـل خـيرٍ مبعـدة
~~٩٤- والمفسَـدُ الخـامِسُ نـوم كثرَا   يورث غفلـة الورى والضردا
~~٩٥- ويثقـل الأبـدان أيـما ثِقَـلْ   ويقتـل الوقت ويبعث الكسل
~~٩٦- والنوم بعد الفجر مما يَقْبُحُ   وهـو لكـل عاقـل لا يصلح
~~٩٧- والَخیْرَ موعود به مَن ترکه   ولا ينـال فـاعلوه البركـة
~~٩۸- ونوم بعد العصر- ضرّهُ اشتهر   وكـل مـن يعتاده يلـق الضرد
~~٩٩- وأول الليـل هـو المحمـودُ   وباعتـدال النـوم تستفيد
# 23 3 2

PageV03P106

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0107.png)

~~۱- الاعتصـام بالإلـه الـراحم   وحَبْلِهِ المنْجِـى مِـنَ القَواصِمِ
~~۲- بـه نجـاة العبـد مـا يُهْلِكُ   وسرّ فـوز مـن إليه يسـلك
~~٣- وإنـه لِلْمَكْرُمَـاتِ هـاديْ   وهـو سلاح الدرء للفسـاد
~~٤- وجـاء في تعريـف الاعتصَـام   بحبـل ربي خـالق الأنَـام
~~٥- بأنـه هـو الجماعـة التي   عـلى كتـاب ربهـا والسـنةِ
~~٦ - تمسكاً بدينـه وعهـدِهِ   ورغبةً مـن عبده في وعدِهِ
~~۷- مستبصراً بقلبـه هُـدَاهُ   بنـور ربه الـذي حبـاهُ
~~۸ - فالاعتصامُ ذا يقي مـن الضَّرَرْ   وكـل شر وبـلاء وخطـرْ
~~۹- مـن شـهوة وشبهة ومتعسِ   وكيـد شيطان رجيم مبلِس
~~۱٠٠- لـه ثـلاثُ درجـاتْ تامَة:   أولهـا هـو اعتصـامُ العَامَـةْ
~~۱۱- من سَلَّموا من دونما منازعَةْ   وأخلصـوا في القصـد والمتابَعَةْ
~~۱۲- وعـاملوا الله عـلى يقـينِ   بدون شكِ وبدون مَـيْنِ
~~۱٣ - بـل عـاملوا بأصـدق المعامَلَة   ولم ينـازعوه فيما هـولَـهُ
~~١٤ - مـن جبروته ووصف الكِبْرِ   بل شکرهم له بدون کُفْرِ
~~۱٥- وبعده يأتي اعتصام الخَاصَّةْ   عبـادةَ لـذي الجـلال خالضْـة

PageV03P107

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0108.png)

# ١٠٧)
~~١٦ - من بَسَطُوا الأخلاق بَسطاً لم يُحَطْ   ليس على قوم مـن الناس فقطْ
~~١٧- واحتملوا الأذى ولم يؤذوا أحدْ   أو يَدَعوا شيئاً به نيـل الرشد
~~۱۸ - قلـوبهم نحـو العـلى تتـوق   ما صدّهم عـن ذاك ما يعوقُ
~~۱۹- بل قطعوا كل معيق قد بطن   ولم يخـافوا ضُرَّ ظـاهرٍ وَلَـنْ
~~٢٠- فمثـل ذا في يـده المـال فقط   وإن يك القلب به قـد انبسط
~~۲۱- لکنه من قلبه قد قطعه   فكـان خـالي الضرجـم المنفعـةٌ
~~۲۲- لأنـه أخرجه مـن قلبه   ولم يعـد منشـغل البـال بِـهِ
~~٢٣- هـذا هـو الزهـد مع اليسـار   والنفع بالمـال بـلا أخطَـارِ
~~٢٤- من أجل ذا كان الصحابة الغرر   في الزهـد في أعـلى مقـام مُعْتَـبَرْ
~~٢٥- أما إذا ما المال في القلـب سَكَنْ   يقـود مـن أحبـه إلى الفِـتَنْ
~~٢٦ - حتى وإن كـان فقيراً مَعْدِمَا   لأنـه بالمـال صـار مُغْرَمَـا
~~۲۷- وذروة اعتصـام كـل معتَصِـمْ   في قربهِ مـن ربَّهِ كـما رُسمْ
~~۲۸- لقوله سبحانه (اسجد واقترب)   معتصما بحبله كـما يحـب
~~٢٩- فإنه يكسب كـل مـؤمنِ   عزاً عظيماً مـا له مـن مُوهنِ

PageV03P108

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0109.png)

~~١- فِـرَّ إلى الـرحمن، لا مِنْـهُ ولا   تكـن لِـذَا الفرار قط مهمـلا
~~٢- فهـو فرارُ الأوليـاءِ السـعدا   والعكس حـال الأشقياء البعـدا
~~٣- وفرَّ مـن جهـلٍ إلى العلـومِ   وسـعة المهـيمن القيـوم
~~٤- ومن تساهلٍ ومـن تقصيرِ   للجـد والخـيرات في تشميرِ
~~٥ - ولا تجب دَوَاعِـي التـواني   وانهض بعـزم مـا له مـداني
~~٦- وجانب التسـويف والتهاونـا   لكي تكـون مفلحـاً وآمنـا
~~٧- والجِدُّ في الفرار حسـن العمـلِ   والصدق والإخـلاص والتوكـل
~~۸- والجهـلُ إمـا فقـد علـم نـافع   أو ترك فعـل وفق أمرِ الشـارعِ
~~٩- وفرّ من ضيق الصدور واهربِ   وكلـما يـدعو الـورى للعَطَبِ
~~١٠ - كالخوف والأحزان والغموم   وغيرهـا مـن سـائر الهمُـومِ
~~۱١- وكلـما في الكـون مِـنْ مَوَانِع   إلى فسيح فضـل ربي الواسِعِ
~~١٢- وفِرَّ مـن رسم إلى الأصـولِ   تَُحْظَ مـن المـولى بكـل سُـولِ
~~۱٣- ومن حظوظ النفس للتجريد   عـلى مـراد المالك الحميـدٍِ
~~١٤- بـدون تقصير ولا عـدوانِ   وإنـما عـلى هـدى الـرحمنِ
~~۱٥- فهـم أخـص سـائر العبيـدِ   في العلـم والإيـمان والتوحيـد
~~١٦ - لكـونهم لـربهم قـد عَرَفُـوا   وعن مرادِ ربهم ما انحرفُوا
~~۱۷ - والحظ مـا سـوى مراد الله   فكـن مـن الحظـوظ في انتبـاهِ

PageV03P109

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0110.png)

# ١٠٩)
~~١٨ - وكـل ذي نقص يفوته العُلا   مثـل الـذي صـفاتِ ربي عَطَّـلا
~~۱۹- ولم يميّز حظـه مـن غَـيْرِهِ   إلا موفقٌ هُـدِيْ في سَـيْرِهِ
~~٢٠ - لعلمـهِ بربـهِ وأمره   ونفسه وحالهـا وَجَهْلِهِ
~~۲۱- مُنْـتَقِلاً بسيرِهِ الرَّشِیدِ   مـن حـظ نفسـه إلى التجريـدِ
~~۲۲- فهـو بغیر الله لـيس يفرحُ   وقلبـه بغـيره لا يُشْرَحُ
~~٢٣- مجاهـداً في ذي الجـلال دائما   ولم يخـف في الله قـط لائـما
~~۲٤ - بربّه سبحانه غنـاهُ   وليس يأسى إن يفت سواه
~~۲٥- لم يفتقـر لغـيره تعـالى   ولم يخـف مـن غـيره إذلالا
~~٢٦ - بـالله لله مـع الله غـدا   فهـو بذا قـد حقـقَ التجردا
~~۲۷_ يقينه بربه ينصرُهُ   لم يقـدر الشـيطان أن يَضرّهُ
~~٢٨ - لم يستجبْ لأي حـظٍ طلبهْ   لأن حب ربه قـد غلبه
~~۲۹- يقـول عَنَّـي إننـي لله   ممتثـل للأمـر والنـواهي
~~٣٠ - إن فـاتني فكـل شيءٍ ذَهَبَا   وإن أجـد مـولاي نلـتُ الرتبا
~~۳۱- لله عـن کلّ الـوری تجرّدا   وَحَـدَهُ سـبحانه وأفْرَدا
~~٣٢- وأَمْرُهُ عَـنْ كُـلِّ شَيءٍ جَرَّدهْ   إلا الـذي يعينـه فاعتمـده
~~۳٣- فليسَ في كُلَّ الحظوظ يُقْدَحُ   بـل إن منهـا نافعـا فيمـدح

PageV03P110

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0111.png)

~~١- وَبالسَّـماع ربنـا قـد أمـرا   أثنـى عـلى أصحابه وبشَّرا
~~٢- وجعـل استماعهم لمـا أمرْ   من قوله وقول أفضـل البشر
~~٣- دَلِيلَ خير فيهم کما ذکَرْ   وبانعدامـه المـروق والخطـرْ
~~٤ - فمن نهی عنه ومن عنه زَجَرْ   فإنـه بـأمر ربـه كفـرْ
~~٥- فهـو رسول القلب للإيـمانِ   وهـو أسـاس الخـير في الإنسـانِ
~~٦ - وما تمـادى في الشرور والغلطْ   إلا الذي مـن كل مسموع خلط
~~٧- أمـا الـذي لـذكر ربـه استَمعْ   ونبـه القلب وللحـق اتبعْ
~~۸- بربه یسمع لیس بـالهوی   فشدّ عزمه وحرك القُـوَى
~~٩- فإنـه الممـدوح مـن مـولاهُ   إصـغاؤه لربـه أعـلاهُ
~~١٠ - لعلمـه فائـدة المسـموع   وكونه لـيس مـن الممنـوعِ
~~۱۱ - وکونه حقـأَ بدونما مِرَا   وَمعْلِيـاَ لسَـامعِ وَمُثْمرا
~~۱٢ - وإن تردْ أقسـامه فإنها   ثلاثـة يعرفهـا أولـو النهـى
~~١٣- أولهـا سـماعنا الإيـماني   مـن ذي الجـلال ربنـا الـرحمنِ
~~١٤- وهـو سماع قولِـهِ المَنـزَّلِ   ومـا أتى عـن النبي المرسَـلِ
~~١٥- بـالفهم والإدراك والتـدبر   وبإنصياع القلب والتـذكر

PageV03P111

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0112.png)

~~١٦ - هـذا سماع الأتقيـاء البَرَرَةُ   مـن أخلصـوا فأَكرموا بـالثمرة
~~۱۷ - لم يسمعوا مغنيـاً ومطربا   وماجنـاً في قولـه مُشَـبَبَا
~~۱۸ - بـل يسمعون حـادي الأرواح   إلى ديـار الأنـس والأفـراح
~~۱۹ - ومـا یثير عـزمهم ويرشدُ   إلى رضـا خلاقهـم ويسعد
~~٢٠ - فاسترشـدوا لحجـةِ وعِـبْرةِ   وأكرمـوا بـالفكر والبصـيرة
~~۲۱- وعلمـوا دلائـل القرآنِ   وفقهـوا الحـديث والمعـاني
~~۲۲- وفندوا ضـلال مـن لم يهتَدِ   وحقَّقوا في النـاس أعـلى الرَّشَدِ
~~۲٣- فهم من النور على نور جَليْ   وعـن مضلات الهـوى في مَعْرْلِ
~~٢٤- حثوا عـلى التُّقَـى بكـل السُّبُلِ   لأنـه حقـا طريـق الكمـل
~~٢٥ - والقلب حَـيُّ بهـداه مبصرُ   في طاعـة المـولى غـدا يشـمَّرُ
~~٢٦ - أمَّـا سماع مـا يضر يحـرمُ   لأن مـن يسمعه لا يسـلم
~~۲٧- فـالفحش والغنـاء بالمعـازفِ   بـاب النفـاق مصـدر المخـاوِفِ
~~۲۸ - والقلبُ بـالقرآن يستفيدُ   وبالغنـا فسـاده أكيـد
~~۲٩- حـبهما في القلـب لا يجتمعُ   فهـل تريـد ضَـاراً لا ينفع
~~۳۰- ودعـك ممـن للغنـا أباحـا   لم يسـترخْ منـه ولا أراحـا
~~۳۱- ومـن عجائب الأولى أباحَوا   الزعم أنهـمْ بـه استراحوا
~~٣٢- وأن طيب الصوت من ضمن النعم   وربنـا لسيء الأصـوات ذمّ
~~۳٣- وأنـه يُسَـكنُ الأطفـالا   وفي المسـير نَشَّـط الجِـمالا

PageV03P112

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0113.png)

~~٣٤ - وأنـه مـن أنعـم الجِنَـانِ   وأنه يطلـب للقـرآن
~~٣٥- والمصطفى قـد قال ليس مِنَّا   مـن لم يَكُـنْ بالـذكر قـد تغنَّى
~~٣٦- وأنـه في العيـد للغنـا أقَـر   عائشـة الفضـلى ولم يكـن زَجَـرْ
~~٣٧- وحَثَّ للغنـاء في الأعـراسِ   وذاك معلـوم لكـل النـاس
~~٣٨- وسـمع الأشـعار والأراجـزًا   ولم يكـن عـن منع ذاك عَـاجِزا
~~۳۹- وقـد أجاز بل دعـا وأيَّدا   وكـل هـذا في الحـديث أسـنِدا
~~٤٠- وقـد أباحـه التقي ابـن عمرْ   كذا ابـن جعفرِ وقوله اشتَهرْ
~~٤١- وأنه أولى من الصوت الشجِيْ   من طائر من دون أدنى حَرَج
~~٤٢ - أيْضاً وقاسوه على الشيء الَحسَنْ   في لونِـهِ أو رِيحِـهِ يـا ذا الفِطَـنْ
~~٤٣- وهذه الأقوال حادت يا تقي   عـن الصـواب فاحترزهـا واتـق
~~٤٤ - فإنه قد جاء عـن خير الورى   بـأن قومـا يستحلون الحـرا
~~٤٥- ويستحلون المعـازف التـي   خلت عـن الخـيرات والفضـيلة
~~٤٦ - (ويستحلون) دليـل واضح   لـيس لصرفه الحـداء صـالح
~~٤٧ - أو هل يباح ما به الطفل انسجم   مـن الأغـاني المفسـدات والـنغم
~~٤٨ - أو بالتذاذ العـين حسـن المنظر   أو شـم ريح طيـب أو عطـرِ
~~٤٩- أو كونُـهُ يوجـد في الجِنَـانِ   أو جـاز في الأعـراس للنسـوانِ
~~٥٠ - فإننـا في روضـة الجنـانِ   نـنعم بالزينـةِ والأغـاني
~~٥١- والخمـرِ والحريرِ والحسـانِ   وسـائر اللـذات والأمـاني
~~٥٢ - ولـيس في الجنـاتِ شيء يحرمُ   فالعبد يعطى ما اشتهى ويكرم
~~٥٣- وقـولهم يطلب للقـرآنِ   نَعَـمْ ولم يُـبِحْ لنـا الأغـاني

PageV03P113

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0114.png)

# ١١٣)
~~٥٤ - لأن كـل مـن بـه تَغَنَّی   یكون بالخیرات قد تهنَّی
~~٥٥- وكـل مـن يستمع الأغـاني   يَعِـشْ مَـعْ الهمـوم والأحـزانِ
~~٥٦ - للفـرق بين قـارئ القرآنِ   وسـالك في سـبل الشـيطانِ
~~٥٧ - وَحِلُّـهُ في العـرس والأعيـادٍِ   صح ولكـن دونما إفسـادِ
~~٥٨ - وما دليلُ غير ذي الأوقاتِ   المـن يـرى الغنـاء كـالأقواتِ
~~٥٩ - وقـولهم إن النبـي استمعا   إلى زهـيرِ ولحسـانِ دعـا
~~٦٠ - قلنـا ومـن يحـرم القصـائدًا   إذا أتـت مملـوعة فوائـدا
~~٦۱- وثالث الأقسـام مـا أبيحـا   فليس مـذموماً ولا ممـدوحا
~~٦٢ - بـدون آلات ولا تَسَفُّلُ   ولا تمايـل ولا تغـزل
~~٦٣- ولـيسَ قَـولُ مـاجنِ ومُفْسدٍِ   ومبعـد عـن السـبيل الأرشـد
~~٦٤- لكن كقول الصحب وهو الأجملُ   (لئن قعـدنا والرسول يعمل)
~~٦٥ - (فـذاك منـا العمـل المضـلَّلُ)   فمثـل هـذا طيـب ويقبل
~~٦٦- وإن يك القائل ذا صوتِ حَسنْ   بمثـل ذا القـول فـذا مـن المـنن
~~٦٧ - والـدف للتحسـين في الغنـاءِ   يحـل في الأعـراس للنسـاء
~~٦٨- هذا هو الذي ندين الله به   وغـيره محـرم أو مشتبه

PageV03P114

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0115.png)

~~١- الخـوف للقلب دواء نـافعُ   وبلسـم مـن العـلاج نـاجع
~~۲- وحكمه فرضّ صلاحُنا به   للأمـن مـن محـرم أوْ شُـبَهِ
~~٣- لأمر مولانـا به ومـدح مَـنْ   يخشـاه في كتابـه وفي السـنن
~~٤ - فالخـائفون في ذرى الجنـاتِ   وهـم أولـو السبق إلى الخيراتِ
~~٥ - قد أخلصوا واجتهدوا إذ عَمِلُوا   في وجـل يخشـون أن لا يقبَلُوا
~~٦ - وهـو توقـع العقوبـات بـلا   توقف ما القلب أضحى عاملا
~~٧- أو اضطراب القَلْبِ ممـا يحـذَرُ   أو قـوة في علمـه تُبَصَّرُ
~~٨ - أو هرب القلب مـن المكروه أنْ   يُحُـلَّ بالخـائف أو أن يَنْـزِلَنْ
~~۹- وقيـل سَـوْطٌ قَـوَمَ الله بهِ   کل عُبَيْدِ شَـارِدٍِ عـن بَابِهِ
~~١٠ - وهو سراج القلب منه يُبْصِرُ   لنـافع وعـن شرور يقصرُ
~~١١- وصادق الخوف مليءٍ بالورغ   للمنكرات كلهـا طرا يدع
~~۱٢ - وإن يكـن مقارنـاً للمعرفـة   فخشية، أنعـم بهـذه الصـفة
~~١٣- قد وصف الله أولي العلـم بها   وصاحبُ الخشيةِ مـن أولي النهى
~~١٤- مستمْسِکاً بربَّهِ ملتجِیْا   من کل شرِ رائحا أو جائیا
~~١٥- والرهبةُ الإمعـانُ في الهـروبِ   وضـدها الرغبـة في المحبـوبِ
~~١٦- والوَجَلُ انْصِدَاعُ قلب الخائفِ   مع انزعـاجِ بفـؤاد راجِفِ
~~١٧ - والهَيْبَةُ الخوف مع التعظيمِ   والحبَّ والإجـلال والتقـديمِ

PageV03P115

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0116.png)

~~۱٨ - واسمع إلى مقالـة الـدارانيْ   منبهـاً لأمـة الإيـمانِ
~~۱٩ - مـا فـارق الخوفُ فؤاداً أبَدَا   إلا غـدا خرابـه مؤكَّـدا
~~٢٠ - لأنـه للشـهوات يُحـرِقُ   وهو الـذي به الوجـوه تشرق
# 5) 2 »

PageV03P116

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0117.png)

~~۱- ورقـة الخـوف هـي الإشـفاقُ   لأهلـه بـين الـورى إشراق
~~۲- أولـه إِشـفاقنا أن تَـذدْهَبَا   أعمالنـا عِنْـدَ إلهنـا هبَـا
~~۳- فمشفق لجمع نفسه نـوی   عـلى هـدى إلهـه بـلا هـوى
~~٤ - أوسطه الإشـفاق أن تُفرَقَـا   أوقاتنـا في تافـةٍ فنغرقَـا
~~٥ - وغايـة المشـفق صـون سعيهِ   عن خطر العجب الذي يودي به
~~٦- وعـن مخاصـمات خلـق ربهِ   بكل مـا يَسْقُطُ قدرهُ بِهِ
~~٧- في غايـة الحـرص عـلى الفـؤادِ   والوقت بالجـد وخير الـزادِ

PageV03P117

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0118.png)

~~١- إن خشـوع القلـب روح الـدينِ   وسـلم الفـلاح والتمكـين
~~۲- والله قـد عاتـب كـلّ مـؤمنِ   لكـي يفـوز بالمقـام الأحسـنِ
~~۳- فهـل علِمْنـا بالعقـاب البيّنِ   وآن أن نخشـع أم لم يَـئنِ
~~٤- ولـيس كالخشـوع شيء ينـدُرُ   حتى يكـون في قليـلِ يُحْصَرُ
~~٥- وَيَـا لِـوَعْي زمـرةِ الصحابةْ   عـن ربهـم وفهمهـم عتابه
~~٦ - ويظهـر الخشـوع في الجـوارح   ويـدفع المرءَ لكـل صـالِحِ
~~٧- لأن مـا يبـدو مـن الإنسـانِ   شِـمَاره في بـاطن الَجنَـانِ
~~۸- وَمِـنْ تخَشُّع النفـاق حـذَّرا   حذيفـةُ الأمـين ثـم أنَـذَرا
~~٩- أجسـامهم تخشـع والقلـوب لا   فيـا لـه مـن سوء حـالٍ وبَـلا
~~١٠ - وقـال أول الـذي سـيُفْقَدُ   من دینکم خشوعکم فَیَفْسدُ
~~۱۱ - وقـال أيضـاً: إنـه لا خـير فيْ   صَلاةِ مَـنْ منها الخشوعُ منتفِيْ
~~١٢- جِمَاعُهُ الـذل لأمـر الآمـرِ   مع انقیادِ باطنِ وظـاهرِ
~~۱۳- وبعـده استسلام هـذا الطـائع   وسيرُه عـلى مـراد الشـارع
~~١٤ - مـع اتضاع القلب والجوارحِ   معتبراً بـالنقص والقبـائح
~~۱٥- معترفـاً بفضـل كـل مفضـلِ   بـلا تعـال وبـلا تَسَـفُّلِ
~~١٦- ولا يرى فضلاً له عـلى أحدْ   ولـو عـلى خادِمِـهِ أو الولـدْ

PageV03P118

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0119.png)

~~١٧ - وان أردت أكمـل الخشـوع   فاسْلَمْ مـنَ الأكـدار والممنـوع
~~۱٨ - كـأن ترائي النـاس بـالأعمالِ   ورؤيـة الإحسـانِ والإفضـالِ
~~١٩- والتـزم الإخفـاء للأحـوالِ   مـن صـالح الأفعـال والأقـوالِ
~~٢٠- لتصـلح الـنفسُ مع الجبـارِ   ولا يـؤول الحـال للبـوارِ
~~۲۱- فذلةٔ وفاقـةُ ومَسْكَنَة   تُبَلَـغُ الصـادق منـا مأمنـهْ
~~۲۲- مـع اعتراف منه بالتقصیرِ   وظلمـه وجهلـه الكثـيرِ
~~۲۳ - وعكسها کم حطمت مِنْ سالكِ   لكونهـا تُوْقِعُ في المهالِـكِ

PageV03P119

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0120.png)

~~١- المخبتـون هـم أولـو التواضعِ   والجِـد في السـير بـلا تَرَاجُعِ
~~٢- وهم لمـا يرضى الإله في عَجَـلْ   مع اصطبارِ والقلوب في وَجَلْ
~~٣- هـم المقيمـون الصـلاة في رَغَبْ   والمنفقـون المـال في شـتى القرَبْ
~~٤- بَشَـرْهُمْ إلهنـا بالجنـةِ   أكـرم بهـا مـن نعمـة ومنَّـةٍ
~~٥- لأنهـم سـاروا بـلا تـردُّدِ   ولازموا الإخباتَ خير مورِدِ
~~٦- وتركـوا خـواطر التعويـقِ   وشـمَّروا بالجـد في الطريـقِ
~~۷- مـع الطمأنينـة دونـما قلـقْ   معظمـين مَـن تفضـلاً رَزَقْ
~~۸- عـلی ثـلاث درجـات يکسبُ   وفي قلـوب الأتقيـاء يكتـبُ
~~٩- أولهـا الحـرب لكـل غفلـةِ   بالصـدق في الهمـة والعزيمَـةِ
~~۱۰ - والكف عن مُثنِ عن الرشادِ   وشـهوات الغـي والفسـاد
~~۱۱ - وتـرك مـا يلهي عـن المرادِ   وكـلِ مـا يضرٌ في المعَـادِ
~~۱٢- فيحتمي المخبـت ممـا ذكـرَا   بربّـه الـذي أنـال الـوَطَرا
~~۱٣ - فشهواته جميعـاً تخمدُ   ويستنير قلبـه ويسعَد
~~١٤- وأول الإخبات هـذي الدرجة   وهـي إلى التي تليهـا مَدْرَجَـة
~~۱٥ - فينتهي تردد الخـواطرِ   ويصـدق العـزم بفضـل القـادر
~~١٦- ويستقيم وفق عـزمِ جـازِمِ   إلى الكـريم ذي البقـاء الـدائم
~~١٧- ويقهـر الحبُ لديه سـلوتَهْ   محطماً شهوته وغفلتة

PageV03P120

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0121.png)

~~۱۸ - وإن أردت أن أريك الثانيـة   من درجاته فقل لي: ما هیه؟
~~١٩ - فهي بأن لا يؤحش القلب التقي   مـن عـارضِ وقـاطع للطُرُقِ
~~۲٠ - كوحشـةِ الوحـدة والتفرُّد   أو وارد عـلى القلـوب مفسِـدٍ
~~٢١- ولا يصح مثـل ذا المـرام   إلا بـإكرام مـن العـلأم
~~۲٢- فـإن قلـبَ صـادِقِ الإخبـاتِ   يُنَـارُ بالأســماء والصـفاتِ
~~۲۳٣- آثـاره تملأً قلبه هُدَی   وتـدفع الشرور عنـه والردى
~~٢٤ - ثالثهـا إخبـات أربـاب النهـى   وهي لقـوم خَصَّهُم ربي بهـا
~~٢٥ - فيستوي المـدح وذَمٌّ عنـدهمْ   واللـوم للنفـوس لازم لهـمْ
~~٢٦ - والمخبتُ التقيُّ دومأً يرتفِعْ   وعـن جميـع المخزيـات يَرْتَـدِعْ
~~۲٧- لأنه من حظ نفسه خَرَجْ   ولم يجـد مـن قـولِ ذام حَرَجْ
~~٢٨ - ولا سروراً وانبساطاً إن مُدِحْ   لأنه فيما سـوى هـذا طَمِحْ
~~۲٩- وإنما بفضـل ربـه فَـرِحْ   وقلبُه بربـه الأعـلى شُرِحْ
~~٣۰- ومن يقف للمدح والذم غدا   منقطـع القلـب لـنفسِ مجهـدا
~~٣١- ولم يـذق حـلاوة التعلَّـقِ   بربـه ولا مـن الشـرّ وُقِـيْ
~~٣٢- خَـلا مـن الله وبالشر مُـليْ   أَقْبِحْ بذا الظـرف وهـذا البَدَلِ
~~٣٣- إذ لم يـذقْ حـلاوة الإيـمانِ   والصـدق واليقين والإحسـان
~~٣٤- حاشا الذي من الكدورات صفا   وعامـل الله بحب وصـفا
~~٣٥- والـنفس عـائق كمثل الجبـل   وليس عـن صعوده مـن حيـل
~~٣٦- وکم به من عقبات وخطرْ   ومن لصوص أوقعوا بنا الضرر
~~٣٧ - وما لنا عن شرهم من معزلِ   ولا طريـقِ غـير هـذا الجبَـلِ

PageV03P121

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0122.png)

~~۳۸- لكنه سهل بفضـل الله   لكـل عبـدٍ صـابرِ أوّاهِ
~~٣٦- يـدلج في الليـل بعـزم سـام   بالـذكر والخشـية والقيـام
~~٤٠ - حتـى إذا قـارب نيـل المبتغـى   يجـد عـدواً في اعتدائه طغـى
~~٤١- محـذِّراً ومنـذراً لا تعـتلي   وإن أردت الأنس عـد للأسفل
~~٤٢- فـإن تحـداه وللأعـلى رقـى   ولم يكـن لقولـه مصـدقا
~~٤٣- تنـدحر الأخطـار ثـم تنتهـي   كـل العـوارض التـي بهـا نُهِيْ
~~٤٤- فهـذه منزلـة الإخبـات   تُوصِـلُ للرَّاحَـةٍ في الجنـاتِ

PageV03P122

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0123.png)

~~١- الزهدُ: تـرك كـل مـا لا ينفعُ   ولا إلى الأخـرى لعبـد يَرْفَعُ
~~۲- وقيل أن تُقْصِر في الدنيا الأمَلْ   وليس أغـلاظ الطعـام والحلـل
~~٣- وليس من هـدي النبي المجتبى   الزهـد فيما الرب عبده حبا
~~٤- مـن أنعـم وطيبـات نافعـة   وللشرور والفسـاد دافعـة
~~٥- ممـا يعيننـا عـلى الإيـمانِ   إذ شكرُها حـق عـلى الإنسـانِ
~~٦ - بـلا تعلـق ولا اشـتغالِ   بهـا عـن الرحمن ذي الجـلالِ
~~٧- وقيـل أن يخلـو فـؤاد العابـدٍِ   عـن كـل مالم يك منهـا في اليـدِ
~~۸- أو بِعُزُوفِـهِ بِـلا تَكَلُّـفِ   عـن هـذه الـدنيا ولا تأسـف
~~٩- وقيـل لا يُفْرِحُـهُ إقبالهـا   أيضـاً ولا يحزنـه إدبارُهـا
~~۱٠ - وقيل ترك كـل شيءٍِ يُشْغِلُ   عـن ربنـا ثـم عليـه نُقبلُ
~~۱۱- ولـيس أن نحَرَّمَ الحـلالا   كـلا ولا بـأن نُضِـيْعَ المـالاً
~~۱٢- لكن بما في يد مولانـا نَثِقْ   حتى وإن كنَّـا لـذاك لم نُطِـقْ
~~١٣- أيضـاً وأن نرغب في الثَّـواب   فيما أصـابنا مـن الصـعَابِ
~~١٤ - وكـل مـادون إلهنـا الأحَـدْ   من كان عنه معرضاً نال الرشَدْ
~~۱٥ - أقسـامه: ثلاثـة فانتبهِ   أولهـا الزهـد اتقـاء الشُّـبَهِ
~~١٦ - من بعد ترك للحرام الواضحِ   وتركـه لموجـب القبـائح
~~١٧۷- وثـانيَ الأقسـام: باغتنـامِ   فراغهُ في طاعـة العـلامِ

PageV03P123

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0124.png)

# (۱۲٣)
~~۱۸ - لكـل فعـلِ صـالح مفيـدِ   لأمـة الإسـلام والتوحيـد
~~١٩ - وَحَسْم جأشِ القلب كي لا يضطربْ   في أمر دنيـاه ويرعـى مـا يجـبْ
~~۲٠- وثالث الأقسام: زهـد الزاهـدِ   في زُهْـدِهِ مع احتقـارٍِ زائدٍِ
~~۲۱- مـوقراً معظماً لربهِ   فلا يرى ذا الزهـد لائقـا بهِ
~~۲۲- ولا يرى ذا الفعـل يعلو شَـانا   ولا يكـون مثلُـهُ قربانـا
~~۲٣- لكنـه مـلازم لفعلـهِ   مستحياً كـل الحيـا مـن ذِكْرِهِ
~~۲٤ - معترفـاً لله بـالتفردِ   في المنـع والعطـا بكـل مَقْصِـدٍ
~~۲٥- فکـل متروك بأمره تُرِك   وكل مفعـول به وليس بك
~~٢٦- فربنـا سبحانه الفعـالُ   ومنعـه ومنحـهُ إفضـال

PageV03P124

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0125.png)

~~١- الورع الخروج مـن كـل الشَّبَهْ   مـن كـل عبدٍِ لمصيره انتبَـهْ
~~۲- محاسـباً لنفسِـهِ مشـدِّدا   وهو ملاك الدين يا من رشدا
~~٣- وإِنَـهُ مطهـر القلـوبِ   مـن دنس الـزلات والذنوب
~~٤ - وكـل مـا يطفئ نـور القلبِ   ويجعـل العبـد رهـين الـذنب
~~٥ - وإنما آفتـه الكـبرى الطَّمَعْ   وحبنـا للشـهوات في هلع
~~٦- فـالوَرعُ التَقِـيُ نَفَسـاً صـانا   بحِفْظِـهِ الأخـلاق والإيمانـا
~~٧۷- ويرتقي ذو ورعِ حتی یدعْ   بعض المباحـات ليقطع الطمع
~~۸- محـترزاً مـن سـائر المنـاهِي   بلا اقـتراب مـن حـدود الله
~~٩- وذاك حـال ذي العـلى في المرتبـة   من عَظَمَ اللهَ وخـلَّى مـا اشتبَهْ
~~١٠ - واعلم بأن الخوف يثمر الوَرَع   فكـن ملازمـا لـه ولا تدع
~~۱۱- أوله الزهـد فكـن منه عـلى   قـدرٍ عظـيم رافع إلى العُـلى
~~۱۲- وهو وقوفّ دونما تأویل   عـلى حـدود العلـم في تبجيـلِ
~~۱۳- حتى يصير ظـاهِرُ الإنسـانِ   لله ذي المنـة والإحْسَـانِ
~~١٤- وإن ترد أجمع قول في الورغ   في كـل مـا تفعلـه ومـا تَدَعْ
~~۱٥ - أن تترکن ما ليس يعنيك فَلا   تأتيـه مجمـلاً ولا مفصَّـلا
~~١٦- وذاك مـن محاسـن الإسـلام   كـما أتـى عـن أشرف الأنـامِ
~~١٧ - صـلى عليـه الله بالـدوام   وآلـه وصحبه الكـرام

PageV03P125

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0126.png)

~~۱٨ - وعن أبي إسحاق ليس أصعبُ   مِـن ورع في مَنْطِـق وأتعـبُ
~~۱۹- وصَحَّ عَـنْ نَبِيَنَا خير البشر   صلى عليـه الله مـا نـور ظهـر
~~٢٠ - أن اللسـان مُوْقِـعٌ في النـار   إن لم يكـن كـف عـن الأخطـار
~~۲۱- فياله مـن خطر عظیم   يَكُـبُّ مطلقيـه في الجحـيم
~~۲۲- وجاءَ عَنْ سُفْيانَ قولُ يُعْقَلُ   بـأن ترك مـا يحيـك أسهلُ
~~۲۳- فكيف لا تترك مـا يشـقيكا   ولم تكـن مراقبـاً باريكـا؟
~~٢٤ - والـورَع المسـبوق بالزهـادة   سر النقـا والطهـر والسعادة
~~۲٥- وعـن أبي هريـرةِ قـد وردًا   :هم جلساء الله ربنـا غـدا

PageV03P126

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0127.png)

~~۱- قـد أَمَـرَ الـرحمنُ بالتبتُّـلِ   عبـاده في ذكـره المنـزَلِ
~~۲- تبـتلاً بكامـل التجريـدِ   والحب والإخـلاص والتوحيـدِ
~~٣- والخـوفِ والرجـاءِ والتوكُّـلِ   والشكر واللجـوء والتـذلّل
~~٤- كي لا يكونوا كأجير عَمِلا   يلاحظُ الأعـواضَ فيما فَعَـلا
~~٥ - حتـى ينـال أجـره فينصرف   لأنـه لغـير ذاك لم يَقِـفْ
~~٦ - والصـادق المخلـص في تبتلـه   يکسی من التقوى بأبهى حلله
~~٧- فقلبـه بربـه الأعـلى اتصَـلْ   وعن جميع ما سوى الله انفصَل
~~۸- ولا يبـالي بسـوى باريهِ   ولم يَـرُمْ غـير الـذي يرضِيهِ
~~۹- عليه حقـاً باشتياق أقـبلا   بتركـه الأغيـار تركـاً مُجْمَـلا
~~١٠ - يرضى بحكـم الله والقضـاءِ   ومـا له في الخلـق مـن رجـاءِ
~~١١- ولم يخفْ شيئاً على الإطـلاقِ   سـوى الإلـهِ الملك الخـلاق
~~۱۲- ونفسـهَ في أمنع الحـروزِ   حِرْزِ القـوي الغالـب العزيـز
~~۱٣- سَـلَّمها طوعـاً إلى باريهـا   فَحفِظَتْ مـن کل ما يؤذيها
~~١٤- فهو بذا الفعل عن الخلق انْقَطَعْ   ولم ينـل أكْمَلـهُ حَتَـى يَدَع
~~١٥- ما كان في النفس من الأهواءِ   في حالـة السـراء والضـراءِ
~~۱٦- مستأنسـاً بِرَبَّـهِ العظـيم   معيـذه مـن فتن الـرجيم
~~١٧ - وَنَسَماتِ الأنْسِ بِالله غَدَتْ   روحـاً لروحه بها حقـاً سَمَتْ

PageV03P127

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0128.png)

~~۱۸ - ونفسُـه أهواءَهـا أماتـا   مـؤملاً مـن ربـه الثباتـا
~~۱۹ - حتی غـدت بالله في تعلُّقِ   ولم يعـد يُثْنِيـهِ أي عَـائقِ
~~۲٠ - من لائم أو مُغرِضِ أو حاقدِ   أو صَـادٍ بـالجبر أو معانِـدِ
~~٢١- بل إنه بالحق أضحى يصدَعُ   وَلم يَخَـفْ مِـنْ أجْلِـهِ مـايَقَعُ

PageV03P128

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0129.png)

~~١ - الله قـد أثنى عـلى أهـل الرَّجـا   وخصـهم بالمكرمـات والنجـا
~~٢- وأمـر النبـي بالإحسـانِ   في ظننـا بربنـا الـديَّانِ
~~۳- لأن ربي عنـد ظـن عبـدِهِ   فكيفما ظـن يعـامَلن بِـهِ
~~٤- وأنـه حـادٍ إلى المحبـوبِ   وحَـاثٌ لِلْمَقْصـدِ المرغـوب
~~٥ - يُطَيَّبُ السَّيْرَ وَيُذْهِبُ العَنَـا   وأنـه لـمُوْصِلُ إلى المنـى
~~٦- وهـو دليـل ثقـة الإنسـانِ   بذي الجـلال المُـنْعِم الرحمن
~~٧- يحصـل بالجـد وبالتَوَكُّـلِ   أمـا الأمـاني فنتـاج الكَسَـلِ
~~۸- والجـد في الطاعـات للمنـان   علامـة الرجـاء في الإنسـانِ
~~٩- وهـو عـلى ثلاثـةِ أقسـام:   راج ثـواب الله ذي الإكـرام
~~۱۰ - وبعـده راج مـن الغفـورِ   عفواً عـن الـزلات والقصور
~~۱۱- وثالث الأقسـام لـيس يُحمدُ   خص بمن يرجو وليس يَعْبُدُ
~~١٢ - وهو رجاء الاغترار والكذبْ   صاحبه لسوء فعلـه نُكبْ
~~۱٣ - ونظـر العبـد لعيـبِ وإلى   آفـات مـا يعملـه إن عَمِـلا
~~١٤- يفتح باب الخوف في الإنسـانِ   مـن ربـه ذي العـز والسـلطان
~~۱٥- وَفَضلُ ربه العظيم الواسِعِ   يجذبـه إلى الرجـاء النـافِع
~~١٦- وقيـل مـن علامـةِ الرَّجِـاءِ   أن تُلْهَـمَ الشكر عـلى العَطَـاءِ
~~١٧- واختلفوا أي الرجـاء أفضـلُ   رجاء من يحسـن فيما يعملُ

PageV03P129

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0130.png)

# (١٢٩)
~~۱۸ - آم أنه رجـاء من قـد تَابَـا   يلـتَمس الغفرَان والثوابا
~~۱۹- وقال يحيى بـن معـاذ أطيب   شيءٍ نَنَالُـهُ الرَّجـا وَأَعْـذَبُ
~~٢٠- وإنـه مـن أعظـم المنـازلِ   وَمِـنَن الـبَرّ الكريم العـادلِ
~~۲۱- وقـدره بوفـق قـدر المعرفَـة   برَبّنَـا بكـل إسـم وَصِـفَة
~~٢٢- لولا الرجـاء في الكـريم المـانح   لَعُطَـلَ القلـبُ مَـعَ الجـوارح
~~٢٣- أيضـاً وَلَولا ريحـهُ لَمـا جَرَتْ   سـفينة الأعـمال بـل لعطلت
~~٢٤- وكلما الحـبُّ عـلا زاد الرجَـا   وكـان سرا للفـلاح والنجا
~~۲٥ - وخوف من يرجو الإله مُطَرد   يخـاف أن يكـون مِمَّن قَدُ طُرَد
~~٢٦ - وخيفـة المحـب خـير مُنْعِشْ   تجعـل قلبَـه بـلا تَـوَحُشِ
~~۲۷- بخوفه مـن ربـه العظـيم   ينعم بـالأمن وبـالتكريمْ
~~٢٨ - والقرب من مولاه ذي الجلالِ   والفـوز في الحـال وفي المَـألِ
~~٢٩- ولـيس في رجائنـا وفي الـدعا   تعارض، يَعْرِفُ هذا من وَعَى
~~٣٠- فربنـا الكـريم ذو الإ فضـالِ   والراحِمُ الغفـورُ ذُو الجَـلالِ
~~۳۱- رحمتـه سـابقة للغضَـبِ   وجودُه ليس له من حجب

PageV03P130

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0131.png)

~~۳۲- وقـال قـوم مَـن رجـا يُقَدَّمُ   حظـوظ نفسـه فـأَنَى يُكْـرَمُ
~~٣٣- وظن بعض الناس أن الرآجي   أضحى لحـظ الـنفس ذا بهـراج
~~٣٤- والظن هذا قد دعانا للعَجَبْ   لسوء فهمهـم وقلـة الأدب
~~٣٥ - لأن راجي الله عن نَفْسِ خَرَجْ   فهـل يكـون حظهـا فيـهِ دَرَجَ
~~٣٦- وهل يكون مخطئاً من طَمِعَا   في فضـل ربـه مُلِحَّـاً وَدَعَـا
~~٣٧- والمصطفى نبيُنَـا قـد أرشـدا   إلى دعـاء رَبَّنـا وأكَـدِا
~~۳٨- والله قـد أثنـى عـلى الـداعينا   وجعـل الإكـرام للراجينـا
~~٣٩- فهم أولو الألباب من بين الورى   والوصف ذا فيهم غدا مشتهرا
~~٤٠- يرجون من ذي الجود أن يمدَّهمْ   ومن عـذاب النار أن يعيذهم
~~٤١- ومـن فوائـد الرجـاءٍ فَـاعْلَم   تبريـد حر الخـوف عنـد المسـلِم
~~٤٢- ويُظهِـر الحاجـاتِ في العِبَـادِ   وفقرَهم للملـك الجَجـوَادِ
~~٤٣ - دعاؤه يصرف عنهم الغضب   لأن ربي لـدعائهم أحـب
~~٤٤- وأنـه حـادٍ لحسـن العَمَـل   وباعث الحـب لمولانـا العـلي
~~٤٥ - وأنـه يـدعو إلى التعلـق   بالمالك المنـان رب الفلـقِ
~~٤٦ - يَطَرِح الراجـي عـلى أعتابِهِ   ولم يـزل مُطَرِحـاً ببابـهِ
~~٤۷- یزداد شکراً ورضا عن ربه   ويعـتلي في قربـه وحُبَّهِ
~~٤٨ - وأنـه يـزداد بـالرحمنِ   معرفـةً تعليـه في الجنَـانِ
~~٤٩- والخـوف والرجـاء في تـلازم   في قلب كـل مخلص وفـاهم

PageV03P131

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0132.png)

# (۱٣١)
~~٥٠ - لأن مـن يملكه الخـوف يَئسْ   وفي العـذاب في الجحيم يـرتكِسْ
~~٥۱- ومن رجا والخوف ما تضمَّنَهْ   يا ويله! من الذي قد أمنه?
~~٥۲- ومن يعش معتدلاً بينهما   فللفـلاح والصـواب أُلهِـما
~~٥٣- وذاك حـال المـؤمنين البَرَرَة   من قد جَنَوْا بِالفِقْهِ أَحْلَى ثَمَرَة
~~٥٤- وقلب ذي الرجـاء في سرورِ   بـأنْعُمِ الله وفي حُبُـورِ
~~٥٥- في بهجـة وفي نشـاط وَفَرَحْ   بـما حبـاه ربه ومـا مَــنَحْ
~~٥٦ - تراه دومـاً راغباً ینتظرُ   فضـل إلهـه الـذي لا يحصَرُ
~~٥٧ - فيستمر لاهجـاً بـذكْرِهِ   ودائبـاً في حمـده وشكرهِ
~~٥٨- مسـارعاً بالسـير في اشـتياقِ   إلى الكـريم المـنعم الـرزاقِ
~~٥٩ - أنـواره لاحـت لـه وبانتْ   والمتعبـات العائقـات هَانَتْ
~~٦٠ - فـازداد في التشمير للوصـولِ   لنَيل مـا يرجـوهُ مِـنْ مـأمُولِ
~~٦۱ - وكلـما دنـا إلى المـماتِ   زاد الرجـا في عَـالِمِ النِيَّـاتِ
~~٦٢- وأول الرجـاء في العبـادِ   ما حَثَّ نحو الخيرِ باجتهـادِ
~~٦٣ - لأنَّ مَـنْ يَرْجُـو لِقَـاءَ الَخَـالقِ   فَمَا لَـهُ في عَزْمـه مِـنْ لاحِـقِ
~~٦٤ - وذاكَ حَقـاً زُبْـدَةُ الإيمانِ   وغايـةُ الغايـاتِ للربـاني
~~٦٥ - فـلا تقرّ عينه ويسعدُ   إلا بلُقْيَـا مَـنْ ِٕلَيْـهِ يَحْفِـدُ
~~٦٦ - ومـا له في الخلـق مـن رُغُوبِ   بـل أنسـه بربـه المحبـوبِ
~~٦٧- إلا الـذي يعينـه ويوصـلُ   فإنـه لفضـله لايَجْهَـلُ
~~٦٨ - وَلَمْ يَكُـنْ مُسْتأنِسـاً بِغَـيْرِهِ   وَإِنَـمَا أَحَبَّـهُ لَخَـيْرِهِ
~~٦٩- لأنَهُ يَـدْعُوهُ نَحْـوَ البـارِي   وَلَمْ يَسرْفي طُــرُقِ الأشرَارِ

PageV03P132

![image file](./0764BahaDinIkhmimi.MunqidhMinZalal_V03_0133.png)

~~۱- ورغبةُ السائر تنسيهِ التَّعبْ   في نَيْل أمره الـذي لـه طَلَبْ
~~٢- فالرغبـة الرجـاء فيما يَطمَعُ   والعلـم يعليهـا لكي لا تقطع
~~٣- وتحفظُ السالكَ من داء الكسلْ   وكـل مـا يؤهنهُ عـن العمـل
~~٤ - ويرتقـي مرتبـة الإحسـانِ   ويكتسِي أبهـى حُـلَى الإيمَانِ
~~٥- مـن بعـد أن يفنى بكل حبهِ   وبالرجـاء خيفـة مـن ربه
~~٦ - وبالعبـادات وبالتبتـلِ   والخـوف والإحسـان والتوكَّـلِ
~~٧- لأنـه أضحى بـأعلى القمـةٍ   برغبـةِ عظيمـةٍ وهمـةِ
~~۸- وعنـد ذاك تحصـل الرعايـة   عـلى طريـق الحـقَّ والهدايـة
~~٩- والعلـم يرعـاه بحسـن العمـل   وكلَّـما يقيـه شرَّ الزلَـلِ
~~١٠ - وسـائر الأعـمال بالإحسـانِ   وصونها عـن مُسْخِطِ الرحمنٍ
~~۱۱ - وحفظها من أي أمرِ مفسدِ   فيا لـه مـن طـائع مسترشد
~~۱۲- والعلـم نـور ما له نهایةٔ   يقـي مـن الضـلال والغوايـة
~~١٣- لـه مراتـبٌُ بهـا الكفايـة   روايـةٌ رعایـةٌ دِرَایَةْ
~~١٤ - فترك تفريطٍ مع الإخْـلالِ   أول مـا يرعـى مـن الأعـمال
~~١٥- وركنهـا الرَّكِينُ بالتوسطِ   وأن يكون مثل خير النمط
~~١٦ - من زمرة الأسلاف خير الأمم   أكـرم بهـم مـن قـدوة وأنعـم
~~١۷- وأن يكـون غـير نـاظرِ لهـا   محتقـراً جهـودَه مـن أجلهـا

