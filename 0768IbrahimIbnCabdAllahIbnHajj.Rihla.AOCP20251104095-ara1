# و لجأ الفـلّ متـن نجـا مـن أهـل إلى الاعتصـام بقصت
~~الّتي هي مـن عقـاب الجـوّ أمنع »و مـن مـنزلة العيّـوق لو لا
~~الغلـوّ لقـيل أرفـع «و ظنّـوا أ نّها ببرجها الّذي لا يضـاهـى 1
~~و ما خصّت به مـن علـوّها و حصـانة مبناها * تصدّ عتهم
~~أمر اللّه و تدفـع»فزحف المـلمـون إليها صيحـة يوم التبت
~~و عـون الله يصحبهم في الكـرّ و الاقـدام * و تأحده يكنفهم
~~بوقـاية النّفـوس و شمـوت الأقـدام فاشتغلوا مـن نـقب الأـوار »
~~بما أدخـل الرّعب في قـلوب الكفّـار ٢ فكـاد وا يتردّدون في
~~طلب الأمـان و لو وطئوا بصـد ورهم أ طـراف الشفـار
# و تـابق أرسـا لهم يتضرّعـون في الانعـام بإبقـاء الأرواح في
~~أجـادهم ۴ و يرغبون في تحليم القـصبة عـلى أن يخرجـوا
~~منها مؤ منين في نفـوسهم و أولادهم » فاعطاهم معظم
~~جلالكـم بذلكـم عقـد الوفـاءو أمـر بـإخراجهم الى أدنى
~~الأمـاكـن منها و أقـرب الأرجـاء » فخرج منها نيّف عـلى
~~خممـائة شخص مـن النّصـارى كـان فيهم مـن أتجـاد الرّمـاة
~~و الرّجـال نحـو مـائة و أربعين تـوفّـر لحمـايتها منهم العدد
~~و تكـاثرت لديهم الأسلحة و العدد 1 فكـان الرّأي في تـأمينهم
~~أ نجح الآراء فـإنّهم وطّـتوا عـلى المـوت نفـوسهم وأداروا
~~بالمنايا بينهم کووسهم 1 .٠٠....٠..١؟) لقـتلوا مـن الملمين
~~أعـدادا* و بلغـوا قبل أن يمـوتـوا في الأخـذ بثـأرهم أمـلا
~~و مـرا دا*و في حـين خر وجهم منها في يوم الأحـد
~~رفعت بها أعلام الايمـان * و نودي لاكـات نـاقوسها وامطال
~~عمـل تيها بشعا ر الأذان » وطتهرهـا الله تعـالى مـن

PageV01P184

![image file](./0768IbrahimIbnCabdAllahIbnHajj.Rihla_0185.png)

~~ارجـاس العدوان 7 و أدناس الترك و الظغيـان * وكـان نيها
~~من أارى المـلمين أزيد مـن أرعين شخصا خلصوا مـن ذلّ
~~الأسر خلاصا مـن قهر الكـفـر و فكّت عـنهم الأقـياد 2 في
~~يوم الفتح الذى تضـاءلت له المـواسم والأعياد
# و اشتغل معظم جلالكـم بالنّظر في مصـالح أمورهـا * ويناء
~~ما تهدّم مـن سورها 7 و شحفها مـن الأسلحة والأطعمـة
~~بمتجادها و مونو رها 7 فشرع في ذلك بأقصى الجدّ
~~و الاجتهاد 1 وبتت الترايا مـن المجـاهدين في أرض الكـفّار
~~فجاوا خلال الدّيار و اقطـار البلادوبلغوا الى حـيث لـم
~~تك تهلغ فيمـا مضى العساكـر المـوفـورة الأعـداد * و عمّمـوا
~~أرجاء الكَبّانِيّة شرقـا و غـربا » و أو سعوا تراها تهتيكـا و سبيا
~~و تحريقا و نهمـا » و جلهوا إلى المحلّة مـن أنـواع المـغانم
~~و الأطعمـة مـا لم يمكـن احصـاو، تـقمدا و لا كتبا * وكـانت
~~كلّ سريّة تـدخـل إلى بلاد التصـارى تقـتل مـن رجـالهم جمـلة
~~و تعـود مـن يـو مها سالمـة غـانمـة كـأنّها لم تلق حربـا »
~~و جـاز المـلمـون خلف الوادي الكـبيـر فغنمـوا في أتْدُ وجَر
~~و فيرها مـغانم كشرة نأدّت لهم بشائر و لأعـدائهم نحمـا
~~و استمرّ مقـام معظم عـلائكـم بظـاهر القَـبْذَاق حـرسه اللّه بعد
~~يوم فتحه ستّـة أيـام أصلح فيه أ موره»و حصل بمخزته
~~مـن الطعـام موفـوره 1 و رتب به مـن أ نجـاد القـوّاد
~~و مختار الرّمـاة والأجنـاد مـن جعل لاقـامـة فـرض
~~الرّبـاط و الجهاد جـدّه و تشمهر،
# و رحل يـوم الأحـد الخـامس عثر مـن شهر شـوّال إلى
~~مَارْتُش فنزل بـاحتها الملتـفّة الحـدأق الآمـنة بطـول
~~الأز مـان مـن حوادث الطـوارق * فـا خذ الملمـون فـي
~~تطع أعنابها و أشجـارها 4 و تسليط أيد ي التـد مير على محو
~~آثارها * نما تم النّهار إلّا و هي قـد لمت حداد ليلهـا

PageV01P185

![image file](./0768IbrahimIbnCabdAllahIbnHajj.Rihla_0186.png)

~~على مـا حلّ بها في نهارهـا
# و رحـل مـنها يوم الاثنيـن إلى قرة تعرف بكَـنْـيُش هي احدى
~~بـنمّات جـيّان 1 و المنمـوصـة مـن خحب الجنّـات وكثرة
~~الأشجـار و الأعـناب بمـا ليس يمكـان 7 فأقنيت في الحـين رحوم
~~ذلك وآثـاره و استـولى عـليه مـن القـطع مـا اتمـل به
~~دمـارهو حُرّقت القـرية تحـريقـا اشتعلت في قـلـوب الكـفّار
~~ناره.
# و رحـل منها يوم الثلاثاء إلى خـارج جَـيّان فتحها الله فـنزل
~~مته يموضع يعرف بعَيْن مُوزَة حيث الجنـات و الكروم * والحدائق
~~التي لها في لبمّة الحسن العقـد المـنظـوم 4 و المحاـن التيكانت
~~تزيد بها جَيّان على البلاد في زمـن المـلمين و زادها حسنـا
~~مـا أحدثته في زمنهم الرّوم4 فأتى المـلمـون عـلن جميع ذلك
~~قطعـا و تحريقـاو تركوهـا كـأن لم تغـن بالأمس تبديدا
~~الشمل محاستها و تفـريقـا *و غـادروهـا و تد سلكـوا بها
~~في اذلال الكـفر و أهله متهجـا يرضي الله عـزّ وجلّ وطـيقـا
# و انتقل مـنه يوم الأرعاء إلى مـوضع يمقربة المور يعـرف
~~بكدية العطمَـاطيّ هـو متوسّط لجنّاتها 1 و مطـلّ عـلـى
~~جميع جهاتها*و بحمث لا يخفر مـنه مـا يُفسَد و لا ما
~~يُتَرَك مـن كر و مها و جمنّاتها * فتـفرّقت الجمـوع عـلى لك
~~المـتغلّات العظيمـة تدمّـرهـا تد ميرا » و تعيد كلّ مكـان
~~منها تاعـا صفصفا بمد آن كـان روضا تضيرا 4 و تذر
~~ديار ا لكـفر بلاقـع لا تجد بها مـنادي أهـلها دامـيا ولا مُجما
~~و لا ولمّا و لا نصيرا و فعلوا مـن ذلك بطـول يومهم افعالا
~~كان موقعها في نفـوس أهل الاحلام عظيمـا و محلّها كمرا »
~~و في صميحـة يوم الخمـيس ركب معظم جلالكـم ليماشر بنفـه ذلكم
~~العمـل الميرور و يستوهب مـا وعـد الله حمحانه عـلى ذلك
~~مـن جزيل المثوبات والأحمـور * ليتولّى المـلمـون نكـلية الكقار

PageV01P186

![image file](./0768IbrahimIbnCabdAllahIbnHajj.Rihla_0187.png)

~~عند الحلول معهم و الحضور 52 بنشاط النّفـوس و انشراح الصدور»
~~فمض مـن ذلك صـدر مـن النّهار » لا يُحص مـا ترتب فيه عـلى
~~الكفّار مـن مـوبقـات الهلاك و الخسار 4 و لا يُدُ رَك بالحصر مـا
~~قطع فيه مـن المـتغلّات و الأشجـار
# و جيّان فتحها الله كمـا في كريم عـلمكم هي محطّ رجـال
~~أهل الكفر * و مجتمـع أهل الضلال للنـهي و الأمـر ٤
~~و مفزع الغـواة عـند حلول الذّعـر * فمـا تخلو قطّ مـن
~~جمع وافـر العَدد 1 متكـاثر الحّدد ، وكـان فيه الاكن نحـو
~~خممـائة فـارس و عشرة آلاف راجـل لم يتـعدّ وا حمـى سور
~~البلد » فلمّـا اشتغل الملمـون بمـا كـانوا بسبيله مـن قطـع
~~الأشجـار دلّاهم شيطـانهم بغـرور ۴وأخـرجهم قـليلا عـن
~~منعة البلد و حمى التور فوتفت الطائفـة التي كـانت مـرتية
~~عـليهم في وجـوههم تنـاو شهم القـتال »و تضيـق عـليهم في
~~الحـرب المجـال 1 وتثرع في صـد ورهم « الرّماح ٤ و تهدي
~~إلى نحو رهم النصـال ٢ فلمّا سمـع الملمـون با نتشاب الحـرب
~~تنـاد وا بشعـار الاسلام و ثـارت حمـائطهم القـويّة و عـزائمهم
~~الكرام 1 وصدّتـوا مـا عـاهـد وا اللّه عـليه فـأسرعـوا لاعـز از
~~دينه صـادق الاتـدام 2 و تحرّك مـعظم جـلالكم نحـو البلد
~~و نصـر الله عـزّ و جـلّ قـد أقـيل و إمـداده بالعون
~~و التـأييـد قـد يتـر المـرغوب مـن فـضله و المـومـل
~~قلم يكـن إلّا أن أظـلّت رايته مهد الكفّـار و فرّوا إلى البلد
~~فلم ينجـهم الفرار
