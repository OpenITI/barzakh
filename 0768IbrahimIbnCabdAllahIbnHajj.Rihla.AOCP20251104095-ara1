# أتّا بعد الحـد للّه حمدا كـثيرا 1 و التكـر ل عـزّ
~~وجهه عـلى وابغ نعمـائه لا تغبّه الألنة ترديدا و تكـريرا *
~~واهب الفتح الذي تفتّحت له أبواب السمـاء *و تو شحت بحمـد ه
~~مجـالى النعمـاء 1 فتعرّف إنجـاز وعـده * و إحـراز الخير مـن
~~عند. ني قـوله عزّ و جلّ ( وَ بشِرِ المّـوْ مِنِينَ بِأن لَهم مِنْ
~~آللّهِ فَصْلا كبِيرا »7 و الضـلاة عـلى سـيّدنا و مـولانا محمّد
~~رـوله المبعوث إلى كـافة الخـلق بشيرا و نذيرا * و داعـيا إلى
~~الله بإذنه و سراجـا مـنيراو نممه الذي فتح لقـبول هـدايته
~~قلو با و شرح صد ورا۴ و نصـره بالرّعب فكان يسری أمـامه
~~إلى قـلوب عـداء دشهورا ، * و عـل آله و أصحـابه الذين
~~تـابقـوا في مـيدان الجهاد و فتحـوا أقطـار الملاد *
~~فأوسعوا ملّة الدى عـلوّا و ظهورا 7 و بذلوا نفـائس النفـوس
~~و أداروا المنايا عـلى الكـفّار مُثرَعـات الكؤوس 2 حتى صـار
~~ولّي الاسلام مـنصـورا و عـدوّه مقهورا والدعـاء لايالتكـم
~~العليّة بنصـر يملأ البيطة نـو را 2 و يجعل لهذه الجزيرة مـن
~~بركـاته حظا موفـورا و إنّه كـتب الله لمـقامكم الأعـلى
~~عادة الدّين و الدّنيا 2 و أمـدّكـم بمـوا د النصر و التمكيـن
~~حتّى تكون عـل يدكـم كـلمـة الله العليا
# مـن حمراء فرناطة حرسها اللّه و لا نريد بمـن الله تعالى
~~إلّا مـا عـوّد الله سبحـانه مـن الاعـلاء لدينه و الاظهـار
~~و اتصـال الفتوح التي تخلّد لمـقـامكم الأعـلى كـريم الآثـار
~~و الحمـد لله حمـدا نستـغرق في أداء واجبه آنـاء اللّيل و أطراف
~~النهار 1 و لتـا كنتم أيّد اللّه مقـامكم ويتـر في تقـريب أمد
~~الفتح مرادكـم ملجـأ أهل الاسلام * و الذي اليه الاستتـاد *
~~و عماد الأنـام الذى عـليه المـعوّل في حفـظ النظـام والاعتمـاد *
~~و كان أفضل مـا يُهْدَى إلى مقـامكم الأعـلى نبأ فتح يعظم فـي
~~الاسلام أثر * ويطيب في الأسمـاع خهره و تتظم في لبّات

PageV01P181

![image file](./0768IbrahimIbnCabdAllahIbnHajj.Rihla_0182.png)

~~الاحسـان لآلـيّ وصفه و دُرَره وجب أن يُمادَر لاعـلام متامكم
~~العلّ بمـا نّاء اللّه عزّ و جـلّ لأهل الايمـان 7 مـن الصنـع
~~الكريـم الذي بمُد العهد بمـثله في سالف الأز مـان ٤ و أن يشرح
~~حديثه يمتطاع الميان *شرحا يعهر عمّـا لله عزّ و جـلّ فيه
~~مـن عوائـد الاحسـان فقد كـانت [ شارتكـم الكنمـة تقـدّمت
~~بالتأكيد في ذلكـم 1 لاعتمـار خاطركـم الكريم يمـا يهمّ المـلمـين
~~و اشتغـال يالكـم
# و ذلكـم أيّدكـم الله أن مـعظم جـلالكـم خرج مـن هـنا كما
~~تقـدّم تعريفكم في يـوم الأرمـاء الرّابع مـن شهر شـوّال تـم
~~التـأريخ بعد مـا تكـامـل عـدد أولياء الله المجـاهـدين ،
~~و أقرّ العيـون مـا بدا مـن صـدق عـزائمـهم في حمـاية الدّيـن *
~~فنزل القَبْذَاق صبيحـة يوم الجمعة بعد. في سـاعـة أذن الله
~~عـز و جـلّ فيها لأبـواب السعـادة أن تفتح * و لتبـاشيـر
~~صباحها أن تشـرق و تتـوضح » و هـذا القَـبْذَاق أيّدكـم
~~الله كمـا علمتم معقـل الكـفـر الّذى كـان إليه يـأرز 7
~~و حمـاه الذى اذا أوى اليه يـفـلّ طـالمه عـن اد راكه و يعجز
~~و لم يـزل في صـدر الاسـلام ينتجى * و بين المـلمين و غزو
~~أعـدائهم بـابا مرتجـا ۴ وطـالمـا اجتمعت هـنا مـن العصابة
~~المرنيّة و فيرهـا مـن القـبائل آلاف فوقـف في الجهاد دون
~~مرامهم * و حال بينهم و بین ما عسى أن يوملوه من
~~إقدامهم و مـن حـن تمـلّك النصـارى لمـاه مـا زالوا يصرفون
~~إلى تحصينه هممـهم * و يجعلونه ممشرهم الذي يأمنـون
~~به و حر مهم،و فيه كـانت أبدا عـدّتهم و مددهم *
~~و إليه مت نقـر المجاهد ون في سميل الله مـن أقص المـلاد
~~يأتي مددهم
# و كسان التصارى دترهم الله لتا بلغهم أمر هـذه الحكة

PageV01P182

![image file](./0768IbrahimIbnCabdAllahIbnHajj.Rihla_0183.png)

~~المباركة * قد اختاروا جمـاعة مـن فرـان مالافزد.-.*(۸)
~~المشهو بين بالزّعامـة 2 و رتمـوهم تهممـا بشأنه للسكنى به
~~و الإتـامـة
# فلمّا استوى بمعظم جلالكـم بخـارجه الاستقـرار * و دارت
~~محلّته به كمـا يدور بالمعصم التـوار * و نهد أوليـاء الله إلى
~~قتال أعـدائه و أ مضـوا عـزائمـهم القـويّة في مقـارعتهم
~~رغبة في إعـز از دين الاسلام و إعـلائه و صمّمـوا إليهم تصمـيم
~~مـن تيقـن أتن الفـوز بالشهاد ة مـن أعـظم مـا وهـبه الله مـن
~~نعماه وأذاقـوهم مـن نكـال القـتال مـا عرّفهم عساقبـة
~~العد وان 1 و رمـوهم مـن بنات الحنايا 4 بارـال المـنايـا
~~و مـن نقـوب الأحوار»بموذيـات اددّ مـار و مـن شعل
~~النّيران 7 بمعجّـل الخسران1 فلم تطل الحال في ذلكـم إلّا
~~بمقدار سـامـة مـن النّهار 7 و إذا بأعـداء الله قـد ولـوا
~~الأدبـار ورأوا مـا لا طـاقـة لهم به مـن تهدّم الأسـوار *
~~و إشراع الأـنّة والشفـار 4 فالتمـوا النجـاة في الغرار
# فدُخل عـلههم الملد بالسيف تهرا » و استـؤصل مـن كـان
~~قيه مـن الرّجال و النّسـاء قتـلا و أـرا حستى امتلأت سككه
~~مـن أشلاء قتلاهم* و صُيّروا مـن نـار الجحيم إلى مستقرّهم
~~و مـاواهم * و لم يكـد الحصر يأخـذ عـدد مـن جـدّل مـن
~~صرعاهم 7 و امتلأت أيد ي الملميـن مـن فـيـئهم و غنائم
~~أموالهم * و سُمـي مـن ذراريهم و نـائهم و عتاق خيلهم
~~و ذواتهم جملة تـو زعها المجـاهـد ون فكـان ذلك أعظـم
~~في نكالهم

PageV01P183

